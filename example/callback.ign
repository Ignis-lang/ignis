// TODO: example to add callback function or lambda function
import { println } from 'std:io';

function map(arr: unknown[], fn: (item: unknown): unknown): unkonwn[] {
  let mut result: unknown[] = [];

  for (let i = 0; i < arr.length(); i++) {
    result.push(fn(arr[i]))
  }

  return result;
}


function main(): void {
  let arr = [1, 2, 3, 4, 5];

  let result = map(arr, (item: int) -> item * 2);

  println(result);
}
