import { length } from "std:array";

function map(arr: unkonwn[], fn: (item: unkonwn): unkonwn): unkonwn[] {
  let mut result: unkonwn[] = [];

  for (let i = 0; i < length(arr); i++) {
    result.push(fn(arr[i]))
  }

  return result;
}


function main(): void {
  let arr = [1, 2, 3, 4, 5];

  let result = map(arr, (item: int) -> item * 2);

  console.log(result);
}
