import { println } from "std:io";

function sum<T>(a: T, b: T): T {
  return a + b;
}

function main(): void {
  let num: int = 1;
  let num2: int = 2;

  let result: int = sum<int>(num, num2);

  println(result.toString());

  let result2: int = sum<int>(num, num2);

  println(result2.toString());

  let numF: float = 1.2;
  let num2F: float = 2.3;

  let floatResult: float = sum<float>(numF, num2F);

  println(floatResult.toString());
}
