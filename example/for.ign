import { println } from "std:io";

function sum(nums: int[]): int {
  let mut total: int = 0;

  for (let i = 0; i < nums.length; i++) {
    total = total + nums[i];
  }

  return total;
}

function main(): void {
  let array: int[] = [1, 2, 3, 4, 5];

  println("Lenght: " + array.length.toString());

  println(sum(array));
}
