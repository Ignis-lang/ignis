import { println } from "std:io";
import { length } from "std:array";
import { toString } from "std:string";

function sum(nums: int[]): int {
  let mut total: int = 0;

  for (let i = 0; i < length(nums); i++) {
    total = total + nums[i];
  }

  return total;
}

function main(): void {
  let array: int[] = [1, 2, 3, 4, 5];

  println("Lenght: " + toString(length(array)));

  println(sum(array));
}
