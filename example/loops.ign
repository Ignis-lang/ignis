import { println } from "std:io";

function main(): void {
	let array: int[] = [1, 2, 3];
	let arrayString: string[] = ["a", "b", "c"];

  for (let i = 0; i < arrayString.length; i++) {
		println(arrayString[i]);
	}

	for (let item of array) {
		println(item);
	}

  let mut count: int = 0;

  while (count < 10) {
    count++;
    println("Count: " + count.toString());
  }
}
