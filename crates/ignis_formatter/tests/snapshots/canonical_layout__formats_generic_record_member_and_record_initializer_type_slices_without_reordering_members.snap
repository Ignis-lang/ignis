record ReducerBox<T> {
  public values: T[];
  public reducer: (T, &T) -> T;
}

function build<T>(values: T[], reducer: (T, &T) -> T): ReducerBox<T> {
  return ReducerBox<T> {
    values: values,
    reducer: reducer,
  };
}
