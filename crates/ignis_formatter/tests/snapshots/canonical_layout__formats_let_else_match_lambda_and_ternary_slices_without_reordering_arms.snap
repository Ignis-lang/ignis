function compute(input: Option<i32>): i32 {
  let Some(value) = input else {
    return 0;
  };
  return match (value) { 0 | 1 -> 1, _ if value > 10 -> ((x: i32): i32 -> x + 1)(value), _ -> value > 2 ? value : 2 };
}
