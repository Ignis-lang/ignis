@test
function resolverAliasPrefixDoesNotShadowLongerSegment(): void {
  // Alias "comp" must NOT resolve the import "compiler::types": "compiler" starts
  // with "comp" but is a distinct segment — no "::" boundary follows "comp" in
  // "compiler::types", so the alias must not match.
  let fixtureRoot: Path::PathBuf = resolverFixturePath("test_cases/selfhost/build/alias_boundary");
  let expectedPath: Path::PathBuf = fixtureRoot.join("expected_diagnostic.txt");
  let expected: String = resolverReadText(&expectedPath).trimAsciiWhitespace();
  let actual: String = Resolver::firstDiagnosticSummary(&fixtureRoot).trimAsciiWhitespace();
  Test::assertEq<str>(actual.toStr(), expected.toStr());
}

@test
function resolverDiscoversAcyclicDiamondInDependencyOrder(): void {
  // Diamond: main imports B and C; both B and C import D.
  // D must appear exactly once in topo order, before B and C.
  let fixtureRoot: Path::PathBuf = resolverFixturePath("test_cases/selfhost/build/diamond");
  let expectedPath: Path::PathBuf = fixtureRoot.join("expected_order.txt");
  let expected: String = resolverReadText(&expectedPath).trimAsciiWhitespace();
  let discovery: DiscoveryResult = match (Resolver::discoverProject(&fixtureRoot)) {
    Result::OK(value) -> value,
    Result::ERROR(_) -> {
      Test::fail();
      return;
    },
  };
  let actual: String = Resolver::orderSummaryRelativeTo(&discovery, &fixtureRoot).trimAsciiWhitespace();
  Test::assertEq<str>(actual.toStr(), expected.toStr());
}

