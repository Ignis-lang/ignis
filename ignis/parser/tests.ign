function assertRealFileParsesWithoutDiagnostics(path: str): void {
  let sourceText: String = readFixture(path);
  let source: SourceFile = SourceFile::create(path, sourceText.toStr());
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  if (diagnostics.length() != 0) {
    if (path.equals("example/add.ign")) {
      @panic("expected example/add.ign to parse without diagnostics");
    }

    if (path.equals("std/vector/tests.ign")) {
      @panic("expected std/vector/tests.ign to parse without diagnostics");
    }

    if (path.equals("ignis/ast/tests.ign")) {
      @panic("expected ignis/ast/tests.ign to parse without diagnostics");
    }

    @panic("expected selected real parser gate file to parse without diagnostics");
  }

  if (module.roots.length() == 0) {
    @panic("expected selected real parser gate file to produce roots");
  }
}

function assertCaptureOverrideKind(
  module: &Ast::Module,
  statementId: Ast::StatementId,
  expectedKind: Ast::Expression::CaptureOverrideKind
): void {
  match (expectStatement(module, statementId)) {
    Ast::Statement::Node::Let(letStatement) -> {
      let lambdaId: Ast::ExpressionId = match (letStatement.value) {
        Option::SOME(value) -> value,
        Option::NONE -> @panic("missing lambda value for capture override"),
      };

      match (expectExpression(module, lambdaId)) {
        Ast::Expression::Node::Lambda(lambdaExpression) -> {
          match (expectStatement(module, lambdaExpression.body)) {
            Ast::Statement::Node::Block(bodyBlock) -> {
              let bodyExpressionId: Ast::ExpressionId = match (bodyBlock.tail) {
                Option::SOME(value) -> value,
                Option::NONE -> @panic("missing capture override tail expression"),
              };

              match (expectExpression(module, bodyExpressionId)) {
                Ast::Expression::Node::CaptureOverride(captureOverride) -> {
                  match (captureOverride.kind) {
                    Ast::Expression::CaptureOverrideKind::Move -> {
                      match (expectedKind) {
                        Ast::Expression::CaptureOverrideKind::Move -> {},
                        _ -> @panic("expected move capture override kind"),
                      };
                    },
                    Ast::Expression::CaptureOverrideKind::Ref -> {
                      match (expectedKind) {
                        Ast::Expression::CaptureOverrideKind::Ref -> {},
                        _ -> @panic("expected ref capture override kind"),
                      };
                    },
                    Ast::Expression::CaptureOverrideKind::RefMut -> {
                      match (expectedKind) {
                        Ast::Expression::CaptureOverrideKind::RefMut -> {},
                        _ -> @panic("expected refMut capture override kind"),
                      };
                    },
                  };

                  match (expectExpression(module, captureOverride.expression)) {
                    Ast::Expression::Node::Path(path) -> Test::assertEq<str>(match (path.segments.get(0)) {
                      Option::SOME(value) -> value.toStr(),
                      Option::NONE -> @panic("missing capture override inner segment"),
                    }, "val"),
                    _ -> @panic("expected path inside capture override"),
                  };
                },
                _ -> @panic("expected capture override tail expression"),
              };
            },
            _ -> @panic("expected block wrapper for capture override lambda body"),
          };
        },
        _ -> @panic("expected lambda expression for capture override"),
      };
    },
    _ -> @panic("expected let statement for capture override"),
  };
}

