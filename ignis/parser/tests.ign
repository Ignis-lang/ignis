@test
function parserRetainsStructuredPatternSurface(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_pattern_surface.ign",
    "function inspect(@trace(input) value: Packet): void { match (packet) { Option::SOME((0 | 1, _, item)) -> value, _ -> value, }; }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  if (diagnostics.length() != 0) {
    let diagnostic: &Diagnostic = match (diagnostics.get(0)) {
      Option::SOME(value) -> value,
      Option::NONE -> @panic("missing structured pattern diagnostic"),
    };
    Io::eprintln(diagnostic.message);
    Io::eprintln(String::create(diagnostic.primarySpan.start).toStr());
    Io::eprintln(String::create(diagnostic.primarySpan.end).toStr());
    @panic("expected structured pattern fixture to parse without diagnostics");
  }
  if (module.roots.length() != 1) {
    @panic("expected structured pattern fixture to have one root");
  }

  let functionId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing structured pattern function root"),
  };

  match (expectItem(&module, functionId)) {
    Ast::Item::Node::Function(functionItem) -> {
      Test::assertEq<u64>(functionItem.parameters.length(), 1);

      let parameterId: Ast::PatternId = match (functionItem.parameters.get(0)) {
        Option::SOME(value) -> *value,
        Option::NONE -> @panic("missing structured pattern parameter"),
      };

      match (expectPattern(&module, parameterId)) {
        Ast::Pattern::Node::Binding(binding) -> {
          Test::assertEq<str>(binding.name.toStr(), "value");
          Test::assertEq<u64>(binding.metadata.attributes.length(), 1);

          let parameterAttribute: &Ast::Attribute = match (binding.metadata.attributes.get(0)) {
            Option::SOME(value) -> value,
            Option::NONE -> @panic("missing structured pattern parameter attribute"),
          };
          let parameterTypeId: Ast::TypeId = match (binding.annotation) {
            Option::SOME(value) -> value,
            Option::NONE -> @panic("missing structured pattern parameter annotation"),
          };

          Test::assertEq<str>(parameterAttribute.name.toStr(), "trace");
          Test::assertEq<str>(match (parameterAttribute.arguments.get(0)) {
            Option::SOME(value) -> value.toStr(),
            Option::NONE -> @panic("missing structured pattern parameter attribute argument"),
          }, "input");

          match (expectType(&module, parameterTypeId)) {
            Ast::Type::Node::Path(pathType) -> Test::assertEq<str>(match (pathType.segments.get(0)) {
              Option::SOME(value) -> value.toStr(),
              Option::NONE -> @panic("missing structured pattern parameter type segment"),
            }, "Packet"),
            _ -> @panic("expected structured pattern parameter annotation path"),
          };
        },
        _ -> @panic("expected structured binding parameter"),
      };

      match (expectStatement(&module, functionItem.body)) {
        Ast::Statement::Node::Block(block) -> {
          let statementId: Ast::StatementId = match (block.statements.get(0)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing structured pattern match statement"),
          };

          match (expectStatement(&module, statementId)) {
            Ast::Statement::Node::Expression(expressionStatement) -> {
              match (expectExpression(&module, expressionStatement.expression)) {
                Ast::Expression::Node::Match(matchExpression) -> {
                  let firstArm: &Ast::Expression::MatchArm = match (matchExpression.arms.get(0)) {
                    Option::SOME(value) -> value,
                    Option::NONE -> @panic("missing structured pattern first match arm"),
                  };

                  match (expectPattern(&module, firstArm.pattern)) {
                    Ast::Pattern::Node::Path(pathPattern) -> {
                      Test::assertEq<u64>(pathPattern.segments.length(), 2);
                      Test::assertEq<u64>(pathPattern.arguments.length(), 1);
                      Test::assertEq<str>(match (pathPattern.segments.get(0)) {
                        Option::SOME(value) -> value.toStr(),
                        Option::NONE -> @panic("missing structured path pattern first segment"),
                      }, "Option");
                      Test::assertEq<str>(match (pathPattern.segments.get(1)) {
                        Option::SOME(value) -> value.toStr(),
                        Option::NONE -> @panic("missing structured path pattern second segment"),
                      }, "SOME");

                      let payloadId: Ast::PatternId = match (pathPattern.arguments.get(0)) {
                        Option::SOME(value) -> *value,
                        Option::NONE -> @panic("missing structured path pattern payload"),
                      };

                      match (expectPattern(&module, payloadId)) {
                        Ast::Pattern::Node::Tuple(tuplePattern) -> {
                          Test::assertEq<u64>(tuplePattern.elements.length(), 3);

                          let firstElementId: Ast::PatternId = match (tuplePattern.elements.get(0)) {
                            Option::SOME(value) -> *value,
                            Option::NONE -> @panic("missing structured tuple first element"),
                          };
                          let secondElementId: Ast::PatternId = match (tuplePattern.elements.get(1)) {
                            Option::SOME(value) -> *value,
                            Option::NONE -> @panic("missing structured tuple second element"),
                          };
                          let thirdElementId: Ast::PatternId = match (tuplePattern.elements.get(2)) {
                            Option::SOME(value) -> *value,
                            Option::NONE -> @panic("missing structured tuple third element"),
                          };

                          match (expectPattern(&module, firstElementId)) {
                            Ast::Pattern::Node::Or(orPattern) -> {
                              Test::assertEq<u64>(orPattern.alternatives.length(), 2);

                              let leftAlternativeId: Ast::PatternId = match (orPattern.alternatives.get(0)) {
                                Option::SOME(value) -> *value,
                                Option::NONE -> @panic("missing structured or-pattern left alternative"),
                              };
                              let rightAlternativeId: Ast::PatternId = match (orPattern.alternatives.get(1)) {
                                Option::SOME(value) -> *value,
                                Option::NONE -> @panic("missing structured or-pattern right alternative"),
                              };

                              match (expectPattern(&module, leftAlternativeId)) {
                                Ast::Pattern::Node::Literal(_) -> {},
                                _ -> @panic("expected structured left literal or-pattern alternative"),
                              };

                              match (expectPattern(&module, rightAlternativeId)) {
                                Ast::Pattern::Node::Literal(_) -> {},
                                _ -> @panic("expected structured right literal or-pattern alternative"),
                              };
                            },
                            _ -> @panic("expected structured tuple or-pattern element"),
                          };

                          match (expectPattern(&module, secondElementId)) {
                            Ast::Pattern::Node::Wildcard(_) -> {},
                            _ -> @panic("expected structured tuple wildcard element"),
                          };

                          match (expectPattern(&module, thirdElementId)) {
                            Ast::Pattern::Node::Binding(binding) -> Test::assertEq<str>(binding.name.toStr(), "item"),
                            _ -> @panic("expected structured tuple binding element"),
                          };
                        },
                        _ -> @panic("expected structured tuple payload pattern"),
                      };
                    },
                    _ -> @panic("expected structured path match pattern"),
                  };
                },
                _ -> @panic("expected structured match expression"),
              };
            },
            _ -> @panic("expected structured pattern expression statement"),
          };
        },
        _ -> @panic("expected structured pattern block body"),
      };
    },
    _ -> @panic("expected structured pattern function item"),
  };

  let rendered: String = Ast::Serializer::render(&module);
  let expectedRenderedNeedle3: String = String::create("Binding span=fixtures/parser_pattern_surface.ign:");
  if (!rendered.contains(&expectedRenderedNeedle3)) {
    @panic("expected serializer to render structured binding pattern line");
  }

  let expectedRenderedNeedle4: String = String::create("metadata=attrs[@trace(input)@fixtures/parser_pattern_surface.ign:");
  if (!rendered.contains(&expectedRenderedNeedle4)) {
    @panic("expected serializer to render structured binding metadata");
  }

  let expectedRenderedNeedle5: String = String::create("segments=[\"Option\", \"SOME\"] arguments=[");
  if (!rendered.contains(&expectedRenderedNeedle5)) {
    @panic("expected serializer to render structured path pattern segments and arguments");
  }

  let expectedRenderedNeedle6: String = String::create("Tuple span=fixtures/parser_pattern_surface.ign:");
  if (!rendered.contains(&expectedRenderedNeedle6)) {
    @panic("expected serializer to render structured tuple pattern line");
  }

  let expectedRenderedNeedle7: String = String::create("Or span=fixtures/parser_pattern_surface.ign:");
  if (!rendered.contains(&expectedRenderedNeedle7)) {
    @panic("expected serializer to render structured or-pattern line");
  }

  let expectedRenderedNeedle8: String = String::create("Wildcard span=fixtures/parser_pattern_surface.ign:");
  if (!rendered.contains(&expectedRenderedNeedle8)) {
    @panic("expected serializer to render structured wildcard pattern line");
  }

  let expectedRenderedNeedle9: String = String::create("Literal span=fixtures/parser_pattern_surface.ign:");
  if (!rendered.contains(&expectedRenderedNeedle9)) {
    @panic("expected serializer to render structured literal pattern line");
  }
}

@test
function parserParsesMatchExpressionGuards(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_match_guard.ign",
    "function main(): void { match (rawErrno) { k if k == errno -> fallback, _ -> other, }; }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 0);

  let functionId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing guarded match function root"),
  };

  match (expectItem(&module, functionId)) {
    Ast::Item::Node::Function(functionItem) -> {
      match (expectStatement(&module, functionItem.body)) {
        Ast::Statement::Node::Block(block) -> {
          let statementId: Ast::StatementId = match (block.statements.get(0)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing guarded match statement"),
          };

          match (expectStatement(&module, statementId)) {
            Ast::Statement::Node::Expression(expressionStatement) -> {
              match (expectExpression(&module, expressionStatement.expression)) {
                Ast::Expression::Node::Match(matchExpression) -> {
                  let firstArm: &Ast::Expression::MatchArm = match (matchExpression.arms.get(0)) {
                    Option::SOME(value) -> value,
                    Option::NONE -> @panic("missing guarded match arm"),
                  };

                  match (expectPattern(&module, firstArm.pattern)) {
                    Ast::Pattern::Node::Binding(binding) -> Test::assertEq<str>(binding.name.toStr(), "k"),
                    _ -> @panic("expected guarded arm binding pattern"),
                  };

                  let guardId: Ast::ExpressionId = match (firstArm.guard) {
                    Option::SOME(value) -> value,
                    Option::NONE -> @panic("missing guarded match arm expression"),
                  };

                  match (expectExpression(&module, guardId)) {
                    Ast::Expression::Node::Binary(binaryExpression) -> {
                      match (binaryExpression.operator) {
                        Ast::Expression::BinaryOperator::Equal -> {},
                        _ -> @panic("expected equality operator in guard expression"),
                      };
                    },
                    _ -> @panic("expected equality guard expression"),
                  };
                },
                _ -> @panic("expected guarded match expression"),
              };
            },
            _ -> @panic("expected guarded match expression statement"),
          };
        },
        _ -> @panic("expected block body for guarded match test"),
      };
    },
    _ -> @panic("expected function root for guarded match test"),
  };
}

@test
function parserParsesLambdaExpressionBodies(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_lambda_basic.ign",
    "function main(): void { let square = (x: i32): i32 -> x * x; let tick = (): void -> { counter = counter + 1; return; }; }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 0);

  let functionId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing lambda function root"),
  };

  match (module.items.get(functionId)) {
    Option::SOME(Ast::Item::Node::Function(functionItem)) -> {
      match (expectStatement(&module, functionItem.body)) {
        Ast::Statement::Node::Block(block) -> {
          Test::assertEq<u64>(block.statements.length(), 2);

          let firstStatementId: Ast::StatementId = match (block.statements.get(0)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing first lambda statement"),
          };
          let secondStatementId: Ast::StatementId = match (block.statements.get(1)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing second lambda statement"),
          };

          match (expectStatement(&module, firstStatementId)) {
            Ast::Statement::Node::Let(letStatement) -> {
              let lambdaId: Ast::ExpressionId = match (letStatement.value) {
                Option::SOME(value) -> value,
                Option::NONE -> @panic("missing expression-body lambda"),
              };

              match (expectExpression(&module, lambdaId)) {
                Ast::Expression::Node::Lambda(lambdaExpression) -> {
                  Test::assertEq<u64>(lambdaExpression.parameters.length(), 1);

                  match (expectStatement(&module, lambdaExpression.body)) {
                    Ast::Statement::Node::Block(bodyBlock) -> {
                      Test::assertEq<u64>(bodyBlock.statements.length(), 0);
                      Test::assertEq<boolean>(bodyBlock.tail.isSome(), true);
                    },
                    _ -> @panic("expected lambda expression body block wrapper"),
                  };
                },
                _ -> @panic("expected expression-body lambda expression"),
              };
            },
            _ -> @panic("expected let statement for expression-body lambda"),
          };

          match (expectStatement(&module, secondStatementId)) {
            Ast::Statement::Node::Let(letStatement) -> {
              let lambdaId: Ast::ExpressionId = match (letStatement.value) {
                Option::SOME(value) -> value,
                Option::NONE -> @panic("missing block-body lambda"),
              };

              match (expectExpression(&module, lambdaId)) {
                Ast::Expression::Node::Lambda(lambdaExpression) -> {
                  Test::assertEq<u64>(lambdaExpression.parameters.length(), 0);

                  match (expectStatement(&module, lambdaExpression.body)) {
                    Ast::Statement::Node::Block(bodyBlock) -> {
                      Test::assertEq<u64>(bodyBlock.statements.length(), 2);
                      Test::assertEq<boolean>(bodyBlock.tail.isSome(), false);

                      let assignmentStatementId: Ast::StatementId = match (bodyBlock.statements.get(0)) {
                        Option::SOME(value) -> *value,
                        Option::NONE -> @panic("missing assignment statement inside lambda block body"),
                      };
                      let returnStatementId: Ast::StatementId = match (bodyBlock.statements.get(1)) {
                        Option::SOME(value) -> *value,
                        Option::NONE -> @panic("missing return statement inside lambda block body"),
                      };

                      match (expectStatement(&module, assignmentStatementId)) {
                        Ast::Statement::Node::Expression(expressionStatement) -> {
                          match (expectExpression(&module, expressionStatement.expression)) {
                            Ast::Expression::Node::Assignment(_) -> {},
                            _ -> @panic("expected assignment expression inside lambda block body"),
                          };
                        },
                        _ -> @panic("expected assignment statement inside lambda block body"),
                      };

                      match (expectStatement(&module, returnStatementId)) {
                        Ast::Statement::Node::Return(returnStatement) -> Test::assertEq<boolean>(returnStatement.value.isNone(), true),
                        _ -> @panic("expected bare return statement inside lambda block body"),
                      };
                    },
                    _ -> @panic("expected block-body lambda statement body"),
                  };
                },
                _ -> @panic("expected block-body lambda expression"),
              };
            },
            _ -> @panic("expected let statement for block-body lambda"),
          };
        },
        _ -> @panic("expected block function body for lambda test"),
      };
    },
    _ -> @panic("expected function root for lambda test"),
  };
}

@test
function parserParsesCaptureOverrideExpressions(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_capture_overrides.ign",
    "function main(): void { let val: i32 = 42; let moved = (): i32 -> @move val; let borrowed = (): i32 -> @ref val; let borrowedMut = (): i32 -> @refMut val; }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 0);

  let functionId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing capture-override function root"),
  };

  match (expectItem(&module, functionId)) {
    Ast::Item::Node::Function(functionItem) -> {
      match (expectStatement(&module, functionItem.body)) {
        Ast::Statement::Node::Block(block) -> {
          Test::assertEq<u64>(block.statements.length(), 4);

          let movedStatementId: Ast::StatementId = match (block.statements.get(1)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing move capture statement"),
          };
          let borrowedStatementId: Ast::StatementId = match (block.statements.get(2)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing ref capture statement"),
          };
          let borrowedMutStatementId: Ast::StatementId = match (block.statements.get(3)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing refMut capture statement"),
          };

          assertCaptureOverrideKind(&module, movedStatementId, Ast::Expression::CaptureOverrideKind::Move);
          assertCaptureOverrideKind(&module, borrowedStatementId, Ast::Expression::CaptureOverrideKind::Ref);
          assertCaptureOverrideKind(&module, borrowedMutStatementId, Ast::Expression::CaptureOverrideKind::RefMut);
        },
        _ -> @panic("expected block body for capture override test"),
      };
    },
    _ -> @panic("expected function item for capture override test"),
  };
}

@test
function parserParsesTraitDeclarationsAndExportedTraits(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_trait_declarations.ign",
    "trait Hash { hash(&self, hasher: &mut Hasher): void; } export trait Eq { equals(&self, other: &Self): boolean; }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 0);
  Test::assertEq<u64>(module.roots.length(), 2);

  let traitId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing trait root"),
  };
  let exportId: Ast::ItemId = match (module.roots.get(1)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing exported trait root"),
  };

  match (module.items.get(traitId)) {
    Option::SOME(Ast::Item::Node::Trait(traitItem)) -> {
      Test::assertEq<str>(traitItem.name.toStr(), "Hash");
      Test::assertEq<u64>(traitItem.methods.length(), 1);

      let methodId: Ast::ItemId = match (traitItem.methods.get(0)) {
        Option::SOME(value) -> *value,
        Option::NONE -> @panic("missing trait method"),
      };

      match (module.items.get(methodId)) {
        Option::SOME(Ast::Item::Node::Function(methodItem)) -> {
          Test::assertEq<str>(methodItem.name.toStr(), "hash");
          Test::assertEq<u64>(methodItem.parameters.length(), 2);

          let receiverId: Ast::PatternId = match (methodItem.parameters.get(0)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing trait receiver parameter"),
          };
          let argumentId: Ast::PatternId = match (methodItem.parameters.get(1)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing trait method argument"),
          };

          match (expectPattern(&module, receiverId)) {
            Ast::Pattern::Node::Binding(binding) -> {
              Test::assertEq<str>(binding.name.toStr(), "self");

              let receiverTypeId: Ast::TypeId = match (binding.annotation) {
                Option::SOME(value) -> value,
                Option::NONE -> @panic("missing synthesized receiver type"),
              };

              match (expectType(&module, receiverTypeId)) {
                Ast::Type::Node::Reference(referenceType) -> Test::assertEq<boolean>(referenceType.mutable, false),
                _ -> @panic("expected reference receiver type"),
              };
            },
            _ -> @panic("expected binding receiver pattern"),
          };

          match (expectPattern(&module, argumentId)) {
            Ast::Pattern::Node::Binding(binding) -> {
              Test::assertEq<str>(binding.name.toStr(), "hasher");

              let argumentTypeId: Ast::TypeId = match (binding.annotation) {
                Option::SOME(value) -> value,
                Option::NONE -> @panic("missing trait method argument type"),
              };

              match (expectType(&module, argumentTypeId)) {
                Ast::Type::Node::Reference(referenceType) -> Test::assertEq<boolean>(referenceType.mutable, true),
                _ -> @panic("expected mutable reference type for trait method argument"),
              };
            },
            _ -> @panic("expected binding trait method argument pattern"),
          };
        },
        _ -> @panic("expected function item inside trait methods"),
      };
    },
    _ -> @panic("expected trait root item"),
  };

  match (module.items.get(exportId)) {
    Option::SOME(Ast::Item::Node::Export(exportItem)) -> {
      let exportedTraitId: Ast::ItemId = match (exportItem.declaration) {
        Option::SOME(value) -> value,
        Option::NONE -> @panic("missing exported trait declaration"),
      };

      match (module.items.get(exportedTraitId)) {
        Option::SOME(Ast::Item::Node::Trait(traitItem)) -> {
          Test::assertEq<str>(traitItem.name.toStr(), "Eq");
          Test::assertEq<u64>(traitItem.methods.length(), 1);
        },
        _ -> @panic("expected trait inside export wrapper"),
      };
    },
    _ -> @panic("expected export root for exported trait"),
  };
}

@test
function parserParsesReExportDeclarations(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_reexport.ign",
    "export HashMap, Hash from \"./hash_map\"; export Eq from \"std::hash\";"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 0);
  Test::assertEq<u64>(module.roots.length(), 2);

  let firstExportId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing first re-export root"),
  };

  match (expectItem(&module, firstExportId)) {
    Ast::Item::Node::Export(exportItem) -> {
      Test::assertEq<boolean>(exportItem.declaration.isNone(), true);
      Test::assertEq<u64>(exportItem.items.length(), 2);
      Test::assertEq<str>(match (exportItem.items.get(0)) {
        Option::SOME(binding) -> match (binding.name) {
          Option::SOME(name) -> name.toStr(),
          Option::NONE -> @panic("missing first re-export binding name"),
        },
        Option::NONE -> @panic("missing first re-export binding"),
      }, "HashMap");
      Test::assertEq<str>(match (exportItem.items.get(1)) {
        Option::SOME(binding) -> match (binding.name) {
          Option::SOME(name) -> name.toStr(),
          Option::NONE -> @panic("missing second re-export binding name"),
        },
        Option::NONE -> @panic("missing second re-export binding"),
      }, "Hash");
      Test::assertEq<str>(match (exportItem.source) {
        Option::SOME(path) -> path.toStr(),
        Option::NONE -> @panic("missing re-export path"),
      }, "./hash_map");
      Test::assertEq<str>(match (exportItem.sourceSpan) {
        Option::SOME(span) -> span.filePath,
        Option::NONE -> @panic("missing re-export from span"),
      }, "fixtures/parser_reexport.ign");
    },
    _ -> @panic("expected export wrapper for re-export declaration"),
  };
}

@test
function parserPreservesImportAndExportStructureInAstAndSerializer(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_import_export_shape.ign",
    "import Foo, _ from \"std::io\"; export Bar from \"./bar\";"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);
  let rendered: String = Ast::Serializer::render(&module);

  Test::assertEq<u64>(diagnostics.length(), 0);
  Test::assertEq<u64>(module.roots.length(), 2);
  let expectedRenderedNeedle10: String = String::create("items=[Named(\"Foo\")@fixtures/parser_import_export_shape.ign:7-10, Discard@fixtures/parser_import_export_shape.ign:12-13] from=\"std::io\"");
  Test::assert(rendered.contains(&expectedRenderedNeedle10));
  let expectedRenderedNeedle11: String = String::create("declaration=none items=[Named(\"Bar\")@fixtures/parser_import_export_shape.ign:37-40] from=\"./bar\"");
  Test::assert(rendered.contains(&expectedRenderedNeedle11));

  match (expectItem(&module, match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing import root"),
  })) {
    Ast::Item::Node::Import(importItem) -> {
      Test::assertEq<u64>(importItem.items.length(), 2);
      Test::assertEq<str>(importItem.source.toStr(), "std::io");
    },
    _ -> @panic("expected import root"),
  };

  match (expectItem(&module, match (module.roots.get(1)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing export root"),
  })) {
    Ast::Item::Node::Export(exportItem) -> {
      Test::assertEq<u64>(exportItem.items.length(), 1);
      Test::assertEq<str>(match (exportItem.source) {
        Option::SOME(value) -> value.toStr(),
        Option::NONE -> @panic("missing export path"),
      }, "./bar");
    },
    _ -> @panic("expected export root"),
  };
}

