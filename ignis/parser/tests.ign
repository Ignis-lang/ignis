@test
function parserParsesBackspaceAndFormFeedCharEscapes(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_char_escapes.ign",
    "function main(): void { '\\b'; '\\f'; }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 0);
  Test::assertEq<u64>(module.roots.length(), 1);

  match (expectItem(&module, match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing char escape function root"),
  })) {
    Ast::Item::Node::Function(functionItem) -> {
      match (expectStatement(&module, functionItem.body)) {
        Ast::Statement::Node::Block(block) -> {
          Test::assertEq<u64>(block.statements.length(), 2);

          let firstStatementId: Ast::StatementId = match (block.statements.get(0)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing backspace literal statement"),
          };
          let secondStatementId: Ast::StatementId = match (block.statements.get(1)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing form-feed literal statement"),
          };

          match (expectStatement(&module, firstStatementId)) {
            Ast::Statement::Node::Expression(firstExpressionStatement) -> {
              match (expectExpression(&module, firstExpressionStatement.expression)) {
                Ast::Expression::Node::Literal(literal) -> {
                  match (literal.value) {
                    Ast::Expression::LiteralValue::Character(value) -> Test::assertEq<char>(value, '\b'),
                    _ -> @panic("expected backspace character literal"),
                  };
                },
                _ -> @panic("expected literal expression for backspace"),
              };
            },
            _ -> @panic("expected expression statement for backspace"),
          };

          match (expectStatement(&module, secondStatementId)) {
            Ast::Statement::Node::Expression(secondExpressionStatement) -> {
              match (expectExpression(&module, secondExpressionStatement.expression)) {
                Ast::Expression::Node::Literal(literal) -> {
                  match (literal.value) {
                    Ast::Expression::LiteralValue::Character(value) -> Test::assertEq<char>(value, '\f'),
                    _ -> @panic("expected form-feed character literal"),
                  };
                },
                _ -> @panic("expected literal expression for form-feed"),
              };
            },
            _ -> @panic("expected expression statement for form-feed"),
          };
        },
        _ -> @panic("expected block body for char escape test"),
      };
    },
    _ -> @panic("expected function root for char escape test"),
  };
}

@test
function parserParsesUnaryCallAndMemberExpressions(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_unary_member.ign",
    "function main(): void { -1; !flag; foo.bar(1, 2); }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 0);
  Test::assertEq<u64>(module.roots.length(), 1);

  let functionId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing unary member function root"),
  };

  match (module.items.get(functionId)) {
    Option::SOME(Ast::Item::Node::Function(functionItem)) -> {
      match (expectStatement(&module, functionItem.body)) {
        Ast::Statement::Node::Block(block) -> {
          Test::assertEq<u64>(block.statements.length(), 3);

          let firstStatementId: Ast::StatementId = match (block.statements.get(0)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing unary negate statement"),
          };
          let secondStatementId: Ast::StatementId = match (block.statements.get(1)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing unary not statement"),
          };
          let thirdStatementId: Ast::StatementId = match (block.statements.get(2)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing member call statement"),
          };

          match (expectStatement(&module, firstStatementId)) {
            Ast::Statement::Node::Expression(expressionStatement) -> {
              match (expectExpression(&module, expressionStatement.expression)) {
                Ast::Expression::Node::Unary(unary) -> Test::assert(unary.operator == Ast::Expression::UnaryOperator::Negate),
                _ -> @panic("expected unary negate expression"),
              };
            },
            _ -> @panic("expected unary negate statement"),
          };

          match (expectStatement(&module, secondStatementId)) {
            Ast::Statement::Node::Expression(expressionStatement) -> {
              match (expectExpression(&module, expressionStatement.expression)) {
                Ast::Expression::Node::Unary(unary) -> Test::assert(unary.operator == Ast::Expression::UnaryOperator::Not),
                _ -> @panic("expected unary not expression"),
              };
            },
            _ -> @panic("expected unary not statement"),
          };

          match (expectStatement(&module, thirdStatementId)) {
            Ast::Statement::Node::Expression(expressionStatement) -> {
              match (expectExpression(&module, expressionStatement.expression)) {
                Ast::Expression::Node::Call(call) -> {
                  Test::assertEq<u64>(call.arguments.length(), 2);

                  match (expectExpression(&module, call.callee)) {
                    Ast::Expression::Node::MemberAccess(access) -> {
                      Test::assert(access.operator == Ast::Expression::AccessOperator::Dot);
                      Test::assertEq<str>(access.member.toStr(), "bar");
                    },
                    _ -> @panic("expected member access call callee"),
                  };
                },
                _ -> @panic("expected call expression"),
              };
            },
            _ -> @panic("expected call expression statement"),
          };
        },
        _ -> @panic("expected block function body for unary member test"),
      };
    },
    _ -> @panic("expected unary member function root"),
  };
}

@test
function parserParsesLetIfWhileBreakAndContinueStatements(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_control_flow.ign",
    "function main(): void { let value: i32 = 1; let mut counter = 2; if (value) { while (counter) { break; } } else { continue; } }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 0);
  Test::assertEq<u64>(module.roots.length(), 1);

  let functionId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing control flow function root"),
  };

  match (module.items.get(functionId)) {
    Option::SOME(Ast::Item::Node::Function(functionItem)) -> {
      match (expectStatement(&module, functionItem.body)) {
        Ast::Statement::Node::Block(block) -> {
          Test::assertEq<u64>(block.statements.length(), 3);

          let firstStatementId: Ast::StatementId = match (block.statements.get(0)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing let statement"),
          };
          let secondStatementId: Ast::StatementId = match (block.statements.get(1)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing mutable variable statement"),
          };
          let thirdStatementId: Ast::StatementId = match (block.statements.get(2)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing if statement"),
          };

          match (expectStatement(&module, firstStatementId)) {
            Ast::Statement::Node::Let(letStatement) -> Test::assertEq<boolean>(letStatement.value.isSome(), true),
            _ -> @panic("expected let statement node"),
          };

          match (expectStatement(&module, secondStatementId)) {
            Ast::Statement::Node::Variable(variableStatement) -> {
              Test::assertEq<boolean>(variableStatement.mutable, true);
              Test::assertEq<boolean>(variableStatement.value.isSome(), true);
            },
            _ -> @panic("expected mutable variable statement node"),
          };

          match (expectStatement(&module, thirdStatementId)) {
            Ast::Statement::Node::If(ifStatement) -> {
              Test::assertEq<boolean>(ifStatement.elseBranch.isSome(), true);

              match (expectStatement(&module, ifStatement.thenBranch)) {
                Ast::Statement::Node::Block(thenBlock) -> {
                  Test::assertEq<u64>(thenBlock.statements.length(), 1);

                  let whileStatementId: Ast::StatementId = match (thenBlock.statements.get(0)) {
                    Option::SOME(value) -> *value,
                    Option::NONE -> @panic("missing while statement in then branch"),
                  };

                  match (expectStatement(&module, whileStatementId)) {
                    Ast::Statement::Node::While(whileStatement) -> {
                      match (expectStatement(&module, whileStatement.body)) {
                        Ast::Statement::Node::Block(whileBlock) -> {
                          Test::assertEq<u64>(whileBlock.statements.length(), 1);

                          let breakStatementId: Ast::StatementId = match (whileBlock.statements.get(0)) {
                            Option::SOME(value) -> *value,
                            Option::NONE -> @panic("missing break statement"),
                          };

                          match (expectStatement(&module, breakStatementId)) {
                            Ast::Statement::Node::Break(_) -> {},
                            _ -> @panic("expected break statement node"),
                          };
                        },
                        _ -> @panic("expected while body block"),
                      };
                    },
                    _ -> @panic("expected while statement node"),
                  };
                },
                _ -> @panic("expected then branch block"),
              };

              let elseBranchId: Ast::StatementId = match (ifStatement.elseBranch) {
                Option::SOME(value) -> value,
                Option::NONE -> @panic("missing else branch"),
              };

              match (expectStatement(&module, elseBranchId)) {
                Ast::Statement::Node::Block(elseBlock) -> {
                  Test::assertEq<u64>(elseBlock.statements.length(), 1);

                  let continueStatementId: Ast::StatementId = match (elseBlock.statements.get(0)) {
                    Option::SOME(value) -> *value,
                    Option::NONE -> @panic("missing continue statement"),
                  };

                  match (expectStatement(&module, continueStatementId)) {
                    Ast::Statement::Node::Continue(_) -> {},
                    _ -> @panic("expected continue statement node"),
                  };
                },
                _ -> @panic("expected else branch block"),
              };
            },
            _ -> @panic("expected if statement node"),
          };
        },
        _ -> @panic("expected block function body for control flow test"),
      };
    },
    _ -> @panic("expected control flow function root"),
  };
}

@test
function parserParsesIfLetTupleLiteralAndWildcardPatterns(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_if_let_patterns.ign",
    "function main(): void { if (let (0, value, _) = pair) {} }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 0);
  Test::assertEq<u64>(module.roots.length(), 1);

  let functionId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing if-let patterns function root"),
  };

  match (module.items.get(functionId)) {
    Option::SOME(Ast::Item::Node::Function(functionItem)) -> {
      match (expectStatement(&module, functionItem.body)) {
        Ast::Statement::Node::Block(block) -> {
          Test::assertEq<u64>(block.statements.length(), 1);

          let ifStatementId: Ast::StatementId = match (block.statements.get(0)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing if-let statement"),
          };

          match (expectStatement(&module, ifStatementId)) {
            Ast::Statement::Node::If(ifStatement) -> {
              match (expectExpression(&module, ifStatement.condition)) {
                Ast::Expression::Node::LetCondition(condition) -> {
                  match (expectPattern(&module, condition.pattern)) {
                    Ast::Pattern::Node::Tuple(tuplePattern) -> {
                      Test::assertEq<u64>(tuplePattern.elements.length(), 3);

                      let firstElement: Ast::PatternId = match (tuplePattern.elements.get(0)) {
                        Option::SOME(value) -> *value,
                        Option::NONE -> @panic("missing tuple literal pattern"),
                      };
                      let secondElement: Ast::PatternId = match (tuplePattern.elements.get(1)) {
                        Option::SOME(value) -> *value,
                        Option::NONE -> @panic("missing tuple binding pattern"),
                      };
                      let thirdElement: Ast::PatternId = match (tuplePattern.elements.get(2)) {
                        Option::SOME(value) -> *value,
                        Option::NONE -> @panic("missing tuple wildcard pattern"),
                      };

                      match (expectPattern(&module, firstElement)) {
                        Ast::Pattern::Node::Literal(_) -> {},
                        _ -> @panic("expected literal tuple pattern element"),
                      };

                      match (expectPattern(&module, secondElement)) {
                        Ast::Pattern::Node::Binding(binding) -> Test::assertEq<str>(binding.name.toStr(), "value"),
                        _ -> @panic("expected binding tuple pattern element"),
                      };

                      match (expectPattern(&module, thirdElement)) {
                        Ast::Pattern::Node::Wildcard(_) -> {},
                        _ -> @panic("expected wildcard tuple pattern element"),
                      };
                    },
                    _ -> @panic("expected tuple pattern for if-let condition"),
                  };
                },
                _ -> @panic("expected let-condition if expression"),
              };
            },
            _ -> @panic("expected if statement node"),
          };
        },
        _ -> @panic("expected block function body for if-let pattern test"),
      };
    },
    _ -> @panic("expected if-let patterns function root"),
  };
}

