@test
function parserParsesForOfStatements(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_for_of.ign",
    "function main(): void { for (let value: &i32 of values) { break; } }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 0);
  Test::assertEq<u64>(module.roots.length(), 1);

  let functionId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing for-of function root"),
  };

  match (expectItem(&module, functionId)) {
    Ast::Item::Node::Function(functionItem) -> {
      match (expectStatement(&module, functionItem.body)) {
        Ast::Statement::Node::Block(block) -> {
          let statementId: Ast::StatementId = match (block.statements.get(0)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing for-of statement"),
          };

          match (expectStatement(&module, statementId)) {
            Ast::Statement::Node::ForOf(forOfStatement) -> {
              match (expectPattern(&module, forOfStatement.pattern)) {
                Ast::Pattern::Node::Binding(binding) -> {
                  Test::assertEq<str>(binding.name.toStr(), "value");

                  let annotationId: Ast::TypeId = match (binding.annotation) {
                    Option::SOME(value) -> value,
                    Option::NONE -> @panic("missing for-of binding annotation"),
                  };

                  match (expectType(&module, annotationId)) {
                    Ast::Type::Node::Reference(referenceType) -> Test::assertEq<boolean>(referenceType.mutable, false),
                    _ -> @panic("expected reference annotation on for-of binding"),
                  };
                },
                _ -> @panic("expected binding pattern for for-of statement"),
              };

              match (expectStatement(&module, forOfStatement.body)) {
                Ast::Statement::Node::Block(bodyBlock) -> Test::assertEq<u64>(bodyBlock.statements.length(), 1),
                _ -> @panic("expected block body for for-of statement"),
              };
            },
            _ -> @panic("expected for-of statement node"),
          };
        },
        _ -> @panic("expected block function body for for-of test"),
      };
    },
    _ -> @panic("expected function root for for-of test"),
  };
}

@test
function parserRetainsStructuredMetadataOnDeclarations(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_metadata_surface.ign",
    "@packed(\"c\", level) public record Packet { @column(id) public value: i32; @builder(init) public static init(@trace(input) value: i32): Packet { return value; } } export inline function add(@trace(left) a: i32, @trace(right) b: i32): i32 { return a + b; }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);
  let rendered: String = Ast::Serializer::render(&module);

  Test::assertEq<u64>(diagnostics.length(), 0);
  Test::assertEq<u64>(module.roots.length(), 2);

  let recordId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing attributed record root"),
  };
  let exportId: Ast::ItemId = match (module.roots.get(1)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing export root"),
  };

  match (expectItem(&module, recordId)) {
    Ast::Item::Node::Record(recordItem) -> {
      Test::assertEq<u64>(recordItem.metadata.attributes.length(), 1);
      Test::assertEq<u64>(recordItem.metadata.modifiers.length(), 1);

      let attribute: &Ast::Attribute = match (recordItem.metadata.attributes.get(0)) {
        Option::SOME(value) -> value,
        Option::NONE -> @panic("missing record attribute"),
      };
      let firstArgument: &String = match (attribute.arguments.get(0)) {
        Option::SOME(value) -> value,
        Option::NONE -> @panic("missing first record attribute argument"),
      };
      let secondArgument: &String = match (attribute.arguments.get(1)) {
        Option::SOME(value) -> value,
        Option::NONE -> @panic("missing second record attribute argument"),
      };

      Test::assertEq<str>(attribute.name.toStr(), "packed");
      Test::assertEq<str>(firstArgument.toStr(), "\"c\"");
      Test::assertEq<str>(secondArgument.toStr(), "level");
      Test::assertEq<str>(attribute.span.filePath, "fixtures/parser_metadata_surface.ign");
      Test::assert(attribute.span.end > attribute.span.start);
      Test::assertEq<u64>(recordItem.fields.length(), 1);
      Test::assertEq<u64>(recordItem.methods.length(), 1);

      let fieldId: Ast::PatternId = match (recordItem.fields.get(0)) {
        Option::SOME(value) -> *value,
        Option::NONE -> @panic("missing record field"),
      };
      let methodId: Ast::ItemId = match (recordItem.methods.get(0)) {
        Option::SOME(value) -> *value,
        Option::NONE -> @panic("missing record method"),
      };

      match (expectPattern(&module, fieldId)) {
        Ast::Pattern::Node::Binding(binding) -> {
          Test::assertEq<u64>(binding.metadata.attributes.length(), 1);
          Test::assertEq<u64>(binding.metadata.modifiers.length(), 1);

          let fieldAttribute: &Ast::Attribute = match (binding.metadata.attributes.get(0)) {
            Option::SOME(value) -> value,
            Option::NONE -> @panic("missing field attribute"),
          };
          let modifier: &Ast::Modifier = match (binding.metadata.modifiers.get(0)) {
            Option::SOME(value) -> value,
            Option::NONE -> @panic("missing field modifier"),
          };

          Test::assertEq<str>(fieldAttribute.name.toStr(), "column");
          Test::assertEq<str>(match (fieldAttribute.arguments.get(0)) {
            Option::SOME(value) -> value.toStr(),
            Option::NONE -> @panic("missing field attribute argument"),
          }, "id");
          Test::assertEq<str>(fieldAttribute.span.filePath, "fixtures/parser_metadata_surface.ign");

          match (modifier) {
            Ast::Modifier::Public -> {},
            _ -> @panic("expected public field modifier"),
          };
        },
        _ -> @panic("expected binding field pattern"),
      };

      match (expectItem(&module, methodId)) {
        Ast::Item::Node::Function(functionItem) -> {
          Test::assertEq<str>(functionItem.name.toStr(), "init");
          Test::assertEq<u64>(functionItem.metadata.attributes.length(), 1);
          Test::assertEq<u64>(functionItem.metadata.modifiers.length(), 2);
          Test::assertEq<u64>(functionItem.parameters.length(), 1);

          let methodAttribute: &Ast::Attribute = match (functionItem.metadata.attributes.get(0)) {
            Option::SOME(value) -> value,
            Option::NONE -> @panic("missing method attribute"),
          };
          Test::assertEq<str>(methodAttribute.name.toStr(), "builder");
          Test::assertEq<str>(match (methodAttribute.arguments.get(0)) {
            Option::SOME(value) -> value.toStr(),
            Option::NONE -> @panic("missing method attribute argument"),
          }, "init");

          let parameterId: Ast::PatternId = match (functionItem.parameters.get(0)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing method parameter"),
          };

          match (expectPattern(&module, parameterId)) {
            Ast::Pattern::Node::Binding(binding) -> {
              Test::assertEq<u64>(binding.metadata.attributes.length(), 1);
              let parameterAttribute: &Ast::Attribute = match (binding.metadata.attributes.get(0)) {
                Option::SOME(value) -> value,
                Option::NONE -> @panic("missing method parameter attribute"),
              };

              Test::assertEq<str>(parameterAttribute.name.toStr(), "trace");
              Test::assertEq<str>(match (parameterAttribute.arguments.get(0)) {
                Option::SOME(value) -> value.toStr(),
                Option::NONE -> @panic("missing method parameter attribute argument"),
              }, "input");
              Test::assertEq<str>(parameterAttribute.span.filePath, "fixtures/parser_metadata_surface.ign");
            },
            _ -> @panic("expected binding method parameter"),
          };
        },
        _ -> @panic("expected function method item"),
      };
    },
    _ -> @panic("expected record item"),
  };

  match (expectItem(&module, exportId)) {
    Ast::Item::Node::Export(exportItem) -> {
      let exportedFunctionId: Ast::ItemId = match (exportItem.declaration) {
        Option::SOME(value) -> value,
        Option::NONE -> @panic("missing exported function declaration"),
      };

      match (expectItem(&module, exportedFunctionId)) {
        Ast::Item::Node::Function(functionItem) -> {
          Test::assertEq<u64>(functionItem.metadata.modifiers.length(), 1);
          Test::assertEq<u64>(functionItem.parameters.length(), 2);

          let modifier: &Ast::Modifier = match (functionItem.metadata.modifiers.get(0)) {
            Option::SOME(value) -> value,
            Option::NONE -> @panic("missing exported function modifier"),
          };

          match (modifier) {
            Ast::Modifier::Inline -> {},
            _ -> @panic("expected inline modifier on exported function"),
          };

          let firstParameterId: Ast::PatternId = match (functionItem.parameters.get(0)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing exported function first parameter"),
          };

          match (expectPattern(&module, firstParameterId)) {
            Ast::Pattern::Node::Binding(binding) -> {
              Test::assertEq<u64>(binding.metadata.attributes.length(), 1);
              let parameterAttribute: &Ast::Attribute = match (binding.metadata.attributes.get(0)) {
                Option::SOME(value) -> value,
                Option::NONE -> @panic("missing exported function parameter attribute"),
              };

              Test::assertEq<str>(parameterAttribute.name.toStr(), "trace");
              Test::assertEq<str>(match (parameterAttribute.arguments.get(0)) {
                Option::SOME(value) -> value.toStr(),
                Option::NONE -> @panic("missing exported function parameter attribute argument"),
              }, "left");
            },
            _ -> @panic("expected exported function parameter binding"),
          };
        },
        _ -> @panic("expected function inside export item"),
      };
    },
    _ -> @panic("expected export item"),
  };

  let expectedRenderedNeedle12: String = String::create("metadata=attrs[@packed(\"c\", level)@fixtures/parser_metadata_surface.ign:");
  Test::assert(rendered.contains(&expectedRenderedNeedle12));
  let expectedRenderedNeedle13: String = String::create("metadata=attrs[@builder(init)@fixtures/parser_metadata_surface.ign:");
  Test::assert(rendered.contains(&expectedRenderedNeedle13));
  let expectedRenderedNeedle14: String = String::create("metadata=attrs[@trace(input)@fixtures/parser_metadata_surface.ign:");
  Test::assert(rendered.contains(&expectedRenderedNeedle14));
}

@test
function parserParsesRecordFieldsAndMethodsWithModifiers(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_record_members.ign",
    "record Tracker { public marker: i32; drop(&mut self): void { return; } public static init(value: i32): Tracker { return Tracker { marker: value }; } }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 0);
  Test::assertEq<u64>(module.roots.length(), 1);

  let recordId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing record root"),
  };

  match (expectItem(&module, recordId)) {
    Ast::Item::Node::Record(recordItem) -> {
      Test::assertEq<u64>(recordItem.fields.length(), 1);
      Test::assertEq<u64>(recordItem.methods.length(), 2);

      let dropMethodId: Ast::ItemId = match (recordItem.methods.get(0)) {
        Option::SOME(value) -> *value,
        Option::NONE -> @panic("missing drop method"),
      };
      let initMethodId: Ast::ItemId = match (recordItem.methods.get(1)) {
        Option::SOME(value) -> *value,
        Option::NONE -> @panic("missing init method"),
      };

      match (expectItem(&module, dropMethodId)) {
        Ast::Item::Node::Function(functionItem) -> Test::assertEq<str>(functionItem.name.toStr(), "drop"),
        _ -> @panic("expected drop function item"),
      };

      match (expectItem(&module, initMethodId)) {
        Ast::Item::Node::Function(functionItem) -> {
          Test::assertEq<str>(functionItem.name.toStr(), "init");
          Test::assertEq<u64>(functionItem.metadata.modifiers.length(), 2);
        },
        _ -> @panic("expected init function item"),
      };
    },
    _ -> @panic("expected record item"),
  };
}

@test
function parserParsesFullStatementSurfaceInsideExpressionBlocks(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_expression_block_surface.ign",
    "function main(): void { let action = (): i32 -> { let mut value: i32 = 0; if (true) { value = 1; } while (false) { continue; } return value; }; let selected = match (1) { 1 -> { let answer: i32 = 2; answer }, _ -> 0 }; }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 0);

  let functionId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing main function root"),
  };

  match (expectItem(&module, functionId)) {
    Ast::Item::Node::Function(functionItem) -> {
      match (expectStatement(&module, functionItem.body)) {
        Ast::Statement::Node::Block(block) -> {
          let actionStatementId: Ast::StatementId = match (block.statements.get(0)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing lambda binding statement"),
          };
          let selectedStatementId: Ast::StatementId = match (block.statements.get(1)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing match binding statement"),
          };

          match (expectStatement(&module, actionStatementId)) {
            Ast::Statement::Node::Let(letStatement) -> {
              let lambdaId: Ast::ExpressionId = match (letStatement.value) {
                Option::SOME(value) -> value,
                Option::NONE -> @panic("missing lambda expression value"),
              };

              match (expectExpression(&module, lambdaId)) {
                Ast::Expression::Node::Lambda(lambda) -> {
                  match (expectStatement(&module, lambda.body)) {
                    Ast::Statement::Node::Block(body) -> Test::assertEq<u64>(body.statements.length(), 4),
                    _ -> @panic("expected block lambda body"),
                  };
                },
                _ -> @panic("expected lambda expression"),
              };
            },
            _ -> @panic("expected lambda let statement"),
          };

          match (expectStatement(&module, selectedStatementId)) {
            Ast::Statement::Node::Let(letStatement) -> {
              let matchId: Ast::ExpressionId = match (letStatement.value) {
                Option::SOME(value) -> value,
                Option::NONE -> @panic("missing match expression value"),
              };

              match (expectExpression(&module, matchId)) {
                Ast::Expression::Node::Match(matchExpression) -> {
                  let firstArm: &Ast::Expression::MatchArm = match (matchExpression.arms.get(0)) {
                    Option::SOME(value) -> value,
                    Option::NONE -> @panic("missing first match arm"),
                  };

                  match (expectExpression(&module, firstArm.body)) {
                    Ast::Expression::Node::Block(blockExpression) -> {
                      Test::assertEq<u64>(blockExpression.statements.length(), 1);
                      Test::assertEq<boolean>(blockExpression.tail.isSome(), true);
                    },
                    _ -> @panic("expected block expression match arm"),
                  };
                },
                _ -> @panic("expected match expression"),
              };
            },
            _ -> @panic("expected match let statement"),
          };
        },
        _ -> @panic("expected function body block"),
      };
    },
    _ -> @panic("expected main function item"),
  };
}

@test
function parserParsesSelfKeywordMemberAccessInsideRecordMethods(): void {
