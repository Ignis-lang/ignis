@test
function parserParsesBuiltinCallsAndIndexExpressions(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_builtin_index.ign",
    "function main(): void { @read<u8>(buffer[1 + 2]); }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 0);
  Test::assertEq<u64>(module.roots.length(), 1);

  let functionId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing builtin/index function root"),
  };

  match (module.items.get(functionId)) {
    Option::SOME(Ast::Item::Node::Function(functionItem)) -> {
      match (expectStatement(&module, functionItem.body)) {
        Ast::Statement::Node::Block(block) -> {
          let statementId: Ast::StatementId = match (block.statements.get(0)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing builtin expression statement"),
          };

          match (expectStatement(&module, statementId)) {
            Ast::Statement::Node::Expression(expressionStatement) -> {
              match (expectExpression(&module, expressionStatement.expression)) {
                Ast::Expression::Node::BuiltinCall(builtinCall) -> {
                  Test::assertEq<str>(builtinCall.name.toStr(), "read");
                  Test::assertEq<u64>(builtinCall.typeArguments.length(), 1);
                  Test::assertEq<u64>(builtinCall.arguments.length(), 1);

                  let argumentId: Ast::ExpressionId = match (builtinCall.arguments.get(0)) {
                    Option::SOME(value) -> *value,
                    Option::NONE -> @panic("missing builtin call argument"),
                  };

                  match (expectExpression(&module, argumentId)) {
                    Ast::Expression::Node::VectorAccess(access) -> {
                      match (expectExpression(&module, access.vector)) {
                        Ast::Expression::Node::Path(path) -> Test::assertEq<u64>(path.segments.length(), 1),
                        _ -> @panic("expected path vector expression"),
                      };

                      match (expectExpression(&module, access.index)) {
                        Ast::Expression::Node::Binary(binaryExpression) -> {
                          match (expectExpression(&module, binaryExpression.left)) {
                            Ast::Expression::Node::Literal(_) -> {},
                            _ -> @panic("expected literal left operand in vector index expression"),
                          };

                          match (expectExpression(&module, binaryExpression.right)) {
                            Ast::Expression::Node::Literal(_) -> {},
                            _ -> @panic("expected literal right operand in vector index expression"),
                          };
                        },
                        _ -> @panic("expected binary index expression"),
                      };
                    },
                    _ -> @panic("expected vector access builtin argument"),
                  };
                },
                _ -> @panic("expected builtin call expression"),
              };
            },
            _ -> @panic("expected expression statement for builtin/index test"),
          };
        },
        _ -> @panic("expected block function body for builtin/index test"),
      };
    },
