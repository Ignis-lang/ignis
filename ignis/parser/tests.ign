@test
function parserRecoversToNextTopLevelItemAfterMalformedTypeAlias(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_recovery.ign",
    "type Broken = ; function recovered(): i32 {}"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  if (diagnostics.length() == 0) {
    @panic("expected malformed trait recovery to emit diagnostics");
  }

  if (module.roots.length() != 1) {
    @panic("expected one recovered root after malformed trait");
  }

  let rootId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing recovered function root"),
  };

  match (module.items.get(rootId)) {
    Option::SOME(Ast::Item::Node::Function(functionItem)) -> Test::assertEq<str>(functionItem.name.toStr(), "recovered"),
    _ -> @panic("expected recovered function item"),
  };
}

@test
function parserParsesRealFileShapeWithImportAndReturnLiteral(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_real_file.ign",
    "import _ from \"@compiler::ast::tests\"; function main(): i32 { return 0; }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 0);
  Test::assertEq<u64>(module.roots.length(), 2);

  let importId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing import root"),
  };

  match (module.items.get(importId)) {
    Option::SOME(Ast::Item::Node::Import(importItem)) -> {
      Test::assertEq<u64>(importItem.items.length(), 1);
      Test::assertEq<str>(importItem.source.toStr(), "@compiler::ast::tests");
      Test::assertEq<str>(importItem.sourceSpan.filePath, "fixtures/parser_real_file.ign");

      match (importItem.items.get(0)) {
        Option::SOME(binding) -> {
          Test::assert(binding.kind == Ast::ImportBindingKind::Discard);
          match (binding.name) {
            Option::NONE -> {},
            Option::SOME(_) -> @panic("expected discard binding without name"),
          };
        },
        Option::NONE -> @panic("missing import binding"),
      };
    },
    _ -> @panic("expected import root item"),
  };

  let functionId: Ast::ItemId = match (module.roots.get(1)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing function root"),
  };

  match (module.items.get(functionId)) {
    Option::SOME(Ast::Item::Node::Function(functionItem)) -> {
      Test::assertEq<str>(functionItem.name.toStr(), "main");

      let returnTypeId: Ast::TypeId = match (functionItem.returnType) {
        Option::SOME(value) -> value,
        Option::NONE -> @panic("missing function return type"),
      };

      match (expectType(&module, returnTypeId)) {
        Ast::Type::Node::Path(pathType) -> {
          Test::assertEq<u64>(pathType.segments.length(), 1);

          let segment: &String = match (pathType.segments.get(0)) {
            Option::SOME(value) -> value,
            Option::NONE -> @panic("missing return type segment"),
          };

          Test::assertEq<str>(segment.toStr(), "i32");
        },
        _ -> @panic("expected path return type"),
      };

      match (expectStatement(&module, functionItem.body)) {
        Ast::Statement::Node::Block(block) -> {
          Test::assertEq<u64>(block.statements.length(), 1);

          let returnStatementId: Ast::StatementId = match (block.statements.get(0)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing return statement"),
          };

          match (expectStatement(&module, returnStatementId)) {
            Ast::Statement::Node::Return(returnStatement) -> {
              let returnValueId: Ast::ExpressionId = match (returnStatement.value) {
                Option::SOME(value) -> value,
                Option::NONE -> @panic("missing return value"),
              };

              match (expectExpression(&module, returnValueId)) {
                Ast::Expression::Node::Literal(literal) -> {
                  match (literal.value) {
                    Ast::Expression::LiteralValue::UInt(number) -> Test::assertEq<u64>(number, 0),
                    _ -> @panic("expected unsigned integer literal"),
                  };
                },
                _ -> @panic("expected literal return expression"),
              };
            },
            _ -> @panic("expected return statement in function body"),
          };
        },
        _ -> @panic("expected function body block"),
      };
    },
    _ -> @panic("expected function root item"),
  };
}

@test
function parserParsesImportListWithTrailingCommaBeforeFrom(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_import_trailing_comma.ign",
    "import Foo,\n  Bar,\nfrom \"std::io\";\nfunction main(): void {}"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 0);
  Test::assertEq<u64>(module.roots.length(), 2);

  let importId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing import root"),
  };

  match (module.items.get(importId)) {
    Option::SOME(Ast::Item::Node::Import(importItem)) -> {
      Test::assertEq<u64>(importItem.items.length(), 2);
      Test::assertEq<str>(importItem.source.toStr(), "std::io");

      match (importItem.items.get(0)) {
        Option::SOME(binding) -> Test::assertEq<str>(match (binding.name) {
          Option::SOME(name) -> name.toStr(),
          Option::NONE -> @panic("missing first import binding name"),
        }, "Foo"),
        Option::NONE -> @panic("missing first import binding"),
      };
      match (importItem.items.get(1)) {
        Option::SOME(binding) -> Test::assertEq<str>(match (binding.name) {
          Option::SOME(name) -> name.toStr(),
          Option::NONE -> @panic("missing second import binding name"),
        }, "Bar"),
        Option::NONE -> @panic("missing second import binding"),
      };
    },
    _ -> @panic("expected import root item"),
  };
}

@test
function parserParsesRealIgnisMainFileWithoutDiagnostics(): void {
  let sourceText: String = readFixture("ignis/main.ign");
  let source: SourceFile = SourceFile::create("ignis/main.ign", sourceText.toStr());
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 0);
  Test::assertEq<u64>(module.roots.length(), 34);
}

@test
function parserParsesBareReturnStatementInsideBlock(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_return_void.ign",
    "function main(): void { return; }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  if (diagnostics.length() != 0) {
    @panic("expected enum-with-methods fixture to parse without diagnostics");
  }

  if (module.roots.length() != 1) {
    @panic("expected enum-with-methods fixture to produce one root");
  }

  let functionId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing void function root"),
  };

  match (module.items.get(functionId)) {
    Option::SOME(Ast::Item::Node::Function(functionItem)) -> {
      match (expectStatement(&module, functionItem.body)) {
        Ast::Statement::Node::Block(block) -> {
          Test::assertEq<u64>(block.statements.length(), 1);

          let returnStatementId: Ast::StatementId = match (block.statements.get(0)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing bare return statement"),
          };

          match (expectStatement(&module, returnStatementId)) {
            Ast::Statement::Node::Return(returnStatement) -> Test::assertEq<boolean>(returnStatement.value.isNone(), true),
            _ -> @panic("expected bare return statement"),
          };
        },
        _ -> @panic("expected function body block"),
      };
    },
    _ -> @panic("expected function root item"),
  };
}

@test
function parserParsesReturnCallExpressionInsideBlock(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_return_call.ign",
    "function main(): i32 { return foo(); }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  if (diagnostics.length() != 0) {
    @panic("expected enum-with-methods fixture to parse without diagnostics");
  }

  if (module.roots.length() != 1) {
    @panic("expected enum-with-methods fixture to produce one root");
  }

  let functionId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing function root"),
  };

  match (module.items.get(functionId)) {
    Option::SOME(Ast::Item::Node::Function(functionItem)) -> {
      match (expectStatement(&module, functionItem.body)) {
        Ast::Statement::Node::Block(block) -> {
          Test::assertEq<u64>(block.statements.length(), 1);

          let returnStatementId: Ast::StatementId = match (block.statements.get(0)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing return statement"),
          };

          match (expectStatement(&module, returnStatementId)) {
            Ast::Statement::Node::Return(returnStatement) -> {
              let returnValueId: Ast::ExpressionId = match (returnStatement.value) {
                Option::SOME(value) -> value,
                Option::NONE -> @panic("missing call return value"),
              };

              match (expectExpression(&module, returnValueId)) {
                Ast::Expression::Node::Call(call) -> {
                  Test::assertEq<u64>(call.arguments.length(), 0);

                  match (expectExpression(&module, call.callee)) {
                    Ast::Expression::Node::Path(path) -> {
                      Test::assertEq<u64>(path.segments.length(), 1);

                      let segment: &String = match (path.segments.get(0)) {
                        Option::SOME(value) -> value,
                        Option::NONE -> @panic("missing call callee segment"),
                      };

                      Test::assertEq<str>(segment.toStr(), "foo");
                    },
                    _ -> @panic("expected path callee for call expression"),
                  };
                },
                _ -> @panic("expected call return expression"),
              };
            },
            _ -> @panic("expected return statement"),
          };
        },
        _ -> @panic("expected block function body"),
      };
    },
    _ -> @panic("expected function root item"),
  };
}

@test
function parserParsesSimplePathExpressionStatementInsideBlock(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_path_statement.ign",
    "function main(): void { foo; }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);
  let rendered: String = Ast::Serializer::render(&module);

  Test::assertEq<u64>(diagnostics.length(), 0);
  Test::assertEq<u64>(module.roots.length(), 1);

  let expressionLine: String = String::create("Expression span=");
  let pathLine: String = String::create("Path span=");
  let fooSegment: String = String::create("segments=[\"foo\"]");

  Test::assert(rendered.contains(&expressionLine));
  Test::assert(rendered.contains(&pathLine));
  Test::assert(rendered.contains(&fooSegment));
}

@test
function parserRecoversInsideBlockToLaterReturnStatement(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_block_recovery.ign",
    "function main(): i32 { foo return 7; }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);
  let rendered: String = Ast::Serializer::render(&module);

  Test::assertEq<u64>(diagnostics.length(), 1);
  Test::assertEq<u64>(module.roots.length(), 1);

  let returnLine: String = String::create("Return span=");
  let literalLine: String = String::create("Literal span=");
  let recoveredValue: String = String::create("UInt(7)");

  Test::assert(rendered.contains(&returnLine));
  Test::assert(rendered.contains(&literalLine));
  Test::assert(rendered.contains(&recoveredValue));
}

@test
function parserParsesGroupedAndBinaryPrecedenceExpressions(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_grouped_binary.ign",
    "function main(): void { (1 + 2) * 3; 1 + 2 * 3 == 7; }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 0);
  Test::assertEq<u64>(module.roots.length(), 1);

  let functionId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing grouped precedence function root"),
  };

  match (module.items.get(functionId)) {
    Option::SOME(Ast::Item::Node::Function(functionItem)) -> {
      match (expectStatement(&module, functionItem.body)) {
        Ast::Statement::Node::Block(block) -> {
          Test::assertEq<u64>(block.statements.length(), 2);

          let firstStatementId: Ast::StatementId = match (block.statements.get(0)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing grouped expression statement"),
          };

          match (expectStatement(&module, firstStatementId)) {
            Ast::Statement::Node::Expression(expressionStatement) -> {
              match (expectExpression(&module, expressionStatement.expression)) {
                Ast::Expression::Node::Binary(binaryExpression) -> {
                  Test::assert(binaryExpression.operator == Ast::Expression::BinaryOperator::Multiply);

                  match (expectExpression(&module, binaryExpression.left)) {
                    Ast::Expression::Node::Grouped(grouped) -> {
                      match (expectExpression(&module, grouped.expression)) {
                        Ast::Expression::Node::Binary(innerBinary) -> Test::assert(innerBinary.operator == Ast::Expression::BinaryOperator::Add),
                        _ -> @panic("expected grouped inner add expression"),
                      };
                    },
                    _ -> @panic("expected grouped left operand"),
                  };
                },
                _ -> @panic("expected multiply expression statement"),
              };
            },
            _ -> @panic("expected grouped expression statement node"),
          };

          let secondStatementId: Ast::StatementId = match (block.statements.get(1)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing precedence equality statement"),
          };

          match (expectStatement(&module, secondStatementId)) {
            Ast::Statement::Node::Expression(expressionStatement) -> {
              match (expectExpression(&module, expressionStatement.expression)) {
                Ast::Expression::Node::Binary(binaryExpression) -> {
                  Test::assert(binaryExpression.operator == Ast::Expression::BinaryOperator::Equal);

                  match (expectExpression(&module, binaryExpression.left)) {
                    Ast::Expression::Node::Binary(addBinary) -> {
                      Test::assert(addBinary.operator == Ast::Expression::BinaryOperator::Add);

                      match (expectExpression(&module, addBinary.right)) {
                        Ast::Expression::Node::Binary(multiplyBinary) -> Test::assert(multiplyBinary.operator == Ast::Expression::BinaryOperator::Multiply),
                        _ -> @panic("expected multiply on add right-hand side"),
                      };
                    },
                    _ -> @panic("expected add expression on equality left-hand side"),
                  };
                },
                _ -> @panic("expected equality expression statement"),
              };
            },
            _ -> @panic("expected precedence expression statement node"),
          };
        },
        _ -> @panic("expected block function body for grouped precedence test"),
      };
    },
    _ -> @panic("expected grouped precedence function root"),
  };
}

