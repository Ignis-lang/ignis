    _ -> @panic("expected recovered function item after malformed const"),
  };
}

@test
function parserParsesExportedNamespaceDeclaration(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_export_namespace.ign",
    "export namespace Parser { function main(): void {} }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 0);
  Test::assertEq<u64>(module.roots.length(), 1);

  let exportId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing export root"),
  };

  match (module.items.get(exportId)) {
    Option::SOME(Ast::Item::Node::Export(exportItem)) -> {
      let exportedNamespaceId: Ast::ItemId = match (exportItem.declaration) {
        Option::SOME(value) -> value,
        Option::NONE -> @panic("missing exported namespace declaration"),
      };

      match (module.items.get(exportedNamespaceId)) {
        Option::SOME(Ast::Item::Node::Namespace(namespaceItem)) -> {
          Test::assertEq<str>(namespaceItem.name.toStr(), "Parser");
          Test::assertEq<u64>(namespaceItem.items.length(), 1);
        },
        _ -> @panic("expected namespace item inside export declaration"),
      };
    },
    _ -> @panic("expected export root item"),
  };
}

@test
function parserParsesGenericCallAndRecordInitTypeArguments(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_generic_call_record_init.ign",
    "function main(): void { make<Vec<i32>>(values); Box<Vec<i32>> { value: values }; left < right; }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 0);

  let functionId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing generic expression function root"),
  };

  match (module.items.get(functionId)) {
    Option::SOME(Ast::Item::Node::Function(functionItem)) -> {
      match (expectStatement(&module, functionItem.body)) {
        Ast::Statement::Node::Block(block) -> {
          Test::assertEq<u64>(block.statements.length(), 3);

          let callStatementId: Ast::StatementId = match (block.statements.get(0)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing generic call statement"),
          };
          let recordStatementId: Ast::StatementId = match (block.statements.get(1)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing generic record init statement"),
          };
          let comparisonStatementId: Ast::StatementId = match (block.statements.get(2)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing comparison expression statement"),
          };

          match (expectStatement(&module, callStatementId)) {
            Ast::Statement::Node::Expression(expressionStatement) -> {
              match (expectExpression(&module, expressionStatement.expression)) {
                Ast::Expression::Node::Call(call) -> Test::assertEq<u64>(call.typeArguments.length(), 1),
                _ -> @panic("expected generic call expression"),
              };
            },
            _ -> @panic("expected generic call expression statement"),
          };

          match (expectStatement(&module, recordStatementId)) {
            Ast::Statement::Node::Expression(expressionStatement) -> {
              match (expectExpression(&module, expressionStatement.expression)) {
                Ast::Expression::Node::RecordInit(recordInit) -> Test::assertEq<u64>(recordInit.typeArguments.length(), 1),
                _ -> @panic("expected generic record init expression"),
              };
            },
            _ -> @panic("expected generic record init expression statement"),
          };

          match (expectStatement(&module, comparisonStatementId)) {
            Ast::Statement::Node::Expression(expressionStatement) -> {
              match (expectExpression(&module, expressionStatement.expression)) {
                Ast::Expression::Node::Binary(binaryExpression) -> {
                  match (binaryExpression.operator) {
                    Ast::Expression::BinaryOperator::LessThan -> {},
                    _ -> @panic("expected less-than operator"),
                  };
                },
                _ -> @panic("expected less-than comparison to remain binary expression"),
              };
            },
            _ -> @panic("expected comparison expression statement"),
          };
        },
        _ -> @panic("expected block function body for generic expression test"),
      };
    },
    _ -> @panic("expected function root for generic expression test"),
  };
}
