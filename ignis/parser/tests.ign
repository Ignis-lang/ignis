  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 2);
  Test::assertEq<u64>(module.roots.length(), 2);

  let firstFunctionId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing first malformed-list function root"),
  };
  let secondFunctionId: Ast::ItemId = match (module.roots.get(1)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing second malformed-list function root"),
  };

  match (module.items.get(firstFunctionId)) {
    Option::SOME(Ast::Item::Node::Function(functionItem)) -> {
      match (expectStatement(&module, functionItem.body)) {
        Ast::Statement::Node::Block(block) -> {
          let statementId: Ast::StatementId = match (block.statements.get(0)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing recovered return after malformed call"),
          };

          match (expectStatement(&module, statementId)) {
            Ast::Statement::Node::Return(_) -> {},
            _ -> @panic("expected recovered return after malformed call"),
          };
        },
        _ -> @panic("expected block body for first malformed-list function"),
      };
    },
    _ -> @panic("expected first malformed-list function root"),
  };

  match (module.items.get(secondFunctionId)) {
    Option::SOME(Ast::Item::Node::Function(functionItem)) -> {
      match (expectStatement(&module, functionItem.body)) {
        Ast::Statement::Node::Block(block) -> {
          let statementId: Ast::StatementId = match (block.statements.get(0)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing recovered return after malformed vector"),
          };

          match (expectStatement(&module, statementId)) {
            Ast::Statement::Node::Return(_) -> {},
            _ -> @panic("expected recovered return after malformed vector"),
          };
        },
        _ -> @panic("expected block body for second malformed-list function"),
      };
    },
    _ -> @panic("expected second malformed-list function root"),
  };
}

@test
function parserParsesAttributedRecordConstExternAndEnumDeclarations(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_declaration_surface.ign",
    "@packed record Packet { value: i32; } const MAX_SIZE: i32 = 7; extern libc { @externName(\"puts\") function puts(message: str): i32; const EOF: i32; } enum Option { Some, None, }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  if (diagnostics.length() != 0) {
    @panic("expected attributed declaration source to parse without diagnostics");
  }

  if (module.roots.length() != 4) {
    @panic("expected attributed declaration source to produce four roots");
  }

  let recordId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing attributed record root"),
  };
  let constantId: Ast::ItemId = match (module.roots.get(1)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing constant root"),
  };
  let externId: Ast::ItemId = match (module.roots.get(2)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing extern root"),
  };
  let enumId: Ast::ItemId = match (module.roots.get(3)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing enum root"),
  };

  match (module.items.get(recordId)) {
    Option::SOME(Ast::Item::Node::Record(recordItem)) -> {
      if (!recordItem.name.equals("Packet")) {
        @panic("expected attributed record to keep its declaration name");
      }
    },
    _ -> @panic("expected attributed record root item"),
  };

  match (module.items.get(constantId)) {
    Option::SOME(Ast::Item::Node::Constant(constantItem)) -> {
      if (!constantItem.name.equals("MAX_SIZE")) {
        @panic("expected constant declaration name to be preserved");
      }

      let constantTypeId: Ast::TypeId = match (constantItem.annotation) {
        Option::SOME(value) -> value,
        Option::NONE -> @panic("missing constant annotation"),
      };

      match (expectType(&module, constantTypeId)) {
        Ast::Type::Node::Path(pathType) -> {
          if (pathType.segments.length() != 1) {
            @panic("expected constant type path to contain one segment");
          }
        },
        _ -> @panic("expected constant path type"),
      };

      match (expectExpression(&module, constantItem.value)) {
        Ast::Expression::Node::Literal(literal) -> {
          match (literal.value) {
            Ast::Expression::LiteralValue::UInt(number) -> {
              if (number != 7) {
                @panic("expected constant literal value to be 7");
              }
            },
            _ -> @panic("expected unsigned integer constant literal"),
          };
        },
        _ -> @panic("expected literal constant value"),
      };
    },
    _ -> @panic("expected constant root item"),
  };

  match (module.items.get(externId)) {
    Option::SOME(Ast::Item::Node::Extern(_)) -> {},
    _ -> @panic("expected extern root item"),
  };

  match (module.items.get(enumId)) {
    Option::SOME(Ast::Item::Node::Enum(enumItem)) -> {
      if (!enumItem.name.equals("Option")) {
        @panic("expected enum declaration name to be preserved");
      }

      if (enumItem.variants.length() != 2) {
        @panic("expected enum declaration to produce two variants");
      }

      let firstVariantId: Ast::PatternId = match (enumItem.variants.get(0)) {
        Option::SOME(value) -> *value,
        Option::NONE -> @panic("missing first enum variant"),
      };
      let secondVariantId: Ast::PatternId = match (enumItem.variants.get(1)) {
        Option::SOME(value) -> *value,
        Option::NONE -> @panic("missing second enum variant"),
      };

      match (expectPattern(&module, firstVariantId)) {
        Ast::Pattern::Node::Path(pathPattern) -> Test::assertEq<str>(match (pathPattern.segments.get(0)) {
          Option::SOME(value) -> value.toStr(),
          Option::NONE -> @panic("missing first enum variant segment"),
        }, "Some"),
        _ -> @panic("expected first enum path variant"),
      };

      match (expectPattern(&module, secondVariantId)) {
        Ast::Pattern::Node::Path(pathPattern) -> Test::assertEq<str>(match (pathPattern.segments.get(0)) {
          Option::SOME(value) -> value.toStr(),
          Option::NONE -> @panic("missing second enum variant segment"),
        }, "None"),
        _ -> @panic("expected second enum path variant"),
      };
    },
    _ -> @panic("expected enum root item"),
  };
}

@test
function parserParsesEnumMethods(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_enum_methods.ign",
    "enum TokenType { Plus, Minus, public static getKeywordFromString(): i32 { return 0; } }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  if (diagnostics.length() != 0) {
    @panic("expected enum-with-methods fixture to parse without diagnostics");
  }

  if (module.roots.length() != 1) {
    @panic("expected enum-with-methods fixture to produce one root");
  }

  let enumId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing enum-with-methods root"),
  };

  match (expectItem(&module, enumId)) {
    Ast::Item::Node::Enum(enumItem) -> {
      if (enumItem.variants.length() != 2) {
        @panic("expected enum-with-methods fixture to keep two variants");
      }

      if (enumItem.methods.length() != 1) {
        @panic("expected enum-with-methods fixture to keep one method");
      }

      let methodId: Ast::ItemId = match (enumItem.methods.get(0)) {
        Option::SOME(value) -> *value,
        Option::NONE -> @panic("missing enum method item"),
      };

      match (expectItem(&module, methodId)) {
        Ast::Item::Node::Function(functionItem) -> {
          if (!functionItem.name.equals("getKeywordFromString")) {
            @panic("expected enum method name to remain getKeywordFromString");
          }
        },
        _ -> @panic("expected function item for enum method"),
      };
    },
    _ -> @panic("expected enum item with methods"),
  };
}

@test
function parserParsesEnumInstanceMethodAfterVariants(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_enum_instance_methods.ign",
    "enum Status { OK, ERROR, equals(&self, other: &Status): boolean { return true; } }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 0);
  Test::assertEq<u64>(module.roots.length(), 1);

  let enumId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing enum instance-method root"),
  };

  match (expectItem(&module, enumId)) {
    Ast::Item::Node::Enum(enumItem) -> {
      Test::assertEq<u64>(enumItem.variants.length(), 2);
      Test::assertEq<u64>(enumItem.methods.length(), 1);

      let methodId: Ast::ItemId = match (enumItem.methods.get(0)) {
        Option::SOME(value) -> *value,
        Option::NONE -> @panic("missing enum instance method item"),
      };

      match (expectItem(&module, methodId)) {
        Ast::Item::Node::Function(functionItem) -> {
          Test::assertEq<str>(functionItem.name.toStr(), "equals");
          Test::assertEq<u64>(functionItem.parameters.length(), 2);

          let receiverId: Ast::PatternId = match (functionItem.parameters.get(0)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing enum instance receiver"),
          };
          let otherId: Ast::PatternId = match (functionItem.parameters.get(1)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing enum instance argument"),
          };

          match (expectPattern(&module, receiverId)) {
            Ast::Pattern::Node::Binding(binding) -> {
              Test::assertEq<str>(binding.name.toStr(), "self");

              let receiverTypeId: Ast::TypeId = match (binding.annotation) {
                Option::SOME(value) -> value,
                Option::NONE -> @panic("missing enum instance receiver type"),
              };

              match (expectType(&module, receiverTypeId)) {
                Ast::Type::Node::Reference(referenceType) -> Test::assertEq<boolean>(referenceType.mutable, false),
                _ -> @panic("expected reference receiver type for enum instance method"),
              };
            },
            _ -> @panic("expected binding receiver pattern for enum instance method"),
          };

          match (expectPattern(&module, otherId)) {
            Ast::Pattern::Node::Binding(binding) -> {
              Test::assertEq<str>(binding.name.toStr(), "other");

              let otherTypeId: Ast::TypeId = match (binding.annotation) {
                Option::SOME(value) -> value,
                Option::NONE -> @panic("missing enum instance argument type"),
              };

              match (expectType(&module, otherTypeId)) {
                Ast::Type::Node::Reference(_) -> {},
                _ -> @panic("expected reference type for enum instance argument"),
              };
            },
            _ -> @panic("expected binding argument pattern for enum instance method"),
          };
        },
        _ -> @panic("expected function item for enum instance method"),
      };
    },
    _ -> @panic("expected enum item with instance method"),
  };
}

@test
function parserParsesPipeExpressions(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_pipe_expression.ign",
    "function printPart(label: str, value: i32): void { value.toString() |> String::create(label).concat |> Io::println; }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 0);

  let functionId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing pipe function root"),
  };

  match (expectItem(&module, functionId)) {
    Ast::Item::Node::Function(functionItem) -> {
      match (expectStatement(&module, functionItem.body)) {
        Ast::Statement::Node::Block(block) -> {
          let statementId: Ast::StatementId = match (block.statements.get(0)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing pipe statement"),
          };

          match (expectStatement(&module, statementId)) {
            Ast::Statement::Node::Expression(expressionStatement) -> {
              match (expectExpression(&module, expressionStatement.expression)) {
                Ast::Expression::Node::Pipe(outerPipe) -> {
                  match (expectExpression(&module, outerPipe.left)) {
                    Ast::Expression::Node::Pipe(_) -> {},
                    _ -> @panic("expected nested pipe on left side of chained pipe"),
                  };

                  match (expectExpression(&module, outerPipe.right)) {
                    Ast::Expression::Node::Path(path) -> {
                      Test::assertEq<str>(match (path.segments.get(0)) {
                        Option::SOME(value) -> value.toStr(),
                        Option::NONE -> @panic("missing pipe rhs segment"),
                      }, "Io");
                    },
                    _ -> @panic("expected path rhs for outer pipe"),
                  };
                },
                _ -> @panic("expected pipe expression statement"),
              };
            },
            _ -> @panic("expected expression statement for pipe expression"),
          };
        },
        _ -> @panic("expected block body for pipe expression test"),
      };
    },
    _ -> @panic("expected function item for pipe expression test"),
  };
}

@test
function parserParsesExportedNameWithoutFromClause(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_export_name.ign",
    "export Layout;"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 0);
  Test::assertEq<u64>(module.roots.length(), 1);

  let exportId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing export-name root"),
  };

  match (expectItem(&module, exportId)) {
    Ast::Item::Node::Export(exportItem) -> {
      Test::assertEq<boolean>(exportItem.declaration.isNone(), true);
      Test::assertEq<u64>(exportItem.items.length(), 1);
      match (exportItem.source) {
        Option::NONE -> {},
        Option::SOME(_) -> @panic("expected export without source path"),
      };
      Test::assertEq<str>(match (exportItem.items.get(0)) {
        Option::SOME(binding) -> match (binding.name) {
          Option::SOME(name) -> name.toStr(),
          Option::NONE -> @panic("missing export-name binding"),
        },
        Option::NONE -> @panic("missing export-name item"),
      }, "Layout");
    },
    _ -> @panic("expected export wrapper for export name"),
  };
}

