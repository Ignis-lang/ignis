  Test::assertEq<u64>(module.roots.length(), 1);

  let recordId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing record root"),
  };

  match (expectItem(&module, recordId)) {
