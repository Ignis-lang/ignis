import Fs from "std::fs";
import Io from "std::io";
import Test from "std::test";

import Diagnostic, DiagnosticBag, SourceFile from "@compiler::diagnostics";
import Ast from "@compiler::ast";
import Parser from "@compiler::parser";

function readFixture(path: str): String {
  return match (Fs::readToString(path)) {
    Result::OK(value) -> value,
    Result::ERROR(_) -> @panic("missing parser fixture"),
  };
}

function expectType(module: &Ast::Module, id: Ast::TypeId): &Ast::Type::Node {
  return match (module.types.get(id)) {
    Option::SOME(node) -> node,
    Option::NONE -> @panic("missing parsed type"),
  };
}

function expectStatement(module: &Ast::Module, id: Ast::StatementId): &Ast::Statement::Node {
  return match (module.statements.get(id)) {
    Option::SOME(node) -> node,
    Option::NONE -> @panic("missing parsed statement"),
  };
}

function expectExpression(module: &Ast::Module, id: Ast::ExpressionId): &Ast::Expression::Node {
  return match (module.expressions.get(id)) {
    Option::SOME(node) -> node,
    Option::NONE -> @panic("missing parsed expression"),
  };
}

function expectPattern(module: &Ast::Module, id: Ast::PatternId): &Ast::Pattern::Node {
  return match (module.patterns.get(id)) {
    Option::SOME(node) -> node,
    Option::NONE -> @panic("missing parsed pattern"),
  };
}

function expectItem(module: &Ast::Module, id: Ast::ItemId): &Ast::Item::Node {
  return match (module.items.get(id)) {
    Option::SOME(node) -> node,
    Option::NONE -> @panic("missing parsed item"),
  };
}

@test
function parserParsesTypeAliasAndFunctionFoundation(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_foundation.ign",
    "type Handler = (i32, Vec<Vec<str>>) -> Result<i32, Error>; function main(value: &mut Vec<Vec<str>>): Handler {}"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);
  Test::assertEq<u64>(diagnostics.length(), 0);
  Test::assertEq<u64>(module.roots.length(), 2);

  match (module.roots.get(0)) {
    Option::SOME(itemId) -> {
      match (module.items.get(*itemId)) {
        Option::SOME(Ast::Item::Node::TypeAlias(alias)) -> Test::assertEq<str>(alias.name.toStr(), "Handler"),
        _ -> @panic("expected type alias root"),
      };
    },
    Option::NONE -> @panic("missing first parser root"),
  };

  match (module.roots.get(1)) {
    Option::SOME(itemId) -> {
      match (module.items.get(*itemId)) {
        Option::SOME(Ast::Item::Node::Function(functionItem)) -> {
          Test::assertEq<str>(functionItem.name.toStr(), "main");
          Test::assertEq<u64>(functionItem.parameters.length(), 1);

          let parameterId: Ast::PatternId = match (functionItem.parameters.get(0)) {
            Option::SOME(value) -> *value,
            Option::NONE -> @panic("missing function parameter"),
          };

          match (module.patterns.get(parameterId)) {
            Option::SOME(Ast::Pattern::Node::Binding(binding)) -> {
              Test::assertEq<str>(binding.name.toStr(), "value");

              let parameterType: Ast::TypeId = match (binding.annotation) {
                Option::SOME(typeId) -> typeId,
                Option::NONE -> @panic("missing function parameter type"),
              };

              match (expectType(&module, parameterType)) {
                Ast::Type::Node::Reference(referenceType) -> Test::assertEq<boolean>(referenceType.mutable, true),
                _ -> @panic("expected reference parameter type"),
              };
            },
            _ -> @panic("expected binding parameter pattern"),
          };
        },
        _ -> @panic("expected function root"),
      };
    },
    Option::NONE -> @panic("missing second parser root"),
  };
}

@test
function parserPreservesGenericBoundsOnItemsAndSerializer(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_generic_bounds.ign",
    "trait Hash { hash(&self): i32; } record Box<T: Hash> { value: T; } function hashValue<T: Hash>(value: T): i32 { return 0; }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);
  let rendered: String = Ast::Serializer::render(&module);

  Test::assertEq<u64>(diagnostics.length(), 0);
  Test::assertEq<u64>(module.roots.length(), 3);
  let expectedRenderedNeedle1: String = String::create("name=\"Box\" generics=[\"T\":[[\"Hash\"]]]");
  Test::assert(rendered.contains(&expectedRenderedNeedle1));
  let expectedRenderedNeedle2: String = String::create("name=\"hashValue\" generics=[\"T\":[[\"Hash\"]]]");
  Test::assert(rendered.contains(&expectedRenderedNeedle2));

  match (expectItem(&module, match (module.roots.get(1)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing generic record root"),
  })) {
    Ast::Item::Node::Record(recordItem) -> {
      Test::assertEq<u64>(recordItem.genericParameters.length(), 1);

      let genericParam: &Ast::GenericParam = match (recordItem.genericParameters.get(0)) {
        Option::SOME(value) -> value,
        Option::NONE -> @panic("missing record generic parameter"),
      };
      let bound: &Ast::GenericBound = match (genericParam.bounds.get(0)) {
        Option::SOME(value) -> value,
        Option::NONE -> @panic("missing record generic bound"),
      };
      let segment: &String = match (bound.segments.get(0)) {
        Option::SOME(value) -> value,
        Option::NONE -> @panic("missing record generic bound segment"),
      };

      Test::assertEq<str>(genericParam.name.toStr(), "T");
      Test::assertEq<str>(segment.toStr(), "Hash");
    },
    _ -> @panic("expected generic record root"),
  };

  match (expectItem(&module, match (module.roots.get(2)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing generic function root"),
  })) {
    Ast::Item::Node::Function(functionItem) -> {
      Test::assertEq<u64>(functionItem.genericParameters.length(), 1);

      let genericParam: &Ast::GenericParam = match (functionItem.genericParameters.get(0)) {
        Option::SOME(value) -> value,
        Option::NONE -> @panic("missing function generic parameter"),
      };
      let bound: &Ast::GenericBound = match (genericParam.bounds.get(0)) {
        Option::SOME(value) -> value,
        Option::NONE -> @panic("missing function generic bound"),
      };
      let segment: &String = match (bound.segments.get(0)) {
        Option::SOME(value) -> value,
        Option::NONE -> @panic("missing function generic bound segment"),
      };

      Test::assertEq<str>(genericParam.name.toStr(), "T");
      Test::assertEq<str>(segment.toStr(), "Hash");
    },
    _ -> @panic("expected generic function root"),
  };
}

@test
function parserParsesRecordFieldArrayAndNestedGenericTypes(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_record_types.ign",
    "record Buffer { bytes: u8[4]; view: u8[]; handler: (i32, Vec<Vec<str>>) -> Result<Vec<str>, Error>; }"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  if (diagnostics.length() != 0) {
    @panic("expected enum-with-methods fixture to parse without diagnostics");
  }

  if (module.roots.length() != 1) {
    @panic("expected enum-with-methods fixture to produce one root");
  }

  let rootId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing record root"),
  };

  match (module.items.get(rootId)) {
    Option::SOME(Ast::Item::Node::Record(recordItem)) -> {
      Test::assertEq<str>(recordItem.name.toStr(), "Buffer");
      Test::assertEq<u64>(recordItem.fields.length(), 3);

      let firstField: Ast::PatternId = match (recordItem.fields.get(0)) {
        Option::SOME(value) -> *value,
        Option::NONE -> @panic("missing first record field"),
      };
      let secondField: Ast::PatternId = match (recordItem.fields.get(1)) {
        Option::SOME(value) -> *value,
        Option::NONE -> @panic("missing second record field"),
      };
      let thirdField: Ast::PatternId = match (recordItem.fields.get(2)) {
        Option::SOME(value) -> *value,
        Option::NONE -> @panic("missing third record field"),
      };

      match (module.patterns.get(firstField)) {
        Option::SOME(Ast::Pattern::Node::Binding(binding)) -> {
          let typeId: Ast::TypeId = match (binding.annotation) {
            Option::SOME(value) -> value,
            Option::NONE -> @panic("missing fixed array field type"),
          };

          match (expectType(&module, typeId)) {
            Ast::Type::Node::FixedArray(arrayType) -> Test::assertEq<u64>(arrayType.size, 4),
            _ -> @panic("expected fixed array type"),
          };
        },
        _ -> @panic("expected binding field pattern"),
      };

      match (module.patterns.get(secondField)) {
        Option::SOME(Ast::Pattern::Node::Binding(binding)) -> {
          let typeId: Ast::TypeId = match (binding.annotation) {
            Option::SOME(value) -> value,
            Option::NONE -> @panic("missing slice field type"),
          };

          match (expectType(&module, typeId)) {
            Ast::Type::Node::Slice(_) -> {},
            _ -> @panic("expected slice type"),
          };
        },
        _ -> @panic("expected binding slice field pattern"),
      };

      match (module.patterns.get(thirdField)) {
        Option::SOME(Ast::Pattern::Node::Binding(binding)) -> {
          let typeId: Ast::TypeId = match (binding.annotation) {
            Option::SOME(value) -> value,
            Option::NONE -> @panic("missing handler field type"),
          };

          match (expectType(&module, typeId)) {
            Ast::Type::Node::Function(functionType) -> Test::assertEq<u64>(functionType.parameters.length(), 2),
            _ -> @panic("expected function type"),
          };
        },
        _ -> @panic("expected binding function field pattern"),
      };
    },
    _ -> @panic("expected record root item"),
  };
}

@test
function parserRejectsUnsupportedUnionTypeSyntaxWithTargetedDiagnostic(): void {
  let source: SourceFile = SourceFile::create(
    "fixtures/parser_union_type_unsupported.ign",
    "type Either = Left | Right; function recovered(): void {}"
  );
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);

  Test::assertEq<u64>(diagnostics.length(), 1);
  Test::assertEq<u64>(module.roots.length(), 1);

  let diagnostic: &Diagnostic = match (diagnostics.get(0)) {
    Option::SOME(value) -> value,
    Option::NONE -> @panic("missing unsupported union type diagnostic"),
  };

  Test::assertEq<str>(diagnostic.code, "I0016");
  Test::assertEq<str>(diagnostic.message, "unsupported type operator");
  Test::assertEq<u64>(diagnostic.primarySpan.start, 19);
  Test::assertEq<u64>(diagnostic.primarySpan.end, 20);

  let functionId: Ast::ItemId = match (module.roots.get(0)) {
    Option::SOME(value) -> *value,
    Option::NONE -> @panic("missing recovered function root after unsupported union type"),
  };

  match (expectItem(&module, functionId)) {
    Ast::Item::Node::Function(functionItem) -> Test::assertEq<str>(functionItem.name.toStr(), "recovered"),
    _ -> @panic("expected recovered function item after unsupported union type"),
  };
}

