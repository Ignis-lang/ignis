function parserCompletenessMatrixPath(): str {
  return "docs/selfhost_parser_completeness_matrix.md";
}

function assertTextContains(text: &String, needle: str): void {
  let expected: String = String::create(needle);

  if (!text.contains(&expected)) {
    let mut message: String = String::create("expected text to contain: ");
    message.pushStr(needle);
    message.pushStr("\nactual:\n");
    message.pushStr(text.toStr());
    Io::eprintln(message);
    Test::fail();
  }
}

@test
function parserCorpusParsesSupportedStdSubsetWithoutDiagnostics(): void {
  let paths: Vector<String> = supportedStdSubset();
  Test::assertEq<u64>(paths.length(), 2);
  assertCorpusParsesWithoutDiagnostics(&paths);
}

