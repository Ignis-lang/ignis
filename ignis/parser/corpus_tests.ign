import Fs from "std::fs";
import Io from "std::io";
import Test from "std::test";
import Vector from "std::vector";

import Ast from "@compiler::ast";
import
  CompatibilityFixture,
  Diagnostic,
  DiagnosticBag,
  DiagnosticFixtureParser,
  SourceFile,
from "@compiler::diagnostics";
import Parser from "@compiler::parser";

record ParseResult {
  public module: Ast::Module;
  public diagnostics: DiagnosticBag;
}

function readCorpusFixture(path: str): String {
  return match (Fs::readToString(path)) {
    Result::OK(value) -> value,
    Result::ERROR(_) -> @panic("missing parser corpus fixture"),
  };
}

function pathEquals(path: &String, expected: str): boolean {
  return path.equals(expected);
}

function renderSeverityToken(diagnostic: &Diagnostic): str {
  let displayName: String = String::create(diagnostic.severity.displayName());

  if (displayName.equals("Error")) {
    return "ERROR";
  }

  if (displayName.equals("Warning")) {
    return "WARNING";
  }

  if (displayName.equals("Info")) {
    return "INFO";
  }

  return "HINT";
}

function skipReasonForPath(path: &String): Option<str> {
  return Option::NONE;
}

function parseText(path: str, sourceText: str): ParseResult {
  let source: SourceFile = SourceFile::create(path, sourceText);
  let mut module: Ast::Module = Ast::Module::init();
  let mut diagnostics = DiagnosticBag::init();
  Parser::parseInto(&source, &mut module, &mut diagnostics);
  return ParseResult {
    module: module,
    diagnostics: diagnostics,
  };
}

function parseFixture(path: str): ParseResult {
  let text: String = readCorpusFixture(path);
  return parseText(path, text.toStr());
}

function isIgnFile(path: &String): boolean {
  if (path.length() < 4) {
    return false;
  }

  let suffix: String = path.substringBytes(path.length() - 4, path.length());
  return suffix.equals(".ign");
}

function collectIgnFiles(rootPath: str): Vector<String> {
  if (!Fs::exists(rootPath)) {
    return Vector::new<String>();
  }

  let walked: Vector<String> = match (Fs::walk(rootPath)) {
    Result::OK(value) -> value,
    Result::ERROR(_) -> @panic("failed to walk parser corpus"),
  };
  let mut files: Vector<String> = Vector::new<String>();
  let mut index: u64 = 0;

  while (index < walked.length()) {
    let Option::SOME(path) = walked.get(index) else {
      index += 1;
      continue;
    };

    if (isIgnFile(path)) {
      files.push(path.clone());
    }

    index += 1;
  }

  return files;
}

function pathHasSuffix(path: &String, suffix: str): boolean {
  let suffixText: String = String::create(suffix);

  if (path.length() < suffixText.length()) {
    return false;
  }

  let actualSuffix: String = path.substringBytes(path.length() - suffixText.length(), path.length());
  return actualSuffix.equals(&suffixText);
}

function collectDiagnosticFixtureRoots(rootPath: str): Vector<String> {
  if (!Fs::exists(rootPath)) {
    return Vector::new<String>();
  }

  let expectedSuffix: String = String::create("/expected.diagnostics");
  let walked: Vector<String> = match (Fs::walk(rootPath)) {
    Result::OK(value) -> value,
    Result::ERROR(_) -> @panic("failed to walk parser diagnostic corpus"),
  };
  let mut roots: Vector<String> = Vector::new<String>();
  let mut index: u64 = 0;

  while (index < walked.length()) {
    let Option::SOME(path) = walked.get(index) else {
      index += 1;
      continue;
    };

    if (pathHasSuffix(path, expectedSuffix.toStr())) {
      roots.push(path.substringBytes(0, path.length() - expectedSuffix.length()));
    }

    index += 1;
  }

  return roots;
}

