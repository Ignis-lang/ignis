@test
function parserAstSnapshotForSelfhostFixture(): void {
  let rendered: String = renderParserFixtureAst("test_cases/selfhost/parser/ast_core");
  Test::assertSnapshot("parser-ast-core", rendered.toStr());
}

@test
function parserDiagnosticSnapshotForRecoveryFixture(): void {
  let rendered: String = renderParserFixtureDiagnostics("test_cases/selfhost/parser/diagnostic_recovery");
  Test::assertSnapshot("parser-diagnostic-recovery", rendered.toStr());
}

@test
function parserDiagnosticCompatibilityHarnessMatchesFixture(): void {
  assertParserDiagnosticsFixtureMatches("test_cases/selfhost/parser/diagnostic_recovery");
}

@test
function parserCompletenessMatrixExistsAndTracksCurrentCorpusGates(): void {
  let path: str = parserCompletenessMatrixPath();
  Test::assert(Fs::exists(path));

  let matrix: String = readCorpusFixture(path);
  assertTextContains(&matrix, "# Selfhost Parser Completeness Matrix");
  assertTextContains(&matrix, "std/**/*.ign");
  assertTextContains(&matrix, "test_cases/analyzer/**/*.ign");
  assertTextContains(&matrix, "example/**/*.ign");
  assertTextContains(&matrix, "Generics and bounds");
  assertTextContains(&matrix, "Import / export structure");
}

@test
function parserMalformedFixtureCorpusMatchesDiagnostics(): void {
  let fixtureRoots: Vector<String> = collectDiagnosticFixtureRoots("test_cases/selfhost/parser/malformed");
  Test::assertEq<u64>(fixtureRoots.length(), 2);
  assertDiagnosticFixtureCorpusMatches(&fixtureRoots);
}

@test
function parserTestCasesCorpusIsExercised(): void {
  let validPaths: Vector<String> = collectIgnFiles("test_cases/parser/valid");
  let diagnosticRoots: Vector<String> = collectDiagnosticFixtureRoots("test_cases/parser/diagnostic");

  Test::assertEq<u64>(validPaths.length(), 2);
  Test::assertEq<u64>(diagnosticRoots.length(), 1);

  assertCorpusParsesWithoutDiagnostics(&validPaths);
  assertDiagnosticFixtureCorpusMatches(&diagnosticRoots);
}
