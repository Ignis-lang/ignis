function renderStructuredDiagnostics(diagnostics: &DiagnosticBag): String {
  let mut rendered: String = String::new();
  let mut diagnosticIndex: u64 = 0;

  while (diagnosticIndex < diagnostics.length()) {
    let Option::SOME(diagnostic) = diagnostics.get(diagnosticIndex) else {
      diagnosticIndex += 1;
      continue;
    };

    rendered.pushStr("[");
    rendered.pushStr(renderSeverityToken(diagnostic));
    rendered.pushStr("] ");
    rendered.pushStr(diagnostic.code);
    rendered.pushStr(": ");
    rendered.pushStr(diagnostic.message);
    rendered.pushStr("\n");
    rendered.pushStr("  at ");
    rendered.pushStr(diagnostic.primarySpan.filePath);
    rendered.pushStr(":");
    rendered.pushStr(String::create(diagnostic.primarySpan.start).toStr());
    rendered.pushStr("-");
    rendered.pushStr(String::create(diagnostic.primarySpan.end).toStr());
    rendered.pushStr("\n");

    let mut labelIndex: u64 = 0;
    while (labelIndex < diagnostic.labels.length()) {
      let Option::SOME(label) = diagnostic.labels.get(labelIndex) else {
        labelIndex += 1;
        continue;
      };

      rendered.pushStr("  label(");
      rendered.pushStr(label.kind.displayName());
      rendered.pushStr("): ");
      rendered.pushStr(label.message);
      rendered.pushStr(" at ");
      rendered.pushStr(label.span.filePath);
      rendered.pushStr(":");
      rendered.pushStr(String::create(label.span.start).toStr());
      rendered.pushStr("-");
      rendered.pushStr(String::create(label.span.end).toStr());
      rendered.pushStr("\n");
      labelIndex += 1;
    }

    let mut noteIndex: u64 = 0;
    while (noteIndex < diagnostic.notes.length()) {
      let Option::SOME(note) = diagnostic.notes.get(noteIndex) else {
        noteIndex += 1;
        continue;
      };

      rendered.pushStr("  ");
      rendered.pushStr(note.kind.displayName());
      rendered.pushStr(": ");
      rendered.pushStr(note.message);
      rendered.pushStr("\n");
      noteIndex += 1;
    }

    if (let Option::SOME(help) = diagnostic.help) {
      rendered.pushStr("  help: ");
      rendered.pushStr(help);
      rendered.pushStr("\n");
    }

    if (diagnosticIndex + 1 < diagnostics.length()) {
      rendered.pushStr("\n");
    }

    diagnosticIndex += 1;
  }

  return rendered;
}

function assertParsesWithoutDiagnostics(path: str): void {
  let result: ParseResult = parseFixture(path);

  if (result.diagnostics.length() != 0) {
    let mut message: String = String::create("expected parser corpus file to parse without diagnostics: ");
    message.pushStr(path);
    message.pushStr("\n");
    message.pushStr(renderStructuredDiagnostics(&result.diagnostics).toStr());
    Io::eprintln(message);
    Test::fail();
  }

  if (result.module.roots.length() == 0) {
    let mut message: String = String::create("expected parser corpus file to produce roots: ");
    message.pushStr(path);
    Io::eprintln(message);
    Test::fail();
  }
}

function assertParsesWithoutDiagnosticsAndIsNotSkipped(path: str): void {
  assertParsesWithoutDiagnostics(path);

  let ownedPath: String = String::create(path);

  match (skipReasonForPath(&ownedPath)) {
    Option::NONE -> {},
    Option::SOME(reason) -> {
      let mut message: String = String::create("expected parser corpus path to stop being skipped after parsing cleanly: ");
      message.pushStr(path);
      message.pushStr("\nreason: ");
      message.pushStr(reason);
      Io::eprintln(message);
      Test::fail();
    },
  };
}

function assertCorpusParsesWithoutDiagnostics(paths: &Vector<String>): void {
  let mut index: u64 = 0;

  while (index < paths.length()) {
    let Option::SOME(path) = paths.get(index) else {
      index += 1;
      continue;
    };

    match (skipReasonForPath(path)) {
      Option::SOME(_) -> {},
      Option::NONE -> assertParsesWithoutDiagnostics(path.toStr()),
    };

    index += 1;
  }
}

function renderParserFixtureAst(rootPath: str): String {
  let fixture: CompatibilityFixture = DiagnosticFixtureParser::loadFixture(rootPath);
  let sourceText: String = match (fixture.input) {
    Option::SOME(value) -> value,
    Option::NONE -> @panic("missing parser AST fixture input"),
  };
  let result: ParseResult = parseText(String::create(rootPath).concat("/input.ign").toStr(), sourceText.toStr());

  Test::assertEq<u64>(result.diagnostics.length(), 0);
  return Ast::Serializer::render(&result.module);
}

function renderParserFixtureDiagnostics(rootPath: str): String {
  let fixture: CompatibilityFixture = DiagnosticFixtureParser::loadFixture(rootPath);
  let sourceText: String = match (fixture.input) {
    Option::SOME(value) -> value,
    Option::NONE -> @panic("missing parser diagnostic fixture input"),
  };
  let result: ParseResult = parseText(String::create(rootPath).concat("/input.ign").toStr(), sourceText.toStr());

  return renderStructuredDiagnostics(&result.diagnostics);
}

function assertParserDiagnosticsFixtureMatches(rootPath: str): void {
  let fixture: CompatibilityFixture = DiagnosticFixtureParser::loadFixture(rootPath);
  let sourceText: String = match (fixture.input) {
    Option::SOME(value) -> value,
    Option::NONE -> @panic("missing parser compatibility input fixture"),
  };
  let expectedDiagnosticsText: String = match (fixture.expectedDiagnostics) {
    Option::SOME(value) -> value,
    Option::NONE -> @panic("missing parser compatibility diagnostics fixture"),
  };
  let expectedDiagnostics = DiagnosticFixtureParser::parse(expectedDiagnosticsText.toStr());
  let result: ParseResult = parseText(String::create(rootPath).concat("/input.ign").toStr(), sourceText.toStr());

  if (!DiagnosticFixtureParser::compare(&expectedDiagnostics, &result.diagnostics)) {
    let mut message: String = String::create("parser compatibility mismatch for ");
    message.pushStr(rootPath);
    message.pushStr("\nexpected:\n");
    message.pushStr(expectedDiagnosticsText.toStr());
    message.pushStr("\nactual:\n");
    message.pushStr(renderStructuredDiagnostics(&result.diagnostics).toStr());
    Io::eprintln(message);
    Test::fail();
  }
}

function assertDiagnosticFixtureCorpusMatches(rootPaths: &Vector<String>): void {
  let mut index: u64 = 0;

  while (index < rootPaths.length()) {
    let Option::SOME(rootPath) = rootPaths.get(index) else {
      index += 1;
      continue;
    };

    assertParserDiagnosticsFixtureMatches(rootPath.toStr());
    index += 1;
  }
}

function countApplicablePaths(paths: &Vector<String>): u64 {
  let mut count: u64 = 0;
  let mut index: u64 = 0;

  while (index < paths.length()) {
    let Option::SOME(path) = paths.get(index) else {
      index += 1;
      continue;
    };

    match (skipReasonForPath(path)) {
      Option::SOME(_) -> {},
      Option::NONE -> count += 1,
    };

    index += 1;
  }

  return count;
}

