/// Scenario: Vector<i32, str> where Vector<T> expects 1 arg — 1 UNDEFINED_TYPE diagnostic.
@test
function resolveEmitsWrongArityDiagnostic(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // Define Vector<T> (arity 1).
  let mut vectorGenericParams: Vector<Ast::GenericParam> = Vector::new<Ast::GenericParam>();
  vectorGenericParams.push(Ast::GenericParam {
    span: resolverDummySpan(),
    name: String::create("T"),
    bounds: Vector::new<Ast::GenericBound>(),
  });

  let _vectorId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("MyVector"),
    genericParameters: vectorGenericParams,
    fields: Vector::new<Ast::PatternId>(),
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  // Field typed MyVector<i32, str> (arity 2 vs expected 1).
  let i32TypeId: Ast::TypeId = addPathType(&mut module, "i32");
  let strTypeId: Ast::TypeId = addPathType(&mut module, "str");

  let mut baseSegments: Vector<String> = Vector::new<String>();
  baseSegments.push(String::create("MyVector"));
