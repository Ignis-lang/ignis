/// Scenario: two runs over identical input produce identical TypeStore length and slot values.
@test
function resolveProducesIdenticalOutputsAcrossTwoRuns(): void {
  // Run A.
  let mut defStoreA: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStoreA: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbolsA: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut moduleA: Ast::Module = Ast::Module::init();

  let typeAnnotA: Ast::TypeId = addPathType(&mut moduleA, "i32");
  let fieldXA: Ast::PatternId = addAnnotatedField(&mut moduleA, "x", typeAnnotA);
  let mut fieldsA: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fieldsA.push(fieldXA);

  let recordIdA: Ast::ItemId = moduleA.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("Point"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: fieldsA,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  let pass1A: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &moduleA.roots,
    &mut defStoreA,
    &mut typeStoreA,
    &mut symbolsA,
    &moduleA,
  );

  let pass2A: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &moduleA.roots,
    &mut defStoreA,
    &mut typeStoreA,
    &mut symbolsA,
    &moduleA,
    &pass1A,
  );

  let _outputA: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStoreA,
    &mut typeStoreA,
    &mut symbolsA,
    &moduleA,
    &pass1A,
    &pass2A,
  );

  // Run B.
  let mut defStoreB: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStoreB: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbolsB: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut moduleB: Ast::Module = Ast::Module::init();

  let typeAnnotB: Ast::TypeId = addPathType(&mut moduleB, "i32");
  let fieldXB: Ast::PatternId = addAnnotatedField(&mut moduleB, "x", typeAnnotB);
  let mut fieldsB: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fieldsB.push(fieldXB);

  let recordIdB: Ast::ItemId = moduleB.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("Point"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: fieldsB,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  let pass1B: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &moduleB.roots,
    &mut defStoreB,
    &mut typeStoreB,
    &mut symbolsB,
    &moduleB,
  );

  let pass2B: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &moduleB.roots,
    &mut defStoreB,
    &mut typeStoreB,
    &mut symbolsB,
    &moduleB,
    &pass1B,
  );

  let _outputB: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStoreB,
    &mut typeStoreB,
    &mut symbolsB,
    &moduleB,
    &pass1B,
    &pass2B,
  );

  // TypeStore lengths must be equal.
  Test::assertEq<u64>(typeStoreA.length(), typeStoreB.length());

  // Field slot TypeIds must be equal.
  let fdA: Analyzer::FieldDef = getFieldDef(&mut defStoreA, &mut typeStoreA, &moduleA, recordIdA, &pass1A, 0);
  let fdB: Analyzer::FieldDef = getFieldDef(&mut defStoreB, &mut typeStoreB, &moduleB, recordIdB, &pass1B, 0);

  Test::assertEq<u32>(fdA.fieldType.raw(), fdB.fieldType.raw());
}

// ============================================================
// Phase 12: Missing spec scenario coverage (W1-W4)
// ============================================================

/// Scenario: Non-VOID slot is not overwritten — idempotence proof.
///
/// Pre-populate a FieldDef's fieldType with the i32 TypeId before calling
/// resolveTypes. The field annotation is also i32, so the resolved value
/// equals the pre-set value. Assert the slot is unchanged after resolution
/// and no diagnostic is emitted.
@test
function resolverDoesNotOverwriteAlreadyResolvedSlot(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let i32TypeAnnot: Ast::TypeId = addPathType(&mut module, "i32");
  let fieldPat: Ast::PatternId = addAnnotatedField(&mut module, "x", i32TypeAnnot);

  let mut fields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fields.push(fieldPat);

  let recordId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("Point"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: fields,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  // Pre-populate the field's fieldType to i32 before calling the resolver.
  let i32TypeId: Analyzer::TypeId = typeStore.intern(Analyzer::Type::I32);
  let fd: Analyzer::FieldDef = getFieldDef(&mut defStore, &mut typeStore, &module, recordId, &pass1, 0);

  let Option::SOME(pointDefId) = Analyzer::Binder::findDef(&pass1, recordId.raw()) else {
    @panic("Point not found in pass-1");
  };

  let Option::SOME(pointDef) = defStore.get(pointDefId) else {
    @panic("defStore.get NONE for Point");
  };

  match (pointDef) {
    Analyzer::Definition::Record(rec) -> {
      let Option::SOME(fieldDefIdRef) = rec.fields.get(0) else {
        @panic("fields.get(0) NONE");
      };

      let preSet: Analyzer::FieldDef = Analyzer::FieldDef {
        name: fd.name,
        fieldType: i32TypeId,
        owner: fd.owner,
        index: fd.index,
      };

      defStore.replace(*fieldDefIdRef, Analyzer::Definition::Field(preSet));
    },
    Analyzer::Definition::Enum(_) -> @panic("expected Record"),
    Analyzer::Definition::Function(_) -> @panic("expected Record"),
    Analyzer::Definition::Variable(_) -> @panic("expected Record"),
    Analyzer::Definition::Field(_) -> @panic("expected Record"),
    Analyzer::Definition::Variant(_) -> @panic("expected Record"),
    Analyzer::Definition::TypeParam(_) -> @panic("expected Record"),
    Analyzer::Definition::TypeAlias(_) -> @panic("expected Record"),
    Analyzer::Definition::Trait(_) -> @panic("expected Record"),
  };

  let output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  // Slot should still hold i32 — resolver resolves the annotation (i32) and
  // writes the same value back, so the TypeId is unchanged.
  let fdAfter: Analyzer::FieldDef = getFieldDef(&mut defStore, &mut typeStore, &module, recordId, &pass1, 0);

  Test::assertEq<u32>(fdAfter.fieldType.raw(), i32TypeId.raw());
  Test::assertEq<u64>(output.diagnostics.length(), 0);
}

/// Scenario: Pair<Box<i32>, boolean> — nested concrete generic instance.
///
/// Asserts that the outer resolved TypeId is Instance(pairDefId, [Instance(boxDefId, [i32]), boolean])
/// matching the spec scenario exactly.
@test
function resolverResolvesConcreteNestedGenericInstance(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // Define Box<T>.
  let mut boxParams: Vector<Ast::GenericParam> = Vector::new<Ast::GenericParam>();
  boxParams.push(Ast::GenericParam {
    span: resolverDummySpan(),
    name: String::create("T"),
    bounds: Vector::new<Ast::GenericBound>(),
  });

  let boxId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("Box"),
    genericParameters: boxParams,
    fields: Vector::new<Ast::PatternId>(),
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  // Define Pair<A, B>.
  let mut pairParams: Vector<Ast::GenericParam> = Vector::new<Ast::GenericParam>();
  pairParams.push(Ast::GenericParam {
    span: resolverDummySpan(),
    name: String::create("A"),
    bounds: Vector::new<Ast::GenericBound>(),
  });
  pairParams.push(Ast::GenericParam {
    span: resolverDummySpan(),
    name: String::create("B"),
    bounds: Vector::new<Ast::GenericBound>(),
  });

  let pairId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("Pair"),
    genericParameters: pairParams,
    fields: Vector::new<Ast::PatternId>(),
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  // Build type annotation: Pair<Box<i32>, boolean>.
  let i32PathId: Ast::TypeId = addPathType(&mut module, "i32");

  let mut boxSegments: Vector<String> = Vector::new<String>();
  boxSegments.push(String::create("Box"));
  let boxPathId: Ast::TypeId = module.addType(Ast::Type::Node::Path(Ast::Type::Path {
    span: resolverDummySpan(),
    segments: boxSegments,
  }));

  let mut boxArgs: Vector<Ast::TypeId> = Vector::new<Ast::TypeId>();
  boxArgs.push(i32PathId);
  let boxI32TypeId: Ast::TypeId = module.addType(Ast::Type::Node::Generic(Ast::Type::Generic {
    span: resolverDummySpan(),
    base: boxPathId,
    arguments: boxArgs,
  }));

  let booleanPathId: Ast::TypeId = addPathType(&mut module, "boolean");

  let mut pairSegments: Vector<String> = Vector::new<String>();
  pairSegments.push(String::create("Pair"));
  let pairPathId: Ast::TypeId = module.addType(Ast::Type::Node::Path(Ast::Type::Path {
    span: resolverDummySpan(),
    segments: pairSegments,
  }));

  let mut pairArgs: Vector<Ast::TypeId> = Vector::new<Ast::TypeId>();
  pairArgs.push(boxI32TypeId);
  pairArgs.push(booleanPathId);
  let nestedTypeId: Ast::TypeId = module.addType(Ast::Type::Node::Generic(Ast::Type::Generic {
    span: resolverDummySpan(),
    base: pairPathId,
    arguments: pairArgs,
  }));

  // Define Container with a field typed Pair<Box<i32>, boolean>.
  let nestedField: Ast::PatternId = addAnnotatedField(&mut module, "nested", nestedTypeId);
  let mut containerFields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  containerFields.push(nestedField);

  let containerId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("Container"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: containerFields,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  let Option::SOME(boxDefId) = Analyzer::Binder::findDef(&pass1, boxId.raw()) else {
    @panic("Box not found in pass-1");
  };

  let Option::SOME(pairDefId) = Analyzer::Binder::findDef(&pass1, pairId.raw()) else {
    @panic("Pair not found in pass-1");
  };

  // Build expected: Instance(pairDefId, [Instance(boxDefId, [i32]), boolean]).
  let i32TypeId: Analyzer::TypeId = typeStore.intern(Analyzer::Type::I32);
  let booleanTypeId: Analyzer::TypeId = typeStore.intern(Analyzer::Type::BOOLEAN);

  let mut innerArgs: Vector<Analyzer::TypeId> = Vector::new<Analyzer::TypeId>();
  innerArgs.push(i32TypeId);
  let boxI32Id: Analyzer::TypeId = typeStore.instance(boxDefId, innerArgs);

  let mut outerArgs: Vector<Analyzer::TypeId> = Vector::new<Analyzer::TypeId>();
  outerArgs.push(boxI32Id);
  outerArgs.push(booleanTypeId);
  let expectedId: Analyzer::TypeId = typeStore.instance(pairDefId, outerArgs);

  let fdNested: Analyzer::FieldDef = getFieldDef(&mut defStore, &mut typeStore, &module, containerId, &pass1, 0);

  Test::assertEq<u32>(fdNested.fieldType.raw(), expectedId.raw());
  Test::assertEq<u64>(output.diagnostics.length(), 0);
}

/// Scenario: Two fields both typed Box<i32> resolve to the same TypeId.
///
/// Proves TypeStore structural deduplication: identical generic instances
/// intern to the same slot rather than growing the store twice.
@test
function resolverCachesIdenticalGenericInstance(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // Define Box<T>.
  let mut boxParams: Vector<Ast::GenericParam> = Vector::new<Ast::GenericParam>();
  boxParams.push(Ast::GenericParam {
    span: resolverDummySpan(),
    name: String::create("T"),
    bounds: Vector::new<Ast::GenericBound>(),
  });

  let boxId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("Box"),
    genericParameters: boxParams,
    fields: Vector::new<Ast::PatternId>(),
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  // Two independent Box<i32> annotations — same structure, separate AST nodes.
  let i32AnnotA: Ast::TypeId = addPathType(&mut module, "i32");
  let mut boxSegA: Vector<String> = Vector::new<String>();
  boxSegA.push(String::create("Box"));
  let boxPathA: Ast::TypeId = module.addType(Ast::Type::Node::Path(Ast::Type::Path {
    span: resolverDummySpan(),
    segments: boxSegA,
  }));
  let mut boxArgsA: Vector<Ast::TypeId> = Vector::new<Ast::TypeId>();
  boxArgsA.push(i32AnnotA);
  let boxI32A: Ast::TypeId = module.addType(Ast::Type::Node::Generic(Ast::Type::Generic {
    span: resolverDummySpan(),
    base: boxPathA,
    arguments: boxArgsA,
  }));

  let i32AnnotB: Ast::TypeId = addPathType(&mut module, "i32");
  let mut boxSegB: Vector<String> = Vector::new<String>();
  boxSegB.push(String::create("Box"));
  let boxPathB: Ast::TypeId = module.addType(Ast::Type::Node::Path(Ast::Type::Path {
    span: resolverDummySpan(),
    segments: boxSegB,
  }));
  let mut boxArgsB: Vector<Ast::TypeId> = Vector::new<Ast::TypeId>();
  boxArgsB.push(i32AnnotB);
  let boxI32B: Ast::TypeId = module.addType(Ast::Type::Node::Generic(Ast::Type::Generic {
    span: resolverDummySpan(),
    base: boxPathB,
    arguments: boxArgsB,
  }));

  // Container with two fields: first: Box<i32>, second: Box<i32>.
  let fieldFirst: Ast::PatternId = addAnnotatedField(&mut module, "first", boxI32A);
  let fieldSecond: Ast::PatternId = addAnnotatedField(&mut module, "second", boxI32B);

  let mut containerFields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  containerFields.push(fieldFirst);
  containerFields.push(fieldSecond);

  let containerId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("Container"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: containerFields,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  let fdFirst: Analyzer::FieldDef = getFieldDef(&mut defStore, &mut typeStore, &module, containerId, &pass1, 0);
  let fdSecond: Analyzer::FieldDef = getFieldDef(&mut defStore, &mut typeStore, &module, containerId, &pass1, 1);

  // Both fields must resolve to the SAME TypeId — TypeStore dedup proof.
  Test::assertEq<u32>(fdFirst.fieldType.raw(), fdSecond.fieldType.raw());
  Test::assertEq<u64>(output.diagnostics.length(), 0);
}

/// Scenario: enum Option<T> { NONE, SOME(T) } — variant payload remains deferred (ADR-R5).
///
/// The resolver does not resolve variant payload type annotations. After resolveTypes,
/// the SOME variant's payload slot remains VOID (binder sentinel) and no diagnostic
/// is emitted — deferral is intentional, not erroneous.
@test
function resolverEnumVariantWithPayloadTypeParamIsDeferred(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // NONE variant — unit, no payload.
  let nonePat: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: resolverDummySpan(),
    name: String::create("NONE"),
    annotation: Option::NONE,
    metadata: Ast::emptyMetadata(),
  }));

  // SOME(T) variant — Path pattern with one argument slot representing the payload.
  let someTArg: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: resolverDummySpan(),
    name: String::create("T"),
    annotation: Option::NONE,
    metadata: Ast::emptyMetadata(),
  }));

  let mut someArgs: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  someArgs.push(someTArg);

  let mut someSegments: Vector<String> = Vector::new<String>();
  someSegments.push(String::create("SOME"));

  let somePat: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Path(Ast::Pattern::Path {
    span: resolverDummySpan(),
    segments: someSegments,
    arguments: someArgs,
  }));

  let mut variants: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  variants.push(nonePat);
  variants.push(somePat);

  // Option<T> generic enum.
  let mut optionParams: Vector<Ast::GenericParam> = Vector::new<Ast::GenericParam>();
  optionParams.push(Ast::GenericParam {
    span: resolverDummySpan(),
    name: String::create("T"),
    bounds: Vector::new<Ast::GenericBound>(),
  });

  let optionId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Enum(Ast::Item::Enum {
    span: resolverDummySpan(),
    name: String::create("Option"),
    genericParameters: optionParams,
    variants: variants,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  // No diagnostic — deferral is intentional per ADR-R5.
  Test::assertEq<u64>(output.diagnostics.length(), 0);

  // Retrieve the Option enum's DefinitionId and find the SOME variant's DefinitionId.
  let Option::SOME(optionDefId) = Analyzer::Binder::findDef(&pass1, optionId.raw()) else {
    @panic("Option not found in pass-1");
  };

  let Option::SOME(optionDef) = defStore.get(optionDefId) else {
    @panic("defStore.get NONE for Option");
  };

  match (optionDef) {
    Analyzer::Definition::Enum(en) -> {
      // variants[0] = NONE (unit), variants[1] = SOME (payload).
      let Option::SOME(someDefIdRef) = en.variants.get(1) else {
        @panic("SOME variant not found at index 1");
      };

      let Option::SOME(someDef) = defStore.get(*someDefIdRef) else {
        @panic("defStore.get NONE for SOME variant");
      };

      match (someDef) {
        Analyzer::Definition::Variant(v) -> {
          // Payload slot must remain VOID — resolver defers variant payloads (ADR-R5).
          let Option::SOME(payloadId) = v.payload.get(0) else {
            @panic("SOME variant payload is empty — expected one VOID sentinel");
          };

          let voidId: Analyzer::TypeId = typeStore.intern(Analyzer::Type::VOID);

          Test::assertEq<u32>(payloadId.raw(), voidId.raw());
        },
        Analyzer::Definition::Record(_) -> @panic("expected Variant, got Record"),
        Analyzer::Definition::Enum(_) -> @panic("expected Variant, got Enum"),
        Analyzer::Definition::Function(_) -> @panic("expected Variant, got Function"),
        Analyzer::Definition::Variable(_) -> @panic("expected Variant, got Variable"),
        Analyzer::Definition::Field(_) -> @panic("expected Variant, got Field"),
        Analyzer::Definition::TypeParam(_) -> @panic("expected Variant, got TypeParam"),
        Analyzer::Definition::TypeAlias(_) -> @panic("expected Variant, got TypeAlias"),
        Analyzer::Definition::Trait(_) -> @panic("expected Variant, got Trait"),
      };
    },
    Analyzer::Definition::Record(_) -> @panic("expected Enum, got Record"),
    Analyzer::Definition::Function(_) -> @panic("expected Enum, got Function"),
    Analyzer::Definition::Variable(_) -> @panic("expected Enum, got Variable"),
    Analyzer::Definition::Field(_) -> @panic("expected Enum, got Field"),
    Analyzer::Definition::Variant(_) -> @panic("expected Enum, got Variant"),
    Analyzer::Definition::TypeParam(_) -> @panic("expected Enum, got TypeParam"),
    Analyzer::Definition::TypeAlias(_) -> @panic("expected Enum, got TypeAlias"),
    Analyzer::Definition::Trait(_) -> @panic("expected Enum, got Trait"),
  };
}

/// Scenario: Wrapper<T> with field inner: Box<T> resolves to Type::Instance(boxDefId, [Param(T)]).
@test
function resolveResolvesWrapperGenericWithTypeParam(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // Define Box<T>.
  let mut boxGenericParams: Vector<Ast::GenericParam> = Vector::new<Ast::GenericParam>();
  boxGenericParams.push(Ast::GenericParam {
    span: resolverDummySpan(),
    name: String::create("T"),
    bounds: Vector::new<Ast::GenericBound>(),
  });

  let boxId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("Box"),
    genericParameters: boxGenericParams,
    fields: Vector::new<Ast::PatternId>(),
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  // Define Wrapper<T> with field inner: Box<T>.
  let tTypeId: Ast::TypeId = addPathType(&mut module, "T");

  let mut boxTypeSegments: Vector<String> = Vector::new<String>();
  boxTypeSegments.push(String::create("Box"));
  let boxPathTypeId: Ast::TypeId = module.addType(Ast::Type::Node::Path(Ast::Type::Path {
    span: resolverDummySpan(),
    segments: boxTypeSegments,
  }));

  let mut boxArgs: Vector<Ast::TypeId> = Vector::new<Ast::TypeId>();
  boxArgs.push(tTypeId);

  let boxTTypeId: Ast::TypeId = module.addType(Ast::Type::Node::Generic(Ast::Type::Generic {
    span: resolverDummySpan(),
    base: boxPathTypeId,
    arguments: boxArgs,
  }));

  let innerField: Ast::PatternId = addAnnotatedField(&mut module, "inner", boxTTypeId);

  let mut wrapperFields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  wrapperFields.push(innerField);

  let mut wrapperGenericParams: Vector<Ast::GenericParam> = Vector::new<Ast::GenericParam>();
  wrapperGenericParams.push(Ast::GenericParam {
    span: resolverDummySpan(),
    name: String::create("T"),
    bounds: Vector::new<Ast::GenericBound>(),
  });

  let wrapperId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("Wrapper"),
    genericParameters: wrapperGenericParams,
    fields: wrapperFields,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  let Option::SOME(boxDefId) = Analyzer::Binder::findDef(&pass1, boxId.raw()) else {
    @panic("Box not found in pass-1");
  };

  let tSym: Analyzer::SymbolId = symbols.intern("T");
  let tParamId: Analyzer::TypeId = typeStore.param(tSym);

  let mut expectedArgs: Vector<Analyzer::TypeId> = Vector::new<Analyzer::TypeId>();
  expectedArgs.push(tParamId);
  let expectedTypeId: Analyzer::TypeId = typeStore.instance(boxDefId, expectedArgs);

  let fdInner: Analyzer::FieldDef = getFieldDef(&mut defStore, &mut typeStore, &module, wrapperId, &pass1, 0);

  Test::assertEq<u32>(fdInner.fieldType.raw(), expectedTypeId.raw());
  Test::assertEq<u64>(output.diagnostics.length(), 0);
}

// ============================================================
// Phase 2A RED tests — TypeAlias body resolution and Trait diagnostics
// ============================================================

/// Scenario: `type MyInt = i32;` — after resolver, TypeAliasDef.aliasedType == i32TypeId.
/// Task 2.9.
@test
function resolveResolvesTypeAliasBody(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let i32AnnId: Ast::TypeId = addPathType(&mut module, "i32");

  let aliasId: Ast::ItemId = module.addRootItem(Ast::Item::Node::TypeAlias(Ast::Item::TypeAlias {
    span: resolverDummySpan(),
    name: String::create("MyInt"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    value: i32AnnId,
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  let Option::SOME(defId) = Analyzer::Binder::findDef(&pass1, aliasId.raw()) else {
    @panic("alias not found in pass-1 output");
  };

  let Option::SOME(def) = defStore.get(defId) else {
    @panic("defStore.get returned NONE for alias defId");
  };

  let i32Id: Analyzer::TypeId = typeStore.intern(Analyzer::Type::I32);
  let voidId: Analyzer::TypeId = typeStore.intern(Analyzer::Type::VOID);

  match (def) {
    Analyzer::Definition::TypeAlias(a) -> {
      // aliasedType must be resolved to i32, not VOID sentinel.
      Test::assertEq<boolean>(a.aliasedType.raw() == voidId.raw(), false);
      Test::assertEq<u32>(a.aliasedType.raw(), i32Id.raw());
    },
    Analyzer::Definition::Record(_) -> @panic("expected TypeAlias, got Record"),
    Analyzer::Definition::Enum(_) -> @panic("expected TypeAlias, got Enum"),
    Analyzer::Definition::Function(_) -> @panic("expected TypeAlias, got Function"),
    Analyzer::Definition::Variable(_) -> @panic("expected TypeAlias, got Variable"),
    Analyzer::Definition::Field(_) -> @panic("expected TypeAlias, got Field"),
    Analyzer::Definition::Variant(_) -> @panic("expected TypeAlias, got Variant"),
    Analyzer::Definition::TypeParam(_) -> @panic("expected TypeAlias, got TypeParam"),
    Analyzer::Definition::Trait(_) -> @panic("expected TypeAlias, got Trait"),
  };

  Test::assertEq<u64>(output.diagnostics.length(), 0);
}

/// Scenario: `trait Foo {} function f(): Foo { ... }` — resolver emits 1 UNDEFINED_TYPE
/// diagnostic because a trait name cannot appear in type position, and the function's
/// return type slot stays VOID.
/// Task 2.11.
@test
function resolveEmitsTraitInTypePositionDiagnostic(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // Declare the trait.
  let _traitId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Trait(Ast::Item::Trait {
    span: resolverDummySpan(),
    name: String::create("Foo"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  // A function with return type `Foo` (trait name in type position).
  let fooRetAnnotId: Ast::TypeId = addPathType(&mut module, "Foo");

  let bodyId: Ast::StatementId = module.addStatement(Ast::Statement::Node::Block(Ast::Statement::Block {
    span: resolverDummySpan(),
    statements: Vector::new<Ast::StatementId>(),
    tail: Option::NONE,
  }));

  let fnId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: resolverDummySpan(),
    name: String::create("f"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::SOME(fooRetAnnotId),
    body: bodyId,
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  // Exactly 1 diagnostic with code UNDEFINED_TYPE.
  Test::assertEq<u64>(output.diagnostics.length(), 1);

  let Option::SOME(diag) = output.diagnostics.get(0) else {
    @panic("expected diagnostic at index 0");
  };

  let expectedCode: String = String::create(DiagnosticCode::UNDEFINED_TYPE);
  let actualCode: String = String::create(diag.code);
  Test::assertEq<boolean>(actualCode.equals(&expectedCode), true);

  // Function return type slot stays VOID.
  let Option::SOME(fnDefId) = Analyzer::Binder::findDef(&pass2, fnId.raw()) else {
    @panic("function not found in pass-2 output");
  };

  let Option::SOME(fnDef) = defStore.get(fnDefId) else {
    @panic("defStore.get returned NONE for function");
  };

  let voidId: Analyzer::TypeId = typeStore.intern(Analyzer::Type::VOID);

  match (fnDef) {
    Analyzer::Definition::Function(fn_) -> {
      Test::assertEq<u32>(fn_.returnType.raw(), voidId.raw());
    },
    Analyzer::Definition::Record(_) -> @panic("expected Function, got Record"),
    Analyzer::Definition::Enum(_) -> @panic("expected Function, got Enum"),
    Analyzer::Definition::Variable(_) -> @panic("expected Function, got Variable"),
    Analyzer::Definition::Field(_) -> @panic("expected Function, got Field"),
    Analyzer::Definition::Variant(_) -> @panic("expected Function, got Variant"),
    Analyzer::Definition::TypeParam(_) -> @panic("expected Function, got TypeParam"),
    Analyzer::Definition::TypeAlias(_) -> @panic("expected Function, got TypeAlias"),
    Analyzer::Definition::Trait(_) -> @panic("expected Function, got Trait"),
  };
}

/// Scenario: Record field typed `*mut u8` — resolver produces mutablePointer(u8).
/// Task 2.12.
@test
function resolveResolvesMutablePointerField(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let u8TypeId: Ast::TypeId = addPathType(&mut module, "u8");

  let mutPtrTypeId: Ast::TypeId = module.addType(Ast::Type::Node::Pointer(Ast::Type::Pointer {
    span: resolverDummySpan(),
    mutable: true,
    pointee: u8TypeId,
  }));

  let fieldPtr: Ast::PatternId = addAnnotatedField(&mut module, "ptr", mutPtrTypeId);

  let mut fields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fields.push(fieldPtr);

  let recordId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("RawMut"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: fields,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let _output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  let u8Id: Analyzer::TypeId = typeStore.intern(Analyzer::Type::U8);
  let mutPtrId: Analyzer::TypeId = typeStore.mutablePointer(u8Id);

  let fdPtr: Analyzer::FieldDef = getFieldDef(&mut defStore, &mut typeStore, &module, recordId, &pass1, 0);

  Test::assertEq<u32>(fdPtr.fieldType.raw(), mutPtrId.raw());
  Test::assertEq<u64>(_output.diagnostics.length(), 0);
}

/// Scenario 4 — Generic TypeAlias type-param sub-defs.
/// Given `type Pair<T> = Wrapper<T>` where `record Wrapper<T> {}` is also in scope,
/// after binder pass-2 and resolver:
///   - TypeAliasDef.typeParams has length 1 (a TypeParam sub-def named "T")
///   - TypeAliasDef.aliasedType resolves to Type::Instance(wrapperDefId, [Param(T)])
/// Covers spec Scenario 4 and exercises the buildTypeParamScope path in resolveTypeAliasBody.
/// Task 2.10 (previously skipped).
@test
function resolverResolvesGenericTypeAliasWithTypeParam(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // Define Wrapper<T> record (the RHS target of the alias).
  let mut wrapperGenericParams: Vector<Ast::GenericParam> = Vector::new<Ast::GenericParam>();
  wrapperGenericParams.push(Ast::GenericParam {
    span: resolverDummySpan(),
    name: String::create("T"),
    bounds: Vector::new<Ast::GenericBound>(),
  });

  let wrapperId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("Wrapper"),
    genericParameters: wrapperGenericParams,
    fields: Vector::new<Ast::PatternId>(),
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  // Build `Wrapper<T>` type syntax for the alias body.
  let tBodyAnnotId: Ast::TypeId = addPathType(&mut module, "T");

  let mut wrapperSegments: Vector<String> = Vector::new<String>();
  wrapperSegments.push(String::create("Wrapper"));
  let wrapperPathTypeId: Ast::TypeId = module.addType(Ast::Type::Node::Path(Ast::Type::Path {
    span: resolverDummySpan(),
    segments: wrapperSegments,
  }));

  let mut aliasBodyArgs: Vector<Ast::TypeId> = Vector::new<Ast::TypeId>();
  aliasBodyArgs.push(tBodyAnnotId);

  let wrapperTTypeId: Ast::TypeId = module.addType(Ast::Type::Node::Generic(Ast::Type::Generic {
    span: resolverDummySpan(),
    base: wrapperPathTypeId,
    arguments: aliasBodyArgs,
  }));

  // Define `type Pair<T> = Wrapper<T>`.
  let mut pairGenericParams: Vector<Ast::GenericParam> = Vector::new<Ast::GenericParam>();
  pairGenericParams.push(Ast::GenericParam {
    span: resolverDummySpan(),
    name: String::create("T"),
    bounds: Vector::new<Ast::GenericBound>(),
  });

  let aliasId: Ast::ItemId = module.addRootItem(Ast::Item::Node::TypeAlias(Ast::Item::TypeAlias {
    span: resolverDummySpan(),
    name: String::create("Pair"),
    genericParameters: pairGenericParams,
    value: wrapperTTypeId,
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  // Retrieve the alias definition after the resolver has patched it.
  let Option::SOME(aliasDefId) = Analyzer::Binder::findDef(&pass1, aliasId.raw()) else {
    @panic("alias not found in pass-1 output");
  };

  let Option::SOME(aliasDef) = defStore.get(aliasDefId) else {
    @panic("defStore.get returned NONE for alias defId");
  };

  let Option::SOME(wrapperDefId) = Analyzer::Binder::findDef(&pass1, wrapperId.raw()) else {
    @panic("Wrapper not found in pass-1");
  };

  match (aliasDef) {
    Analyzer::Definition::TypeAlias(a) -> {
      // typeParams must contain exactly 1 sub-def (the T TypeParam).
      Test::assertEq<u64>(a.typeParams.length(), 1);

      // aliasedType must be non-VOID and equal to Instance(Wrapper, [Param(T)]).
      let voidId: Analyzer::TypeId = typeStore.intern(Analyzer::Type::VOID);
      Test::assertEq<boolean>(a.aliasedType.raw() == voidId.raw(), false);

      let tSym: Analyzer::SymbolId = symbols.intern("T");
      let tParamId: Analyzer::TypeId = typeStore.param(tSym);

      let mut expectedArgs: Vector<Analyzer::TypeId> = Vector::new<Analyzer::TypeId>();
      expectedArgs.push(tParamId);
      let expectedAliasedType: Analyzer::TypeId = typeStore.instance(wrapperDefId, expectedArgs);

      Test::assertEq<u32>(a.aliasedType.raw(), expectedAliasedType.raw());
    },
    Analyzer::Definition::Record(_) -> @panic("expected TypeAlias, got Record"),
    Analyzer::Definition::Enum(_) -> @panic("expected TypeAlias, got Enum"),
    Analyzer::Definition::Function(_) -> @panic("expected TypeAlias, got Function"),
    Analyzer::Definition::Variable(_) -> @panic("expected TypeAlias, got Variable"),
    Analyzer::Definition::Field(_) -> @panic("expected TypeAlias, got Field"),
    Analyzer::Definition::Variant(_) -> @panic("expected TypeAlias, got Variant"),
    Analyzer::Definition::TypeParam(_) -> @panic("expected TypeAlias, got TypeParam"),
    Analyzer::Definition::Trait(_) -> @panic("expected TypeAlias, got Trait"),
  };

  Test::assertEq<u64>(output.diagnostics.length(), 0);
}

function resolverMethodSelfParam(module: &mut Ast::Module): Ast::PatternId {
  let mut moduleRef: &mut Ast::Module = module;
  let selfPath: Ast::TypeId = addPathType(module, "Self");
  let selfRef: Ast::TypeId = moduleRef.addType(Ast::Type::Node::Reference(Ast::Type::Reference {
    span: resolverDummySpan(),
    mutable: false,
    target: selfPath,
  }));

  return moduleRef.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: resolverDummySpan(),
    name: String::create("self"),
    annotation: Option::SOME(selfRef),
    metadata: Ast::emptyMetadata(),
  }));
}

@test
function resolverResolvesRecordMethodSignatureSelf(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let body: Ast::StatementId = module.addStatement(Ast::Statement::Node::Block(Ast::Statement::Block {
    span: resolverDummySpan(),
    statements: Vector::new<Ast::StatementId>(),
    tail: Option::NONE,
  }));
  let mut params: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  params.push(resolverMethodSelfParam(&mut module));
  let methodId: Ast::ItemId = module.addItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: resolverDummySpan(),
    name: String::create("cloneSelf"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: params,
    returnType: Option::SOME(addPathType(&mut module, "Self")),
    body: body,
    metadata: Ast::emptyMetadata(),
  }));
  let mut methods: Vector<Ast::ItemId> = Vector::new<Ast::ItemId>();
  methods.push(methodId);
  let recordId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("Box"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: Vector::new<Ast::PatternId>(),
    methods: methods,
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(&module.roots, &mut defStore, &mut typeStore, &mut symbols, &module);
  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(&module.roots, &mut defStore, &mut typeStore, &mut symbols, &module, &pass1);
  let output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(&mut defStore, &mut typeStore, &mut symbols, &module, &pass1, &pass2);
  Test::assertEq<u64>(output.diagnostics.length(), 0);

  let Option::SOME(recordDefId) = Analyzer::Binder::findDef(&pass1, recordId.raw()) else {
    @panic("record not found");
  };
  let expectedSelf: Analyzer::TypeId = typeStore.recordType(recordDefId);
  let Option::SOME(methodDefId) = Analyzer::Binder::findDef(&pass2, methodId.raw()) else {
    @panic("method not found");
  };

  let Option::SOME(def) = defStore.get(methodDefId) else {
    @panic("method def missing");
  };
  match (def) {
    Analyzer::Definition::Method(method) -> {
      Test::assertEq<u32>(method.returnType.raw(), expectedSelf.raw());
      let Option::SOME(paramId) = method.params.get(0) else {
        @panic("self param missing");
      };
      let Option::SOME(paramDef) = defStore.get(*paramId) else {
        @panic("self param def missing");
      };
      match (paramDef) {
        Analyzer::Definition::Variable(param) -> {
          let expectedRef: Analyzer::TypeId = typeStore.reference(expectedSelf);
          Test::assertEq<u32>(param.declaredType.raw(), expectedRef.raw());
        },
        Analyzer::Definition::Method(_) -> @panic("expected Variable"),
        Analyzer::Definition::Record(_) -> @panic("expected Variable"),
        Analyzer::Definition::Enum(_) -> @panic("expected Variable"),
        Analyzer::Definition::Function(_) -> @panic("expected Variable"),
        Analyzer::Definition::Field(_) -> @panic("expected Variable"),
        Analyzer::Definition::Variant(_) -> @panic("expected Variable"),
        Analyzer::Definition::TypeParam(_) -> @panic("expected Variable"),
        Analyzer::Definition::TypeAlias(_) -> @panic("expected Variable"),
        Analyzer::Definition::Trait(_) -> @panic("expected Variable"),
      };
    },
    Analyzer::Definition::Record(_) -> @panic("expected Method"),
    Analyzer::Definition::Enum(_) -> @panic("expected Method"),
    Analyzer::Definition::Function(_) -> @panic("expected Method"),
    Analyzer::Definition::Variable(_) -> @panic("expected Method"),
    Analyzer::Definition::Field(_) -> @panic("expected Method"),
    Analyzer::Definition::Variant(_) -> @panic("expected Method"),
    Analyzer::Definition::TypeParam(_) -> @panic("expected Method"),
    Analyzer::Definition::TypeAlias(_) -> @panic("expected Method"),
    Analyzer::Definition::Trait(_) -> @panic("expected Method"),
  };
}

@test
function resolverResolvesGenericRecordMethodSignatureSelf(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let body: Ast::StatementId = module.addStatement(Ast::Statement::Node::Block(Ast::Statement::Block {
    span: resolverDummySpan(),
    statements: Vector::new<Ast::StatementId>(),
    tail: Option::NONE,
  }));
  let mut params: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  params.push(resolverMethodSelfParam(&mut module));

  let methodId: Ast::ItemId = module.addItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: resolverDummySpan(),
    name: String::create("cloneSelf"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: params,
    returnType: Option::SOME(addPathType(&mut module, "Self")),
    body: body,
    metadata: Ast::emptyMetadata(),
  }));
  let mut methods: Vector<Ast::ItemId> = Vector::new<Ast::ItemId>();
  methods.push(methodId);

  let mut genericParams: Vector<Ast::GenericParam> = Vector::new<Ast::GenericParam>();
  genericParams.push(Ast::GenericParam {
    span: resolverDummySpan(),
    name: String::create("T"),
    bounds: Vector::new<Ast::GenericBound>(),
  });

  let recordId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("Box"),
    genericParameters: genericParams,
    fields: Vector::new<Ast::PatternId>(),
    methods: methods,
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(&module.roots, &mut defStore, &mut typeStore, &mut symbols, &module);
  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(&module.roots, &mut defStore, &mut typeStore, &mut symbols, &module, &pass1);
  let output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(&mut defStore, &mut typeStore, &mut symbols, &module, &pass1, &pass2);
  Test::assertEq<u64>(output.diagnostics.length(), 0);

  let Option::SOME(recordDefId) = Analyzer::Binder::findDef(&pass1, recordId.raw()) else {
    @panic("record not found");
  };
  let tSym: Analyzer::SymbolId = symbols.intern("T");
  let mut args: Vector<Analyzer::TypeId> = Vector::new<Analyzer::TypeId>();
  args.push(typeStore.param(tSym));
  let expectedSelf: Analyzer::TypeId = typeStore.instance(recordDefId, args);

  let Option::SOME(methodDefId) = Analyzer::Binder::findDef(&pass2, methodId.raw()) else {
    @panic("method not found");
  };
  let Option::SOME(def) = defStore.get(methodDefId) else {
    @panic("method def missing");
  };

  match (def) {
    Analyzer::Definition::Method(method) -> {
      Test::assertEq<u32>(method.returnType.raw(), expectedSelf.raw());
      let Option::SOME(paramId) = method.params.get(0) else {
        @panic("self param missing");
      };
      let Option::SOME(paramDef) = defStore.get(*paramId) else {
        @panic("self param def missing");
      };
      match (paramDef) {
        Analyzer::Definition::Variable(param) -> {
          let expectedRef: Analyzer::TypeId = typeStore.reference(expectedSelf);
          Test::assertEq<u32>(param.declaredType.raw(), expectedRef.raw());
        },
        Analyzer::Definition::Method(_) -> @panic("expected Variable"),
        Analyzer::Definition::Record(_) -> @panic("expected Variable"),
        Analyzer::Definition::Enum(_) -> @panic("expected Variable"),
        Analyzer::Definition::Function(_) -> @panic("expected Variable"),
        Analyzer::Definition::Field(_) -> @panic("expected Variable"),
        Analyzer::Definition::Variant(_) -> @panic("expected Variable"),
        Analyzer::Definition::TypeParam(_) -> @panic("expected Variable"),
        Analyzer::Definition::TypeAlias(_) -> @panic("expected Variable"),
        Analyzer::Definition::Trait(_) -> @panic("expected Variable"),
      };
    },
    Analyzer::Definition::Record(_) -> @panic("expected Method"),
    Analyzer::Definition::Enum(_) -> @panic("expected Method"),
    Analyzer::Definition::Function(_) -> @panic("expected Method"),
    Analyzer::Definition::Variable(_) -> @panic("expected Method"),
    Analyzer::Definition::Field(_) -> @panic("expected Method"),
    Analyzer::Definition::Variant(_) -> @panic("expected Method"),
    Analyzer::Definition::TypeParam(_) -> @panic("expected Method"),
    Analyzer::Definition::TypeAlias(_) -> @panic("expected Method"),
    Analyzer::Definition::Trait(_) -> @panic("expected Method"),
  };
}

@test
function resolverRejectsSelfOutsideMethodSignature(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let body: Ast::StatementId = module.addStatement(Ast::Statement::Node::Block(Ast::Statement::Block {
    span: resolverDummySpan(),
    statements: Vector::new<Ast::StatementId>(),
    tail: Option::NONE,
  }));
  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: resolverDummySpan(),
    name: String::create("f"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::SOME(addPathType(&mut module, "Self")),
    body: body,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::Resolver::ResolverOutput = runResolver(&mut defStore, &mut typeStore, &mut symbols, &module);

  Test::assertEq<u64>(output.diagnostics.length(), 1);
  let Option::SOME(diag) = output.diagnostics.get(0) else {
    @panic("expected diagnostic at index 0");
  };
  Test::assertEq<str>(diag.code, DiagnosticCode::UNDEFINED_TYPE);
}
