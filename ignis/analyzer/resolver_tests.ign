/// Scenario: record Box<T> { value: T } — value field resolves to Type::Param(T sym).
@test
function resolveResolvesTypeParamInRecord(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let tTypeId: Ast::TypeId = addPathType(&mut module, "T");
  let valueField: Ast::PatternId = addAnnotatedField(&mut module, "value", tTypeId);

  let mut fields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fields.push(valueField);

  let mut genericParams: Vector<Ast::GenericParam> = Vector::new<Ast::GenericParam>();
  genericParams.push(Ast::GenericParam {
    span: resolverDummySpan(),
    name: String::create("T"),
    bounds: Vector::new<Ast::GenericBound>(),
  });

  let boxId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("Box"),
    genericParameters: genericParams,
    fields: fields,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  // The interned sym for "T".
  let tSym: Analyzer::SymbolId = symbols.intern("T");
  let expectedTypeId: Analyzer::TypeId = typeStore.param(tSym);

  let fdValue: Analyzer::FieldDef = getFieldDef(&mut defStore, &mut typeStore, &module, boxId, &pass1, 0);

  Test::assertEq<u32>(fdValue.fieldType.raw(), expectedTypeId.raw());
  Test::assertEq<u64>(output.diagnostics.length(), 0);
}

/// Scenario: function id<T>(x: T): T — both param and return type resolve to Type::Param(T).
@test
function resolveResolvesTypeParamInFunction(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let tAnnotParam: Ast::TypeId = addPathType(&mut module, "T");
  let tAnnotRet: Ast::TypeId = addPathType(&mut module, "T");

  let paramX: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: resolverDummySpan(),
    name: String::create("x"),
    annotation: Option::SOME(tAnnotParam),
    metadata: Ast::emptyMetadata(),
  }));

  let mut params: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  params.push(paramX);

  let mut genericParams: Vector<Ast::GenericParam> = Vector::new<Ast::GenericParam>();
  genericParams.push(Ast::GenericParam {
    span: resolverDummySpan(),
    name: String::create("T"),
    bounds: Vector::new<Ast::GenericBound>(),
  });

  let bodyId: Ast::StatementId = module.addStatement(Ast::Statement::Node::Block(Ast::Statement::Block {
    span: resolverDummySpan(),
    statements: Vector::new<Ast::StatementId>(),
    tail: Option::NONE,
  }));

  let fnId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: resolverDummySpan(),
    name: String::create("id"),
    genericParameters: genericParams,
    parameters: params,
    returnType: Option::SOME(tAnnotRet),
    body: bodyId,
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  let tSym: Analyzer::SymbolId = symbols.intern("T");
  let expectedTypeId: Analyzer::TypeId = typeStore.param(tSym);

  let Option::SOME(fnDefId) = Analyzer::Binder::findDef(&pass2, fnId.raw()) else {
    @panic("function not found in pass-2 output");
  };

  let Option::SOME(fnDef) = defStore.get(fnDefId) else {
    @panic("defStore.get NONE for function");
  };

  match (fnDef) {
    Analyzer::Definition::Function(fn_) -> {
      Test::assertEq<u32>(fn_.returnType.raw(), expectedTypeId.raw());

      let Option::SOME(p0Id) = fn_.params.get(0) else {
        @panic("missing param 0");
      };

      let Option::SOME(p0) = defStore.get(*p0Id) else {
        @panic("param 0 defStore miss");
      };

      match (p0) {
        Analyzer::Definition::Variable(v) -> {
          Test::assertEq<u32>(v.declaredType.raw(), expectedTypeId.raw());
        },
        Analyzer::Definition::Record(_) -> @panic("expected Variable"),
        Analyzer::Definition::Enum(_) -> @panic("expected Variable"),
        Analyzer::Definition::Function(_) -> @panic("expected Variable"),
        Analyzer::Definition::Field(_) -> @panic("expected Variable"),
        Analyzer::Definition::Variant(_) -> @panic("expected Variable"),
        Analyzer::Definition::TypeParam(_) -> @panic("expected Variable"),
        Analyzer::Definition::TypeAlias(_) -> @panic("expected Variable"),
        Analyzer::Definition::Trait(_) -> @panic("expected Variable"),
      };
    },
    Analyzer::Definition::Record(_) -> @panic("expected Function"),
    Analyzer::Definition::Enum(_) -> @panic("expected Function"),
    Analyzer::Definition::Variable(_) -> @panic("expected Function"),
    Analyzer::Definition::Field(_) -> @panic("expected Function"),
    Analyzer::Definition::Variant(_) -> @panic("expected Function"),
    Analyzer::Definition::TypeParam(_) -> @panic("expected Function"),
    Analyzer::Definition::TypeAlias(_) -> @panic("expected Function"),
    Analyzer::Definition::Trait(_) -> @panic("expected Function"),
  };

  Test::assertEq<u64>(output.diagnostics.length(), 0);
}

/// Scenario: type-param T shadows global record of the same name.
@test
function resolveTypeParamShadowsGlobalRecord(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // Top-level record named "T".
  let _topTId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("T"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: Vector::new<Ast::PatternId>(),
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  // Generic record Box<T> with field value: T. The type-param "T" shadows the global "T".
  let tTypeId: Ast::TypeId = addPathType(&mut module, "T");
  let valueField: Ast::PatternId = addAnnotatedField(&mut module, "value", tTypeId);

  let mut boxFields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  boxFields.push(valueField);

  let mut genericParams: Vector<Ast::GenericParam> = Vector::new<Ast::GenericParam>();
  genericParams.push(Ast::GenericParam {
    span: resolverDummySpan(),
    name: String::create("T"),
    bounds: Vector::new<Ast::GenericBound>(),
  });

  let boxId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("Box"),
    genericParameters: genericParams,
    fields: boxFields,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  let tSym: Analyzer::SymbolId = symbols.intern("T");
  let paramTypeId: Analyzer::TypeId = typeStore.param(tSym);

  let fdValue: Analyzer::FieldDef = getFieldDef(&mut defStore, &mut typeStore, &module, boxId, &pass1, 0);

  // Must resolve to Param(T), not to the global record named T.
  Test::assertEq<u32>(fdValue.fieldType.raw(), paramTypeId.raw());
  Test::assertEq<u64>(output.diagnostics.length(), 0);
}

