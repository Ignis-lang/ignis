/// Scenario: Line { origin: Point } — origin field resolves to Type::Record(pointDefId).
@test
function resolveResolvesUserRecordByName(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // Define Point record with no fields.
  let pointId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("Point"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: Vector::new<Ast::PatternId>(),
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  // Define Line record with origin: Point.
  let originTypeId: Ast::TypeId = addPathType(&mut module, "Point");
  let originField: Ast::PatternId = addAnnotatedField(&mut module, "origin", originTypeId);

  let mut lineFields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  lineFields.push(originField);

  let lineId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("Line"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: lineFields,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  // Find Point's DefinitionId.
  let Option::SOME(pointDefId) = Analyzer::Binder::findDef(&pass1, pointId.raw()) else {
    @panic("Point not found in pass-1");
  };

  let expectedTypeId: Analyzer::TypeId = typeStore.recordType(pointDefId);

  let fdOrigin: Analyzer::FieldDef = getFieldDef(&mut defStore, &mut typeStore, &module, lineId, &pass1, 0);

  Test::assertEq<u32>(fdOrigin.fieldType.raw(), expectedTypeId.raw());
  Test::assertEq<u64>(output.diagnostics.length(), 0);
}

/// Scenario: Container { tag: Direction } where Direction is an enum.
