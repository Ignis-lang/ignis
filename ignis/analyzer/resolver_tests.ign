  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  let u64Id: Analyzer::TypeId = typeStore.intern(Analyzer::Type::U64);

  let Option::SOME(constDefId) = Analyzer::Binder::findDef(&pass2, constId.raw()) else {
    @panic("constant not found in pass-2 output");
  };

  let Option::SOME(constDef) = defStore.get(constDefId) else {
    @panic("defStore.get NONE for constant");
  };

  match (constDef) {
    Analyzer::Definition::Variable(v) -> {
      Test::assertEq<u32>(v.declaredType.raw(), u64Id.raw());
    },
    Analyzer::Definition::Record(_) -> @panic("expected Variable"),
    Analyzer::Definition::Enum(_) -> @panic("expected Variable"),
    Analyzer::Definition::Function(_) -> @panic("expected Variable"),
    Analyzer::Definition::Field(_) -> @panic("expected Variable"),
    Analyzer::Definition::Variant(_) -> @panic("expected Variable"),
    Analyzer::Definition::TypeParam(_) -> @panic("expected Variable"),
    Analyzer::Definition::TypeAlias(_) -> @panic("expected Variable"),
    Analyzer::Definition::Trait(_) -> @panic("expected Variable"),
  };

  Test::assertEq<u64>(output.diagnostics.length(), 0);
}

/// Scenario: enum Direction { NORTH, SOUTH, EAST, WEST } — no TypeStore growth for payloads.
@test
function resolveEnumUnitVariantsHaveNoPayloadGrowth(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let northPat: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: resolverDummySpan(),
    name: String::create("NORTH"),
    annotation: Option::NONE,
    metadata: Ast::emptyMetadata(),
  }));

  let southPat: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: resolverDummySpan(),
    name: String::create("SOUTH"),
    annotation: Option::NONE,
    metadata: Ast::emptyMetadata(),
  }));

  let mut variants: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  variants.push(northPat);
  variants.push(southPat);

  let _enumId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Enum(Ast::Item::Enum {
    span: resolverDummySpan(),
    name: String::create("Direction"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    variants: variants,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let typeStoreLengthAfterBinder: u64 = typeStore.length();

  let output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  // Resolver must not grow TypeStore for enum unit variants.
  Test::assertEq<u64>(typeStore.length(), typeStoreLengthAfterBinder);
  Test::assertEq<u64>(output.diagnostics.length(), 0);
}

