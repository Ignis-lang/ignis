/// Scenario: let MAX: u64 = ... — constant annotation resolved to u64.
@test
function resolveResolvesConstantAnnotation(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let u64AnnotId: Ast::TypeId = addPathType(&mut module, "u64");

  // Dummy constant value expression.
  let valueExpr: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::Literal(Ast::Expression::Literal {
    span: resolverDummySpan(),
    value: Ast::Expression::LiteralValue::UInt(100),
  }));

  let constId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Constant(Ast::Item::Constant {
    span: resolverDummySpan(),
    name: String::create("MAX"),
    annotation: Option::SOME(u64AnnotId),
    value: valueExpr,
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
