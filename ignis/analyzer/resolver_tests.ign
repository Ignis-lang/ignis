import Test from "std::test";

import DiagnosticCode, SourceSpan from "@compiler::diagnostics";
import Ast from "@compiler::ast";
import Analyzer from "@compiler::analyzer";

/// Build a zero-byte source span suitable for test diagnostics.
function resolverDummySpan(): SourceSpan {
  return SourceSpan::new("resolver_test.ign", 0, 0);
}

/// Run pass-1 + pass-2 binder, then the resolver on the given module.
/// Returns the resolver output. All stores are mutated in-place.
function runResolver(
  defStore: &mut Analyzer::DefinitionStore,
  typeStore: &mut Analyzer::TypeStore,
  symbols: &mut Analyzer::SymbolTable,
  module: &Ast::Module,
): Analyzer::Resolver::ResolverOutput {
  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    defStore,
    typeStore,
    symbols,
    module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    defStore,
    typeStore,
    symbols,
    module,
    &pass1,
  );

  return Analyzer::Resolver::resolveTypes(
    defStore,
    typeStore,
    symbols,
    module,
    &pass1,
    &pass2,
  );
}

/// Get the FieldDef at `index` inside the RecordDef identified by `recordItemId`.
///
/// Follows the binder_tests convention: all values are extracted via nested
/// match / let-else chains with no block tail expressions.
function getFieldDef(
  defStore: &mut Analyzer::DefinitionStore,
  typeStore: &mut Analyzer::TypeStore,
  module: &Ast::Module,
  recordItemId: Ast::ItemId,
  pass1: &Analyzer::Binder::BinderOutput,
  fieldIndex: u64,
): Analyzer::FieldDef {
  let Option::SOME(defId) = Analyzer::Binder::findDef(pass1, recordItemId.raw()) else {
    @panic("record not found in pass-1 output");
  };

  match (defStore.get(defId)) {
    Option::SOME(def) -> match (def) {
      Analyzer::Definition::Record(rec) -> {
        let Option::SOME(fidRef) = rec.fields.get(fieldIndex) else {
          @panic("field index out of bounds");
        };

        match (defStore.get(*fidRef)) {
          Option::SOME(fieldDef) -> match (fieldDef) {
            Analyzer::Definition::Field(fd) -> {
              return Analyzer::FieldDef {
                name: fd.name,
                fieldType: fd.fieldType,
                owner: fd.owner,
                index: fd.index,
              };
            },
            Analyzer::Definition::Record(_) -> @panic("expected Field, got Record"),
            Analyzer::Definition::Enum(_) -> @panic("expected Field, got Enum"),
            Analyzer::Definition::Function(_) -> @panic("expected Field, got Function"),
            Analyzer::Definition::Variable(_) -> @panic("expected Field, got Variable"),
            Analyzer::Definition::Variant(_) -> @panic("expected Field, got Variant"),
            Analyzer::Definition::TypeParam(_) -> @panic("expected Field, got TypeParam"),
            Analyzer::Definition::TypeAlias(_) -> @panic("expected Field, got TypeAlias"),
            Analyzer::Definition::Trait(_) -> @panic("expected Field, got Trait"),
          },
          Option::NONE -> @panic("defStore.get returned NONE for field defId"),
        };
      },
      Analyzer::Definition::Enum(_) -> @panic("expected Record, got Enum"),
      Analyzer::Definition::Function(_) -> @panic("expected Record, got Function"),
      Analyzer::Definition::Variable(_) -> @panic("expected Record, got Variable"),
      Analyzer::Definition::Field(_) -> @panic("expected Record, got Field"),
      Analyzer::Definition::Variant(_) -> @panic("expected Record, got Variant"),
      Analyzer::Definition::TypeParam(_) -> @panic("expected Record, got TypeParam"),
      Analyzer::Definition::TypeAlias(_) -> @panic("expected Record, got TypeAlias"),
      Analyzer::Definition::Trait(_) -> @panic("expected Record, got Trait"),
    },
    Option::NONE -> @panic("defStore.get returned NONE for record defId"),
  };

  @panic("getFieldDef: unreachable after match");
}

/// Add a simple Path type annotation to the module and return its TypeId.
function addPathType(module: &mut Ast::Module, name: str): Ast::TypeId {
  let mut segments: Vector<String> = Vector::new<String>();
  segments.push(String::create(name));

  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addType(Ast::Type::Node::Path(Ast::Type::Path {
    span: resolverDummySpan(),
    segments: segments,
  }));
}

/// Add a field Pattern::Binding with a type annotation to the module.
function addAnnotatedField(
  module: &mut Ast::Module,
  name: str,
  typeAnnotation: Ast::TypeId
): Ast::PatternId {
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: resolverDummySpan(),
    name: String::create(name),
    annotation: Option::SOME(typeAnnotation),
    metadata: Ast::emptyMetadata(),
  }));
}

// ============================================================
// Phase 1: Scaffolding + empty-module no-op
// ============================================================

/// Scenario: Empty module produces no diagnostics and stores are unchanged.
@test
function resolveEmptyModuleIsNoOp(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let typeStoreLengthBefore: u64 = typeStore.length();
  let defStoreLengthBefore: u64 = defStore.length();

  let output: Analyzer::Resolver::ResolverOutput = runResolver(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  Test::assertEq<u64>(output.diagnostics.length(), 0);
  Test::assertEq<u64>(typeStore.length(), typeStoreLengthBefore);
  Test::assertEq<u64>(defStore.length(), defStoreLengthBefore);
}

// ============================================================
// Phase 2: Primitive type resolution
// ============================================================

/// Scenario: Record with i32 and str fields — both slots resolved, TypeStore unchanged.
@test
function resolveResolvesPrimitiveFieldTypes(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let typeAnnotationX: Ast::TypeId = addPathType(&mut module, "i32");
  let typeAnnotationY: Ast::TypeId = addPathType(&mut module, "str");

  let fieldX: Ast::PatternId = addAnnotatedField(&mut module, "x", typeAnnotationX);
  let fieldY: Ast::PatternId = addAnnotatedField(&mut module, "y", typeAnnotationY);

  let mut fields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fields.push(fieldX);
  fields.push(fieldY);

  let recordId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("Point"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: fields,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  // Run pass-1 to set up defStore.
  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let typeStoreLengthAfterBinder: u64 = typeStore.length();

  let _output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  // Primitives must not grow TypeStore.
  Test::assertEq<u64>(typeStore.length(), typeStoreLengthAfterBinder);

  let i32Id: Analyzer::TypeId = typeStore.intern(Analyzer::Type::I32);
  let strId: Analyzer::TypeId = typeStore.intern(Analyzer::Type::STR);

  let fdX: Analyzer::FieldDef = getFieldDef(&mut defStore, &mut typeStore, &module, recordId, &pass1, 0);
  let fdY: Analyzer::FieldDef = getFieldDef(&mut defStore, &mut typeStore, &module, recordId, &pass1, 1);

  Test::assertEq<u32>(fdX.fieldType.raw(), i32Id.raw());
  Test::assertEq<u32>(fdY.fieldType.raw(), strId.raw());
  Test::assertEq<u64>(_output.diagnostics.length(), 0);
}

// ============================================================
// Phase 3: Compound type resolution
// ============================================================

/// Scenario: Record with &str (immutable) and &mut str (mutable) reference fields.
@test
function resolveResolvesReferenceField(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let strTypeId: Ast::TypeId = addPathType(&mut module, "str");

  let immutRefTypeId: Ast::TypeId = module.addType(Ast::Type::Node::Reference(Ast::Type::Reference {
    span: resolverDummySpan(),
    mutable: false,
    target: strTypeId,
  }));

  let mutRefTypeId: Ast::TypeId = module.addType(Ast::Type::Node::Reference(Ast::Type::Reference {
    span: resolverDummySpan(),
    mutable: true,
    target: strTypeId,
  }));

  let fieldName: Ast::PatternId = addAnnotatedField(&mut module, "name", immutRefTypeId);
  let fieldRaw: Ast::PatternId = addAnnotatedField(&mut module, "raw", mutRefTypeId);

  let mut fields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fields.push(fieldName);
  fields.push(fieldRaw);

  let recordId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("Foo"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: fields,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let typeStoreLengthAfterBinder: u64 = typeStore.length();

  let _output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  // TypeStore grew by 2 (one immutable Reference, one mutable Reference).
  Test::assertEq<u64>(typeStore.length(), typeStoreLengthAfterBinder + 2);

  let strId: Analyzer::TypeId = typeStore.intern(Analyzer::Type::STR);
  let immutRefId: Analyzer::TypeId = typeStore.reference(strId);
  let mutRefId: Analyzer::TypeId = typeStore.mutableReference(strId);

  let fdName: Analyzer::FieldDef = getFieldDef(&mut defStore, &mut typeStore, &module, recordId, &pass1, 0);
  let fdRaw: Analyzer::FieldDef = getFieldDef(&mut defStore, &mut typeStore, &module, recordId, &pass1, 1);

  Test::assertEq<u32>(fdName.fieldType.raw(), immutRefId.raw());
  Test::assertEq<u32>(fdRaw.fieldType.raw(), mutRefId.raw());
  Test::assertEq<u64>(_output.diagnostics.length(), 0);
}

/// Scenario: Record with *u8 (immutable) pointer field. TypeStore grows by 1.
@test
function resolveResolvesPointerField(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let u8TypeId: Ast::TypeId = addPathType(&mut module, "u8");

  let ptrTypeId: Ast::TypeId = module.addType(Ast::Type::Node::Pointer(Ast::Type::Pointer {
    span: resolverDummySpan(),
    mutable: false,
    pointee: u8TypeId,
  }));

  let fieldPtr: Ast::PatternId = addAnnotatedField(&mut module, "ptr", ptrTypeId);

  let mut fields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fields.push(fieldPtr);

  let recordId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("Raw"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: fields,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let typeStoreLengthAfterBinder: u64 = typeStore.length();

  let _output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  // TypeStore grew by 1 (Pointer(u8)).
  Test::assertEq<u64>(typeStore.length(), typeStoreLengthAfterBinder + 1);

  let u8Id: Analyzer::TypeId = typeStore.intern(Analyzer::Type::U8);
  let ptrId: Analyzer::TypeId = typeStore.pointer(u8Id);

  let fdPtr: Analyzer::FieldDef = getFieldDef(&mut defStore, &mut typeStore, &module, recordId, &pass1, 0);

  Test::assertEq<u32>(fdPtr.fieldType.raw(), ptrId.raw());
  Test::assertEq<u64>(_output.diagnostics.length(), 0);
}

/// Scenario: Record with (i32, boolean) tuple field. TypeStore grows by 1.
@test
function resolveResolvesTupleField(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let i32TypeId: Ast::TypeId = addPathType(&mut module, "i32");
  let boolTypeId: Ast::TypeId = addPathType(&mut module, "boolean");

  let mut tupleElements: Vector<Ast::TypeId> = Vector::new<Ast::TypeId>();
  tupleElements.push(i32TypeId);
  tupleElements.push(boolTypeId);

  let tupleTypeId: Ast::TypeId = module.addType(Ast::Type::Node::Tuple(Ast::Type::Tuple {
    span: resolverDummySpan(),
    elements: tupleElements,
  }));

  let fieldPair: Ast::PatternId = addAnnotatedField(&mut module, "pair", tupleTypeId);

  let mut fields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fields.push(fieldPair);

  let recordId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("Container"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: fields,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let typeStoreLengthAfterBinder: u64 = typeStore.length();

  let _output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  // TypeStore grew by 1 (Tuple([i32, boolean])).
  Test::assertEq<u64>(typeStore.length(), typeStoreLengthAfterBinder + 1);

  let i32Id: Analyzer::TypeId = typeStore.intern(Analyzer::Type::I32);
  let boolId: Analyzer::TypeId = typeStore.intern(Analyzer::Type::BOOLEAN);
  let mut tupleElems: Vector<Analyzer::TypeId> = Vector::new<Analyzer::TypeId>();
  tupleElems.push(i32Id);
  tupleElems.push(boolId);
  let tupleId: Analyzer::TypeId = typeStore.tuple(tupleElems);

  let fdPair: Analyzer::FieldDef = getFieldDef(&mut defStore, &mut typeStore, &module, recordId, &pass1, 0);

  Test::assertEq<u32>(fdPair.fieldType.raw(), tupleId.raw());
  Test::assertEq<u64>(_output.diagnostics.length(), 0);
}

/// Scenario: Record with [i32] slice field. TypeStore grows by 1.
@test
function resolveResolvesSliceField(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let i32TypeId: Ast::TypeId = addPathType(&mut module, "i32");

  let sliceTypeId: Ast::TypeId = module.addType(Ast::Type::Node::Slice(Ast::Type::Slice {
    span: resolverDummySpan(),
    element: i32TypeId,
  }));

  let fieldItems: Ast::PatternId = addAnnotatedField(&mut module, "items", sliceTypeId);

  let mut fields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fields.push(fieldItems);

  let recordId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("SliceHolder"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: fields,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let typeStoreLengthAfterBinder: u64 = typeStore.length();

  let _output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  // TypeStore grew by 1 (Slice(i32)).
  Test::assertEq<u64>(typeStore.length(), typeStoreLengthAfterBinder + 1);

  let i32Id: Analyzer::TypeId = typeStore.intern(Analyzer::Type::I32);
  let sliceId: Analyzer::TypeId = typeStore.slice(i32Id);

  let fdItems: Analyzer::FieldDef = getFieldDef(&mut defStore, &mut typeStore, &module, recordId, &pass1, 0);

  Test::assertEq<u32>(fdItems.fieldType.raw(), sliceId.raw());
  Test::assertEq<u64>(_output.diagnostics.length(), 0);
}

/// Scenario: Record with [u8; 16] fixed-array field. TypeStore grows by 1.
@test
function resolveResolvesFixedArrayField(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let u8TypeId: Ast::TypeId = addPathType(&mut module, "u8");

  let fixedArrTypeId: Ast::TypeId = module.addType(Ast::Type::Node::FixedArray(Ast::Type::FixedArray {
    span: resolverDummySpan(),
    element: u8TypeId,
    size: 16,
  }));

  let fieldBuf: Ast::PatternId = addAnnotatedField(&mut module, "buf", fixedArrTypeId);

  let mut fields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fields.push(fieldBuf);

  let recordId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("Buffer"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: fields,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let typeStoreLengthAfterBinder: u64 = typeStore.length();

  let _output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  // TypeStore grew by 1 (FixedArray(u8, 16)).
  Test::assertEq<u64>(typeStore.length(), typeStoreLengthAfterBinder + 1);

  let u8Id: Analyzer::TypeId = typeStore.intern(Analyzer::Type::U8);
  let fixedArrId: Analyzer::TypeId = typeStore.fixedArray(u8Id, 16);

  let fdBuf: Analyzer::FieldDef = getFieldDef(&mut defStore, &mut typeStore, &module, recordId, &pass1, 0);

  Test::assertEq<u32>(fdBuf.fieldType.raw(), fixedArrId.raw());
  Test::assertEq<u64>(_output.diagnostics.length(), 0);
}

/// Scenario: Record with (i32) -> str function-type field. TypeStore grows by 1.
@test
function resolveResolvesFunctionTypeField(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let i32TypeId: Ast::TypeId = addPathType(&mut module, "i32");
  let strTypeId: Ast::TypeId = addPathType(&mut module, "str");

  let mut fnParams: Vector<Ast::TypeId> = Vector::new<Ast::TypeId>();
  fnParams.push(i32TypeId);

  let fnTypeId: Ast::TypeId = module.addType(Ast::Type::Node::Function(Ast::Type::Function {
    span: resolverDummySpan(),
    parameters: fnParams,
    returnType: strTypeId,
  }));

  let fieldCb: Ast::PatternId = addAnnotatedField(&mut module, "callback", fnTypeId);

  let mut fields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fields.push(fieldCb);

  let recordId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: resolverDummySpan(),
    name: String::create("Transformer"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: fields,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let typeStoreLengthAfterBinder: u64 = typeStore.length();

  let _output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  // TypeStore grew by 1 (Function([i32], str)).
  Test::assertEq<u64>(typeStore.length(), typeStoreLengthAfterBinder + 1);

  let i32Id: Analyzer::TypeId = typeStore.intern(Analyzer::Type::I32);
  let strId: Analyzer::TypeId = typeStore.intern(Analyzer::Type::STR);
  let mut fnParamsResolved: Vector<Analyzer::TypeId> = Vector::new<Analyzer::TypeId>();
  fnParamsResolved.push(i32Id);
  let fnId: Analyzer::TypeId = typeStore.functionType(fnParamsResolved, strId);

  let fdCb: Analyzer::FieldDef = getFieldDef(&mut defStore, &mut typeStore, &module, recordId, &pass1, 0);

  Test::assertEq<u32>(fdCb.fieldType.raw(), fnId.raw());
  Test::assertEq<u64>(_output.diagnostics.length(), 0);
}

// ============================================================
// Phase 4: Function type-syntax resolution
// ============================================================

/// Scenario: function add(a: i32, b: i32): i32 — both params and return type resolved.
@test
function resolveResolvesFunctionParamsAndReturn(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let i32AnnotA: Ast::TypeId = addPathType(&mut module, "i32");
  let i32AnnotB: Ast::TypeId = addPathType(&mut module, "i32");
  let i32AnnotRet: Ast::TypeId = addPathType(&mut module, "i32");

  let paramA: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: resolverDummySpan(),
    name: String::create("a"),
    annotation: Option::SOME(i32AnnotA),
    metadata: Ast::emptyMetadata(),
  }));

  let paramB: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: resolverDummySpan(),
    name: String::create("b"),
    annotation: Option::SOME(i32AnnotB),
    metadata: Ast::emptyMetadata(),
  }));

  let mut params: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  params.push(paramA);
  params.push(paramB);

  let bodyId: Ast::StatementId = module.addStatement(Ast::Statement::Node::Block(Ast::Statement::Block {
    span: resolverDummySpan(),
    statements: Vector::new<Ast::StatementId>(),
    tail: Option::NONE,
  }));

  let fnId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: resolverDummySpan(),
    name: String::create("add"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: params,
    returnType: Option::SOME(i32AnnotRet),
    body: bodyId,
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let _output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  let i32Id: Analyzer::TypeId = typeStore.intern(Analyzer::Type::I32);

  // Find the FunctionDef in pass-2 output.
  let Option::SOME(fnDefId) = Analyzer::Binder::findDef(&pass2, fnId.raw()) else {
    @panic("function not found in pass-2 output");
  };

  let Option::SOME(fnDef) = defStore.get(fnDefId) else {
    @panic("defStore.get returned NONE for function");
  };

  match (fnDef) {
    Analyzer::Definition::Function(fn_) -> {
      // Return type resolved to i32.
      Test::assertEq<u32>(fn_.returnType.raw(), i32Id.raw());

      // Both params resolved to i32.
      Test::assertEq<u64>(fn_.params.length(), 2);

      let Option::SOME(param0Id) = fn_.params.get(0) else {
        @panic("missing param 0");
      };
      let Option::SOME(param1Id) = fn_.params.get(1) else {
        @panic("missing param 1");
      };

      let Option::SOME(p0) = defStore.get(*param0Id) else {
        @panic("param 0 defStore miss");
      };
      let Option::SOME(p1) = defStore.get(*param1Id) else {
        @panic("param 1 defStore miss");
      };

      match (p0) {
        Analyzer::Definition::Variable(v) -> {
          Test::assertEq<u32>(v.declaredType.raw(), i32Id.raw());
        },
        Analyzer::Definition::Record(_) -> @panic("expected Variable"),
        Analyzer::Definition::Enum(_) -> @panic("expected Variable"),
        Analyzer::Definition::Function(_) -> @panic("expected Variable"),
        Analyzer::Definition::Field(_) -> @panic("expected Variable"),
        Analyzer::Definition::Variant(_) -> @panic("expected Variable"),
        Analyzer::Definition::TypeParam(_) -> @panic("expected Variable"),
        Analyzer::Definition::TypeAlias(_) -> @panic("expected Variable"),
        Analyzer::Definition::Trait(_) -> @panic("expected Variable"),
      };

      match (p1) {
        Analyzer::Definition::Variable(v) -> {
          Test::assertEq<u32>(v.declaredType.raw(), i32Id.raw());
        },
        Analyzer::Definition::Record(_) -> @panic("expected Variable"),
        Analyzer::Definition::Enum(_) -> @panic("expected Variable"),
        Analyzer::Definition::Function(_) -> @panic("expected Variable"),
        Analyzer::Definition::Field(_) -> @panic("expected Variable"),
        Analyzer::Definition::Variant(_) -> @panic("expected Variable"),
        Analyzer::Definition::TypeParam(_) -> @panic("expected Variable"),
        Analyzer::Definition::TypeAlias(_) -> @panic("expected Variable"),
        Analyzer::Definition::Trait(_) -> @panic("expected Variable"),
      };
    },
    Analyzer::Definition::Record(_) -> @panic("expected Function"),
    Analyzer::Definition::Enum(_) -> @panic("expected Function"),
    Analyzer::Definition::Variable(_) -> @panic("expected Function"),
    Analyzer::Definition::Field(_) -> @panic("expected Function"),
    Analyzer::Definition::Variant(_) -> @panic("expected Function"),
    Analyzer::Definition::TypeParam(_) -> @panic("expected Function"),
    Analyzer::Definition::TypeAlias(_) -> @panic("expected Function"),
    Analyzer::Definition::Trait(_) -> @panic("expected Function"),
  };

  Test::assertEq<u64>(_output.diagnostics.length(), 0);
}

/// Scenario: function with no return type annotation — VOID slot unchanged, no diagnostic.
@test
function resolveLeavesFunctionReturnVoidWhenAbsent(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let bodyId: Ast::StatementId = module.addStatement(Ast::Statement::Node::Block(Ast::Statement::Block {
    span: resolverDummySpan(),
    statements: Vector::new<Ast::StatementId>(),
    tail: Option::NONE,
  }));

  let fnId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: resolverDummySpan(),
    name: String::create("doSomething"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: bodyId,
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let output: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  let voidId: Analyzer::TypeId = typeStore.intern(Analyzer::Type::VOID);

  let Option::SOME(fnDefId) = Analyzer::Binder::findDef(&pass2, fnId.raw()) else {
    @panic("function not found in pass-2 output");
  };

  let Option::SOME(fnDef) = defStore.get(fnDefId) else {
    @panic("defStore.get NONE");
  };

  match (fnDef) {
    Analyzer::Definition::Function(fn_) -> {
      // Return type must still be VOID (no annotation).
      Test::assertEq<u32>(fn_.returnType.raw(), voidId.raw());
    },
    Analyzer::Definition::Record(_) -> @panic("expected Function"),
    Analyzer::Definition::Enum(_) -> @panic("expected Function"),
    Analyzer::Definition::Variable(_) -> @panic("expected Function"),
    Analyzer::Definition::Field(_) -> @panic("expected Function"),
    Analyzer::Definition::Variant(_) -> @panic("expected Function"),
    Analyzer::Definition::TypeParam(_) -> @panic("expected Function"),
    Analyzer::Definition::TypeAlias(_) -> @panic("expected Function"),
    Analyzer::Definition::Trait(_) -> @panic("expected Function"),
  };

  // No diagnostic for absent return type.
  Test::assertEq<u64>(output.diagnostics.length(), 0);
}

