import Eq from "std::hash";

import Id from "@compiler::ids";
import IndexVec from "@compiler::indexing";
import Symbol from "@compiler::symbols";

import _ from "./ids";
import _ from "./symbols";
import _ from "./definitions";

export namespace Analyzer {
  /// Wrapper record for the Tuple variant payload. Holds element types in order.
  record TupleType {
    public elements: Vector<Analyzer::TypeId>;
  }

  /// Wrapper record for the Function variant payload.
  /// Holds parameter types in declaration order and the return type.
  record FunctionType {
    public params: Vector<Analyzer::TypeId>;
    public returnType: Analyzer::TypeId;
  }

  /// Wrapper record for the Reference variant payload.
  /// Holds the referent type id and a `mutable` flag distinguishing `&T` from `&mut T`.
  record ReferenceType {
    public referent: Analyzer::TypeId;
    public mutable: boolean;
  }

  /// Wrapper record for the Instance variant payload.
  ///
  /// Represents a generic nominal type applied to concrete type arguments
  /// before monomorphization, e.g. `Vector<i32>` resolves to
  /// `Instance(InstanceType { definition: <Vector defId>, typeArguments: [<i32 id>] })`.
  /// After monomorphization, instances are replaced by their specialized
  /// `Record(...)` / `Enum(...)` ids; verifiers may assert no `Instance` remains.
  record InstanceType {
    public definition: Analyzer::DefinitionId;
    public typeArguments: Vector<Analyzer::TypeId>;
  }

  @implements(Eq)
  enum Type {
    I8,
    I16,
    I32,
    I64,
    U8,
    U16,
    U32,
    U64,
    F32,
    F64,
    BOOLEAN,
    CHAR,
    STR,
    VOID,
    NEVER,

    Pointer(Analyzer::TypeId),
    Reference(Analyzer::ReferenceType),
    Slice(Analyzer::TypeId),
    FixedArray(Analyzer::TypeId, u64),
    Tuple(Analyzer::TupleType),
    Function(Analyzer::FunctionType),
    Record(Analyzer::DefinitionId),
    Enum(Analyzer::DefinitionId),

    /// Unresolved generic type parameter, identified by the interned symbol of
    /// its declared name. Lives until monomorphization substitutes it for a
    /// concrete `TypeId`.
    Param(Symbol),

    /// Generic nominal instantiated with concrete type arguments. Replaced by
    /// `Record(...)` or `Enum(...)` for the monomorphized definition once
    /// `Monomorphizer::run` completes.
    Instance(Analyzer::InstanceType),

    public name(&self): str {
      return match (self) {
        Analyzer::Type::I8 -> "i8",
        Analyzer::Type::I16 -> "i16",
        Analyzer::Type::I32 -> "i32",
        Analyzer::Type::I64 -> "i64",
        Analyzer::Type::U8 -> "u8",
        Analyzer::Type::U16 -> "u16",
        Analyzer::Type::U32 -> "u32",
        Analyzer::Type::U64 -> "u64",
        Analyzer::Type::F32 -> "f32",
        Analyzer::Type::F64 -> "f64",
        Analyzer::Type::BOOLEAN -> "boolean",
        Analyzer::Type::CHAR -> "char",
        Analyzer::Type::STR -> "str",
        Analyzer::Type::VOID -> "void",
        Analyzer::Type::NEVER -> "never",
        Analyzer::Type::Pointer(_) -> @panic("Analyzer::Type::name called on compound variant; use TypeStore::nameOf"),
        Analyzer::Type::Reference(_) -> @panic("Analyzer::Type::name called on compound variant; use TypeStore::nameOf"),
        Analyzer::Type::Slice(_) -> @panic("Analyzer::Type::name called on compound variant; use TypeStore::nameOf"),
        Analyzer::Type::FixedArray(_, _) -> @panic("Analyzer::Type::name called on compound variant; use TypeStore::nameOf"),
        Analyzer::Type::Tuple(_) -> @panic("Analyzer::Type::name called on compound variant; use TypeStore::nameOf"),
        Analyzer::Type::Function(_) -> @panic("Analyzer::Type::name called on compound variant; use TypeStore::nameOf"),
        Analyzer::Type::Record(_) -> @panic("Analyzer::Type::name called on compound variant; use TypeStore::nameOf"),
        Analyzer::Type::Enum(_) -> @panic("Analyzer::Type::name called on compound variant; use TypeStore::nameOf"),
        Analyzer::Type::Param(_) -> @panic("Analyzer::Type::name called on compound variant; use TypeStore::nameOf"),
        Analyzer::Type::Instance(_) -> @panic("Analyzer::Type::name called on compound variant; use TypeStore::nameOf"),
      };
    }

    // Exhaustive nested-match equality. Each outer arm matches one variant of `self`,
    // then an inner match enumerates every variant of `other`. The matching variant
    // returns the structural result; every other variant returns false.
    // No wildcard `_` arms are used so that adding a future variant forces a compile
    // error at every match site, preserving exhaustiveness discipline.
    public equals(&self, other: &Analyzer::Type): boolean {
      return match (self) {
        Analyzer::Type::I8 -> match (other) {
          Analyzer::Type::I8 -> true,
          Analyzer::Type::I16 -> false,
          Analyzer::Type::I32 -> false,
          Analyzer::Type::I64 -> false,
          Analyzer::Type::U8 -> false,
          Analyzer::Type::U16 -> false,
          Analyzer::Type::U32 -> false,
          Analyzer::Type::U64 -> false,
          Analyzer::Type::F32 -> false,
          Analyzer::Type::F64 -> false,
          Analyzer::Type::BOOLEAN -> false,
          Analyzer::Type::CHAR -> false,
          Analyzer::Type::STR -> false,
          Analyzer::Type::VOID -> false,
          Analyzer::Type::NEVER -> false,
          Analyzer::Type::Pointer(_) -> false,
          Analyzer::Type::Reference(_) -> false,
          Analyzer::Type::Slice(_) -> false,
          Analyzer::Type::FixedArray(_, _) -> false,
          Analyzer::Type::Tuple(_) -> false,
          Analyzer::Type::Function(_) -> false,
          Analyzer::Type::Record(_) -> false,
          Analyzer::Type::Enum(_) -> false,
          Analyzer::Type::Param(_) -> false,
          Analyzer::Type::Instance(_) -> false,
        },
        Analyzer::Type::I16 -> match (other) {
          Analyzer::Type::I8 -> false,
          Analyzer::Type::I16 -> true,
