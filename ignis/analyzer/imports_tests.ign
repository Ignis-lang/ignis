import Test from "std::test";

import DiagnosticCode, SourceSpan from "@compiler::diagnostics";
import Ast from "@compiler::ast";
import Analyzer from "@compiler::analyzer";

function importsDummySpan(): SourceSpan {
  return SourceSpan::new("imports_tests.ign", 0, 0);
}

function importsSpan(start: u64, end: u64): SourceSpan {
  return SourceSpan::new("imports_tests.ign", start, end);
}

function importsEmptyOverlay(): Analyzer::Imports::ImportOverlay {
  return Analyzer::Imports::ImportOverlay {
    syms: Vector::new<Analyzer::SymbolId>(),
    defs: Vector::new<Analyzer::DefinitionId>(),
    spans: Vector::new<SourceSpan>(),
    targets: Vector::new<u64>(),
  };
}

function importsModuleInfo(index: u64, path: str): Analyzer::Imports::ModuleInfo {
  return Analyzer::Imports::ModuleInfo {
    index: index,
    pathText: String::create(path),
    kind: Analyzer::Imports::ModuleKind::PROJECT,
  };
}

function importsAddBoolLiteral(module: &mut Ast::Module, value: boolean): Ast::ExpressionId {
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addExpression(Ast::Expression::Node::Literal(Ast::Expression::Literal {
    span: importsDummySpan(),
    value: Ast::Expression::LiteralValue::Boolean(value),
  }));
}

function importsAddReturn(module: &mut Ast::Module): Ast::StatementId {
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addStatement(Ast::Statement::Node::Return(Ast::Statement::Return {
    span: importsDummySpan(),
    value: Option::NONE,
  }));
}

function importsAddBlock(
  module: &mut Ast::Module,
  stmts: Vector<Ast::StatementId>
): Ast::StatementId {
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addStatement(Ast::Statement::Node::Block(Ast::Statement::Block {
    span: importsDummySpan(),
    statements: stmts,
    tail: Option::NONE,
  }));
}

function importsFunctionItem(name: str, body: Ast::StatementId): Ast::Item::Function {
  return Ast::Item::Function {
    span: importsDummySpan(),
    name: String::create(name),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: body,
    metadata: Ast::emptyMetadata(),
  };
}

function importsAddFunction(
  module: &mut Ast::Module,
  name: str,
  body: Ast::StatementId,
): Ast::ItemId {
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addRootItem(Ast::Item::Node::Function(importsFunctionItem(name, body)));
}

function importsAddNestedFunction(
  module: &mut Ast::Module,
  name: str,
  body: Ast::StatementId,
): Ast::ItemId {
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addItem(Ast::Item::Node::Function(importsFunctionItem(name, body)));
}

function importsNamespaceWithNestedFunction(): Ast::Module {
  let mut module: Ast::Module = Ast::Module::init();
  let ret: Ast::StatementId = importsAddReturn(&mut module);
  let mut statements: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  statements.push(ret);
  let body: Ast::StatementId = importsAddBlock(&mut module, statements);
  let nested: Ast::ItemId = importsAddNestedFunction(&mut module, "inner", body);

  let mut namespaceItems: Vector<Ast::ItemId> = Vector::new<Ast::ItemId>();
  namespaceItems.push(nested);

  module.addRootItem(Ast::Item::Node::Namespace(Ast::Item::Namespace {
    span: importsDummySpan(),
    name: String::create("Outer"),
    items: namespaceItems,
    metadata: Ast::emptyMetadata(),
  }));

  return module;
}

function importsExportedFunctionModule(name: str): Ast::Module {
  let mut module: Ast::Module = Ast::Module::init();
  let ret: Ast::StatementId = importsAddReturn(&mut module);
  let mut statements: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  statements.push(ret);
  let body: Ast::StatementId = importsAddBlock(&mut module, statements);
  let mut moduleRef: &mut Ast::Module = &mut module;
  let inner: Ast::ItemId = moduleRef.addItem(Ast::Item::Node::Function(importsFunctionItem(name, body)));

  moduleRef.addRootItem(Ast::Item::Node::Export(Ast::Item::Export {
    span: importsDummySpan(),
    declaration: Option::SOME(inner),
    items: Vector::new<Ast::ImportBinding>(),
    source: Option::NONE,
    sourceSpan: Option::NONE,
    metadata: Ast::emptyMetadata(),
  }));

  return module;
}

function importsFunctionModule(name: str): Ast::Module {
  let mut module: Ast::Module = Ast::Module::init();
  let ret: Ast::StatementId = importsAddReturn(&mut module);
  let mut statements: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  statements.push(ret);
  let body: Ast::StatementId = importsAddBlock(&mut module, statements);
  importsAddFunction(&mut module, name, body);
  return module;
}

function importsAddPathType(module: &mut Ast::Module, name: str): Ast::TypeId {
  let mut segments: Vector<String> = Vector::new<String>();
  segments.push(String::create(name));

  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addType(Ast::Type::Node::Path(Ast::Type::Path {
    span: importsDummySpan(),
    segments: segments,
  }));
}

function importsAddGenericPathType(
  module: &mut Ast::Module,
  baseName: str,
  argumentName: str,
): Ast::TypeId {
  let base: Ast::TypeId = importsAddPathType(module, baseName);
  let argument: Ast::TypeId = importsAddPathType(module, argumentName);
  let mut arguments: Vector<Ast::TypeId> = Vector::new<Ast::TypeId>();
  arguments.push(argument);

  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addType(Ast::Type::Node::Generic(Ast::Type::Generic {
    span: importsDummySpan(),
    base: base,
    arguments: arguments,
  }));
}

function importsAddAnnotatedField(
  module: &mut Ast::Module,
  name: str,
  typeAnnotation: Ast::TypeId,
): Ast::PatternId {
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: importsDummySpan(),
    name: String::create(name),
    annotation: Option::SOME(typeAnnotation),
    metadata: Ast::emptyMetadata(),
  }));
}

function importsAddRecord(
  module: &mut Ast::Module,
  name: str,
  fields: Vector<Ast::PatternId>,
): Ast::ItemId {
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: importsDummySpan(),
    name: String::create(name),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: fields,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));
}

function importsRecordModule(name: str): Ast::Module {
  let mut module: Ast::Module = Ast::Module::init();
  let fields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  importsAddRecord(&mut module, name, fields);
  return module;
}

function importsGenericTraitModule(name: str): Ast::Module {
  let mut module: Ast::Module = Ast::Module::init();
  let mut genericParameters: Vector<Ast::GenericParam> = Vector::new<Ast::GenericParam>();
  genericParameters.push(Ast::GenericParam {
    span: importsDummySpan(),
    name: String::create("T"),
    bounds: Vector::new<Ast::GenericBound>(),
  });
  module.addRootItem(Ast::Item::Node::Trait(Ast::Item::Trait {
    span: importsDummySpan(),
    name: String::create(name),
    genericParameters: genericParameters,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));
  return module;
}

function importsNamedBinding(name: str): Ast::ImportBinding {
  return importsNamedBindingAt(name, 0, 0);
}

function importsNamedBindingAt(name: str, start: u64, end: u64): Ast::ImportBinding {
  return Ast::ImportBinding {
    span: importsSpan(start, end),
    kind: Ast::ImportBindingKind::Named,
    name: Option::SOME(String::create(name)),
    alias: Option::NONE,
  };
}

function importsAliasedBinding(name: str, alias: str): Ast::ImportBinding {
  return importsAliasedBindingAt(name, alias, 0, 0);
}

function importsAliasedBindingAt(name: str, alias: str, start: u64, end: u64): Ast::ImportBinding {
  return Ast::ImportBinding {
    span: importsSpan(start, end),
    kind: Ast::ImportBindingKind::Named,
    name: Option::SOME(String::create(name)),
    alias: Option::SOME(String::create(alias)),
  };
}

function importsDiscardBinding(): Ast::ImportBinding {
  return Ast::ImportBinding {
    span: importsDummySpan(),
    kind: Ast::ImportBindingKind::Discard,
    name: Option::NONE,
    alias: Option::NONE,
  };
}

function importsImportItem(source: str, bindings: Vector<Ast::ImportBinding>): Ast::Item::Import {
  return importsImportItemAt(source, bindings, 0, 0);
}

function importsImportItemAt(
  source: str,
  bindings: Vector<Ast::ImportBinding>,
  sourceStart: u64,
  sourceEnd: u64,
): Ast::Item::Import {
  return Ast::Item::Import {
    span: importsDummySpan(),
    items: bindings,
    source: String::create(source),
    sourceSpan: importsSpan(sourceStart, sourceEnd),
    metadata: Ast::emptyMetadata(),
  };
}

function importsModuleWithImport(source: str, bindings: Vector<Ast::ImportBinding>): Ast::Module {
  let mut module: Ast::Module = Ast::Module::init();
  let mut moduleRef: &mut Ast::Module = &mut module;
  moduleRef.addRootItem(Ast::Item::Node::Import(importsImportItem(source, bindings)));
  return module;
}

function importsModuleWithImportAndTypedRecord(
  source: str,
  bindings: Vector<Ast::ImportBinding>,
  recordName: str,
  fieldTypeName: str,
): Ast::Module {
  let mut module: Ast::Module = importsModuleWithImport(source, bindings);
  let fieldType: Ast::TypeId = importsAddPathType(&mut module, fieldTypeName);
  let field: Ast::PatternId = importsAddAnnotatedField(&mut module, "field", fieldType);
  let mut fields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fields.push(field);
  importsAddRecord(&mut module, recordName, fields);
  return module;
}

function importsModuleWithImportAndFunction(
  source: str,
  bindings: Vector<Ast::ImportBinding>,
  functionName: str,
): Ast::Module {
  let mut module: Ast::Module = importsModuleWithImport(source, bindings);
  let ret: Ast::StatementId = importsAddReturn(&mut module);
  let mut statements: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  statements.push(ret);
  let body: Ast::StatementId = importsAddBlock(&mut module, statements);
  importsAddFunction(&mut module, functionName, body);
  return module;
}

function importsAnalyzeTwoModules(
  first: Ast::Module,
  second: Ast::Module,
): Vector<Analyzer::ModuleAnalysisRecord> {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();

  let mut modules: Vector<Ast::Module> = Vector::new<Ast::Module>();
  modules.push(first);
  modules.push(second);

  let mut infos: Vector<Analyzer::Imports::ModuleInfo> = Vector::new<Analyzer::Imports::ModuleInfo>();
  infos.push(importsModuleInfo(0, "a.ign"));
  infos.push(importsModuleInfo(1, "b.ign"));

  return Analyzer::analyzeProgram(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &modules,
    &infos,
  );
}

function importsBinderOutputContainsDef(
  output: &Analyzer::Binder::BinderOutput,
  defId: Analyzer::DefinitionId,
): boolean {
  let mut index: u64 = 0;

  while (index < output.defIds.length()) {
    let Option::SOME(stored) = output.defIds.get(index) else {
      index += 1;
      continue;
    };

    if (stored.raw() == defId.raw()) {
      return true;
    }

    index += 1;
  }

  return false;
}

function importsOverlayWithOne(
  sym: Analyzer::SymbolId,
  defId: Analyzer::DefinitionId,
): Analyzer::Imports::ImportOverlay {
  let mut overlay: Analyzer::Imports::ImportOverlay = importsEmptyOverlay();
  overlay.syms.push(sym);
  overlay.defs.push(defId);
  overlay.spans.push(importsDummySpan());
  overlay.targets.push(0);
  return overlay;
}

function importsRecordFieldType(
  defStore: &mut Analyzer::DefinitionStore,
  recordItemId: Ast::ItemId,
  pass1: &Analyzer::Binder::BinderOutput,
  fieldIndex: u64,
): Analyzer::TypeId {
  let Option::SOME(recordDefId) = Analyzer::Binder::findDef(pass1, recordItemId.raw()) else {
    @panic("missing record definition");
  };

  match (defStore.get(recordDefId)) {
    Option::SOME(definition) -> match (definition) {
      Analyzer::Definition::Record(recordDef) -> {
        let Option::SOME(fieldDefId) = recordDef.fields.get(fieldIndex) else {
          @panic("missing record field definition");
        };

        match (defStore.get(*fieldDefId)) {
          Option::SOME(fieldDefinition) -> match (fieldDefinition) {
            Analyzer::Definition::Field(field) -> {
              return field.fieldType;
            },
            Analyzer::Definition::Record(_) -> @panic("expected field definition"),
            Analyzer::Definition::Enum(_) -> @panic("expected field definition"),
            Analyzer::Definition::Function(_) -> @panic("expected field definition"),
            Analyzer::Definition::Variable(_) -> @panic("expected field definition"),
            Analyzer::Definition::Variant(_) -> @panic("expected field definition"),
            Analyzer::Definition::TypeParam(_) -> @panic("expected field definition"),
            Analyzer::Definition::TypeAlias(_) -> @panic("expected field definition"),
            Analyzer::Definition::Trait(_) -> @panic("expected field definition"),
          },
          Option::NONE -> @panic("missing field definition"),
        };
      },
      Analyzer::Definition::Enum(_) -> @panic("expected record definition"),
      Analyzer::Definition::Function(_) -> @panic("expected record definition"),
      Analyzer::Definition::Variable(_) -> @panic("expected record definition"),
      Analyzer::Definition::Field(_) -> @panic("expected record definition"),
      Analyzer::Definition::Variant(_) -> @panic("expected record definition"),
      Analyzer::Definition::TypeParam(_) -> @panic("expected record definition"),
      Analyzer::Definition::TypeAlias(_) -> @panic("expected record definition"),
      Analyzer::Definition::Trait(_) -> @panic("expected record definition"),
    },
    Option::NONE -> @panic("missing record definition"),
  };

  @panic("unreachable record field lookup");
}

@test
function analyzeProgramRetainsModuleOrder(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();

  let mut modules: Vector<Ast::Module> = Vector::new<Ast::Module>();
  modules.push(importsFunctionModule("first"));
  modules.push(importsFunctionModule("second"));

  let mut infos: Vector<Analyzer::Imports::ModuleInfo> = Vector::new<Analyzer::Imports::ModuleInfo>();
  infos.push(importsModuleInfo(7, "a.ign"));
  infos.push(importsModuleInfo(3, "b.ign"));

  let records: Vector<Analyzer::ModuleAnalysisRecord> = Analyzer::analyzeProgram(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &modules,
    &infos,
  );

  Test::assertEq<u64>(records.length(), 2);

  let Option::SOME(first) = records.get(0) else {
    @panic("missing first analysis record");
  };
  let Option::SOME(second) = records.get(1) else {
    @panic("missing second analysis record");
  };

  Test::assertEq<u64>(first.info.index, 7);
  Test::assertEq<str>(first.info.pathText.toStr(), "a.ign");
  Test::assertEq<u64>(second.info.index, 3);
  Test::assertEq<str>(second.info.pathText.toStr(), "b.ign");
  Test::assertEq<u64>(first.output.diagnostics.length(), 0);
  Test::assertEq<u64>(second.output.diagnostics.length(), 0);
}

@test
function analyzeProgramPreservesModulesWhenInfosAreShort(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();

  let mut modules: Vector<Ast::Module> = Vector::new<Ast::Module>();
  modules.push(importsFunctionModule("only"));

  let infos: Vector<Analyzer::Imports::ModuleInfo> = Vector::new<Analyzer::Imports::ModuleInfo>();
  let records: Vector<Analyzer::ModuleAnalysisRecord> = Analyzer::analyzeProgram(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &modules,
    &infos,
  );

  Test::assertEq<u64>(records.length(), 1);
  let Option::SOME(analysisRecord) = records.get(0) else {
    @panic("missing fallback analysis record");
  };

  Test::assertEq<u64>(analysisRecord.info.index, 0);
  Test::assertEq<str>(analysisRecord.info.pathText.toStr(), "");
  Test::assertEq<u64>(analysisRecord.output.diagnostics.length(), 0);
}

@test
function directIndexKeepsOnlyRootDeclarationsWithRealSpans(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();

  let mut modules: Vector<Ast::Module> = Vector::new<Ast::Module>();
  modules.push(importsNamespaceWithNestedFunction());

  let mut infos: Vector<Analyzer::Imports::ModuleInfo> = Vector::new<Analyzer::Imports::ModuleInfo>();
  infos.push(importsModuleInfo(0, "namespace.ign"));

  let records: Vector<Analyzer::ModuleAnalysisRecord> = Analyzer::analyzeProgram(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &modules,
    &infos,
  );

  let Option::SOME(analysisRecord) = records.get(0) else {
    @panic("missing namespace analysis record");
  };

  Test::assertEq<u64>(analysisRecord.direct.defs.length(), 1);
  let Option::SOME(directSym) = analysisRecord.direct.syms.get(0) else {
    @panic("missing direct declaration symbol");
  };
  let Option::SOME(directName) = symbols.resolve(*directSym) else {
    @panic("missing direct declaration symbol name");
  };
  let Option::SOME(declarationSpan) = analysisRecord.direct.spans.get(0) else {
    @panic("missing direct declaration span");
  };

  Test::assertEq<str>(directName, "Outer");
  Test::assertEq<str>(declarationSpan.filePath, "imports_tests.ign");
}

@test
function directIndexIncludesExportWrappedDeclarations(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();

  let mut modules: Vector<Ast::Module> = Vector::new<Ast::Module>();
  modules.push(importsExportedFunctionModule("exportedFn"));

  let mut infos: Vector<Analyzer::Imports::ModuleInfo> = Vector::new<Analyzer::Imports::ModuleInfo>();
  infos.push(importsModuleInfo(0, "exported.ign"));

  let records: Vector<Analyzer::ModuleAnalysisRecord> = Analyzer::analyzeProgram(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &modules,
    &infos,
  );

  let Option::SOME(analysisRecord) = records.get(0) else {
    @panic("missing exported analysis record");
  };

  Test::assertEq<u64>(analysisRecord.direct.defs.length(), 1);
  let Option::SOME(directSym) = analysisRecord.direct.syms.get(0) else {
    @panic("missing exported direct declaration symbol");
  };
  let Option::SOME(directName) = symbols.resolve(*directSym) else {
    @panic("missing exported direct declaration symbol name");
  };

  Test::assertEq<str>(directName, "exportedFn");
}

@test
function analyzeModuleWithEmptyOverlayMatchesAnalyzeModuleDiagnostics(): void {
  let module: Ast::Module = importsFunctionModule("main");

  let mut singleDefs: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut singleTypes: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut singleSymbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let single: Analyzer::AnalyzerOutput = Analyzer::analyzeModule(
    &mut singleDefs,
    &mut singleTypes,
    &mut singleSymbols,
    &module,
  );

  let mut overlayDefs: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut overlayTypes: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut overlaySymbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let emptyOverlay: Analyzer::Imports::ImportOverlay = importsEmptyOverlay();
  let overlay: Analyzer::AnalyzerOutput = Analyzer::analyzeModuleWithImports(
    &mut overlayDefs,
    &mut overlayTypes,
    &mut overlaySymbols,
    &module,
    &emptyOverlay,
  );

  Test::assertEq<u64>(overlay.pass1.diagnostics.length(), single.pass1.diagnostics.length());
  Test::assertEq<u64>(overlay.pass2.diagnostics.length(), single.pass2.diagnostics.length());
  Test::assertEq<u64>(overlay.resolvedTypes.diagnostics.length(), single.resolvedTypes.diagnostics.length());
  Test::assertEq<u64>(overlay.resolvedBodies.diagnostics.length(), single.resolvedBodies.diagnostics.length());
  Test::assertEq<u64>(overlay.typecheck.diagnostics.length(), single.typecheck.diagnostics.length());
  Test::assertEq<u64>(overlay.diagnostics.length(), single.diagnostics.length());
}

@test
function importOverlayAddsResolvedDirectBinding(): void {
  let first: Ast::Module = importsFunctionModule("Exported");
  let mut bindings: Vector<Ast::ImportBinding> = Vector::new<Ast::ImportBinding>();
  bindings.push(importsNamedBinding("Exported"));
  let second: Ast::Module = importsModuleWithImport("a.ign", bindings);

  let records: Vector<Analyzer::ModuleAnalysisRecord> = importsAnalyzeTwoModules(first, second);
  let Option::SOME(targetRecord) = records.get(0) else {
    @panic("missing target record");
  };
  let Option::SOME(importingRecord) = records.get(1) else {
    @panic("missing importing record");
  };

  Test::assertEq<u64>(importingRecord.imports.syms.length(), 1);
  Test::assertEq<u64>(importingRecord.imports.defs.length(), 1);
  let Option::SOME(importedDef) = importingRecord.imports.defs.get(0) else {
    @panic("missing imported definition");
  };
  let Option::SOME(targetDef) = targetRecord.direct.defs.get(0) else {
    @panic("missing target direct definition");
  };

  Test::assertEq<u32>(importedDef.raw(), targetDef.raw());
  Test::assertEq<u64>(importingRecord.output.diagnostics.length(), 0);
}

@test
function importOverlayDiagnosesMissingDirectBinding(): void {
  let first: Ast::Module = importsFunctionModule("Exported");
  let mut bindings: Vector<Ast::ImportBinding> = Vector::new<Ast::ImportBinding>();
  bindings.push(importsNamedBinding("Missing"));
  let second: Ast::Module = importsModuleWithImport("a.ign", bindings);

  let records: Vector<Analyzer::ModuleAnalysisRecord> = importsAnalyzeTwoModules(first, second);
  let Option::SOME(importingRecord) = records.get(1) else {
    @panic("missing importing record");
  };
  let Option::SOME(diagnostic) = importingRecord.output.diagnostics.get(0) else {
    @panic("missing import diagnostic");
  };

  Test::assertEq<u64>(importingRecord.imports.syms.length(), 0);
  Test::assertEq<str>(diagnostic.code, DiagnosticCode::UNDECLARED_VARIABLE);
}

@test
function importOverlayDiagnosesUnknownImportSource(): void {
  let first: Ast::Module = importsFunctionModule("Exported");
  let mut bindings: Vector<Ast::ImportBinding> = Vector::new<Ast::ImportBinding>();
  bindings.push(importsNamedBinding("Exported"));

  let mut second: Ast::Module = Ast::Module::init();
  let mut moduleRef: &mut Ast::Module = &mut second;
  moduleRef.addRootItem(Ast::Item::Node::Import(importsImportItemAt("missing.ign", bindings, 50, 60)));

  let records: Vector<Analyzer::ModuleAnalysisRecord> = importsAnalyzeTwoModules(first, second);
  let Option::SOME(importingRecord) = records.get(1) else {
    @panic("missing importing record");
  };
  let Option::SOME(diagnostic) = importingRecord.output.diagnostics.get(0) else {
    @panic("missing source diagnostic");
  };

  Test::assertEq<u64>(importingRecord.imports.syms.length(), 0);
  Test::assertEq<str>(diagnostic.code, DiagnosticCode::UNDECLARED_VARIABLE);
  Test::assertEq<u64>(diagnostic.primarySpan.start, 50);
}

@test
function importOverlayDiagnosesDuplicateLocalImportName(): void {
  let mut first: Ast::Module = importsFunctionModule("Exported");
  let ret: Ast::StatementId = importsAddReturn(&mut first);
  let mut statements: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  statements.push(ret);
  let body: Ast::StatementId = importsAddBlock(&mut first, statements);
  importsAddFunction(&mut first, "Other", body);

  let mut bindings: Vector<Ast::ImportBinding> = Vector::new<Ast::ImportBinding>();
  bindings.push(importsNamedBindingAt("Exported", 10, 20));
  bindings.push(importsAliasedBindingAt("Other", "Exported", 30, 40));
  let second: Ast::Module = importsModuleWithImport("a.ign", bindings);

  let records: Vector<Analyzer::ModuleAnalysisRecord> = importsAnalyzeTwoModules(first, second);
  let Option::SOME(importingRecord) = records.get(1) else {
    @panic("missing importing record");
  };
  let Option::SOME(diagnostic) = importingRecord.output.diagnostics.get(0) else {
    @panic("missing duplicate diagnostic");
  };
  let Option::SOME(primaryLabel) = diagnostic.labels.get(0) else {
    @panic("missing duplicate primary label");
  };
  let Option::SOME(secondaryLabel) = diagnostic.labels.get(1) else {
    @panic("missing duplicate secondary label");
  };

  Test::assertEq<u64>(importingRecord.imports.syms.length(), 1);
  Test::assertEq<str>(diagnostic.code, DiagnosticCode::TYPE_ALREADY_DEFINED);
  Test::assertEq<u64>(primaryLabel.span.start, 30);
  Test::assertEq<u64>(secondaryLabel.span.start, 10);
}

@test
function importOverlayDiagnosesLocalDeclarationConflict(): void {
  let first: Ast::Module = importsFunctionModule("Exported");
  let mut bindings: Vector<Ast::ImportBinding> = Vector::new<Ast::ImportBinding>();
  bindings.push(importsNamedBinding("Exported"));
  let second: Ast::Module = importsModuleWithImportAndFunction("a.ign", bindings, "Exported");

  let records: Vector<Analyzer::ModuleAnalysisRecord> = importsAnalyzeTwoModules(first, second);
  let Option::SOME(importingRecord) = records.get(1) else {
    @panic("missing importing record");
  };
  let Option::SOME(diagnostic) = importingRecord.output.diagnostics.get(0) else {
    @panic("missing conflict diagnostic");
  };

  Test::assertEq<u64>(importingRecord.imports.syms.length(), 0);
  Test::assertEq<str>(diagnostic.code, DiagnosticCode::TYPE_ALREADY_DEFINED);
}

@test
function importOverlaySkipsDiscardBinding(): void {
  let first: Ast::Module = importsFunctionModule("Exported");
  let mut bindings: Vector<Ast::ImportBinding> = Vector::new<Ast::ImportBinding>();
  bindings.push(importsDiscardBinding());
  let second: Ast::Module = importsModuleWithImport("a.ign", bindings);

  let records: Vector<Analyzer::ModuleAnalysisRecord> = importsAnalyzeTwoModules(first, second);
  let Option::SOME(importingRecord) = records.get(1) else {
    @panic("missing importing record");
  };

  Test::assertEq<u64>(importingRecord.imports.syms.length(), 0);
  Test::assertEq<u64>(importingRecord.output.diagnostics.length(), 0);
}

@test
function analyzeProgramResolvesImportedTypeAnnotations(): void {
  let first: Ast::Module = importsRecordModule("ImportedType");
  let mut bindings: Vector<Ast::ImportBinding> = Vector::new<Ast::ImportBinding>();
  bindings.push(importsNamedBinding("ImportedType"));
  let second: Ast::Module = importsModuleWithImportAndTypedRecord("a.ign", bindings, "UsesImported", "ImportedType");

  let records: Vector<Analyzer::ModuleAnalysisRecord> = importsAnalyzeTwoModules(first, second);
  let Option::SOME(targetRecord) = records.get(0) else {
    @panic("missing target record");
  };
  let Option::SOME(importingRecord) = records.get(1) else {
    @panic("missing importing record");
  };
  let Option::SOME(importedDef) = targetRecord.direct.defs.get(0) else {
    @panic("missing imported definition");
  };

  Test::assertEq<u64>(importingRecord.imports.syms.length(), 1);
  Test::assertEq<boolean>(importsBinderOutputContainsDef(&importingRecord.pass1, *importedDef), false);
  Test::assertEq<boolean>(importsBinderOutputContainsDef(&importingRecord.pass2, *importedDef), false);
  Test::assertEq<u64>(importingRecord.output.resolvedTypes.diagnostics.length(), 0);
  Test::assertEq<u64>(importingRecord.output.diagnostics.length(), 0);
}

@test
function analyzeProgramRejectsImportedGenericTraitInTypePosition(): void {
  let first: Ast::Module = importsGenericTraitModule("ImportedTrait");
  let mut bindings: Vector<Ast::ImportBinding> = Vector::new<Ast::ImportBinding>();
  bindings.push(importsNamedBinding("ImportedTrait"));
  let mut second: Ast::Module = importsModuleWithImport("a.ign", bindings);
  let fieldType: Ast::TypeId = importsAddGenericPathType(&mut second, "ImportedTrait", "i32");
  let field: Ast::PatternId = importsAddAnnotatedField(&mut second, "field", fieldType);
  let mut fields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fields.push(field);
  importsAddRecord(&mut second, "UsesTrait", fields);

  let records: Vector<Analyzer::ModuleAnalysisRecord> = importsAnalyzeTwoModules(first, second);
  let Option::SOME(importingRecord) = records.get(1) else {
    @panic("missing importing record");
  };
  let Option::SOME(diagnostic) = importingRecord.output.resolvedTypes.diagnostics.get(0) else {
    @panic("missing trait-in-type-position diagnostic");
  };

  Test::assertEq<u64>(importingRecord.imports.syms.length(), 1);
  Test::assertEq<str>(diagnostic.code, DiagnosticCode::UNDEFINED_TYPE);
}

@test
function analyzeProgramDoesNotLeakUnimportedTypes(): void {
