@test
function analyzeProgramSkipsImportOverlayWhenLocalDeclarationConflicts(): void {
  let first: Ast::Module = importsRecordModule("SharedType");
  let mut bindings: Vector<Ast::ImportBinding> = Vector::new<Ast::ImportBinding>();
  bindings.push(importsNamedBinding("SharedType"));
  let mut second: Ast::Module = importsModuleWithImportAndTypedRecord("a.ign", bindings, "UsesLocal", "SharedType");
  let localFields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  importsAddRecord(&mut second, "SharedType", localFields);

  let records: Vector<Analyzer::ModuleAnalysisRecord> = importsAnalyzeTwoModules(first, second);
  let Option::SOME(importingRecord) = records.get(1) else {
    @panic("missing importing record");
  };

  Test::assertEq<u64>(importingRecord.imports.syms.length(), 0);
  Test::assertEq<u64>(importingRecord.output.resolvedTypes.diagnostics.length(), 0);
  Test::assertEq<u64>(importingRecord.output.diagnostics.length(), 1);
}

@test
function resolveTypesPrefersLocalTypeOverImportOverlay(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();

  let first: Ast::Module = importsRecordModule("SharedType");
  let firstOutput: Analyzer::AnalyzerOutput = Analyzer::analyzeModule(&mut defStore, &mut typeStore, &mut symbols, &first);
  let firstDirect: Analyzer::Imports::DirectDeclarationIndex = Analyzer::buildDirectDeclarationIndex(
    &mut defStore,
    &first,
    &firstOutput.pass1,
    &firstOutput.pass2,
  );
  let Option::SOME(importedSym) = firstDirect.syms.get(0) else {
    @panic("missing imported symbol");
  };
  let Option::SOME(importedDef) = firstDirect.defs.get(0) else {
    @panic("missing imported definition");
  };

  let mut second: Ast::Module = Ast::Module::init();
  let fieldType: Ast::TypeId = importsAddPathType(&mut second, "SharedType");
  let field: Ast::PatternId = importsAddAnnotatedField(&mut second, "field", fieldType);
  let mut fields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fields.push(field);
  let usesLocalId: Ast::ItemId = importsAddRecord(&mut second, "UsesLocal", fields);
  let localFields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  let localItemId: Ast::ItemId = importsAddRecord(&mut second, "SharedType", localFields);
  let overlay: Analyzer::Imports::ImportOverlay = importsOverlayWithOne(*importedSym, *importedDef);

  let output: Analyzer::AnalyzerOutput = Analyzer::analyzeModuleWithImports(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &second,
    &overlay,
  );
  let Option::SOME(localDefId) = Analyzer::Binder::findDef(&output.pass1, localItemId.raw()) else {
    @panic("missing local definition");
  };
  let expectedLocalType: Analyzer::TypeId = typeStore.intern(Analyzer::Type::Record(localDefId));
  let actualFieldType: Analyzer::TypeId = importsRecordFieldType(&mut defStore, usesLocalId, &output.pass1, 0);

  Test::assertEq<u32>(actualFieldType.raw(), expectedLocalType.raw());
  Test::assertEq<u64>(output.resolvedTypes.diagnostics.length(), 0);
}
