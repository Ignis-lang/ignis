import Test from "std::test";

import SourceSpan from "@compiler::diagnostics";
import Ast from "@compiler::ast";
import Analyzer from "@compiler::analyzer";
import Id from "@compiler::ids";

/// Build a zero-byte source span suitable for test use.
function bodiesDummySpan(): SourceSpan {
  return SourceSpan::new("resolver_bodies_test.ign", 0, 0);
}

/// Run binder pass-1, binder pass-2, `resolveTypes`, then `resolveBodies`.
///
/// Returns the body resolver output. Binder and `resolveTypes` mutate the stores
/// in-place; `resolveBodies` itself is read-only except for `symbols.intern`
/// cache writes.
function runResolveBodies(
  defStore: &mut Analyzer::DefinitionStore,
  typeStore: &mut Analyzer::TypeStore,
  symbols: &mut Analyzer::SymbolTable,
  module: &Ast::Module,
): Analyzer::ResolverBodies::ResolverBodiesOutput {
  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    defStore,
    typeStore,
    symbols,
    module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    defStore,
    typeStore,
    symbols,
    module,
    &pass1,
  );

  let _resolveOutput: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    defStore,
    typeStore,
    symbols,
    module,
    &pass1,
    &pass2,
  );

  return Analyzer::ResolverBodies::resolveBodies(
    defStore,
    typeStore,
    symbols,
    module,
    &pass1,
    &pass2,
  );
}

/// Add a simple binding pattern without annotation.
function addBinding(module: &mut Ast::Module, name: str): Ast::PatternId {
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: bodiesDummySpan(),
    name: String::create(name),
    annotation: Option::NONE,
    metadata: Ast::emptyMetadata(),
  }));
}

/// Add a binding pattern with a path-type annotation.
function addAnnotatedBinding(
  module: &mut Ast::Module,
  name: str,
  typeAnnotation: Ast::TypeId
): Ast::PatternId {
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: bodiesDummySpan(),
    name: String::create(name),
    annotation: Option::SOME(typeAnnotation),
    metadata: Ast::emptyMetadata(),
  }));
}

/// Add a simple Path type annotation to the module.
function addPathType(module: &mut Ast::Module, name: str): Ast::TypeId {
  let mut segments: Vector<String> = Vector::new<String>();
  segments.push(String::create(name));
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addType(Ast::Type::Node::Path(Ast::Type::Path {
    span: bodiesDummySpan(),
    segments: segments,
  }));
}

/// Add a Variable expression (identifier reference) to the module.
function addVariable(module: &mut Ast::Module, name: str): Ast::ExpressionId {
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addExpression(Ast::Expression::Node::Variable(Ast::Expression::Variable {
    span: bodiesDummySpan(),
    name: String::create(name),
  }));
}

/// Add a Return statement (with a value expression) to the module.
function addReturnExpr(module: &mut Ast::Module, exprId: Ast::ExpressionId): Ast::StatementId {
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addStatement(Ast::Statement::Node::Return(Ast::Statement::Return {
    span: bodiesDummySpan(),
    value: Option::SOME(exprId),
  }));
}

/// Add a void Return statement to the module.
function addReturn(module: &mut Ast::Module): Ast::StatementId {
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addStatement(Ast::Statement::Node::Return(Ast::Statement::Return {
    span: bodiesDummySpan(),
    value: Option::NONE,
  }));
}

/// Add a Block statement from a list of statement ids.
function addBlock(module: &mut Ast::Module, stmts: Vector<Ast::StatementId>): Ast::StatementId {
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addStatement(Ast::Statement::Node::Block(Ast::Statement::Block {
    span: bodiesDummySpan(),
    statements: stmts,
    tail: Option::NONE,
  }));
}

/// Add an integer literal expression.
function addIntLiteral(module: &mut Ast::Module, value: i64): Ast::ExpressionId {
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addExpression(Ast::Expression::Node::Literal(Ast::Expression::Literal {
    span: bodiesDummySpan(),
    value: Ast::Expression::LiteralValue::Int(value),
  }));
}

/// Assert that the body resolution map contains an expression ref at the given ExpressionId.
function assertExprRef(
  map: &Analyzer::ResolverBodies::BodyResolutionMap,
  exprId: Ast::ExpressionId,
): Analyzer::ResolverBodies::ResolvedRef {
  let result: Option<Analyzer::ResolverBodies::ResolvedRef> = Analyzer::ResolverBodies::findExprRef(map, exprId.raw());
  let Option::SOME(r) = result else {
    @panic("assertExprRef: no entry found for ExpressionId");
  };
  return r;
}

/// Assert that a ResolvedRef is Local and return its LocalId.
function assertLocal(r: Analyzer::ResolverBodies::ResolvedRef): Analyzer::ResolverBodies::LocalId {
  match (r) {
    Analyzer::ResolverBodies::ResolvedRef::Local(lid) -> {
      return lid;
    },
    Analyzer::ResolverBodies::ResolvedRef::Definition(_) -> {
      @panic("assertLocal: expected Local, got Definition");
    },
    Analyzer::ResolverBodies::ResolvedRef::TypeParam(_) -> {
      @panic("assertLocal: expected Local, got TypeParam");
    },
    Analyzer::ResolverBodies::ResolvedRef::Unresolved(_) -> {
      @panic("assertLocal: expected Local, got Unresolved");
    },
  };
}

/// Assert that a ResolvedRef is Definition and return its DefinitionId.
function assertDefinitionRef(r: Analyzer::ResolverBodies::ResolvedRef): Analyzer::DefinitionId {
  match (r) {
    Analyzer::ResolverBodies::ResolvedRef::Local(_) -> {
      @panic("assertDefinitionRef: expected Definition, got Local");
    },
    Analyzer::ResolverBodies::ResolvedRef::Definition(did) -> {
      return did;
    },
    Analyzer::ResolverBodies::ResolvedRef::TypeParam(_) -> {
      @panic("assertDefinitionRef: expected Definition, got TypeParam");
    },
    Analyzer::ResolverBodies::ResolvedRef::Unresolved(_) -> {
      @panic("assertDefinitionRef: expected Definition, got Unresolved");
    },
  };
}

/// Assert that a ResolvedRef is Unresolved.
function assertUnresolved(r: Analyzer::ResolverBodies::ResolvedRef): void {
  match (r) {
    Analyzer::ResolverBodies::ResolvedRef::Local(_) -> {
      @panic("assertUnresolved: expected Unresolved, got Local");
    },
    Analyzer::ResolverBodies::ResolvedRef::Definition(_) -> {
      @panic("assertUnresolved: expected Unresolved, got Definition");
    },
    Analyzer::ResolverBodies::ResolvedRef::TypeParam(_) -> {
      @panic("assertUnresolved: expected Unresolved, got TypeParam");
    },
    Analyzer::ResolverBodies::ResolvedRef::Unresolved(_) -> {},
  };
}

/// Assert a pattern ref is Local and return LocalId.
function assertPatternLocal(
  map: &Analyzer::ResolverBodies::BodyResolutionMap,
  patId: Ast::PatternId,
): Analyzer::ResolverBodies::LocalId {
  let result: Option<Analyzer::ResolverBodies::ResolvedRef> = Analyzer::ResolverBodies::findPatternRef(map, patId.raw());
  let Option::SOME(r) = result else {
    @panic("assertPatternLocal: no entry found for PatternId");
  };
  return assertLocal(r);
}

/// Assert a ResolvedRef is Definition(Method) and return its DefinitionId.
function assertResolvesToMethod(
  defStore: &mut Analyzer::DefinitionStore,
  r: Analyzer::ResolverBodies::ResolvedRef,
): Analyzer::DefinitionId {
  let defId: Analyzer::DefinitionId = assertDefinitionRef(r);
  let Option::SOME(def) = defStore.get(defId) else {
    @panic("assertResolvesToMethod: defId not found in defStore");
  };

  match (def) {
    Analyzer::Definition::Method(_) -> {
      return defId;
    },
    Analyzer::Definition::Function(_) -> {
      @panic("assertResolvesToMethod: expected Method, got Function");
    },
    Analyzer::Definition::Record(_) -> {
      @panic("assertResolvesToMethod: expected Method, got Record");
    },
    Analyzer::Definition::Enum(_) -> {
      @panic("assertResolvesToMethod: expected Method, got Enum");
    },
    Analyzer::Definition::Variable(_) -> {
      @panic("assertResolvesToMethod: expected Method, got Variable");
    },
    Analyzer::Definition::Field(_) -> {
      @panic("assertResolvesToMethod: expected Method, got Field");
    },
    Analyzer::Definition::Variant(_) -> {
      @panic("assertResolvesToMethod: expected Method, got Variant");
    },
    Analyzer::Definition::TypeParam(_) -> {
      @panic("assertResolvesToMethod: expected Method, got TypeParam");
    },
    Analyzer::Definition::TypeAlias(_) -> {
      @panic("assertResolvesToMethod: expected Method, got TypeAlias");
    },
    Analyzer::Definition::Trait(_) -> {
      @panic("assertResolvesToMethod: expected Method, got Trait");
    },
  };
}

/// Assert a ResolvedRef is Definition(Variant) and return its DefinitionId.
function assertResolvesToVariant(
  defStore: &mut Analyzer::DefinitionStore,
  r: Analyzer::ResolverBodies::ResolvedRef,
): Analyzer::DefinitionId {
  let defId: Analyzer::DefinitionId = assertDefinitionRef(r);
  let Option::SOME(def) = defStore.get(defId) else {
    @panic("assertResolvesToVariant: defId not found in defStore");
  };

  match (def) {
    Analyzer::Definition::Variant(_) -> {
      return defId;
    },
    Analyzer::Definition::Function(_) -> {
      @panic("assertResolvesToVariant: expected Variant, got Function");
    },
    Analyzer::Definition::Method(_) -> {
      @panic("assertResolvesToVariant: expected Variant, got Method");
    },
    Analyzer::Definition::Record(_) -> {
      @panic("assertResolvesToVariant: expected Variant, got Record");
    },
    Analyzer::Definition::Enum(_) -> {
      @panic("assertResolvesToVariant: expected Variant, got Enum");
    },
    Analyzer::Definition::Variable(_) -> {
      @panic("assertResolvesToVariant: expected Variant, got Variable");
    },
    Analyzer::Definition::Field(_) -> {
      @panic("assertResolvesToVariant: expected Variant, got Field");
    },
    Analyzer::Definition::TypeParam(_) -> {
      @panic("assertResolvesToVariant: expected Variant, got TypeParam");
    },
    Analyzer::Definition::TypeAlias(_) -> {
      @panic("assertResolvesToVariant: expected Variant, got TypeAlias");
    },
    Analyzer::Definition::Trait(_) -> {
      @panic("assertResolvesToVariant: expected Variant, got Trait");
    },
  };
}

/// Add a 2-segment Path expression.
function addPathExpr2(module: &mut Ast::Module, seg0: str, seg1: str): Ast::ExpressionId {
  let mut segs: Vector<String> = Vector::new<String>();
  segs.push(String::create(seg0));
  segs.push(String::create(seg1));
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addExpression(Ast::Expression::Node::Path(Ast::Expression::Path {
    span: bodiesDummySpan(),
    segments: segs,
  }));
}

/// Add a 3-segment Path expression.
function addPathExpr3(module: &mut Ast::Module, seg0: str, seg1: str, seg2: str): Ast::ExpressionId {
  let mut segs: Vector<String> = Vector::new<String>();
  segs.push(String::create(seg0));
  segs.push(String::create(seg1));
  segs.push(String::create(seg2));
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addExpression(Ast::Expression::Node::Path(Ast::Expression::Path {
    span: bodiesDummySpan(),
    segments: segs,
  }));
}

/// Add a 2-segment Path pattern with the given sub-pattern arguments.
function addPathPattern2(module: &mut Ast::Module, seg0: str, seg1: str, args: Vector<Ast::PatternId>): Ast::PatternId {
  let mut segs: Vector<String> = Vector::new<String>();
  segs.push(String::create(seg0));
  segs.push(String::create(seg1));
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addPattern(Ast::Pattern::Node::Path(Ast::Pattern::Path {
    span: bodiesDummySpan(),
    segments: segs,
    arguments: args,
  }));
}

/// Add a 3-segment Path pattern with the given sub-pattern arguments.
function addPathPattern3(module: &mut Ast::Module, seg0: str, seg1: str, seg2: str, args: Vector<Ast::PatternId>): Ast::PatternId {
  let mut segs: Vector<String> = Vector::new<String>();
  segs.push(String::create(seg0));
  segs.push(String::create(seg1));
  segs.push(String::create(seg2));
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addPattern(Ast::Pattern::Node::Path(Ast::Pattern::Path {
    span: bodiesDummySpan(),
    segments: segs,
    arguments: args,
  }));
}

/// Add a Function item usable as a record/enum method (static: empty/no-self
/// `params`; instance: first entry in `params` bound to the name `self`).
function addMethodItem(
  module: &mut Ast::Module,
  name: str,
  params: Vector<Ast::PatternId>,
  bodyStmts: Vector<Ast::StatementId>,
): Ast::ItemId {
  let body: Ast::StatementId = addBlock(module, bodyStmts);
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create(name),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: params,
    returnType: Option::NONE,
    body: body,
    metadata: Ast::emptyMetadata(),
  }));
}

/// Add a top-level function with the given body statements, wrapping a Path
/// expression statement followed by a `return;`. Used by the WU1 static-method
/// and multi-segment-path fixtures to keep each `@test` focused on setup.
function addPathExprStmtFunction(module: &mut Ast::Module, fnName: str, pathExpr: Ast::ExpressionId): void {
  let mut moduleRef: &mut Ast::Module = module;
  let exprStmt: Ast::StatementId = moduleRef.addStatement(Ast::Statement::Node::Expression(Ast::Statement::Expression {
    span: bodiesDummySpan(),
    expression: pathExpr,
  }));
  let retStmt: Ast::StatementId = addReturn(module);
  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(exprStmt);
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = addBlock(module, bodyStmts);

  let mut rootRef: &mut Ast::Module = module;
  rootRef.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create(fnName),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));
}

/// Add a top-level function `fnName` with a single-arm match over a dummy
/// int-literal scrutinee, using `armPat` as the (already-added) arm pattern.
/// Used by WU1 pattern-position fixtures — only the pattern's resolution is
/// under test, not the scrutinee's type.
function addMatchArmFunction(module: &mut Ast::Module, fnName: str, armPat: Ast::PatternId): void {
  let scrutinee: Ast::ExpressionId = addIntLiteral(module, 0);
  let mut armBodyRef: &mut Ast::Module = module;
  let armBodyExpr: Ast::ExpressionId = armBodyRef.addExpression(Ast::Expression::Node::Block(Ast::Expression::Block {
    span: bodiesDummySpan(),
    statements: Vector::new<Ast::StatementId>(),
    tail: Option::NONE,
  }));

  let mut arms: Vector<Ast::Expression::MatchArm> = Vector::new<Ast::Expression::MatchArm>();
  arms.push(Ast::Expression::MatchArm {
    pattern: armPat,
    guard: Option::NONE,
    body: armBodyExpr,
  });

  let mut matchExprRef: &mut Ast::Module = module;
  let matchExpr: Ast::ExpressionId = matchExprRef.addExpression(Ast::Expression::Node::Match(Ast::Expression::Match {
    span: bodiesDummySpan(),
    scrutinee: scrutinee,
    arms: arms,
  }));

  let mut matchStmtRef: &mut Ast::Module = module;
  let matchStmt: Ast::StatementId = matchStmtRef.addStatement(Ast::Statement::Node::Expression(Ast::Statement::Expression {
    span: bodiesDummySpan(),
    expression: matchExpr,
  }));

  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(matchStmt);
  let bodyBlock: Ast::StatementId = addBlock(module, bodyStmts);

  let mut moduleRef: &mut Ast::Module = module;
  moduleRef.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create(fnName),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));
}

// ============================================================
// Phase 1: Empty module — scaffolding smoke test
// ============================================================

/// Scenario: Empty module produces an empty BodyResolutionMap and no diagnostics.
@test
function resolveBodiesEmptyModuleProducesEmptyOutput(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  Test::assertEq<u64>(output.bodyResolution.nodeIds.length(), 0);
  Test::assertEq<u64>(output.diagnostics.length(), 0);
}

// ============================================================
// Phase 2: LocalStack scope mechanics
// ============================================================

/// Scenario: Push scope, bind a name, pop scope — name is no longer findable.
@test
function resolveBodiesPushPopScopeIsBalanced(): void {
  let mut stack: Analyzer::ResolverBodies::LocalStack = Analyzer::ResolverBodies::LocalStack {
    scopeStarts: Vector::new<u64>(),
    names: Vector::new<Analyzer::SymbolId>(),
    locals: Vector::new<Analyzer::ResolverBodies::LocalId>(),
  };
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();

  let sym: Analyzer::SymbolId = symbols.intern("x");

  Analyzer::ResolverBodies::pushScope(&mut stack);
  let dummyDef: Analyzer::DefinitionId = Id::fromRaw<Analyzer::DefinitionTag>(0);
  Analyzer::ResolverBodies::bindLocalRaw(&mut stack, sym, dummyDef);
  let beforePop: Option<Analyzer::ResolverBodies::LocalId> = Analyzer::ResolverBodies::lookupLocal(&stack, sym);
  Test::assertEq<boolean>(beforePop.isSome(), true);

  Analyzer::ResolverBodies::popScope(&mut stack);
  let afterPop: Option<Analyzer::ResolverBodies::LocalId> = Analyzer::ResolverBodies::lookupLocal(&stack, sym);
  Test::assertEq<boolean>(afterPop.isNone(), true);
}

/// Scenario: Shadowing — innermost binding wins.
@test
function resolveBodiesShadowingPrefersInnermost(): void {
  let mut stack: Analyzer::ResolverBodies::LocalStack = Analyzer::ResolverBodies::LocalStack {
    scopeStarts: Vector::new<u64>(),
    names: Vector::new<Analyzer::SymbolId>(),
    locals: Vector::new<Analyzer::ResolverBodies::LocalId>(),
  };
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();

  let sym: Analyzer::SymbolId = symbols.intern("a");
  let dummyDef: Analyzer::DefinitionId = Id::fromRaw<Analyzer::DefinitionTag>(0);

  // Outer scope: bind 'a' as index 0.
  Analyzer::ResolverBodies::pushScope(&mut stack);
  Analyzer::ResolverBodies::bindLocalRaw(&mut stack, sym, dummyDef);
  let Option::SOME(outer) = Analyzer::ResolverBodies::lookupLocal(&stack, sym) else {
    @panic("outer binding not found");
  };
  Test::assertEq<u32>(outer.index, 0);

  // Inner scope: bind 'a' as index 1.
  Analyzer::ResolverBodies::pushScope(&mut stack);
  Analyzer::ResolverBodies::bindLocalRaw(&mut stack, sym, dummyDef);
  let Option::SOME(inner) = Analyzer::ResolverBodies::lookupLocal(&stack, sym) else {
    @panic("inner binding not found");
  };
  Test::assertEq<u32>(inner.index, 1);

  // Pop inner; outer should be visible again.
  Analyzer::ResolverBodies::popScope(&mut stack);
  let Option::SOME(outerAgain) = Analyzer::ResolverBodies::lookupLocal(&stack, sym) else {
    @panic("outer binding should be visible after pop");
  };
  Test::assertEq<u32>(outerAgain.index, 0);
}

/// Scenario: Global index contains top-level function and record definitions.
@test
function resolveBodiesGlobalIndexContainsTopLevelDefinitions(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // Add a record definition.
  module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: bodiesDummySpan(),
    name: String::create("Point"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: Vector::new<Ast::PatternId>(),
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  // Add a function with a block body.
  let retStmt: Ast::StatementId = addReturn(&mut module);
  let bodyBlock: Ast::StatementId = addBlock(&mut module, Vector::new<Ast::StatementId>());
  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("helper"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  // After running, the global index should have been built. We can't inspect it
  // directly (it's internal state), but we can verify the output is valid.
  Test::assertEq<u64>(output.diagnostics.length(), 0);
}

// ============================================================
// Phase 3: Expression walker — identifier and path resolution
// ============================================================

/// Scenario SC-01 (partial): function `f(x: i32): i32 { return x; }` —
/// the Variable node for `x` in the return resolves to Local(index:0).
@test
function resolveBodiesResolvesParameterReference(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // Build: function f(x: i32): i32 { return x; }
  let i32TypeId: Ast::TypeId = addPathType(&mut module, "i32");
  let paramPat: Ast::PatternId = addAnnotatedBinding(&mut module, "x", i32TypeId);

  let xVarExpr: Ast::ExpressionId = addVariable(&mut module, "x");
  let retStmt: Ast::StatementId = addReturnExpr(&mut module, xVarExpr);

  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = addBlock(&mut module, bodyStmts);

  let mut params: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  params.push(paramPat);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("f"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: params,
    returnType: Option::SOME(i32TypeId),
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  Test::assertEq<u64>(output.diagnostics.length(), 0);

  let ref_: Analyzer::ResolverBodies::ResolvedRef = assertExprRef(
    &output.bodyResolution,
    xVarExpr,
  );
  let lid: Analyzer::ResolverBodies::LocalId = assertLocal(ref_);
  Test::assertEq<u32>(lid.index, 0);
}

/// Scenario SC-02: global function reference resolves to Definition.
@test
function resolveBodiesResolvesGlobalFunction(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // function helper(): void { return; }
  let helperBody: Ast::StatementId = addReturn(&mut module);
  let helperBodyBlock: Ast::StatementId = addBlock(&mut module, Vector::new<Ast::StatementId>());
  let helperItemId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("helper"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: helperBodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  // function f(): void { helper(); return; }
  let helperVarExpr: Ast::ExpressionId = addVariable(&mut module, "helper");
  let mut callArgs: Vector<Ast::ExpressionId> = Vector::new<Ast::ExpressionId>();
  let callExpr: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::Call(Ast::Expression::Call {
    span: bodiesDummySpan(),
    callee: helperVarExpr,
    typeArguments: Vector::new<Ast::TypeId>(),
    arguments: callArgs,
  }));

  let callStmt: Ast::StatementId = module.addStatement(Ast::Statement::Node::Expression(Ast::Statement::Expression {
    span: bodiesDummySpan(),
    expression: callExpr,
  }));
  let retStmt: Ast::StatementId = addReturn(&mut module);

  let mut fBodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  fBodyStmts.push(callStmt);
  fBodyStmts.push(retStmt);
  let fBodyBlock: Ast::StatementId = addBlock(&mut module, fBodyStmts);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("f"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: fBodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  Test::assertEq<u64>(output.diagnostics.length(), 0);

  let ref_: Analyzer::ResolverBodies::ResolvedRef = assertExprRef(
    &output.bodyResolution,
    helperVarExpr,
  );
  let _did: Analyzer::DefinitionId = assertDefinitionRef(ref_);
}

/// Scenario SC-03: undefined variable emits UNDECLARED_VARIABLE + Unresolved.
@test
function resolveBodiesEmitsUndeclaredVariable(): void {
