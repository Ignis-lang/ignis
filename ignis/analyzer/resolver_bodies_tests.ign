/// Scenario: `Ns::Rec` resolves via the TypeFallback branch in pattern
/// position too (qualified record-constructor pattern parity). REQ-P1/REQ-P2.
@test
function resolveBodiesQualifiedRecordTypeFallbackPattern(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
