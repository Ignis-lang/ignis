/// Scenario: unknown enum variant emits UNDECLARED_VARIABLE.
@test
function resolveBodiesEmitsUnknownEnumVariant(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // enum E { A }
  let mut variants: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  let variantBind: Ast::PatternId = addBinding(&mut module, "A");
  variants.push(variantBind);
  module.addRootItem(Ast::Item::Node::Enum(Ast::Item::Enum {
    span: bodiesDummySpan(),
    name: String::create("E"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    variants: variants,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  // function f(): void { E::ZZZ; return; }
  let mut pathSegs: Vector<String> = Vector::new<String>();
  pathSegs.push(String::create("E"));
  pathSegs.push(String::create("ZZZ"));
  let pathExpr: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::Path(Ast::Expression::Path {
    span: bodiesDummySpan(),
    segments: pathSegs,
  }));

  let exprStmt: Ast::StatementId = module.addStatement(Ast::Statement::Node::Expression(Ast::Statement::Expression {
    span: bodiesDummySpan(),
    expression: pathExpr,
  }));
  let retStmt: Ast::StatementId = addReturn(&mut module);

  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(exprStmt);
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = addBlock(&mut module, bodyStmts);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("f"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  Test::assertEq<u64>(output.diagnostics.length(), 1);
}

/// Scenario: MemberAccess — no entry for member; receiver IS resolved.
@test
function resolveBodiesSkipsMethodResolution(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // function f(obj: i32): void { obj.field; return; }
  let i32TypeId: Ast::TypeId = addPathType(&mut module, "i32");
  let objPat: Ast::PatternId = addAnnotatedBinding(&mut module, "obj", i32TypeId);

  let objVarExpr: Ast::ExpressionId = addVariable(&mut module, "obj");
  let memberExpr: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::MemberAccess(Ast::Expression::MemberAccess {
    span: bodiesDummySpan(),
    object: objVarExpr,
    operator: Ast::Expression::AccessOperator::Dot,
    member: String::create("field"),
  }));

  let exprStmt: Ast::StatementId = module.addStatement(Ast::Statement::Node::Expression(Ast::Statement::Expression {
    span: bodiesDummySpan(),
    expression: memberExpr,
  }));
  let retStmt: Ast::StatementId = addReturn(&mut module);

  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(exprStmt);
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = addBlock(&mut module, bodyStmts);

  let mut fParams: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fParams.push(objPat);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("f"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: fParams,
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  // No diagnostic: obj is resolved, member is not walked.
  Test::assertEq<u64>(output.diagnostics.length(), 0);

  // obj receiver IS in side table.
  let objRef: Analyzer::ResolverBodies::ResolvedRef = assertExprRef(
    &output.bodyResolution,
    objVarExpr,
  );
  let _lid: Analyzer::ResolverBodies::LocalId = assertLocal(objRef);

  // The MemberAccess node itself has NO entry in the side table.
  let memberResult: Option<Analyzer::ResolverBodies::ResolvedRef> = Analyzer::ResolverBodies::findExprRef(
    &output.bodyResolution,
    memberExpr.raw(),
  );
  Test::assertEq<boolean>(memberResult.isNone(), true);
}

// ============================================================
// Phase 9: Determinism, idempotence, non-mutation
// ============================================================

/// Scenario SC-13: two calls to resolveBodies produce identical output.
@test
function resolveBodiesDeterministicAcrossTwoRuns(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // function f(x: i32): i32 { return x; }
  let i32TypeId: Ast::TypeId = addPathType(&mut module, "i32");
  let xPat: Ast::PatternId = addAnnotatedBinding(&mut module, "x", i32TypeId);
  let xVarExpr: Ast::ExpressionId = addVariable(&mut module, "x");
  let retStmt: Ast::StatementId = addReturnExpr(&mut module, xVarExpr);

  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = addBlock(&mut module, bodyStmts);

  let mut params: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  params.push(xPat);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("f"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: params,
    returnType: Option::SOME(i32TypeId),
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );
  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let _resolveOutput: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  let out1: Analyzer::ResolverBodies::ResolverBodiesOutput = Analyzer::ResolverBodies::resolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  let out2: Analyzer::ResolverBodies::ResolverBodiesOutput = Analyzer::ResolverBodies::resolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  Test::assertEq<u64>(out1.bodyResolution.nodeIds.length(), out2.bodyResolution.nodeIds.length());
  Test::assertEq<u64>(out1.diagnostics.length(), out2.diagnostics.length());

  let mut i: u64 = 0;
  while (i < out1.bodyResolution.nodeIds.length()) {
    let Option::SOME(id1) = out1.bodyResolution.nodeIds.get(i) else {
      i += 1;
      continue;
    };
    let Option::SOME(id2) = out2.bodyResolution.nodeIds.get(i) else {
      i += 1;
      continue;
    };
    Test::assertEq<u32>(*id1, *id2);
    i += 1;
  }
}

/// Scenario SC-14: resolveBodies does not mutate DefinitionStore.
@test
function resolveBodiesDoesNotMutateDefinitionStore(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // record R {}
  module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: bodiesDummySpan(),
    name: String::create("R"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: Vector::new<Ast::PatternId>(),
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  // After binder + resolveBodies, defStore should contain the Record def.
  // Running resolveBodies again should not add new definitions.
  let defCountAfterFirst: u64 = defStore.length();

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );
  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let _resolveOutput: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  let _out2: Analyzer::ResolverBodies::ResolverBodiesOutput = Analyzer::ResolverBodies::resolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  // The defStore length after re-running binder+resolveBodies should be
  // consistent: the extra binder run may add defs, but resolveBodies itself
  // must not add defs on its own. We verify the count matches the second binder run.
  let defCountAfterSecond: u64 = defStore.length();

  // resolveBodies alone does not add definitions — tested by running it again
  // on the same pass1/pass2 outputs without re-running the binder.
  let _out3: Analyzer::ResolverBodies::ResolverBodiesOutput = Analyzer::ResolverBodies::resolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );
  Test::assertEq<u64>(defStore.length(), defCountAfterSecond);
}

/// Scenario: ForOf binding is visible inside loop body, not after.
@test
function resolveBodiesBindsForOfPattern(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // function f(xs: i32): void { for x of xs { return x; } }
  let i32TypeId: Ast::TypeId = addPathType(&mut module, "i32");
  let xsParamPat: Ast::PatternId = addAnnotatedBinding(&mut module, "xs", i32TypeId);

  let xsVarExpr: Ast::ExpressionId = addVariable(&mut module, "xs");
  let xIterPat: Ast::PatternId = addBinding(&mut module, "x");
  let xVarInBody: Ast::ExpressionId = addVariable(&mut module, "x");
  let retStmt: Ast::StatementId = addReturnExpr(&mut module, xVarInBody);

  let mut loopBodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  loopBodyStmts.push(retStmt);
  let loopBodyBlock: Ast::StatementId = addBlock(&mut module, loopBodyStmts);

  let forOfStmt: Ast::StatementId = module.addStatement(Ast::Statement::Node::ForOf(Ast::Statement::ForOf {
    span: bodiesDummySpan(),
    pattern: xIterPat,
    iterable: xsVarExpr,
    body: loopBodyBlock,
  }));

  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(forOfStmt);
  let bodyBlock: Ast::StatementId = addBlock(&mut module, bodyStmts);

  let mut fParams: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fParams.push(xsParamPat);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("f"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: fParams,
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  Test::assertEq<u64>(output.diagnostics.length(), 0);

  // x in loop body maps to Local.
  let xRef: Analyzer::ResolverBodies::ResolvedRef = assertExprRef(&output.bodyResolution, xVarInBody);
  let _xLid: Analyzer::ResolverBodies::LocalId = assertLocal(xRef);
}

/// Scenario: Or pattern — bindings in alternatives are independent.
@test
function resolveBodiesResolvesOrPattern(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // function f(x: i32): void { match x { 0 | 1 => return; } }
  let i32TypeId: Ast::TypeId = addPathType(&mut module, "i32");
  let xParamPat: Ast::PatternId = addAnnotatedBinding(&mut module, "x", i32TypeId);

  let xScrut: Ast::ExpressionId = addVariable(&mut module, "x");

  // literal patterns
  let lit0: Ast::ExpressionId = addIntLiteral(&mut module, 0);
  let lit1: Ast::ExpressionId = addIntLiteral(&mut module, 1);
  let litPat0: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Literal(Ast::Pattern::Literal {
    span: bodiesDummySpan(),
    expression: lit0,
  }));
  let litPat1: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Literal(Ast::Pattern::Literal {
    span: bodiesDummySpan(),
    expression: lit1,
  }));

  let mut alts: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  alts.push(litPat0);
  alts.push(litPat1);
  let orPat: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Or(Ast::Pattern::Or {
    span: bodiesDummySpan(),
    alternatives: alts,
  }));

  let retStmt: Ast::StatementId = addReturn(&mut module);
  let armBodyExpr: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::Block(Ast::Expression::Block {
    span: bodiesDummySpan(),
    statements: Vector::new<Ast::StatementId>(),
    tail: Option::NONE,
  }));

  let mut arms: Vector<Ast::Expression::MatchArm> = Vector::new<Ast::Expression::MatchArm>();
  arms.push(Ast::Expression::MatchArm {
    pattern: orPat,
    guard: Option::NONE,
    body: armBodyExpr,
  });

  let matchExpr: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::Match(Ast::Expression::Match {
    span: bodiesDummySpan(),
    scrutinee: xScrut,
    arms: arms,
  }));

  let matchStmt: Ast::StatementId = module.addStatement(Ast::Statement::Node::Expression(Ast::Statement::Expression {
    span: bodiesDummySpan(),
    expression: matchExpr,
  }));

  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(matchStmt);
  let bodyBlock: Ast::StatementId = addBlock(&mut module, bodyStmts);

  let mut fParams: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fParams.push(xParamPat);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("f"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: fParams,
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  // No diagnostics — x in scrutinee is resolved as Local.
  Test::assertEq<u64>(output.diagnostics.length(), 0);

  let xRef: Analyzer::ResolverBodies::ResolvedRef = assertExprRef(&output.bodyResolution, xScrut);
  let _xLid: Analyzer::ResolverBodies::LocalId = assertLocal(xRef);
}

// ============================================================
// W-01: SC-06 — Record destructure in let
// ============================================================

/// Scenario SC-06: `let Point(x, y) = p;` where Point is a global Record.
///
/// The Path pattern for the constructor resolves to `Definition(pointDefId)`.
/// The Binding patterns for `x` and `y` each become a Local in the enclosing function.
/// The initializer `p` (a parameter) resolves to Local.
@test
function resolveBodiesRecordDestructureInLet(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // record Point {}
  module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: bodiesDummySpan(),
    name: String::create("Point"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: Vector::new<Ast::PatternId>(),
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  // function main(p: Point): void { let Point(x, y) = p; return x; }
  let pointTypeId: Ast::TypeId = addPathType(&mut module, "Point");
  let pParamPat: Ast::PatternId = addAnnotatedBinding(&mut module, "p", pointTypeId);

  let pVarExpr: Ast::ExpressionId = addVariable(&mut module, "p");

  // Sub-patterns for x and y.
  let xSubPat: Ast::PatternId = addBinding(&mut module, "x");
  let ySubPat: Ast::PatternId = addBinding(&mut module, "y");
  let mut destructureArgs: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  destructureArgs.push(xSubPat);
  destructureArgs.push(ySubPat);

  // Pattern::Path { segments: ["Point"], arguments: [xSubPat, ySubPat] }
  let mut ctorSegs: Vector<String> = Vector::new<String>();
  ctorSegs.push(String::create("Point"));
  let ctorPathPat: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Path(Ast::Pattern::Path {
    span: bodiesDummySpan(),
    segments: ctorSegs,
    arguments: destructureArgs,
  }));

  let letStmt: Ast::StatementId = module.addStatement(Ast::Statement::Node::Let(Ast::Statement::Let {
    span: bodiesDummySpan(),
    pattern: ctorPathPat,
    annotation: Option::NONE,
    value: Option::SOME(pVarExpr),
  }));

  let xVarExpr: Ast::ExpressionId = addVariable(&mut module, "x");
  let retStmt: Ast::StatementId = addReturnExpr(&mut module, xVarExpr);

  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(letStmt);
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = addBlock(&mut module, bodyStmts);

  let mut mainParams: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  mainParams.push(pParamPat);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("main"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: mainParams,
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  // No diagnostics: Point is a known Record, x and y bind successfully.
  Test::assertEq<u64>(output.diagnostics.length(), 0);

  // The constructor path pattern resolves to Definition (the Point record).
  let ctorRef: Option<Analyzer::ResolverBodies::ResolvedRef> = Analyzer::ResolverBodies::findPatternRef(
    &output.bodyResolution,
    ctorPathPat.raw(),
  );
  let Option::SOME(ctorRefVal) = ctorRef else {
    @panic("resolveBodiesRecordDestructureInLet: Point constructor pattern ref not found");
  };
  let _pointDefId: Analyzer::DefinitionId = assertDefinitionRef(ctorRefVal);

  // x and y sub-patterns resolve to Local.
  let _xLid: Analyzer::ResolverBodies::LocalId = assertPatternLocal(&output.bodyResolution, xSubPat);
  let _yLid: Analyzer::ResolverBodies::LocalId = assertPatternLocal(&output.bodyResolution, ySubPat);

  // x in the return expression resolves to the same local as the x binding.
  let xExprRef: Analyzer::ResolverBodies::ResolvedRef = assertExprRef(&output.bodyResolution, xVarExpr);
  let xExprLid: Analyzer::ResolverBodies::LocalId = assertLocal(xExprRef);
  let xPatLid: Analyzer::ResolverBodies::LocalId = assertPatternLocal(&output.bodyResolution, xSubPat);
  Test::assertEq<u32>(xExprLid.index, xPatLid.index);
}

// ============================================================
// W-02: SC-09 — if-let binding scoped to then-branch only
// ============================================================

/// Scenario SC-09: `if (let v = expr) { return v; } return v;` —
/// `v` is a Local visible inside the then-branch but not in the surrounding scope
/// after the if expression exits.
///
/// Uses a plain Binding pattern in the LetCondition to avoid enum-variant arity
/// complications; the scope-discipline assertion is the same.
@test
function resolveBodiesIfLetBindingScopedToThenBranch(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // function f(x: i32): void {
  //   if (let v = x) { return v; }
  //   return v;  // v is NOT in scope here — UNDECLARED_VARIABLE expected
  // }
  let i32TypeId: Ast::TypeId = addPathType(&mut module, "i32");
  let xParamPat: Ast::PatternId = addAnnotatedBinding(&mut module, "x", i32TypeId);

  // `x` in the LetCondition value position.
  let xVarExpr: Ast::ExpressionId = addVariable(&mut module, "x");

  // Binding pattern `v` in the LetCondition.
  let vBindPat: Ast::PatternId = addBinding(&mut module, "v");

  // LetCondition: `let v = x`.
  let letCondExpr: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::LetCondition(Ast::Expression::LetCondition {
    span: bodiesDummySpan(),
    pattern: vBindPat,
    value: xVarExpr,
  }));

  // `v` used inside then-branch body.
  let vInsideThen: Ast::ExpressionId = addVariable(&mut module, "v");
  let retVStmt: Ast::StatementId = addReturnExpr(&mut module, vInsideThen);
  let mut thenStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  thenStmts.push(retVStmt);
  let thenBlock: Ast::StatementId = addBlock(&mut module, thenStmts);

  // if expression wrapping the LetCondition.
  let ifExpr: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::If(Ast::Expression::If {
    span: bodiesDummySpan(),
    condition: letCondExpr,
    thenBranch: thenBlock,
    elseBranch: Option::NONE,
  }));

  let ifStmt: Ast::StatementId = module.addStatement(Ast::Statement::Node::Expression(Ast::Statement::Expression {
    span: bodiesDummySpan(),
    expression: ifExpr,
  }));

  // `v` used AFTER the if-expression — should be Unresolved.
  let vAfterIf: Ast::ExpressionId = addVariable(&mut module, "v");
  let retAfterStmt: Ast::StatementId = addReturnExpr(&mut module, vAfterIf);

  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(ifStmt);
  bodyStmts.push(retAfterStmt);
  let bodyBlock: Ast::StatementId = addBlock(&mut module, bodyStmts);

  let mut fParams: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fParams.push(xParamPat);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("f"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: fParams,
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  // One diagnostic for `v` after the if-block (UNDECLARED_VARIABLE).
  Test::assertEq<u64>(output.diagnostics.length(), 1);

  // `v` inside the then-branch resolves to Local (binding introduced by LetCondition).
  let vThenRef: Analyzer::ResolverBodies::ResolvedRef = assertExprRef(&output.bodyResolution, vInsideThen);
  let _vLid: Analyzer::ResolverBodies::LocalId = assertLocal(vThenRef);

  // `v` after the if resolves to Unresolved (not in scope outside if-let scope).
  let vAfterRef: Analyzer::ResolverBodies::ResolvedRef = assertExprRef(&output.bodyResolution, vAfterIf);
  assertUnresolved(vAfterRef);
}

// ============================================================
// W-02: SC-11 — Type-param shadowed by local parameter
// ============================================================

/// Scenario SC-11: `function f<T>(x: T): T { return x; }` —
/// `x` in the return expression resolves to Local (the parameter), not TypeParam(T).
/// Confirms innermost-first lookup: local scope is checked before type-param scope.
@test
function resolveBodiesTypeParamShadowedByLocal(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // function f<T>(x: T): T { return x; }
  let tTypeId: Ast::TypeId = addPathType(&mut module, "T");
  let xParamPat: Ast::PatternId = addAnnotatedBinding(&mut module, "x", tTypeId);

  let xVarExpr: Ast::ExpressionId = addVariable(&mut module, "x");
  let retStmt: Ast::StatementId = addReturnExpr(&mut module, xVarExpr);
  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = addBlock(&mut module, bodyStmts);

  // Generic parameter <T>.
  let mut tBounds: Vector<Ast::GenericBound> = Vector::new<Ast::GenericBound>();
  let tGenericParam: Ast::GenericParam = Ast::GenericParam {
    span: bodiesDummySpan(),
    name: String::create("T"),
    bounds: tBounds,
  };
  let mut genericParams: Vector<Ast::GenericParam> = Vector::new<Ast::GenericParam>();
  genericParams.push(tGenericParam);

  let mut fParams: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fParams.push(xParamPat);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("f"),
    genericParameters: genericParams,
    parameters: fParams,
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  // No diagnostics: `x` resolves to the parameter.
  Test::assertEq<u64>(output.diagnostics.length(), 0);

  // `x` resolves to Local (the parameter), not TypeParam.
  let xRef: Analyzer::ResolverBodies::ResolvedRef = assertExprRef(&output.bodyResolution, xVarExpr);
  let _xLid: Analyzer::ResolverBodies::LocalId = assertLocal(xRef);
}

// ============================================================
// W-03: Non-mutation — TypeStore and BinderOutput
// ============================================================

/// Scenario SC-14 (TypeStore): resolveBodies does not mutate TypeStore.
///
/// Captures the TypeStore type count after `resolveTypes`; body resolution must
/// not grow it, even for generic functions whose type-param scope is already interned.
@test
function resolveBodiesDoesNotMutateTypeStore(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // function f<T>(x: T) { return x; }
  let tTypeId: Ast::TypeId = addPathType(&mut module, "T");
  let xParamPat: Ast::PatternId = addAnnotatedBinding(&mut module, "x", tTypeId);
  let xVarExpr: Ast::ExpressionId = addVariable(&mut module, "x");
  let retStmt: Ast::StatementId = addReturnExpr(&mut module, xVarExpr);
  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = addBlock(&mut module, bodyStmts);

  let mut tBounds: Vector<Ast::GenericBound> = Vector::new<Ast::GenericBound>();
  let tGenericParam: Ast::GenericParam = Ast::GenericParam {
    span: bodiesDummySpan(),
    name: String::create("T"),
    bounds: tBounds,
  };
  let mut genericParams: Vector<Ast::GenericParam> = Vector::new<Ast::GenericParam>();
  genericParams.push(tGenericParam);

  let mut fParams: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fParams.push(xParamPat);
  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("f"),
    genericParameters: genericParams,
    parameters: fParams,
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );
  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let resolveOutput: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );
  Test::assertEq<u64>(resolveOutput.diagnostics.length(), 0);

  let typeCountBefore: u64 = typeStore.length();

  let _out: Analyzer::ResolverBodies::ResolverBodiesOutput = Analyzer::ResolverBodies::resolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );
  Test::assertEq<u64>(typeStore.length(), typeCountBefore);

  let _out2: Analyzer::ResolverBodies::ResolverBodiesOutput = Analyzer::ResolverBodies::resolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );
  Test::assertEq<u64>(typeStore.length(), typeCountBefore);
}

/// Scenario SC-14 (BinderOutput): resolveBodies does not mutate binder pass-1 or pass-2 outputs.
///
/// Captures nodeIds lengths before and after; they must not change.
@test
function resolveBodiesDoesNotMutateBinderOutputs(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // function g(): void { return; }
  let retStmt: Ast::StatementId = addReturn(&mut module);
  let bodyBlock: Ast::StatementId = addBlock(&mut module, Vector::new<Ast::StatementId>());
  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("g"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );
  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  let _resolveOutput: Analyzer::Resolver::ResolverOutput = Analyzer::Resolver::resolveTypes(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  // Capture binder output sizes before resolveBodies.
  let pass1NodesBefore: u64 = pass1.nodeIds.length();
  let pass2NodesBefore: u64 = pass2.nodeIds.length();

  let _out: Analyzer::ResolverBodies::ResolverBodiesOutput = Analyzer::ResolverBodies::resolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
    &pass2,
  );

  // resolveBodies must not modify binder outputs.
  Test::assertEq<u64>(pass1.nodeIds.length(), pass1NodesBefore);
  Test::assertEq<u64>(pass2.nodeIds.length(), pass2NodesBefore);
}

// ============================================================
// Phase 8: Method body traversal (selfhost-methods-binder PR5)
// ============================================================

/// Scenario: record instance method body is walked — the `self` parameter
/// binds as Local index 0, and a `self` reference inside the body resolves to
/// that same Local. Without method-body traversal this entry is absent.
/// Spec: selfhost-method-body-checking — Method body traversal.
@test
function resolveBodiesWalksRecordMethodBodyBindsSelf(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // record R { m(self): void { return self; } }
  let selfPat: Ast::PatternId = addBinding(&mut module, "self");
  let selfExpr: Ast::ExpressionId = addVariable(&mut module, "self");
  let retStmt: Ast::StatementId = addReturnExpr(&mut module, selfExpr);
  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(retStmt);
  let methodBody: Ast::StatementId = addBlock(&mut module, bodyStmts);

  let mut params: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  params.push(selfPat);

  let methodId: Ast::ItemId = module.addItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("m"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: params,
    returnType: Option::NONE,
    body: methodBody,
    metadata: Ast::emptyMetadata(),
  }));

  let mut methods: Vector<Ast::ItemId> = Vector::new<Ast::ItemId>();
  methods.push(methodId);

  module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: bodiesDummySpan(),
    name: String::create("R"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: Vector::new<Ast::PatternId>(),
    methods: methods,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  Test::assertEq<u64>(output.diagnostics.length(), 0);

  let selfPatLid: Analyzer::ResolverBodies::LocalId = assertPatternLocal(&output.bodyResolution, selfPat);
  Test::assertEq<u32>(selfPatLid.index, 0);

  let selfRef: Analyzer::ResolverBodies::ResolvedRef = assertExprRef(&output.bodyResolution, selfExpr);
  let selfExprLid: Analyzer::ResolverBodies::LocalId = assertLocal(selfRef);
  Test::assertEq<u32>(selfExprLid.index, 0);
}

/// Scenario: trait signature-only method is traversed — the `self` parameter
/// binds as Local even though the method body is an empty block. Without
/// traversal the entry is absent.
