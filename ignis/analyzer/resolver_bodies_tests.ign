function resolveBodiesPatternUnknownOwnerEmitsUndeclaredVariable(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // function f(): void { match 0 { Zzz::member => {} } }
  let armPat: Ast::PatternId = addPathPattern2(&mut module, "Zzz", "member", Vector::new<Ast::PatternId>());
  addMatchArmFunction(&mut module, "f", armPat);

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  Test::assertEq<u64>(output.diagnostics.length(), 1);

  let patResult: Option<Analyzer::ResolverBodies::ResolvedRef> = Analyzer::ResolverBodies::findPatternRef(&output.bodyResolution, armPat.raw());
  let Option::SOME(patRef) = patResult else {
    @panic("resolveBodiesPatternUnknownOwnerEmitsUndeclaredVariable: pattern ref not found");
  };
  assertUnresolved(patRef);
}

/// Scenario: a bare single-segment identifier matching only a method name
/// (present in a Record's `staticMethods`, never in the flat global index)
/// still resolves as UNDECLARED_VARIABLE — regression guard for
/// `buildBodyGlobalNameIndex`'s Method exclusion (design section 5). REQ-NG.
@test
function resolveBodiesBareMethodNameNotInGlobalIndex(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // record R { staticMethod(): void { return; } }
  let mut staticBody: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  staticBody.push(addReturn(&mut module));
  let staticMethodId: Ast::ItemId = addMethodItem(&mut module, "staticMethod", Vector::new<Ast::PatternId>(), staticBody);
  let mut methods: Vector<Ast::ItemId> = Vector::new<Ast::ItemId>();
  methods.push(staticMethodId);

  module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: bodiesDummySpan(),
    name: String::create("R"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: Vector::new<Ast::PatternId>(),
    methods: methods,
    metadata: Ast::emptyMetadata(),
  }));

  // function f(): void { staticMethod; return; }
  let bareExpr: Ast::ExpressionId = addVariable(&mut module, "staticMethod");
  addPathExprStmtFunction(&mut module, "f", bareExpr);

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  Test::assertEq<u64>(output.diagnostics.length(), 1);

  let ref_: Analyzer::ResolverBodies::ResolvedRef = assertExprRef(&output.bodyResolution, bareExpr);
  assertUnresolved(ref_);
}
