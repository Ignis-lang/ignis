// Phase 6: Function-body and constant integration
// ============================================================

/// Scenario SC-01 (full): function add(a: i32, b: i32) — a→index:0, b→index:1.
@test
function resolveBodiesResolvesParametersThenBody(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // function add(a: i32, b: i32): i32 { return a; }
  let i32TypeId: Ast::TypeId = addPathType(&mut module, "i32");
  let aPat: Ast::PatternId = addAnnotatedBinding(&mut module, "a", i32TypeId);
  let bPat: Ast::PatternId = addAnnotatedBinding(&mut module, "b", i32TypeId);

  let aVarExpr: Ast::ExpressionId = addVariable(&mut module, "a");
  let retStmt: Ast::StatementId = addReturnExpr(&mut module, aVarExpr);

  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = addBlock(&mut module, bodyStmts);

  let mut params: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  params.push(aPat);
  params.push(bPat);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("add"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: params,
    returnType: Option::SOME(i32TypeId),
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  Test::assertEq<u64>(output.diagnostics.length(), 0);

  let aPatLid: Analyzer::ResolverBodies::LocalId = assertPatternLocal(&output.bodyResolution, aPat);
  let bPatLid: Analyzer::ResolverBodies::LocalId = assertPatternLocal(&output.bodyResolution, bPat);

  Test::assertEq<u32>(aPatLid.index, 0);
  Test::assertEq<u32>(bPatLid.index, 1);

  let aExprRef: Analyzer::ResolverBodies::ResolvedRef = assertExprRef(
    &output.bodyResolution,
    aVarExpr,
  );
  let aExprLid: Analyzer::ResolverBodies::LocalId = assertLocal(aExprRef);
  Test::assertEq<u32>(aExprLid.index, 0);
}

/// Scenario: constant initializer is walked; K resolves to Definition in function body.
@test
function resolveBodiesResolvesConstantInitializer(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // const K: i32 = 5;
  let i32TypeId: Ast::TypeId = addPathType(&mut module, "i32");
  let kLit: Ast::ExpressionId = addIntLiteral(&mut module, 5);
  module.addRootItem(Ast::Item::Node::Constant(Ast::Item::Constant {
    span: bodiesDummySpan(),
    name: String::create("K"),
    annotation: Option::SOME(i32TypeId),
    value: kLit,
    metadata: Ast::emptyMetadata(),
  }));

  // function f(): i32 { return K; }
  let kVarExpr: Ast::ExpressionId = addVariable(&mut module, "K");
  let retStmt: Ast::StatementId = addReturnExpr(&mut module, kVarExpr);

  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = addBlock(&mut module, bodyStmts);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("f"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::SOME(i32TypeId),
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  Test::assertEq<u64>(output.diagnostics.length(), 0);

  let ref_: Analyzer::ResolverBodies::ResolvedRef = assertExprRef(
    &output.bodyResolution,
    kVarExpr,
  );
  let _did: Analyzer::DefinitionId = assertDefinitionRef(ref_);
}

// ============================================================
// Phase 7: Scope discipline edge cases
// ============================================================

/// Scenario SC-05: shadowing — inner let wins over outer.
@test
function resolveBodiesShadowingPrefersLocal(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // function f(): void { let x = 1; { let x = 2; return x; } }
  let lit1: Ast::ExpressionId = addIntLiteral(&mut module, 1);
  let xOuterPat: Ast::PatternId = addBinding(&mut module, "x");
  let outerLet: Ast::StatementId = module.addStatement(Ast::Statement::Node::Let(Ast::Statement::Let {
    span: bodiesDummySpan(),
    pattern: xOuterPat,
    annotation: Option::NONE,
    value: Option::SOME(lit1),
  }));

  let lit2: Ast::ExpressionId = addIntLiteral(&mut module, 2);
  let xInnerPat: Ast::PatternId = addBinding(&mut module, "x");
  let innerLet: Ast::StatementId = module.addStatement(Ast::Statement::Node::Let(Ast::Statement::Let {
    span: bodiesDummySpan(),
    pattern: xInnerPat,
    annotation: Option::NONE,
    value: Option::SOME(lit2),
  }));

  let xVarExpr: Ast::ExpressionId = addVariable(&mut module, "x");
  let retStmt: Ast::StatementId = addReturnExpr(&mut module, xVarExpr);

  let mut innerStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  innerStmts.push(innerLet);
  innerStmts.push(retStmt);
  let innerBlock: Ast::StatementId = addBlock(&mut module, innerStmts);

  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(outerLet);
  bodyStmts.push(innerBlock);
  let bodyBlock: Ast::StatementId = addBlock(&mut module, bodyStmts);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("f"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  Test::assertEq<u64>(output.diagnostics.length(), 0);

  // Inner x has a higher index.
  let innerLid: Analyzer::ResolverBodies::LocalId = assertPatternLocal(&output.bodyResolution, xInnerPat);
  let exprRef: Analyzer::ResolverBodies::ResolvedRef = assertExprRef(&output.bodyResolution, xVarExpr);
  let exprLid: Analyzer::ResolverBodies::LocalId = assertLocal(exprRef);
  Test::assertEq<u32>(innerLid.index, exprLid.index);
}

/// Scenario: global record resolves as Definition.
@test
function resolveBodiesGlobalRecordResolves(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // record R {}
  module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: bodiesDummySpan(),
    name: String::create("R"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: Vector::new<Ast::PatternId>(),
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  // function f(): void { R; return; }
  let rVarExpr: Ast::ExpressionId = addVariable(&mut module, "R");
  let exprStmt: Ast::StatementId = module.addStatement(Ast::Statement::Node::Expression(Ast::Statement::Expression {
    span: bodiesDummySpan(),
    expression: rVarExpr,
  }));
  let retStmt: Ast::StatementId = addReturn(&mut module);

  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(exprStmt);
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = addBlock(&mut module, bodyStmts);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("f"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  Test::assertEq<u64>(output.diagnostics.length(), 0);

  let ref_: Analyzer::ResolverBodies::ResolvedRef = assertExprRef(&output.bodyResolution, rVarExpr);
  let _did: Analyzer::DefinitionId = assertDefinitionRef(ref_);
}

/// Scenario: local shadows global of same name.
@test
function resolveBodiesShadowingGlobalWithLocal(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // record R {}
  module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: bodiesDummySpan(),
    name: String::create("R"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: Vector::new<Ast::PatternId>(),
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  // function f(): void { let R = 1; return R; }
  let lit1: Ast::ExpressionId = addIntLiteral(&mut module, 1);
  let rLocalPat: Ast::PatternId = addBinding(&mut module, "R");
  let letStmt: Ast::StatementId = module.addStatement(Ast::Statement::Node::Let(Ast::Statement::Let {
    span: bodiesDummySpan(),
    pattern: rLocalPat,
    annotation: Option::NONE,
    value: Option::SOME(lit1),
  }));

  let rVarExpr: Ast::ExpressionId = addVariable(&mut module, "R");
  let retStmt: Ast::StatementId = addReturnExpr(&mut module, rVarExpr);

  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(letStmt);
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = addBlock(&mut module, bodyStmts);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("f"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  Test::assertEq<u64>(output.diagnostics.length(), 0);

  // R should resolve to Local (the let binding), not Definition (the record).
  let ref_: Analyzer::ResolverBodies::ResolvedRef = assertExprRef(&output.bodyResolution, rVarExpr);
  let _lid: Analyzer::ResolverBodies::LocalId = assertLocal(ref_);
}

