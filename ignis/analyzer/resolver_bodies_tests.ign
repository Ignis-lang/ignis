/// Scenario SC-04: let binding — the Variable for `a` in return resolves to Local.
@test
function resolveBodiesBindsLetPattern(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // function f(): void { let a = 0; return a; }
  let intLit: Ast::ExpressionId = addIntLiteral(&mut module, 0);
  let aPat: Ast::PatternId = addBinding(&mut module, "a");

  let letStmt: Ast::StatementId = module.addStatement(Ast::Statement::Node::Let(Ast::Statement::Let {
    span: bodiesDummySpan(),
    pattern: aPat,
    annotation: Option::NONE,
    value: Option::SOME(intLit),
  }));

  let aVarExpr: Ast::ExpressionId = addVariable(&mut module, "a");
  let retStmt: Ast::StatementId = addReturnExpr(&mut module, aVarExpr);

  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(letStmt);
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = addBlock(&mut module, bodyStmts);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("f"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  Test::assertEq<u64>(output.diagnostics.length(), 0);

  // The pattern Binding node should map to Local.
  let patLid: Analyzer::ResolverBodies::LocalId = assertPatternLocal(
    &output.bodyResolution,
    aPat,
  );

  // The Variable expression 'a' in return should map to same Local index.
  let exprRef: Analyzer::ResolverBodies::ResolvedRef = assertExprRef(
    &output.bodyResolution,
    aVarExpr,
  );
  let exprLid: Analyzer::ResolverBodies::LocalId = assertLocal(exprRef);
  Test::assertEq<u32>(patLid.index, exprLid.index);
}

/// Scenario: tuple pattern binds both elements as distinct locals.
@test
function resolveBodiesBindsTuplePattern(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // function f(): void { let (a, b) = (1, 2); return a; }
  let lit1: Ast::ExpressionId = addIntLiteral(&mut module, 1);
  let lit2: Ast::ExpressionId = addIntLiteral(&mut module, 2);

  let mut tupleElems: Vector<Ast::ExpressionId> = Vector::new<Ast::ExpressionId>();
  tupleElems.push(lit1);
  tupleElems.push(lit2);
  let tupleExpr: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::Tuple(Ast::Expression::Tuple {
    span: bodiesDummySpan(),
    elements: tupleElems,
  }));

  let aPat: Ast::PatternId = addBinding(&mut module, "a");
  let bPat: Ast::PatternId = addBinding(&mut module, "b");
  let mut tuplePats: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  tuplePats.push(aPat);
  tuplePats.push(bPat);
  let tuplePat: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Tuple(Ast::Pattern::Tuple {
    span: bodiesDummySpan(),
    elements: tuplePats,
  }));

  let letStmt: Ast::StatementId = module.addStatement(Ast::Statement::Node::Let(Ast::Statement::Let {
    span: bodiesDummySpan(),
    pattern: tuplePat,
    annotation: Option::NONE,
    value: Option::SOME(tupleExpr),
  }));

  let aVarExpr: Ast::ExpressionId = addVariable(&mut module, "a");
  let retStmt: Ast::StatementId = addReturnExpr(&mut module, aVarExpr);

  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(letStmt);
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = addBlock(&mut module, bodyStmts);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("f"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  Test::assertEq<u64>(output.diagnostics.length(), 0);

  let aLid: Analyzer::ResolverBodies::LocalId = assertPatternLocal(&output.bodyResolution, aPat);
  let bLid: Analyzer::ResolverBodies::LocalId = assertPatternLocal(&output.bodyResolution, bPat);

  // a and b should have different indices.
  Test::assertEq<boolean>(aLid.index != bLid.index, true);
}

/// Scenario: enum variant destructure in pattern resolves to Definition.
@test
function resolveBodiesResolvesEnumVariantDestructure(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // enum E { A }
  let mut variants: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  let variantBindPat: Ast::PatternId = addBinding(&mut module, "A");
  variants.push(variantBindPat);
  module.addRootItem(Ast::Item::Node::Enum(Ast::Item::Enum {
    span: bodiesDummySpan(),
    name: String::create("E"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    variants: variants,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  // function f(e: E): void { match e { E::A => return; } }
  let eParamTypeId: Ast::TypeId = addPathType(&mut module, "E");
  let eParamPat: Ast::PatternId = addAnnotatedBinding(&mut module, "e", eParamTypeId);

  let eVarExpr: Ast::ExpressionId = addVariable(&mut module, "e");

  // Match arm pattern: E::A (2-segment path pattern)
  let mut armSegs: Vector<String> = Vector::new<String>();
  armSegs.push(String::create("E"));
  armSegs.push(String::create("A"));
  let armPathPat: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Path(Ast::Pattern::Path {
    span: bodiesDummySpan(),
    segments: armSegs,
    arguments: Vector::new<Ast::PatternId>(),
  }));

  let armRetStmt: Ast::StatementId = addReturn(&mut module);
  let armBodyExpr: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::Block(Ast::Expression::Block {
    span: bodiesDummySpan(),
    statements: Vector::new<Ast::StatementId>(),
    tail: Option::NONE,
  }));

  let mut arms: Vector<Ast::Expression::MatchArm> = Vector::new<Ast::Expression::MatchArm>();
  arms.push(Ast::Expression::MatchArm {
    pattern: armPathPat,
    guard: Option::NONE,
    body: armBodyExpr,
  });

  let matchExpr: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::Match(Ast::Expression::Match {
    span: bodiesDummySpan(),
    scrutinee: eVarExpr,
    arms: arms,
  }));

  let matchStmt: Ast::StatementId = module.addStatement(Ast::Statement::Node::Expression(Ast::Statement::Expression {
    span: bodiesDummySpan(),
    expression: matchExpr,
  }));

  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(matchStmt);
  let bodyBlock: Ast::StatementId = addBlock(&mut module, bodyStmts);

  let mut fParams: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fParams.push(eParamPat);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("f"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: fParams,
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  // No diagnostics: E and A are valid.
  Test::assertEq<u64>(output.diagnostics.length(), 0);

  // The path pattern E::A should map to Definition.
  let patResult: Option<Analyzer::ResolverBodies::ResolvedRef> = Analyzer::ResolverBodies::findPatternRef(
    &output.bodyResolution,
    armPathPat.raw(),
  );
  let Option::SOME(patRef) = patResult else {
    @panic("E::A pattern ref not found");
  };
  let _did: Analyzer::DefinitionId = assertDefinitionRef(patRef);
}

/// Scenario: pattern arity mismatch emits INVALID_NUMBER_OF_ARGUMENTS.
@test
function resolveBodiesEmitsPatternArityMismatch(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // enum E { A }  — A has empty payload.
  let mut variants: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  let variantBind: Ast::PatternId = addBinding(&mut module, "A");
  variants.push(variantBind);
  module.addRootItem(Ast::Item::Node::Enum(Ast::Item::Enum {
    span: bodiesDummySpan(),
    name: String::create("E"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    variants: variants,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  // function f(e: E): void { match e { E::A(x) => return; } }
  // E::A has empty payload; matching with one argument is an arity mismatch.
  let eParamTypeId: Ast::TypeId = addPathType(&mut module, "E");
  let eParamPat: Ast::PatternId = addAnnotatedBinding(&mut module, "e", eParamTypeId);
  let eVarExpr: Ast::ExpressionId = addVariable(&mut module, "e");

  let xSubPat: Ast::PatternId = addBinding(&mut module, "x");
  let mut argPats: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  argPats.push(xSubPat);

  let mut armSegs: Vector<String> = Vector::new<String>();
  armSegs.push(String::create("E"));
  armSegs.push(String::create("A"));
  let armPathPat: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Path(Ast::Pattern::Path {
    span: bodiesDummySpan(),
    segments: armSegs,
    arguments: argPats,
  }));

  let armBodyExpr: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::Block(Ast::Expression::Block {
    span: bodiesDummySpan(),
    statements: Vector::new<Ast::StatementId>(),
    tail: Option::NONE,
  }));

  let mut arms: Vector<Ast::Expression::MatchArm> = Vector::new<Ast::Expression::MatchArm>();
  arms.push(Ast::Expression::MatchArm {
    pattern: armPathPat,
    guard: Option::NONE,
    body: armBodyExpr,
  });

  let matchExpr: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::Match(Ast::Expression::Match {
    span: bodiesDummySpan(),
    scrutinee: eVarExpr,
    arms: arms,
  }));

  let matchStmt: Ast::StatementId = module.addStatement(Ast::Statement::Node::Expression(Ast::Statement::Expression {
    span: bodiesDummySpan(),
    expression: matchExpr,
  }));

  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(matchStmt);
  let bodyBlock: Ast::StatementId = addBlock(&mut module, bodyStmts);

  let mut fParams: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fParams.push(eParamPat);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("f"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: fParams,
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  // Arity mismatch: one INVALID_NUMBER_OF_ARGUMENTS expected.
  Test::assertEq<u64>(output.diagnostics.length(), 1);
}

