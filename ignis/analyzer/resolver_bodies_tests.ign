  assertUnresolved(ref_);
}

/// Scenario: enum variant resolved via 2-segment path expression.
@test
function resolveBodiesResolvesEnumVariantPath(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // enum E { A }
  let mut variants: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  let variantPat: Ast::PatternId = addBinding(&mut module, "A");
  variants.push(variantPat);
  module.addRootItem(Ast::Item::Node::Enum(Ast::Item::Enum {
    span: bodiesDummySpan(),
    name: String::create("E"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    variants: variants,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  // function f(): void { E::A; return; }
  let mut pathSegs: Vector<String> = Vector::new<String>();
  pathSegs.push(String::create("E"));
  pathSegs.push(String::create("A"));
  let pathExpr: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::Path(Ast::Expression::Path {
    span: bodiesDummySpan(),
    segments: pathSegs,
  }));

  let pathStmt: Ast::StatementId = module.addStatement(Ast::Statement::Node::Expression(Ast::Statement::Expression {
    span: bodiesDummySpan(),
    expression: pathExpr,
  }));
  let retStmt: Ast::StatementId = addReturn(&mut module);

  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(pathStmt);
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = addBlock(&mut module, bodyStmts);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: bodiesDummySpan(),
    name: String::create("f"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  Test::assertEq<u64>(output.diagnostics.length(), 0);

  let ref_: Analyzer::ResolverBodies::ResolvedRef = assertExprRef(
    &output.bodyResolution,
    pathExpr,
  );
  let _did: Analyzer::DefinitionId = assertDefinitionRef(ref_);
}

/// Scenario: multi-segment path (3+ segments) with an unresolvable owner
/// segment now emits one UNDECLARED_VARIABLE diagnostic (REQ-M2 "unknown
/// static target" — superseded the pre-WU1 REQ-F4 silent-Unresolved behavior;
/// `resolvePathTail` resolves the LAST TWO segments, `B::C` here, and neither
/// resolves as an owner nor as a member-as-type fallback).
@test
function resolveBodiesMultiSegmentPathIsUnresolvedNoDiagnostic(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // function f(): void { A::B::C; return; }
  let pathExpr: Ast::ExpressionId = addPathExpr3(&mut module, "A", "B", "C");
  addPathExprStmtFunction(&mut module, "f", pathExpr);

  let output: Analyzer::ResolverBodies::ResolverBodiesOutput = runResolveBodies(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  Test::assertEq<u64>(output.diagnostics.length(), 1);

  let ref_: Analyzer::ResolverBodies::ResolvedRef = assertExprRef(
    &output.bodyResolution,
    pathExpr,
  );
  assertUnresolved(ref_);
}

/// Scenario: Lambda expression records Unresolved, no diagnostic (REQ-B18).
@test
function resolveBodiesEmitsClosuresUnsupported(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // function f(): void { lambda body = { return; }; return; }
