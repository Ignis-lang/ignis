  let _aliasId: Ast::ItemId = typecheckAddTypeAliasItem(&mut module, "AliasPoint", typecheckAddPathType(&mut module, "Point"));

  let aliasPath: Ast::ExpressionId = typecheckAddVariable(&mut module, "AliasPoint");
  let oneExpr: Ast::ExpressionId = typecheckAddIntLiteral(&mut module, 1);
  let trueExpr: Ast::ExpressionId = typecheckAddBoolLiteral(&mut module, true);
