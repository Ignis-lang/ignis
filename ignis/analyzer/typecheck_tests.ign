@test
function typecheckBinaryComparisonAndEqualityReturnBoolean(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let boolTypeId: Ast::TypeId = typecheckAddPathType(&mut module, "boolean");
  let equalityExpr: Ast::ExpressionId = typecheckAddBinary(
    &mut module,
    Ast::Expression::BinaryOperator::Equal,
    typecheckAddIntLiteral(&mut module, 1),
    typecheckAddIntLiteral(&mut module, 2),
  );
  let compareExpr: Ast::ExpressionId = typecheckAddBinary(
    &mut module,
    Ast::Expression::BinaryOperator::LessThan,
    typecheckAddIntLiteral(&mut module, 3),
    typecheckAddIntLiteral(&mut module, 4),
  );
  let equalityStmt: Ast::StatementId = typecheckAddExprStmt(&mut module, equalityExpr);
  let compareStmt: Ast::StatementId = typecheckAddReturnExpr(&mut module, compareExpr);
  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(equalityStmt);
  bodyStmts.push(compareStmt);
  let bodyBlock: Ast::StatementId = typecheckAddBlock(&mut module, bodyStmts);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: typecheckDummySpan(),
    name: String::create("compareI32"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::SOME(boolTypeId),
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::Typecheck::TypecheckOutput = typecheckRunTypecheck(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  Test::assertEq<u64>(output.diagnostics.length(), 0);
  assertExprType(&output, equalityExpr, typeStore.intern(Analyzer::Type::BOOLEAN));
  assertExprType(&output, compareExpr, typeStore.intern(Analyzer::Type::BOOLEAN));
}

