  let badArithmeticExpr: Ast::ExpressionId = typecheckAddBinary(
    &mut module,
    Ast::Expression::BinaryOperator::Add,
    typecheckAddIntLiteral(&mut module, 1),
    module.addExpression(Ast::Expression::Node::Literal(Ast::Expression::Literal {
