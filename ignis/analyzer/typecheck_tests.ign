@test
function typecheckForStatementUsesLoopLocalAcrossSurface(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let i32TypeId: Ast::TypeId = typecheckAddPathType(&mut module, "i32");
  let indexPattern: Ast::PatternId = typecheckAddAnnotatedBinding(&mut module, "i", i32TypeId);
  let initStmt: Ast::StatementId = typecheckAddMutableVariableStmt(
    &mut module,
    indexPattern,
    i32TypeId,
    typecheckAddIntLiteral(&mut module, 0),
  );
  let conditionExpr: Ast::ExpressionId = typecheckAddBinary(
    &mut module,
    Ast::Expression::BinaryOperator::LessThan,
    typecheckAddVariable(&mut module, "i"),
    typecheckAddIntLiteral(&mut module, 3),
  );
  let updateExpr: Ast::ExpressionId = typecheckAddAssignment(
    &mut module,
    Ast::Expression::AssignmentOperator::Assign,
    typecheckAddVariable(&mut module, "i"),
    typecheckAddBinary(
      &mut module,
      Ast::Expression::BinaryOperator::Add,
      typecheckAddVariable(&mut module, "i"),
      typecheckAddIntLiteral(&mut module, 1),
    ),
  );
  let bodyUseExpr: Ast::ExpressionId = typecheckAddVariable(&mut module, "i");
  let bodyUseStmt: Ast::StatementId = typecheckAddExprStmt(&mut module, bodyUseExpr);
  let mut loopBodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  loopBodyStmts.push(bodyUseStmt);
  let loopBody: Ast::StatementId = typecheckAddBlock(&mut module, loopBodyStmts);
  let forStmt: Ast::StatementId = typecheckAddForStatement(
    &mut module,
    Option::SOME(initStmt),
    Option::SOME(conditionExpr),
    Option::SOME(updateExpr),
    loopBody,
  );
  let retStmt: Ast::StatementId = typecheckAddReturn(&mut module);
  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(forStmt);
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = typecheckAddBlock(&mut module, bodyStmts);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: typecheckDummySpan(),
    name: String::create("forSurface"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::AnalyzerOutput = typecheckAnalyzeModule(&mut defStore, &mut typeStore, &mut symbols, &module);

  Test::assertEq<u64>(output.diagnostics.length(), 0);
  assertExprType(&output, conditionExpr, typeStore.intern(Analyzer::Type::BOOLEAN));
  assertExprType(&output, updateExpr, typeStore.intern(Analyzer::Type::I32));
  assertExprType(&output, bodyUseExpr, typeStore.intern(Analyzer::Type::I32));
}

@test
function typecheckForLoopLocalDoesNotEscape(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let i32TypeId: Ast::TypeId = typecheckAddPathType(&mut module, "i32");
  let indexPattern: Ast::PatternId = typecheckAddAnnotatedBinding(&mut module, "i", i32TypeId);
  let initStmt: Ast::StatementId = typecheckAddMutableVariableStmt(
    &mut module,
    indexPattern,
    i32TypeId,
    typecheckAddIntLiteral(&mut module, 0),
  );
  let loopBody: Ast::StatementId = typecheckAddBlock(&mut module, Vector::new<Ast::StatementId>());
  let forStmt: Ast::StatementId = typecheckAddForStatement(
    &mut module,
    Option::SOME(initStmt),
    Option::SOME(typecheckAddBoolLiteral(&mut module, true)),
    Option::NONE,
    loopBody,
  );
  let escapedExpr: Ast::ExpressionId = typecheckAddVariable(&mut module, "i");
  let escapedStmt: Ast::StatementId = typecheckAddExprStmt(&mut module, escapedExpr);
  let retStmt: Ast::StatementId = typecheckAddReturn(&mut module);
  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(forStmt);
  bodyStmts.push(escapedStmt);
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = typecheckAddBlock(&mut module, bodyStmts);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: typecheckDummySpan(),
    name: String::create("forEscape"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::AnalyzerOutput = typecheckAnalyzeModule(&mut defStore, &mut typeStore, &mut symbols, &module);

  assertSingleDiagnostic(&output, DiagnosticCode::TYPE_MISMATCH, "typecheck does not support unresolved expression reference");
}

@test
function typecheckLoopControlDiagnosticsRespectLoopDepth(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let nestedBreak: Ast::StatementId = typecheckAddBreakStatement(&mut module, Option::NONE);
  let nestedContinue: Ast::StatementId = typecheckAddContinueStatement(&mut module);
  let mut whileBodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  whileBodyStmts.push(nestedBreak);
  whileBodyStmts.push(nestedContinue);
  let whileBody: Ast::StatementId = typecheckAddBlock(&mut module, whileBodyStmts);
  let whileStmt: Ast::StatementId = typecheckAddWhileStatement(
    &mut module,
    typecheckAddBoolLiteral(&mut module, true),
    whileBody,
  );
  let outsideBreak: Ast::StatementId = typecheckAddBreakStatement(&mut module, Option::NONE);
  let outsideContinue: Ast::StatementId = typecheckAddContinueStatement(&mut module);
  let retStmt: Ast::StatementId = typecheckAddReturn(&mut module);
  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(whileStmt);
  bodyStmts.push(outsideBreak);
  bodyStmts.push(outsideContinue);
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = typecheckAddBlock(&mut module, bodyStmts);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: typecheckDummySpan(),
    name: String::create("loopDepth"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::AnalyzerOutput = typecheckAnalyzeModule(&mut defStore, &mut typeStore, &mut symbols, &module);

  Test::assertEq<u64>(output.diagnostics.length(), 2);
  let Option::SOME(firstDiagnostic) = output.diagnostics.get(0) else {
    @panic("typecheckLoopControlDiagnosticsRespectLoopDepth: missing first diagnostic");
  };
  let Option::SOME(secondDiagnostic) = output.diagnostics.get(1) else {
    @panic("typecheckLoopControlDiagnosticsRespectLoopDepth: missing second diagnostic");
  };
  Test::assertEq<str>(firstDiagnostic.message, "`break` used outside of loop");
  Test::assertEq<str>(secondDiagnostic.message, "`continue` used outside of loop");
}

