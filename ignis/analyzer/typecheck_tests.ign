  let aliasPointTypeId: Ast::TypeId = typecheckAddPathType(&mut module, "AliasPoint");
  let pointPattern: Ast::PatternId = typecheckAddAnnotatedBinding(&mut module, "point", aliasPointTypeId);
  let pointStmt: Ast::StatementId = module.addStatement(Ast::Statement::Node::Let(Ast::Statement::Let {
    span: typecheckDummySpan(),
