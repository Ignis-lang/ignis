  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(pointStmt);
  bodyStmts.push(accessStmt);
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = typecheckAddBlock(&mut module, bodyStmts);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: typecheckDummySpan(),
    name: String::create("badMemberField"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::AnalyzerOutput = typecheckAnalyzeModule(&mut defStore, &mut typeStore, &mut symbols, &module);

  assertSingleDiagnostic(&output, DiagnosticCode::TYPE_MISMATCH, "unknown record field `z`");
}

@test
function typecheckRecordDestructureAnnotatedLetBindsFieldTypes(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let i32Type: Ast::TypeId = typecheckAddPathType(&mut module, "i32");
  let pointType: Ast::TypeId = typecheckAddPathType(&mut module, "Point");
  let boolType: Ast::TypeId = typecheckAddPathType(&mut module, "boolean");

  let mut fields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fields.push(typecheckAddAnnotatedField(&mut module, "x", i32Type));
  fields.push(typecheckAddAnnotatedField(&mut module, "flag", boolType));
  typecheckAddRecordItem(&mut module, "Point", Vector::new<Ast::GenericParam>(), fields);

  let pointPath: Ast::ExpressionId = typecheckAddVariable(&mut module, "Point");
  let mut initFields: Vector<Ast::Expression::RecordInitField> = Vector::new<Ast::Expression::RecordInitField>();
  initFields.push(typecheckRecordInitField("x", typecheckAddIntLiteral(&mut module, 1)));
  initFields.push(typecheckRecordInitField("flag", typecheckAddBoolLiteral(&mut module, true)));
  let initExpr: Ast::ExpressionId = typecheckAddRecordInit(&mut module, pointPath, Vector::new<Ast::TypeId>(), initFields);

  let aPattern: Ast::PatternId = typecheckAddBinding(&mut module, "a");
  let bPattern: Ast::PatternId = typecheckAddBinding(&mut module, "b");
  let mut args: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  args.push(aPattern);
  args.push(bPattern);
  let destructurePattern: Ast::PatternId = typecheckAddPathPattern(&mut module, "Point", args);
  let destructureStmt: Ast::StatementId = typecheckAddLetStmt(&mut module, destructurePattern, pointType, initExpr);

  let bExpr: Ast::ExpressionId = typecheckAddVariable(&mut module, "b");
  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(destructureStmt);
  bodyStmts.push(typecheckAddExprStmt(&mut module, bExpr));
  bodyStmts.push(typecheckAddReturn(&mut module));
  let body: Ast::StatementId = typecheckAddBlock(&mut module, bodyStmts);
  typecheckAddFunctionItem(&mut module, "main", Option::NONE, body);

  let output: Analyzer::AnalyzerOutput = typecheckAnalyzeModule(&mut defStore, &mut typeStore, &mut symbols, &module);

  Test::assertEq<u64>(output.diagnostics.length(), 0);
}

