@test
function typecheckRecordInitAndMemberAccessHappyPath(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let i32TypeId: Ast::TypeId = typecheckAddPathType(&mut module, "i32");
  let boolTypeId: Ast::TypeId = typecheckAddPathType(&mut module, "boolean");
  let xField: Ast::PatternId = typecheckAddAnnotatedField(&mut module, "x", i32TypeId);
  let yField: Ast::PatternId = typecheckAddAnnotatedField(&mut module, "y", boolTypeId);
  let mut pointFields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  pointFields.push(xField);
  pointFields.push(yField);
  let _pointId: Ast::ItemId = typecheckAddRecordItem(&mut module, "Point", Vector::new<Ast::GenericParam>(), pointFields);

  let pointPath: Ast::ExpressionId = typecheckAddVariable(&mut module, "Point");
  let oneExpr: Ast::ExpressionId = typecheckAddIntLiteral(&mut module, 1);
  let trueExpr: Ast::ExpressionId = typecheckAddBoolLiteral(&mut module, true);
  let mut initFields: Vector<Ast::Expression::RecordInitField> = Vector::new<Ast::Expression::RecordInitField>();
  initFields.push(typecheckRecordInitField("x", oneExpr));
  initFields.push(typecheckRecordInitField("y", trueExpr));
  let initExpr: Ast::ExpressionId = typecheckAddRecordInit(&mut module, pointPath, Vector::new<Ast::TypeId>(), initFields);

  let pointPattern: Ast::PatternId = typecheckAddAnnotatedBinding(&mut module, "point", typecheckAddPathType(&mut module, "Point"));
  let pointStmt: Ast::StatementId = module.addStatement(Ast::Statement::Node::Let(Ast::Statement::Let {
    span: typecheckDummySpan(),
    pattern: pointPattern,
    annotation: Option::SOME(typecheckAddPathType(&mut module, "Point")),
    value: Option::SOME(initExpr),
  }));
  let pointExpr: Ast::ExpressionId = typecheckAddVariable(&mut module, "point");
  let accessExpr: Ast::ExpressionId = typecheckAddMemberAccess(&mut module, pointExpr, "x");
  let retStmt: Ast::StatementId = typecheckAddReturnExpr(&mut module, accessExpr);

  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(pointStmt);
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = typecheckAddBlock(&mut module, bodyStmts);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: typecheckDummySpan(),
    name: String::create("buildPoint"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::SOME(i32TypeId),
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::AnalyzerOutput = typecheckAnalyzeModule(&mut defStore, &mut typeStore, &mut symbols, &module);

  Test::assertEq<u64>(output.diagnostics.length(), 0);
  let Option::SOME(initType) = findExprType(&output, initExpr) else {
    @panic("typecheckRecordInitAndMemberAccessHappyPath: missing init type");
  };
  let Option::SOME(pointType) = findExprType(&output, pointExpr) else {
    @panic("typecheckRecordInitAndMemberAccessHappyPath: missing point type");
  };
  Test::assertEq<u32>(initType.raw(), pointType.raw());
  assertExprType(&output, accessExpr, typeStore.intern(Analyzer::Type::I32));
}

