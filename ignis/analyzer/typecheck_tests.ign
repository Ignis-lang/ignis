/// Build a `self` receiver pattern that mirrors what the self-hosted parser
/// actually produces for `&self`/`&mut self` (`ParserDeclarations::createSelfReceiverPattern`
/// in `ignis/parser/declarations.ign`): a `Binding` pattern named `self` with
/// an explicit `Reference(mutable, Path("Self"))` annotation. Test fixtures
/// that build `self` via a bare unannotated `typecheckAddBinding` do not
/// exercise this real shape.
function typecheckAddSelfReceiverPattern(
  module: &mut Ast::Module,
  mutable: boolean
): Ast::PatternId {
  let mut selfSegments: Vector<String> = Vector::new<String>();
  selfSegments.push(String::create("Self"));
  let mut moduleRef: &mut Ast::Module = module;
  let selfPathType: Ast::TypeId = moduleRef.addType(Ast::Type::Node::Path(Ast::Type::Path {
    span: typecheckDummySpan(),
    segments: selfSegments,
  }));

  let mut moduleRef2: &mut Ast::Module = module;
  let selfRefType: Ast::TypeId = moduleRef2.addType(Ast::Type::Node::Reference(Ast::Type::Reference {
    span: typecheckDummySpan(),
    mutable: mutable,
    target: selfPathType,
  }));

  let mut moduleRef3: &mut Ast::Module = module;
  return moduleRef3.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: typecheckDummySpan(),
    name: String::create("self"),
    annotation: Option::SOME(selfRefType),
    metadata: Ast::emptyMetadata(),
  }));
}

function typecheckAddPathExpr2(module: &mut Ast::Module, seg0: str, seg1: str): Ast::ExpressionId {
  let mut segments: Vector<String> = Vector::new<String>();
  segments.push(String::create(seg0));
  segments.push(String::create(seg1));
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addExpression(Ast::Expression::Node::Path(Ast::Expression::Path {
    span: typecheckDummySpan(),
    segments: segments,
  }));
}

function typecheckAddPathType2(module: &mut Ast::Module, seg0: str, seg1: str): Ast::TypeId {
  let mut segments: Vector<String> = Vector::new<String>();
  segments.push(String::create(seg0));
  segments.push(String::create(seg1));
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addType(Ast::Type::Node::Path(Ast::Type::Path {
    span: typecheckDummySpan(),
    segments: segments,
  }));
}

function typecheckAnalyzeModule(
  defStore: &mut Analyzer::DefinitionStore,
  typeStore: &mut Analyzer::TypeStore,
  symbols: &mut Analyzer::SymbolTable,
  module: &Ast::Module,
): Analyzer::AnalyzerOutput {
  return Analyzer::analyzeModule(defStore, typeStore, symbols, module);
}

function findExprType(
  output: &Analyzer::AnalyzerOutput,
  exprId: Ast::ExpressionId,
): Option<Analyzer::TypeId> {
  let mut index: u64 = 0;

  while (index < output.typecheck.exprTypes.nodeIds.length()) {
    let Option::SOME(nodeId) = output.typecheck.exprTypes.nodeIds.get(index) else {
      index += 1;
      continue;
    };

    if (*nodeId == exprId.raw()) {
      let Option::SOME(typeId) = output.typecheck.exprTypes.typeIds.get(index) else {
        return Option::NONE;
      };

      return Option::SOME(*typeId);
    }

    index += 1;
  }

  return Option::NONE;
}

function assertExprType(
  output: &Analyzer::AnalyzerOutput,
  exprId: Ast::ExpressionId,
  expected: Analyzer::TypeId,
): void {
  let Option::SOME(actual) = findExprType(output, exprId) else {
    @panic("assertExprType: expression type entry not found");
  };

  Test::assertEq<u32>(actual.raw(), expected.raw());
}

function assertSingleDiagnosticCode(output: &Analyzer::AnalyzerOutput, code: str): void {
  Test::assertEq<u64>(output.typecheck.diagnostics.length(), 1);
  let Option::SOME(diagnostic) = output.typecheck.diagnostics.get(0) else {
    @panic("assertSingleDiagnosticCode: missing diagnostic");
  };
  Test::assertEq<str>(diagnostic.code, code);
}

function assertSingleDiagnostic(output: &Analyzer::AnalyzerOutput, code: str, message: str): void {
  Test::assertEq<u64>(output.typecheck.diagnostics.length(), 1);
  let Option::SOME(diagnostic) = output.typecheck.diagnostics.get(0) else {
    @panic("assertSingleDiagnostic: missing diagnostic");
  };
  Test::assertEq<str>(diagnostic.code, code);
  Test::assertEq<str>(diagnostic.message, message);
}

@test
function typecheckConstantAnnotationHappyPath(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let i32TypeId: Ast::TypeId = typecheckAddPathType(&mut module, "i32");
  let literalExpr: Ast::ExpressionId = typecheckAddIntLiteral(&mut module, 7);

  module.addRootItem(Ast::Item::Node::Constant(Ast::Item::Constant {
    span: typecheckDummySpan(),
    name: String::create("K"),
    annotation: Option::SOME(i32TypeId),
    value: literalExpr,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::AnalyzerOutput = typecheckAnalyzeModule(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  Test::assertEq<u64>(output.diagnostics.length(), 0);
  assertExprType(&output, literalExpr, typeStore.intern(Analyzer::Type::I32));
}

@test
function typecheckSimpleTypedFunctionBodyHappyPath(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let i32TypeId: Ast::TypeId = typecheckAddPathType(&mut module, "i32");
  let xPattern: Ast::PatternId = typecheckAddAnnotatedBinding(&mut module, "x", i32TypeId);
  let oneExpr: Ast::ExpressionId = typecheckAddIntLiteral(&mut module, 1);
  let letStmt: Ast::StatementId = module.addStatement(Ast::Statement::Node::Let(Ast::Statement::Let {
    span: typecheckDummySpan(),
    pattern: xPattern,
    annotation: Option::SOME(i32TypeId),
    value: Option::SOME(oneExpr),
  }));
  let xExpr: Ast::ExpressionId = typecheckAddVariable(&mut module, "x");
  let retStmt: Ast::StatementId = typecheckAddReturnExpr(&mut module, xExpr);

  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(letStmt);
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = typecheckAddBlock(&mut module, bodyStmts);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: typecheckDummySpan(),
    name: String::create("main"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::SOME(i32TypeId),
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::AnalyzerOutput = typecheckAnalyzeModule(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  Test::assertEq<u64>(output.diagnostics.length(), 0);
  assertExprType(&output, oneExpr, typeStore.intern(Analyzer::Type::I32));
  assertExprType(&output, xExpr, typeStore.intern(Analyzer::Type::I32));
}

@test
function typecheckWrongReturnTypeProducesDiagnostic(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let i32TypeId: Ast::TypeId = typecheckAddPathType(&mut module, "i32");
  let boolExpr: Ast::ExpressionId = typecheckAddBoolLiteral(&mut module, true);
  let retStmt: Ast::StatementId = typecheckAddReturnExpr(&mut module, boolExpr);
  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = typecheckAddBlock(&mut module, bodyStmts);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: typecheckDummySpan(),
    name: String::create("badReturn"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::SOME(i32TypeId),
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::AnalyzerOutput = typecheckAnalyzeModule(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  assertSingleDiagnosticCode(&output, DiagnosticCode::TYPE_MISMATCH);
}

@test
function typecheckWrongLetInitializerTypeProducesDiagnostic(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let i32TypeId: Ast::TypeId = typecheckAddPathType(&mut module, "i32");
  let xPattern: Ast::PatternId = typecheckAddAnnotatedBinding(&mut module, "x", i32TypeId);
  let boolExpr: Ast::ExpressionId = typecheckAddBoolLiteral(&mut module, true);
  let letStmt: Ast::StatementId = module.addStatement(Ast::Statement::Node::Let(Ast::Statement::Let {
    span: typecheckDummySpan(),
    pattern: xPattern,
    annotation: Option::SOME(i32TypeId),
    value: Option::SOME(boolExpr),
  }));
  let retStmt: Ast::StatementId = typecheckAddReturn(&mut module);

  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(letStmt);
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = typecheckAddBlock(&mut module, bodyStmts);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: typecheckDummySpan(),
    name: String::create("badLet"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::AnalyzerOutput = typecheckAnalyzeModule(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  assertSingleDiagnosticCode(&output, DiagnosticCode::TYPE_MISMATCH);
}

@test
function typecheckWrongDirectCallArityProducesDiagnostic(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let i32TypeId: Ast::TypeId = typecheckAddPathType(&mut module, "i32");
  let helperParam: Ast::PatternId = typecheckAddAnnotatedBinding(&mut module, "value", i32TypeId);
  let helperExpr: Ast::ExpressionId = typecheckAddVariable(&mut module, "value");
  let helperRet: Ast::StatementId = typecheckAddReturnExpr(&mut module, helperExpr);
  let mut helperBodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  helperBodyStmts.push(helperRet);
  let helperBody: Ast::StatementId = typecheckAddBlock(&mut module, helperBodyStmts);
  let mut helperParams: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  helperParams.push(helperParam);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: typecheckDummySpan(),
    name: String::create("helper"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: helperParams,
    returnType: Option::SOME(i32TypeId),
    body: helperBody,
    metadata: Ast::emptyMetadata(),
  }));

  let helperCallee: Ast::ExpressionId = typecheckAddVariable(&mut module, "helper");
  let badCall: Ast::ExpressionId = typecheckAddCall(&mut module, helperCallee, Vector::new<Ast::ExpressionId>());
  let badReturn: Ast::StatementId = typecheckAddReturnExpr(&mut module, badCall);
  let mut badBodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  badBodyStmts.push(badReturn);
  let badBody: Ast::StatementId = typecheckAddBlock(&mut module, badBodyStmts);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: typecheckDummySpan(),
    name: String::create("badArity"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::SOME(i32TypeId),
    body: badBody,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::AnalyzerOutput = typecheckAnalyzeModule(
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  assertSingleDiagnosticCode(&output, DiagnosticCode::INVALID_NUMBER_OF_ARGUMENTS);
}

