import Test from "std::test";

import DiagnosticCode, SourceSpan from "@compiler::diagnostics";
import Ast from "@compiler::ast";
import Analyzer from "@compiler::analyzer";

function typecheckDummySpan(): SourceSpan {
  return SourceSpan::new("typecheck_tests.ign", 0, 0);
}

function typecheckAddPathType(module: &mut Ast::Module, name: str): Ast::TypeId {
  let mut segments: Vector<String> = Vector::new<String>();
  segments.push(String::create(name));
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addType(Ast::Type::Node::Path(Ast::Type::Path {
    span: typecheckDummySpan(),
    segments: segments,
  }));
}

function typecheckAddBinding(module: &mut Ast::Module, name: str): Ast::PatternId {
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: typecheckDummySpan(),
    name: String::create(name),
    annotation: Option::NONE,
    metadata: Ast::emptyMetadata(),
  }));
}

function typecheckAddWildcardPattern(module: &mut Ast::Module): Ast::PatternId {
  let mut moduleRef: &mut Ast::Module = module;
  return moduleRef.addPattern(Ast::Pattern::Node::Wildcard(Ast::Pattern::Wildcard {
    span: typecheckDummySpan(),
  }));
}

