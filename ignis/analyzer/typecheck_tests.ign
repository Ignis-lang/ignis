  let mut genericParams: Vector<Ast::GenericParam> = Vector::new<Ast::GenericParam>();
  genericParams.push(typecheckGenericParam("T"));
  let _boxId: Ast::ItemId = typecheckAddRecordItem(&mut module, "Box", genericParams, boxFields);

  let boxPath: Ast::ExpressionId = typecheckAddVariable(&mut module, "Box");
  let mut typeArguments: Vector<Ast::TypeId> = Vector::new<Ast::TypeId>();
  typeArguments.push(typecheckAddPathType(&mut module, "i32"));
  let mut initFields: Vector<Ast::Expression::RecordInitField> = Vector::new<Ast::Expression::RecordInitField>();
  initFields.push(typecheckRecordInitField("value", typecheckAddIntLiteral(&mut module, 1)));
  let initExpr: Ast::ExpressionId = typecheckAddRecordInit(&mut module, boxPath, typeArguments, initFields);
  let exprStmt: Ast::StatementId = typecheckAddExprStmt(&mut module, initExpr);
  let retStmt: Ast::StatementId = typecheckAddReturn(&mut module);
  let mut bodyStmts: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();
  bodyStmts.push(exprStmt);
  bodyStmts.push(retStmt);
  let bodyBlock: Ast::StatementId = typecheckAddBlock(&mut module, bodyStmts);

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: typecheckDummySpan(),
    name: String::create("genericInit"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: bodyBlock,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::Typecheck::TypecheckOutput = typecheckRunTypecheck(&mut defStore, &mut typeStore, &mut symbols, &module);

  assertSingleDiagnostic(&output, DiagnosticCode::TYPE_MISMATCH, "typecheck does not support generic record initializers");
}

