import Test from "std::test";

import Id from "@compiler::ids";

import Analyzer from "@compiler::analyzer";

@test
function definitionStoreInitIsEmpty(): void {
  let store: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();

  Test::assertEq<u64>(store.length(), 0);

  match (store.get(Id::fromRaw<Analyzer::DefinitionTag>(0))) {
    Option::SOME(_) -> @panic("expected None on empty store but got Some"),
    Option::NONE -> Test::assert(true),
  };
}

@test
function definitionStorePushAssignsDeterministicInsertionOrderIds(): void {
  let mut table: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let funcSym: Analyzer::SymbolId = table.intern("func");
  let recSym: Analyzer::SymbolId = table.intern("rec");
  let enumSym: Analyzer::SymbolId = table.intern("enumVal");
  let varSym: Analyzer::SymbolId = table.intern("var");

  let mut types: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let voidId: Analyzer::TypeId = types.intern(Analyzer::Type::VOID);
  let boolId: Analyzer::TypeId = types.intern(Analyzer::Type::BOOLEAN);
  let stubTypeId: Analyzer::TypeId = types.intern(Analyzer::Type::I32);

  let mut store: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();

  let id0: Analyzer::DefinitionId = store.push(Analyzer::Definition::Function(Analyzer::FunctionDef {
    name: funcSym,
    visibility: Analyzer::Visibility::PUBLIC,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    params: Vector::new<Analyzer::DefinitionId>(),
    returnType: voidId,
  }));
  let id1: Analyzer::DefinitionId = store.push(Analyzer::Definition::Record(Analyzer::RecordDef {
    name: recSym,
    visibility: Analyzer::Visibility::PUBLIC,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    fields: Vector::new<Analyzer::DefinitionId>(),
    instanceMethods: Vector::new<Analyzer::DefinitionId>(),
    staticMethods: Vector::new<Analyzer::DefinitionId>(),
    typeId: stubTypeId,
  }));
  let id2: Analyzer::DefinitionId = store.push(Analyzer::Definition::Enum(Analyzer::EnumDef {
    name: enumSym,
    visibility: Analyzer::Visibility::PUBLIC,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    variants: Vector::new<Analyzer::DefinitionId>(),
    instanceMethods: Vector::new<Analyzer::DefinitionId>(),
    staticMethods: Vector::new<Analyzer::DefinitionId>(),
    typeId: stubTypeId,
  }));
  let id3: Analyzer::DefinitionId = store.push(Analyzer::Definition::Variable(Analyzer::VariableDef {
    name: varSym,
    visibility: Analyzer::Visibility::PRIVATE,
    declaredType: boolId,
    mutable: false,
  }));

  Test::assertEq<u32>(id0.raw(), 0);
  Test::assertEq<u32>(id1.raw(), 1);
  Test::assertEq<u32>(id2.raw(), 2);
  Test::assertEq<u32>(id3.raw(), 3);
  Test::assertEq<u64>(store.length(), 4);
}

@test
function definitionStoreGetRoundTripsEachVariant(): void {
  let mut table: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let funcSym: Analyzer::SymbolId = table.intern("func");
  let recSym: Analyzer::SymbolId = table.intern("rec");
  let enumSym: Analyzer::SymbolId = table.intern("enumVal");
  let varSym: Analyzer::SymbolId = table.intern("var");

  let mut types: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let voidId: Analyzer::TypeId = types.intern(Analyzer::Type::VOID);
  let boolId: Analyzer::TypeId = types.intern(Analyzer::Type::BOOLEAN);
  let stubTypeId: Analyzer::TypeId = types.intern(Analyzer::Type::I32);

  let mut store: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();

  let id0: Analyzer::DefinitionId = store.push(Analyzer::Definition::Function(Analyzer::FunctionDef {
    name: funcSym,
    visibility: Analyzer::Visibility::PUBLIC,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    params: Vector::new<Analyzer::DefinitionId>(),
    returnType: voidId,
  }));
  let id1: Analyzer::DefinitionId = store.push(Analyzer::Definition::Record(Analyzer::RecordDef {
    name: recSym,
    visibility: Analyzer::Visibility::PRIVATE,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    fields: Vector::new<Analyzer::DefinitionId>(),
    instanceMethods: Vector::new<Analyzer::DefinitionId>(),
    staticMethods: Vector::new<Analyzer::DefinitionId>(),
    typeId: stubTypeId,
  }));
  let id2: Analyzer::DefinitionId = store.push(Analyzer::Definition::Enum(Analyzer::EnumDef {
    name: enumSym,
    visibility: Analyzer::Visibility::PUBLIC,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    variants: Vector::new<Analyzer::DefinitionId>(),
    instanceMethods: Vector::new<Analyzer::DefinitionId>(),
    staticMethods: Vector::new<Analyzer::DefinitionId>(),
    typeId: stubTypeId,
  }));
  let id3: Analyzer::DefinitionId = store.push(Analyzer::Definition::Variable(Analyzer::VariableDef {
    name: varSym,
    visibility: Analyzer::Visibility::PRIVATE,
    declaredType: boolId,
    mutable: false,
  }));

  match (store.get(id0)) {
    Option::SOME(def) -> match (def) {
      Analyzer::Definition::Function(wrapper) -> Test::assertEq<u32>(wrapper.name.raw(), funcSym.raw()),
      Analyzer::Definition::Record(_)         -> @panic("expected Function variant"),
      Analyzer::Definition::Enum(_)           -> @panic("expected Function variant"),
      Analyzer::Definition::Variable(_)       -> @panic("expected Function variant"),
      Analyzer::Definition::Field(_)          -> @panic("expected Function variant"),
      Analyzer::Definition::Variant(_)        -> @panic("expected Function variant"),
      Analyzer::Definition::TypeParam(_)      -> @panic("expected Function variant"),
    },
    Option::NONE -> @panic("expected Some for id0 but got None"),
  };

  match (store.get(id1)) {
    Option::SOME(def) -> match (def) {
      Analyzer::Definition::Function(_)       -> @panic("expected Record variant"),
      Analyzer::Definition::Record(wrapper)   -> Test::assertEq<u32>(wrapper.name.raw(), recSym.raw()),
      Analyzer::Definition::Enum(_)           -> @panic("expected Record variant"),
      Analyzer::Definition::Variable(_)       -> @panic("expected Record variant"),
      Analyzer::Definition::Field(_)          -> @panic("expected Record variant"),
      Analyzer::Definition::Variant(_)        -> @panic("expected Record variant"),
      Analyzer::Definition::TypeParam(_)      -> @panic("expected Record variant"),
    },
    Option::NONE -> @panic("expected Some for id1 but got None"),
  };

  match (store.get(id2)) {
    Option::SOME(def) -> match (def) {
      Analyzer::Definition::Function(_)       -> @panic("expected Enum variant"),
      Analyzer::Definition::Record(_)         -> @panic("expected Enum variant"),
      Analyzer::Definition::Enum(wrapper)     -> Test::assertEq<u32>(wrapper.name.raw(), enumSym.raw()),
      Analyzer::Definition::Variable(_)       -> @panic("expected Enum variant"),
      Analyzer::Definition::Field(_)          -> @panic("expected Enum variant"),
      Analyzer::Definition::Variant(_)        -> @panic("expected Enum variant"),
      Analyzer::Definition::TypeParam(_)      -> @panic("expected Enum variant"),
    },
    Option::NONE -> @panic("expected Some for id2 but got None"),
  };

  match (store.get(id3)) {
    Option::SOME(def) -> match (def) {
      Analyzer::Definition::Function(_)         -> @panic("expected Variable variant"),
      Analyzer::Definition::Record(_)           -> @panic("expected Variable variant"),
      Analyzer::Definition::Enum(_)             -> @panic("expected Variable variant"),
      Analyzer::Definition::Variable(wrapper)   -> Test::assertEq<u32>(wrapper.name.raw(), varSym.raw()),
      Analyzer::Definition::Field(_)            -> @panic("expected Variable variant"),
      Analyzer::Definition::Variant(_)          -> @panic("expected Variable variant"),
      Analyzer::Definition::TypeParam(_)        -> @panic("expected Variable variant"),
    },
    Option::NONE -> @panic("expected Some for id3 but got None"),
  };
}

@test
function definitionStoreLengthCountsDuplicatePushes(): void {
  let mut table: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let sym: Analyzer::SymbolId = table.intern("foo");

  let mut types: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let voidId: Analyzer::TypeId = types.intern(Analyzer::Type::VOID);

  let mut store: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();

  let id0: Analyzer::DefinitionId = store.push(Analyzer::Definition::Function(Analyzer::FunctionDef {
    name: sym,
    visibility: Analyzer::Visibility::PUBLIC,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    params: Vector::new<Analyzer::DefinitionId>(),
    returnType: voidId,
  }));
  let id1: Analyzer::DefinitionId = store.push(Analyzer::Definition::Function(Analyzer::FunctionDef {
    name: sym,
    visibility: Analyzer::Visibility::PUBLIC,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    params: Vector::new<Analyzer::DefinitionId>(),
    returnType: voidId,
  }));

  Test::assertEq<u64>(store.length(), 2);
  Test::assert(id0.raw() != id1.raw());
}

@test
function definitionNameReturnsEmbeddedSymbolIdForEachVariant(): void {
  let mut table: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let funcSym: Analyzer::SymbolId = table.intern("func");
  let recSym: Analyzer::SymbolId = table.intern("rec");
  let enumSym: Analyzer::SymbolId = table.intern("enumVal");
  let varSym: Analyzer::SymbolId = table.intern("var");
  let fieldSym: Analyzer::SymbolId = table.intern("field");
  let variantSym: Analyzer::SymbolId = table.intern("variant");
  let typeParamSym: Analyzer::SymbolId = table.intern("typeParam");

  let mut types: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let voidId: Analyzer::TypeId = types.intern(Analyzer::Type::VOID);
  let i32Id: Analyzer::TypeId = types.intern(Analyzer::Type::I32);
  let stubTypeId: Analyzer::TypeId = types.intern(Analyzer::Type::I32);
  let stubDefId: Analyzer::DefinitionId = Id::fromRaw<Analyzer::DefinitionTag>(99);

  let funcDef: Analyzer::Definition = Analyzer::Definition::Function(Analyzer::FunctionDef {
    name: funcSym,
    visibility: Analyzer::Visibility::PUBLIC,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    params: Vector::new<Analyzer::DefinitionId>(),
    returnType: voidId,
  });
  let recDef: Analyzer::Definition = Analyzer::Definition::Record(Analyzer::RecordDef {
    name: recSym,
    visibility: Analyzer::Visibility::PUBLIC,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    fields: Vector::new<Analyzer::DefinitionId>(),
    instanceMethods: Vector::new<Analyzer::DefinitionId>(),
    staticMethods: Vector::new<Analyzer::DefinitionId>(),
    typeId: stubTypeId,
  });
  let enumDef: Analyzer::Definition = Analyzer::Definition::Enum(Analyzer::EnumDef {
    name: enumSym,
    visibility: Analyzer::Visibility::PUBLIC,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    variants: Vector::new<Analyzer::DefinitionId>(),
    instanceMethods: Vector::new<Analyzer::DefinitionId>(),
    staticMethods: Vector::new<Analyzer::DefinitionId>(),
    typeId: stubTypeId,
  });
  let varDef: Analyzer::Definition = Analyzer::Definition::Variable(Analyzer::VariableDef {
    name: varSym,
    visibility: Analyzer::Visibility::PRIVATE,
    declaredType: i32Id,
    mutable: false,
  });
  let fieldDef: Analyzer::Definition = Analyzer::Definition::Field(Analyzer::FieldDef {
    name: fieldSym,
    fieldType: i32Id,
    owner: stubDefId,
    index: 0,
  });
  let variantDef: Analyzer::Definition = Analyzer::Definition::Variant(Analyzer::VariantDef {
    name: variantSym,
    payload: Vector::new<Analyzer::TypeId>(),
    owner: stubDefId,
    tagValue: 0,
  });
  let typeParamDef: Analyzer::Definition = Analyzer::Definition::TypeParam(Analyzer::TypeParamDef {
    name: typeParamSym,
    owner: stubDefId,
    index: 0,
  });

  Test::assertEq<u32>(funcDef.name().raw(), funcSym.raw());
  Test::assertEq<u32>(recDef.name().raw(), recSym.raw());
  Test::assertEq<u32>(enumDef.name().raw(), enumSym.raw());
  Test::assertEq<u32>(varDef.name().raw(), varSym.raw());
  Test::assertEq<u32>(fieldDef.name().raw(), fieldSym.raw());
  Test::assertEq<u32>(variantDef.name().raw(), variantSym.raw());
  Test::assertEq<u32>(typeParamDef.name().raw(), typeParamSym.raw());
}

// --- New tests for Phase 1 RED -> GREEN ---

@test
function definitionVisibilityEqualityHolds(): void {
  let pub1: Analyzer::Visibility = Analyzer::Visibility::PUBLIC;
  let pub2: Analyzer::Visibility = Analyzer::Visibility::PUBLIC;
  let priv1: Analyzer::Visibility = Analyzer::Visibility::PRIVATE;
  let priv2: Analyzer::Visibility = Analyzer::Visibility::PRIVATE;

  let pubMatchesPub: boolean = match (pub1) {
    Analyzer::Visibility::PUBLIC -> match (pub2) {
      Analyzer::Visibility::PUBLIC -> true,
      Analyzer::Visibility::PRIVATE -> false,
    },
    Analyzer::Visibility::PRIVATE -> false,
  };

  let pubMatchesPriv: boolean = match (pub1) {
    Analyzer::Visibility::PUBLIC -> match (priv1) {
      Analyzer::Visibility::PUBLIC -> true,
      Analyzer::Visibility::PRIVATE -> false,
    },
    Analyzer::Visibility::PRIVATE -> false,
  };

  let privMatchesPriv: boolean = match (priv1) {
    Analyzer::Visibility::PUBLIC -> false,
    Analyzer::Visibility::PRIVATE -> match (priv2) {
      Analyzer::Visibility::PUBLIC -> false,
      Analyzer::Visibility::PRIVATE -> true,
    },
  };

  Test::assert(pubMatchesPub);
  Test::assert(!pubMatchesPriv);
  Test::assert(privMatchesPriv);
}

@test
function definitionVariableDefRoundTrip(): void {
  let mut table: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let sym: Analyzer::SymbolId = table.intern("myVar");

  let mut types: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let boolId: Analyzer::TypeId = types.intern(Analyzer::Type::BOOLEAN);

  let mut store: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();

  let id: Analyzer::DefinitionId = store.push(Analyzer::Definition::Variable(Analyzer::VariableDef {
    name: sym,
    visibility: Analyzer::Visibility::PRIVATE,
    declaredType: boolId,
    mutable: true,
  }));

  match (store.get(id)) {
    Option::SOME(def) -> match (def) {
      Analyzer::Definition::Function(_)       -> @panic("expected Variable variant"),
      Analyzer::Definition::Record(_)         -> @panic("expected Variable variant"),
      Analyzer::Definition::Enum(_)           -> @panic("expected Variable variant"),
      Analyzer::Definition::Variable(wrapper) -> {
        Test::assertEq<u32>(wrapper.name.raw(), sym.raw());
        Test::assertEq<u32>(wrapper.declaredType.raw(), boolId.raw());
        Test::assert(wrapper.mutable);

        let isPrivate: boolean = match (wrapper.visibility) {
          Analyzer::Visibility::PUBLIC  -> false,
          Analyzer::Visibility::PRIVATE -> true,
        };

        Test::assert(isPrivate);
      },
      Analyzer::Definition::Field(_)          -> @panic("expected Variable variant"),
      Analyzer::Definition::Variant(_)        -> @panic("expected Variable variant"),
      Analyzer::Definition::TypeParam(_)      -> @panic("expected Variable variant"),
    },
    Option::NONE -> @panic("expected Some but got None"),
  };
}

@test
function definitionFieldDefRoundTrip(): void {
  let mut table: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let sym: Analyzer::SymbolId = table.intern("myField");

  let mut types: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let i32Id: Analyzer::TypeId = types.intern(Analyzer::Type::I32);

  let ownerDefId: Analyzer::DefinitionId = Id::fromRaw<Analyzer::DefinitionTag>(99);

  let mut store: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();

  let id: Analyzer::DefinitionId = store.push(Analyzer::Definition::Field(Analyzer::FieldDef {
    name: sym,
    fieldType: i32Id,
    owner: ownerDefId,
    index: 0,
  }));

  match (store.get(id)) {
    Option::SOME(def) -> match (def) {
      Analyzer::Definition::Function(_)    -> @panic("expected Field variant"),
      Analyzer::Definition::Record(_)      -> @panic("expected Field variant"),
      Analyzer::Definition::Enum(_)        -> @panic("expected Field variant"),
      Analyzer::Definition::Variable(_)    -> @panic("expected Field variant"),
      Analyzer::Definition::Field(wrapper) -> {
        Test::assertEq<u32>(wrapper.name.raw(), sym.raw());
        Test::assertEq<u32>(wrapper.fieldType.raw(), i32Id.raw());
        Test::assertEq<u32>(wrapper.owner.raw(), ownerDefId.raw());
        Test::assertEq<u32>(wrapper.index, 0);
      },
      Analyzer::Definition::Variant(_)     -> @panic("expected Field variant"),
      Analyzer::Definition::TypeParam(_)   -> @panic("expected Field variant"),
    },
    Option::NONE -> @panic("expected Some but got None"),
  };
}

@test
function definitionVariantDefRoundTripWithPayload(): void {
  let mut table: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let sym: Analyzer::SymbolId = table.intern("SomeVariant");

  let mut types: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let i32Id: Analyzer::TypeId = types.intern(Analyzer::Type::I32);

  let ownerDefId: Analyzer::DefinitionId = Id::fromRaw<Analyzer::DefinitionTag>(99);

  let mut payload: Vector<Analyzer::TypeId> = Vector::new<Analyzer::TypeId>();
  payload.push(i32Id);

  let mut store: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();

  let id: Analyzer::DefinitionId = store.push(Analyzer::Definition::Variant(Analyzer::VariantDef {
    name: sym,
    payload: payload,
    owner: ownerDefId,
    tagValue: 1,
  }));

  match (store.get(id)) {
    Option::SOME(def) -> match (def) {
      Analyzer::Definition::Function(_)       -> @panic("expected Variant variant"),
      Analyzer::Definition::Record(_)         -> @panic("expected Variant variant"),
      Analyzer::Definition::Enum(_)           -> @panic("expected Variant variant"),
      Analyzer::Definition::Variable(_)       -> @panic("expected Variant variant"),
      Analyzer::Definition::Field(_)          -> @panic("expected Variant variant"),
      Analyzer::Definition::Variant(wrapper)  -> {
        Test::assertEq<u64>(wrapper.payload.length(), 1);
        Test::assertEq<u32>(wrapper.tagValue, 1);
      },
      Analyzer::Definition::TypeParam(_)      -> @panic("expected Variant variant"),
    },
    Option::NONE -> @panic("expected Some but got None"),
  };
}

