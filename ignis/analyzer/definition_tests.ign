    visibility: Analyzer::Visibility::PUBLIC,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    variants: Vector::new<Analyzer::DefinitionId>(),
    instanceMethods: instanceMethods,
    staticMethods: Vector::new<Analyzer::DefinitionId>(),
    typeId: voidId,
  }));

  match (store.get(enumId)) {
    Option::SOME(def) -> match (def) {
      Analyzer::Definition::Enum(enum_) -> {
        Test::assertEq<u64>(enum_.instanceMethods.length(), 1);
        Test::assertEq<u64>(enum_.staticMethods.length(), 0);
        let Option::SOME(instanceId) = enum_.instanceMethods.get(0) else {
          @panic("expected instance method id");
        };
        Test::assertEq<u32>(instanceId.raw(), instanceMethodId.raw());
      },
      Analyzer::Definition::Function(_)   -> @panic("expected Enum variant"),
      Analyzer::Definition::Record(_)     -> @panic("expected Enum variant"),
      Analyzer::Definition::Variable(_)   -> @panic("expected Enum variant"),
      Analyzer::Definition::Field(_)      -> @panic("expected Enum variant"),
      Analyzer::Definition::Variant(_)    -> @panic("expected Enum variant"),
      Analyzer::Definition::TypeParam(_)  -> @panic("expected Enum variant"),
      Analyzer::Definition::TypeAlias(_)  -> @panic("expected Enum variant"),
      Analyzer::Definition::Trait(_)      -> @panic("expected Enum variant"),
      Analyzer::Definition::Method(_)     -> @panic("expected Enum variant"),
    },
    Option::NONE -> @panic("expected Some after push"),
  };
}
