@test
function recordDefHoldsOwnerMethodTables(): void {
  let mut syms: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut types: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let voidId: Analyzer::TypeId = types.intern(Analyzer::Type::VOID);
  let recSym: Analyzer::SymbolId = syms.intern("Shape");
  let methodName: Analyzer::SymbolId = syms.intern("area");
  let staticName: Analyzer::SymbolId = syms.intern("unit");

  let mut store: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();

  let instanceMethodId: Analyzer::DefinitionId = store.push(Analyzer::Definition::Method(Analyzer::MethodDef {
    name: methodName,
    visibility: Analyzer::Visibility::PUBLIC,
    owner: Id::fromRaw<Analyzer::DefinitionTag>(0),
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    params: Vector::new<Analyzer::DefinitionId>(),
    returnType: voidId,
    isStatic: false,
    selfMutable: false,
  }));
  let staticMethodId: Analyzer::DefinitionId = store.push(Analyzer::Definition::Method(Analyzer::MethodDef {
    name: staticName,
    visibility: Analyzer::Visibility::PUBLIC,
    owner: Id::fromRaw<Analyzer::DefinitionTag>(0),
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    params: Vector::new<Analyzer::DefinitionId>(),
    returnType: voidId,
    isStatic: true,
    selfMutable: false,
  }));

  let mut instanceMethods: Vector<Analyzer::DefinitionId> = Vector::new<Analyzer::DefinitionId>();
  instanceMethods.push(instanceMethodId);
  let mut staticMethods: Vector<Analyzer::DefinitionId> = Vector::new<Analyzer::DefinitionId>();
  staticMethods.push(staticMethodId);

  let recId: Analyzer::DefinitionId = store.push(Analyzer::Definition::Record(Analyzer::RecordDef {
    name: recSym,
    visibility: Analyzer::Visibility::PUBLIC,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    fields: Vector::new<Analyzer::DefinitionId>(),
    instanceMethods: instanceMethods,
    staticMethods: staticMethods,
    typeId: voidId,
  }));

  match (store.get(recId)) {
    Option::SOME(def) -> match (def) {
      Analyzer::Definition::Record(recDef) -> {
        Test::assertEq<u64>(recDef.instanceMethods.length(), 1);
        Test::assertEq<u64>(recDef.staticMethods.length(), 1);
        let Option::SOME(instanceId) = recDef.instanceMethods.get(0) else {
          @panic("expected instance method id");
        };
        Test::assertEq<u32>(instanceId.raw(), instanceMethodId.raw());
        let Option::SOME(staticId) = recDef.staticMethods.get(0) else {
          @panic("expected static method id");
        };
        Test::assertEq<u32>(staticId.raw(), staticMethodId.raw());
      },
      Analyzer::Definition::Function(_)   -> @panic("expected Record variant"),
      Analyzer::Definition::Enum(_)       -> @panic("expected Record variant"),
      Analyzer::Definition::Variable(_)   -> @panic("expected Record variant"),
      Analyzer::Definition::Field(_)      -> @panic("expected Record variant"),
      Analyzer::Definition::Variant(_)    -> @panic("expected Record variant"),
      Analyzer::Definition::TypeParam(_)  -> @panic("expected Record variant"),
      Analyzer::Definition::TypeAlias(_)  -> @panic("expected Record variant"),
      Analyzer::Definition::Trait(_)      -> @panic("expected Record variant"),
      Analyzer::Definition::Method(_)     -> @panic("expected Record variant"),
    },
    Option::NONE -> @panic("expected Some after push"),
  };
}

