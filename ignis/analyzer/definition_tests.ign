@test
function methodDefRoundTrip(): void {
  let mut syms: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut types: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let voidId: Analyzer::TypeId = types.intern(Analyzer::Type::VOID);
  let i32Id: Analyzer::TypeId = types.intern(Analyzer::Type::I32);
  let nameSym: Analyzer::SymbolId = syms.intern("area");
  let ownerSym: Analyzer::SymbolId = syms.intern("Rect");

  let mut store: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();

  // Owner record placeholder so the method has a real owner id to reference.
  let ownerId: Analyzer::DefinitionId = store.push(Analyzer::Definition::Record(Analyzer::RecordDef {
    name: ownerSym,
    visibility: Analyzer::Visibility::PUBLIC,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    fields: Vector::new<Analyzer::DefinitionId>(),
    instanceMethods: Vector::new<Analyzer::DefinitionId>(),
    staticMethods: Vector::new<Analyzer::DefinitionId>(),
    typeId: voidId,
  }));

  let defId: Analyzer::DefinitionId = store.push(Analyzer::Definition::Method(Analyzer::MethodDef {
    name: nameSym,
    visibility: Analyzer::Visibility::PUBLIC,
    owner: ownerId,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    params: Vector::new<Analyzer::DefinitionId>(),
    returnType: i32Id,
    isStatic: false,
    selfMutable: false,
  }));

  match (store.get(defId)) {
    Option::SOME(def) -> match (def) {
      Analyzer::Definition::Method(method) -> {
        Test::assertEq<u32>(method.name.raw(), nameSym.raw());
        Test::assertEq<boolean>(method.visibility.equals(&Analyzer::Visibility::PUBLIC), true);
        Test::assertEq<u32>(method.owner.raw(), ownerId.raw());
        Test::assertEq<u64>(method.typeParams.length(), 0);
        Test::assertEq<u64>(method.params.length(), 0);
        Test::assertEq<u32>(method.returnType.raw(), i32Id.raw());
        Test::assertEq<boolean>(method.isStatic, false);
        Test::assertEq<boolean>(method.selfMutable, false);
      },
      Analyzer::Definition::Function(_)    -> @panic("expected Method variant"),
      Analyzer::Definition::Record(_)       -> @panic("expected Method variant"),
      Analyzer::Definition::Enum(_)         -> @panic("expected Method variant"),
      Analyzer::Definition::Variable(_)     -> @panic("expected Method variant"),
      Analyzer::Definition::Field(_)        -> @panic("expected Method variant"),
      Analyzer::Definition::Variant(_)      -> @panic("expected Method variant"),
      Analyzer::Definition::TypeParam(_)    -> @panic("expected Method variant"),
      Analyzer::Definition::TypeAlias(_)    -> @panic("expected Method variant"),
      Analyzer::Definition::Trait(_)        -> @panic("expected Method variant"),
    },
    Option::NONE -> @panic("expected Some after push"),
  };
}

@test
function methodDefStaticFlagDistinguishesInstanceFromStatic(): void {
  let mut syms: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut types: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let voidId: Analyzer::TypeId = types.intern(Analyzer::Type::VOID);
  let i32Id: Analyzer::TypeId = types.intern(Analyzer::Type::I32);
  let instanceName: Analyzer::SymbolId = syms.intern("getX");
  let staticName: Analyzer::SymbolId = syms.intern("origin");
  let ownerSym: Analyzer::SymbolId = syms.intern("Point");

  let mut store: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let ownerId: Analyzer::DefinitionId = store.push(Analyzer::Definition::Record(Analyzer::RecordDef {
    name: ownerSym,
    visibility: Analyzer::Visibility::PUBLIC,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    fields: Vector::new<Analyzer::DefinitionId>(),
    instanceMethods: Vector::new<Analyzer::DefinitionId>(),
    staticMethods: Vector::new<Analyzer::DefinitionId>(),
    typeId: voidId,
  }));

  let instanceId: Analyzer::DefinitionId = store.push(Analyzer::Definition::Method(Analyzer::MethodDef {
    name: instanceName,
    visibility: Analyzer::Visibility::PUBLIC,
    owner: ownerId,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    params: Vector::new<Analyzer::DefinitionId>(),
    returnType: i32Id,
    isStatic: false,
    selfMutable: true,
  }));
  let staticId: Analyzer::DefinitionId = store.push(Analyzer::Definition::Method(Analyzer::MethodDef {
    name: staticName,
    visibility: Analyzer::Visibility::PUBLIC,
    owner: ownerId,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    params: Vector::new<Analyzer::DefinitionId>(),
    returnType: voidId,
    isStatic: true,
    selfMutable: false,
  }));

  let Option::SOME(instanceDef) = store.get(instanceId) else {
    @panic("expected instance method");
  };
  let Option::SOME(staticDef) = store.get(staticId) else {
    @panic("expected static method");
  };
  match (instanceDef) {
    Analyzer::Definition::Method(instanceMethod) -> {
      Test::assertEq<boolean>(instanceMethod.isStatic, false);
      Test::assertEq<boolean>(instanceMethod.selfMutable, true);
    },
    Analyzer::Definition::Function(_)    -> @panic("expected Method variant for instance"),
    Analyzer::Definition::Record(_)       -> @panic("expected Method variant for instance"),
    Analyzer::Definition::Enum(_)         -> @panic("expected Method variant for instance"),
    Analyzer::Definition::Variable(_)     -> @panic("expected Method variant for instance"),
    Analyzer::Definition::Field(_)        -> @panic("expected Method variant for instance"),
    Analyzer::Definition::Variant(_)      -> @panic("expected Method variant for instance"),
    Analyzer::Definition::TypeParam(_)    -> @panic("expected Method variant for instance"),
    Analyzer::Definition::TypeAlias(_)    -> @panic("expected Method variant for instance"),
    Analyzer::Definition::Trait(_)        -> @panic("expected Method variant for instance"),
  };
  match (staticDef) {
    Analyzer::Definition::Method(staticMethod) -> {
      Test::assertEq<boolean>(staticMethod.isStatic, true);
      Test::assertEq<boolean>(staticMethod.selfMutable, false);
      Test::assertEq<u32>(staticMethod.returnType.raw(), voidId.raw());
    },
    Analyzer::Definition::Function(_)    -> @panic("expected Method variant for static"),
    Analyzer::Definition::Record(_)       -> @panic("expected Method variant for static"),
    Analyzer::Definition::Enum(_)         -> @panic("expected Method variant for static"),
    Analyzer::Definition::Variable(_)     -> @panic("expected Method variant for static"),
    Analyzer::Definition::Field(_)        -> @panic("expected Method variant for static"),
    Analyzer::Definition::Variant(_)      -> @panic("expected Method variant for static"),
    Analyzer::Definition::TypeParam(_)    -> @panic("expected Method variant for static"),
    Analyzer::Definition::TypeAlias(_)    -> @panic("expected Method variant for static"),
    Analyzer::Definition::Trait(_)        -> @panic("expected Method variant for static"),
  };
}

