@test
function definitionFunctionDefRoundTrip(): void {
  let mut table: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let funcSym: Analyzer::SymbolId = table.intern("myFunc");
  let paramSym: Analyzer::SymbolId = table.intern("myParam");

  let mut types: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let voidId: Analyzer::TypeId = types.intern(Analyzer::Type::VOID);
  let i32Id: Analyzer::TypeId = types.intern(Analyzer::Type::I32);

  let mut store: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();

  // Push the parameter VariableDef first so we can reference it from FunctionDef.
  let paramDefId: Analyzer::DefinitionId = store.push(Analyzer::Definition::Variable(Analyzer::VariableDef {
    name: paramSym,
    visibility: Analyzer::Visibility::PRIVATE,
    declaredType: i32Id,
    mutable: false,
  }));

  let mut params: Vector<Analyzer::DefinitionId> = Vector::new<Analyzer::DefinitionId>();
  params.push(paramDefId);

  let id: Analyzer::DefinitionId = store.push(Analyzer::Definition::Function(Analyzer::FunctionDef {
    name: funcSym,
    visibility: Analyzer::Visibility::PUBLIC,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    params: params,
    returnType: voidId,
  }));

  match (store.get(id)) {
    Option::SOME(def) -> match (def) {
      Analyzer::Definition::Function(wrapper)  -> {
        Test::assertEq<u32>(wrapper.name.raw(), funcSym.raw());
        Test::assertEq<u32>(wrapper.returnType.raw(), voidId.raw());
        Test::assertEq<u64>(wrapper.params.length(), 1);
        Test::assertEq<u64>(wrapper.typeParams.length(), 0);

        let isPublic: boolean = match (wrapper.visibility) {
          Analyzer::Visibility::PUBLIC  -> true,
          Analyzer::Visibility::PRIVATE -> false,
        };

        Test::assert(isPublic);
      },
      Analyzer::Definition::Record(_)          -> @panic("expected Function variant"),
      Analyzer::Definition::Enum(_)            -> @panic("expected Function variant"),
      Analyzer::Definition::Variable(_)        -> @panic("expected Function variant"),
      Analyzer::Definition::Field(_)           -> @panic("expected Function variant"),
      Analyzer::Definition::Variant(_)         -> @panic("expected Function variant"),
      Analyzer::Definition::TypeParam(_)       -> @panic("expected Function variant"),
    },
    Option::NONE -> @panic("expected Some but got None"),
  };
}

@test
function definitionRecordDefRoundTrip(): void {
  let mut table: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let recSym: Analyzer::SymbolId = table.intern("MyRecord");
  let f0Sym: Analyzer::SymbolId = table.intern("field0");
  let f1Sym: Analyzer::SymbolId = table.intern("field1");

  let mut types: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let i32Id: Analyzer::TypeId = types.intern(Analyzer::Type::I32);
  let stubTypeId: Analyzer::TypeId = types.intern(Analyzer::Type::I32);

  // Placeholder owner for fields (the record's future id — use stub since fields are pushed first).
  let stubOwner: Analyzer::DefinitionId = Id::fromRaw<Analyzer::DefinitionTag>(99);

  let mut store: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();

  let fid0: Analyzer::DefinitionId = store.push(Analyzer::Definition::Field(Analyzer::FieldDef {
    name: f0Sym,
    fieldType: i32Id,
    owner: stubOwner,
    index: 0,
  }));
  let fid1: Analyzer::DefinitionId = store.push(Analyzer::Definition::Field(Analyzer::FieldDef {
    name: f1Sym,
    fieldType: i32Id,
    owner: stubOwner,
    index: 1,
  }));

  let mut fields: Vector<Analyzer::DefinitionId> = Vector::new<Analyzer::DefinitionId>();
  fields.push(fid0);
  fields.push(fid1);

  let id: Analyzer::DefinitionId = store.push(Analyzer::Definition::Record(Analyzer::RecordDef {
    name: recSym,
    visibility: Analyzer::Visibility::PRIVATE,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    fields: fields,
    instanceMethods: Vector::new<Analyzer::DefinitionId>(),
    staticMethods: Vector::new<Analyzer::DefinitionId>(),
    typeId: stubTypeId,
  }));

  match (store.get(id)) {
    Option::SOME(def) -> match (def) {
      Analyzer::Definition::Function(_)        -> @panic("expected Record variant"),
      Analyzer::Definition::Record(wrapper)    -> {
        Test::assertEq<u64>(wrapper.fields.length(), 2);

        match (wrapper.fields.get(0)) {
          Option::SOME(gotFid0) -> Test::assertEq<u32>(gotFid0.raw(), fid0.raw()),
          Option::NONE -> @panic("expected fields[0] to be Some"),
        };

        match (wrapper.fields.get(1)) {
          Option::SOME(gotFid1) -> Test::assertEq<u32>(gotFid1.raw(), fid1.raw()),
          Option::NONE -> @panic("expected fields[1] to be Some"),
        };

        let isPrivate: boolean = match (wrapper.visibility) {
          Analyzer::Visibility::PUBLIC  -> false,
          Analyzer::Visibility::PRIVATE -> true,
        };

        Test::assert(isPrivate);
      },
      Analyzer::Definition::Enum(_)            -> @panic("expected Record variant"),
      Analyzer::Definition::Variable(_)        -> @panic("expected Record variant"),
      Analyzer::Definition::Field(_)           -> @panic("expected Record variant"),
      Analyzer::Definition::Variant(_)         -> @panic("expected Record variant"),
      Analyzer::Definition::TypeParam(_)       -> @panic("expected Record variant"),
    },
    Option::NONE -> @panic("expected Some but got None"),
  };
}

@test
function definitionEnumDefRoundTrip(): void {
  let mut table: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let enumSym: Analyzer::SymbolId = table.intern("MyEnum");
  let v0Sym: Analyzer::SymbolId = table.intern("Variant0");
  let v1Sym: Analyzer::SymbolId = table.intern("Variant1");

  let stubTypeId: Analyzer::TypeId = Id::fromRaw<Analyzer::TypeTag>(0);
  let stubOwner: Analyzer::DefinitionId = Id::fromRaw<Analyzer::DefinitionTag>(99);

  let mut store: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();

  let vid0: Analyzer::DefinitionId = store.push(Analyzer::Definition::Variant(Analyzer::VariantDef {
    name: v0Sym,
    payload: Vector::new<Analyzer::TypeId>(),
    owner: stubOwner,
    tagValue: 0,
  }));
  let vid1: Analyzer::DefinitionId = store.push(Analyzer::Definition::Variant(Analyzer::VariantDef {
    name: v1Sym,
    payload: Vector::new<Analyzer::TypeId>(),
    owner: stubOwner,
    tagValue: 1,
  }));

  let mut variants: Vector<Analyzer::DefinitionId> = Vector::new<Analyzer::DefinitionId>();
  variants.push(vid0);
  variants.push(vid1);

  let id: Analyzer::DefinitionId = store.push(Analyzer::Definition::Enum(Analyzer::EnumDef {
    name: enumSym,
    visibility: Analyzer::Visibility::PUBLIC,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    variants: variants,
    instanceMethods: Vector::new<Analyzer::DefinitionId>(),
    staticMethods: Vector::new<Analyzer::DefinitionId>(),
    typeId: stubTypeId,
  }));

  match (store.get(id)) {
    Option::SOME(def) -> match (def) {
      Analyzer::Definition::Function(_)      -> @panic("expected Enum variant"),
      Analyzer::Definition::Record(_)        -> @panic("expected Enum variant"),
      Analyzer::Definition::Enum(wrapper)    -> {
        Test::assertEq<u64>(wrapper.variants.length(), 2);

        match (wrapper.variants.get(0)) {
          Option::SOME(gotVid0) -> Test::assertEq<u32>(gotVid0.raw(), vid0.raw()),
          Option::NONE -> @panic("expected variants[0] to be Some"),
        };

        match (wrapper.variants.get(1)) {
          Option::SOME(gotVid1) -> Test::assertEq<u32>(gotVid1.raw(), vid1.raw()),
          Option::NONE -> @panic("expected variants[1] to be Some"),
        };
      },
      Analyzer::Definition::Variable(_)      -> @panic("expected Enum variant"),
      Analyzer::Definition::Field(_)         -> @panic("expected Enum variant"),
      Analyzer::Definition::Variant(_)       -> @panic("expected Enum variant"),
      Analyzer::Definition::TypeParam(_)     -> @panic("expected Enum variant"),
    },
    Option::NONE -> @panic("expected Some but got None"),
  };
}

@test
function definitionSubDefFromParentRetrieval(): void {
  let mut table: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let recSym: Analyzer::SymbolId = table.intern("Container");
  let f0Sym: Analyzer::SymbolId = table.intern("alpha");
  let f1Sym: Analyzer::SymbolId = table.intern("beta");

  let mut types: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let i32Id: Analyzer::TypeId = types.intern(Analyzer::Type::I32);
  let stubTypeId: Analyzer::TypeId = types.intern(Analyzer::Type::I32);

  let stubOwner: Analyzer::DefinitionId = Id::fromRaw<Analyzer::DefinitionTag>(99);

  let mut store: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();

  let fid0: Analyzer::DefinitionId = store.push(Analyzer::Definition::Field(Analyzer::FieldDef {
    name: f0Sym,
    fieldType: i32Id,
    owner: stubOwner,
    index: 0,
  }));
  let fid1: Analyzer::DefinitionId = store.push(Analyzer::Definition::Field(Analyzer::FieldDef {
    name: f1Sym,
    fieldType: i32Id,
    owner: stubOwner,
    index: 1,
  }));

  let mut fields: Vector<Analyzer::DefinitionId> = Vector::new<Analyzer::DefinitionId>();
  fields.push(fid0);
  fields.push(fid1);

  store.push(Analyzer::Definition::Record(Analyzer::RecordDef {
    name: recSym,
    visibility: Analyzer::Visibility::PUBLIC,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    fields: fields,
    instanceMethods: Vector::new<Analyzer::DefinitionId>(),
    staticMethods: Vector::new<Analyzer::DefinitionId>(),
    typeId: stubTypeId,
  }));

  // Sub-defs must be retrievable independently via their own DefinitionIds.
  match (store.get(fid0)) {
    Option::SOME(def) -> match (def) {
      Analyzer::Definition::Function(_)    -> @panic("expected Field variant for fid0"),
      Analyzer::Definition::Record(_)      -> @panic("expected Field variant for fid0"),
      Analyzer::Definition::Enum(_)        -> @panic("expected Field variant for fid0"),
      Analyzer::Definition::Variable(_)    -> @panic("expected Field variant for fid0"),
      Analyzer::Definition::Field(wrapper) -> Test::assertEq<u32>(wrapper.name.raw(), f0Sym.raw()),
      Analyzer::Definition::Variant(_)     -> @panic("expected Field variant for fid0"),
      Analyzer::Definition::TypeParam(_)   -> @panic("expected Field variant for fid0"),
    },
    Option::NONE -> @panic("expected Some for fid0 but got None"),
  };

  match (store.get(fid1)) {
    Option::SOME(def) -> match (def) {
      Analyzer::Definition::Function(_)    -> @panic("expected Field variant for fid1"),
      Analyzer::Definition::Record(_)      -> @panic("expected Field variant for fid1"),
      Analyzer::Definition::Enum(_)        -> @panic("expected Field variant for fid1"),
      Analyzer::Definition::Variable(_)    -> @panic("expected Field variant for fid1"),
      Analyzer::Definition::Field(wrapper) -> Test::assertEq<u32>(wrapper.name.raw(), f1Sym.raw()),
      Analyzer::Definition::Variant(_)     -> @panic("expected Field variant for fid1"),
      Analyzer::Definition::TypeParam(_)   -> @panic("expected Field variant for fid1"),
    },
    Option::NONE -> @panic("expected Some for fid1 but got None"),
  };
}

@test
function definitionLengthAfterMixedVariants(): void {
  let mut table: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let sym: Analyzer::SymbolId = table.intern("x");

  let mut types: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let i32Id: Analyzer::TypeId = types.intern(Analyzer::Type::I32);
  let voidId: Analyzer::TypeId = types.intern(Analyzer::Type::VOID);

  let stubOwner: Analyzer::DefinitionId = Id::fromRaw<Analyzer::DefinitionTag>(99);

  let mut store: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();

  // Push 3 FieldDefs.
  store.push(Analyzer::Definition::Field(Analyzer::FieldDef {
    name: sym,
    fieldType: i32Id,
    owner: stubOwner,
    index: 0,
  }));
  store.push(Analyzer::Definition::Field(Analyzer::FieldDef {
    name: sym,
    fieldType: i32Id,
    owner: stubOwner,
    index: 1,
  }));
  store.push(Analyzer::Definition::Field(Analyzer::FieldDef {
    name: sym,
    fieldType: i32Id,
    owner: stubOwner,
    index: 2,
  }));

  // Push 2 VariantDefs.
  store.push(Analyzer::Definition::Variant(Analyzer::VariantDef {
    name: sym,
    payload: Vector::new<Analyzer::TypeId>(),
    owner: stubOwner,
    tagValue: 0,
  }));
  store.push(Analyzer::Definition::Variant(Analyzer::VariantDef {
    name: sym,
    payload: Vector::new<Analyzer::TypeId>(),
    owner: stubOwner,
    tagValue: 1,
  }));

  // Push 1 FunctionDef.
  store.push(Analyzer::Definition::Function(Analyzer::FunctionDef {
    name: sym,
    visibility: Analyzer::Visibility::PUBLIC,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    params: Vector::new<Analyzer::DefinitionId>(),
    returnType: voidId,
  }));

  Test::assertEq<u64>(store.length(), 6);
}

