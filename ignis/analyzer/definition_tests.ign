@test
function typeAliasDefRoundTrip(): void {
  let mut syms: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut types: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let voidId: Analyzer::TypeId = types.intern(Analyzer::Type::VOID);
  let nameSym: Analyzer::SymbolId = syms.intern("MyInt");

  let mut store: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();

  let defId: Analyzer::DefinitionId = store.push(Analyzer::Definition::TypeAlias(Analyzer::TypeAliasDef {
    name: nameSym,
    visibility: Analyzer::Visibility::PUBLIC,
    typeParams: Vector::new<Analyzer::DefinitionId>(),
    aliasedType: voidId,
    typeId: voidId,
  }));

  match (store.get(defId)) {
    Option::SOME(def) -> match (def) {
      Analyzer::Definition::TypeAlias(alias) -> {
        Test::assertEq<u32>(alias.name.raw(), nameSym.raw());
        Test::assertEq<u64>(alias.typeParams.length(), 0);
        Test::assertEq<u32>(alias.aliasedType.raw(), voidId.raw());
        Test::assertEq<u32>(alias.typeId.raw(), voidId.raw());
      },
      Analyzer::Definition::Record(_) -> @panic("expected TypeAlias"),
      Analyzer::Definition::Enum(_) -> @panic("expected TypeAlias"),
      Analyzer::Definition::Function(_) -> @panic("expected TypeAlias"),
      Analyzer::Definition::Variable(_) -> @panic("expected TypeAlias"),
      Analyzer::Definition::Field(_) -> @panic("expected TypeAlias"),
      Analyzer::Definition::Variant(_) -> @panic("expected TypeAlias"),
      Analyzer::Definition::TypeParam(_) -> @panic("expected TypeAlias"),
      Analyzer::Definition::Trait(_) -> @panic("expected TypeAlias"),
    },
    Option::NONE -> @panic("expected Some after push"),
  };
}

