@test
function recordRoundTripPreservesDefinitionId(): void {
  let mut store: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let defId: Analyzer::DefinitionId = Id::fromRaw<Analyzer::DefinitionTag>(99);

  let id: Analyzer::TypeId = store.recordType(defId);

  match (store.get(id)) {
    Option::NONE -> @panic("expected SOME for record type id"),
    Option::SOME(type_) -> match (type_) {
      Analyzer::Type::I8 -> @panic("expected Record variant"),
      Analyzer::Type::I16 -> @panic("expected Record variant"),
      Analyzer::Type::I32 -> @panic("expected Record variant"),
      Analyzer::Type::I64 -> @panic("expected Record variant"),
      Analyzer::Type::U8 -> @panic("expected Record variant"),
      Analyzer::Type::U16 -> @panic("expected Record variant"),
      Analyzer::Type::U32 -> @panic("expected Record variant"),
      Analyzer::Type::U64 -> @panic("expected Record variant"),
      Analyzer::Type::F32 -> @panic("expected Record variant"),
      Analyzer::Type::F64 -> @panic("expected Record variant"),
      Analyzer::Type::BOOLEAN -> @panic("expected Record variant"),
      Analyzer::Type::CHAR -> @panic("expected Record variant"),
      Analyzer::Type::STR -> @panic("expected Record variant"),
      Analyzer::Type::VOID -> @panic("expected Record variant"),
      Analyzer::Type::NEVER -> @panic("expected Record variant"),
      Analyzer::Type::Pointer(_) -> @panic("expected Record variant"),
      Analyzer::Type::Reference(_) -> @panic("expected Record variant"),
      Analyzer::Type::Slice(_) -> @panic("expected Record variant"),
      Analyzer::Type::FixedArray(_, _) -> @panic("expected Record variant"),
      Analyzer::Type::Tuple(_) -> @panic("expected Record variant"),
      Analyzer::Type::Function(_) -> @panic("expected Record variant"),
      Analyzer::Type::Record(d) -> Test::assertEq<u32>(d.raw(), 99),
      Analyzer::Type::Enum(_) -> @panic("expected Record variant"),
      Analyzer::Type::Param(_) -> @panic("expected Record variant"),
      Analyzer::Type::Instance(_) -> @panic("expected Record variant"),
    },
  };
}

