@test
function compoundTypeNameOfMultiElementTupleWithCompoundInside(): void {
  let mut store: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let idI32: Analyzer::TypeId = store.intern(Analyzer::Type::I32);
  let idStr: Analyzer::TypeId = store.intern(Analyzer::Type::STR);
  let ptrStr: Analyzer::TypeId = store.pointer(idStr);

  let mut elements: Vector<Analyzer::TypeId> = Vector::new<Analyzer::TypeId>();
  elements.push(idI32);
  elements.push(ptrStr);
  let tupleId: Analyzer::TypeId = store.tuple(elements);

  Test::assertEq<str>(store.nameOf(tupleId).toStr(), "(i32, *str)");
}

@test
function equalsTrueForIdenticalFunctionSignatures(): void {
  let idZero: Analyzer::TypeId = Id::fromRaw<Analyzer::TypeTag>(0);

  let ft1: Analyzer::FunctionType = Analyzer::FunctionType { params: Vector::new<Analyzer::TypeId>(), returnType: idZero };
  let ft2: Analyzer::FunctionType = Analyzer::FunctionType { params: Vector::new<Analyzer::TypeId>(), returnType: idZero };

  let type1: Analyzer::Type = Analyzer::Type::Function(ft1);
  let type2: Analyzer::Type = Analyzer::Type::Function(ft2);

  Test::assert(type1.equals(&type2));
}

@test
function functionInterningIsIdempotentForEmptyParams(): void {
  let mut store: Analyzer::TypeStore = Analyzer::TypeStore::init();
