@test
function functionDistinctFromTupleWithSameElements(): void {
  let mut store: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let idI32: Analyzer::TypeId = store.intern(Analyzer::Type::I32);
  let voidId: Analyzer::TypeId = store.intern(Analyzer::Type::VOID);

  let mut tupleElements: Vector<Analyzer::TypeId> = Vector::new<Analyzer::TypeId>();
  tupleElements.push(idI32);
  let tupleId: Analyzer::TypeId = store.tuple(tupleElements);

  let mut fnParams: Vector<Analyzer::TypeId> = Vector::new<Analyzer::TypeId>();
  fnParams.push(idI32);
  let fnId: Analyzer::TypeId = store.functionType(fnParams, voidId);

  Test::assert(tupleId.raw() != fnId.raw());
}

