@test
function nominalTypeIsNotEqualToStructuralType(): void {
  let mut store: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let defId: Analyzer::DefinitionId = Id::fromRaw<Analyzer::DefinitionTag>(0);
  let idI32: Analyzer::TypeId = store.intern(Analyzer::Type::I32);

  let mut elements: Vector<Analyzer::TypeId> = Vector::new<Analyzer::TypeId>();
  elements.push(idI32);

  store.recordType(defId);
  let tupId: Analyzer::TypeId = store.tuple(elements);

  let recType: Analyzer::Type = Analyzer::Type::Record(defId);

  match (store.get(tupId)) {
    Option::NONE -> @panic("expected tuple type"),
    Option::SOME(t) -> Test::assert(!recType.equals(t)),
  };
}

