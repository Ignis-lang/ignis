  let first: Analyzer::TypeId = store.functionType(Vector::new<Analyzer::TypeId>(), voidId);

  let lengthAfterFirst: u64 = store.length();

  let second: Analyzer::TypeId = store.functionType(Vector::new<Analyzer::TypeId>(), voidId);

  Test::assertEq<u32>(first.raw(), second.raw());
  Test::assertEq<u64>(store.length(), lengthAfterFirst);
}

