  let idStr: Analyzer::TypeId = store.intern(Analyzer::Type::STR);

  let ptrI32: Analyzer::TypeId = store.pointer(idI32);
  let sliceStr: Analyzer::TypeId = store.slice(idStr);

  let mut params: Vector<Analyzer::TypeId> = Vector::new<Analyzer::TypeId>();
  params.push(ptrI32);
  let fId: Analyzer::TypeId = store.functionType(params, sliceStr);

  Test::assertEq<str>(store.nameOf(fId).toStr(), "fn(*i32) -> str[]");
}

@test
function compoundTypeNameOfHigherOrderFunction(): void {
  let mut store: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let idI32: Analyzer::TypeId = store.intern(Analyzer::Type::I32);

  let inner: Analyzer::TypeId = store.functionType(Vector::new<Analyzer::TypeId>(), idI32);
  let outer: Analyzer::TypeId = store.functionType(Vector::new<Analyzer::TypeId>(), inner);

  Test::assertEq<str>(store.nameOf(outer).toStr(), "fn() -> fn() -> i32");
}

@test
function equalsFalseForFunctionVsTuple(): void {
  let idZero: Analyzer::TypeId = Id::fromRaw<Analyzer::TypeTag>(0);

  let ft: Analyzer::FunctionType = Analyzer::FunctionType { params: Vector::new<Analyzer::TypeId>(), returnType: idZero };
  let tt: Analyzer::TupleType = Analyzer::TupleType { elements: Vector::new<Analyzer::TypeId>() };

  let fnType: Analyzer::Type = Analyzer::Type::Function(ft);
  let tupleType: Analyzer::Type = Analyzer::Type::Tuple(tt);

  Test::assert(!fnType.equals(&tupleType));
  Test::assert(!tupleType.equals(&fnType));
}

@test
function equalsFalseForFunctionWithDifferentReturnTypes(): void {
  let idZero: Analyzer::TypeId = Id::fromRaw<Analyzer::TypeTag>(0);
  let idOne: Analyzer::TypeId = Id::fromRaw<Analyzer::TypeTag>(1);

  let ft1: Analyzer::FunctionType = Analyzer::FunctionType { params: Vector::new<Analyzer::TypeId>(), returnType: idZero };
  let ft2: Analyzer::FunctionType = Analyzer::FunctionType { params: Vector::new<Analyzer::TypeId>(), returnType: idOne };

  let type1: Analyzer::Type = Analyzer::Type::Function(ft1);
  let type2: Analyzer::Type = Analyzer::Type::Function(ft2);

  Test::assert(!type1.equals(&type2));
}

@test
