@test
function nameOfRecordReturnsPlaceholder(): void {
  let mut store: Analyzer::TypeStore = Analyzer::TypeStore::init();

  let defId0: Analyzer::DefinitionId = Id::fromRaw<Analyzer::DefinitionTag>(0);
