@test
function instanceRoundTripPreservesDefinitionAndArgs(): void {
  let mut store: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let defId: Analyzer::DefinitionId = Id::fromRaw<Analyzer::DefinitionTag>(77);
  let idI32: Analyzer::TypeId = store.intern(Analyzer::Type::I32);
  let idStr: Analyzer::TypeId = store.intern(Analyzer::Type::STR);

  let mut args: Vector<Analyzer::TypeId> = Vector::new<Analyzer::TypeId>();
  args.push(idI32);
  args.push(idStr);
  let id: Analyzer::TypeId = store.instance(defId, args);

  match (store.get(id)) {
    Option::NONE -> @panic("expected SOME for instance type id"),
    Option::SOME(type_) -> match (type_) {
      Analyzer::Type::I8 -> @panic("expected Instance variant"),
      Analyzer::Type::I16 -> @panic("expected Instance variant"),
      Analyzer::Type::I32 -> @panic("expected Instance variant"),
      Analyzer::Type::I64 -> @panic("expected Instance variant"),
      Analyzer::Type::U8 -> @panic("expected Instance variant"),
      Analyzer::Type::U16 -> @panic("expected Instance variant"),
      Analyzer::Type::U32 -> @panic("expected Instance variant"),
      Analyzer::Type::U64 -> @panic("expected Instance variant"),
      Analyzer::Type::F32 -> @panic("expected Instance variant"),
      Analyzer::Type::F64 -> @panic("expected Instance variant"),
      Analyzer::Type::BOOLEAN -> @panic("expected Instance variant"),
      Analyzer::Type::CHAR -> @panic("expected Instance variant"),
      Analyzer::Type::STR -> @panic("expected Instance variant"),
      Analyzer::Type::VOID -> @panic("expected Instance variant"),
      Analyzer::Type::NEVER -> @panic("expected Instance variant"),
      Analyzer::Type::Pointer(_) -> @panic("expected Instance variant"),
      Analyzer::Type::Reference(_) -> @panic("expected Instance variant"),
      Analyzer::Type::Slice(_) -> @panic("expected Instance variant"),
      Analyzer::Type::FixedArray(_, _) -> @panic("expected Instance variant"),
      Analyzer::Type::Tuple(_) -> @panic("expected Instance variant"),
      Analyzer::Type::Function(_) -> @panic("expected Instance variant"),
      Analyzer::Type::Record(_) -> @panic("expected Instance variant"),
      Analyzer::Type::Enum(_) -> @panic("expected Instance variant"),
      Analyzer::Type::Param(_) -> @panic("expected Instance variant"),
      Analyzer::Type::Instance(instance) -> {
        Test::assertEq<u32>(instance.definition.raw(), 77);
        Test::assertEq<u64>(instance.typeArguments.length(), 2);

        match (instance.typeArguments.get(0)) {
          Option::SOME(argId) -> Test::assertEq<u32>(argId.raw(), idI32.raw()),
          Option::NONE -> @panic("expected first type argument"),
        };

        match (instance.typeArguments.get(1)) {
          Option::SOME(argId) -> Test::assertEq<u32>(argId.raw(), idStr.raw()),
          Option::NONE -> @panic("expected second type argument"),
        };
      },
    },
  };
}

@test
function nameOfParamReturnsPlaceholderWithSymbolId(): void {
  let mut store: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let id: Analyzer::TypeId = store.param(Symbol::fromRaw(13));

  let expected: String = String::create("<param:Symbol(13)>");
  let actual: String = store.nameOf(id);

  Test::assertEq<str>(actual.toStr(), expected.toStr());
}

@test
function nameOfInstanceReturnsPlaceholderWithArgs(): void {
  let mut store: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let defId: Analyzer::DefinitionId = Id::fromRaw<Analyzer::DefinitionTag>(4);
  let idI32: Analyzer::TypeId = store.intern(Analyzer::Type::I32);
  let idStr: Analyzer::TypeId = store.intern(Analyzer::Type::STR);

  let mut args: Vector<Analyzer::TypeId> = Vector::new<Analyzer::TypeId>();
  args.push(idI32);
  args.push(idStr);
  let id: Analyzer::TypeId = store.instance(defId, args);

  let expected: String = String::create("<instance:DefId(4)<i32, str>>");
  let actual: String = store.nameOf(id);

  Test::assertEq<str>(actual.toStr(), expected.toStr());
}
