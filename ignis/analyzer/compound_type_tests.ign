  let mut args2: Vector<Analyzer::TypeId> = Vector::new<Analyzer::TypeId>();
  args2.push(idI32);
  let id2: Analyzer::TypeId = store.instance(defId, args2);

  Test::assertEq<u32>(id1.raw(), id2.raw());
}

