@test
function equalsDistinguishesImmutableFromMutableReference(): void {
  let idI32: Analyzer::TypeId = Id::fromRaw<Analyzer::TypeTag>(2);

  let immutableRef: Analyzer::Type = Analyzer::Type::Reference(Analyzer::ReferenceType { referent: idI32, mutable: false });
  let mutableRef: Analyzer::Type = Analyzer::Type::Reference(Analyzer::ReferenceType { referent: idI32, mutable: true });

  Test::assert(!immutableRef.equals(&mutableRef));
  Test::assert(!mutableRef.equals(&immutableRef));
}

@test
function compoundTypeNameOfReferenceUnchanged(): void {
  let mut store: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let idI32: Analyzer::TypeId = store.intern(Analyzer::Type::I32);
  let refId: Analyzer::TypeId = store.reference(idI32);

  Test::assertEq<str>(store.nameOf(refId).toStr(), "&i32");
}

@test
function equalsFalseForFunctionWithDifferentParams(): void {
  let idZero: Analyzer::TypeId = Id::fromRaw<Analyzer::TypeTag>(0);
  let idOne: Analyzer::TypeId = Id::fromRaw<Analyzer::TypeTag>(1);

  let mut params1: Vector<Analyzer::TypeId> = Vector::new<Analyzer::TypeId>();
  params1.push(idZero);
  let ft1: Analyzer::FunctionType = Analyzer::FunctionType { params: params1, returnType: idZero };

  let mut params2: Vector<Analyzer::TypeId> = Vector::new<Analyzer::TypeId>();
  params2.push(idOne);
  let ft2: Analyzer::FunctionType = Analyzer::FunctionType { params: params2, returnType: idZero };

  let type1: Analyzer::Type = Analyzer::Type::Function(ft1);
  let type2: Analyzer::Type = Analyzer::Type::Function(ft2);

  Test::assert(!type1.equals(&type2));
}

