  // TypeStore must not grow during pass-1.
  Test::assertEq<u64>(typeStore.length(), typeStoreLengthBefore);

  // No diagnostics.
  Test::assertEq<u64>(output.diagnostics.length(), 0);
}

/// Scenario: Record wrapped in Export::Declaration.
/// Spec: export unwrapping — the inner record's NodeId is mapped, not the export wrapper.
@test
function binderUnwrapsExportDeclaration(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  // Add the inner record as a non-root item so we capture its ItemId.
  let innerRecordId: Ast::ItemId = module.addItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: dummySpan(),
    name: String::create("Foo"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: Vector::new<Ast::PatternId>(),
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  // Wrap it in an Export::Declaration and add THAT as the root.
  let exportId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Export(Ast::Item::Export {
    span: dummySpan(),
    declaration: Option::SOME(innerRecordId),
    items: Vector::new<Ast::ImportBinding>(),
    source: Option::NONE,
    sourceSpan: Option::NONE,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  // Exactly one definition: the inner record (not the export wrapper).
  Test::assertEq<u64>(defStore.length(), 1);

  // The inner record's NodeId is in nodeDefs.
  assertItemPredeclared(&output, innerRecordId.raw());

  // The export wrapper itself is NOT in nodeDefs.
  assertItemNotPredeclared(&output, exportId.raw());

  // No diagnostics.
  Test::assertEq<u64>(output.diagnostics.length(), 0);
}

/// Scenario: Function is silently skipped.
/// Spec: functions and variables are not predeclared — roots containing only a Function
/// leave defStore empty and nodeDefs empty.
@test
function binderSkipsFunctionRoots(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let typeStoreLengthBefore: u64 = typeStore.length();

  // Build a minimal dummy function body (empty block).
  let bodyId: Ast::StatementId = module.addStatement(Ast::Statement::Node::Block(Ast::Statement::Block {
    span: dummySpan(),
    statements: Vector::new<Ast::StatementId>(),
    tail: Option::NONE,
  }));

  let _fnId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: dummySpan(),
    name: String::create("main"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: bodyId,
    metadata: Ast::emptyMetadata(),
  }));

  let output: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  // Function must not create any definition in pass-1.
  Test::assertEq<u64>(defStore.length(), 0);

  // nodeDefs must be empty.
  Test::assertEq<u64>(Analyzer::Binder::nodeDefCount(&output), 0);

  // TypeStore must not grow.
  Test::assertEq<u64>(typeStore.length(), typeStoreLengthBefore);

  // No diagnostics.
  Test::assertEq<u64>(output.diagnostics.length(), 0);
}
