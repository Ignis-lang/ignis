/// Phase 8.7 RED: Duplicate function names in a namespace.
/// 1 diagnostic, only first function's DefinitionId in pass-2 output.
@test
function binderDuplicateFunctionName(): void {
  let mut defStore: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStore: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbols: Analyzer::SymbolTable = Analyzer::SymbolTable::init();
  let mut module: Ast::Module = Ast::Module::init();

  let bodyId: Ast::StatementId = module.addStatement(Ast::Statement::Node::Block(Ast::Statement::Block {
    span: dummySpan(),
    statements: Vector::new<Ast::StatementId>(),
    tail: Option::NONE,
  }));

  let fn1Id: Ast::ItemId = module.addItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: dummySpan(),
    name: String::create("foo"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: bodyId,
    metadata: Ast::emptyMetadata(),
  }));

  let fn2Id: Ast::ItemId = module.addItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: dummySpan(),
    name: String::create("foo"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: bodyId,
    metadata: Ast::emptyMetadata(),
  }));

  let mut nsItems: Vector<Ast::ItemId> = Vector::new<Ast::ItemId>();
  nsItems.push(fn1Id);
  nsItems.push(fn2Id);

  let _nsId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Namespace(Ast::Item::Namespace {
    span: dummySpan(),
    name: String::create("Ns"),
    items: nsItems,
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
  );

  let pass2: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
    &module,
    &pass1,
  );

  // 1 diagnostic for duplicate "foo".
  Test::assertEq<u64>(pass2.diagnostics.length(), 1);

  // First "foo" is in pass-2 output.
  match (Analyzer::Binder::findDef(&pass2, fn1Id.raw())) {
    Option::SOME(_) -> {},
    Option::NONE -> @panic("first 'foo' function not found in pass-2 output"),
  };

  // Second "foo" is NOT in pass-2 output.
  match (Analyzer::Binder::findDef(&pass2, fn2Id.raw())) {
    Option::SOME(_) -> @panic("second 'foo' should not be in pass-2 output"),
    Option::NONE -> {},
  };
}

/// Phase 9.1 RED: Two independent pass-1 + pass-2 sequences over structurally identical
/// AST inputs produce byte-identical DefinitionId ordinals and same TypeStore length.
@test
function binderPass2ProducesIdenticalOutputsAcrossTwoRuns(): void {
  // Build module A: Record<T> with 1 field, Enum with 2 variants, Function with 1 param.

  // Run A.
  let mut moduleA: Ast::Module = Ast::Module::init();

  let fieldAId: Ast::PatternId = moduleA.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: dummySpan(),
    name: String::create("val"),
    annotation: Option::NONE,
    metadata: Ast::emptyMetadata(),
  }));

  let mut fieldsA: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fieldsA.push(fieldAId);

  let mut tpA: Vector<Ast::GenericParam> = Vector::new<Ast::GenericParam>();
  tpA.push(Ast::GenericParam {
    span: dummySpan(),
    name: String::create("T"),
    bounds: Vector::new<Ast::GenericBound>(),
  });

  let _recIdA: Ast::ItemId = moduleA.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: dummySpan(),
    name: String::create("Box"),
    genericParameters: tpA,
    fields: fieldsA,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  let var0A: Ast::PatternId = moduleA.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: dummySpan(),
    name: String::create("A"),
    annotation: Option::NONE,
    metadata: Ast::emptyMetadata(),
  }));
  let var1A: Ast::PatternId = moduleA.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: dummySpan(),
    name: String::create("B"),
    annotation: Option::NONE,
    metadata: Ast::emptyMetadata(),
  }));
  let mut variantsA: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  variantsA.push(var0A);
  variantsA.push(var1A);

  let _enumIdA: Ast::ItemId = moduleA.addRootItem(Ast::Item::Node::Enum(Ast::Item::Enum {
    span: dummySpan(),
    name: String::create("Dir"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    variants: variantsA,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  let paramA: Ast::PatternId = moduleA.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: dummySpan(),
    name: String::create("n"),
    annotation: Option::NONE,
    metadata: Ast::emptyMetadata(),
  }));
  let mut paramsA: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  paramsA.push(paramA);
  let bodyA: Ast::StatementId = moduleA.addStatement(Ast::Statement::Node::Block(Ast::Statement::Block {
    span: dummySpan(),
    statements: Vector::new<Ast::StatementId>(),
    tail: Option::NONE,
  }));
  let _fnIdA: Ast::ItemId = moduleA.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: dummySpan(),
    name: String::create("abs"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: paramsA,
    returnType: Option::NONE,
    body: bodyA,
    metadata: Ast::emptyMetadata(),
  }));

  let mut defStoreA: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStoreA: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbolsA: Analyzer::SymbolTable = Analyzer::SymbolTable::init();

  let pass1A: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &moduleA.roots,
    &mut defStoreA,
    &mut typeStoreA,
    &mut symbolsA,
    &moduleA,
  );

  let pass2A: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &moduleA.roots,
    &mut defStoreA,
    &mut typeStoreA,
    &mut symbolsA,
    &moduleA,
    &pass1A,
  );

  // Run B: identical structure.
  let mut moduleB: Ast::Module = Ast::Module::init();

  let fieldBId: Ast::PatternId = moduleB.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: dummySpan(),
    name: String::create("val"),
    annotation: Option::NONE,
    metadata: Ast::emptyMetadata(),
  }));

  let mut fieldsB: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  fieldsB.push(fieldBId);

  let mut tpB: Vector<Ast::GenericParam> = Vector::new<Ast::GenericParam>();
  tpB.push(Ast::GenericParam {
    span: dummySpan(),
    name: String::create("T"),
    bounds: Vector::new<Ast::GenericBound>(),
  });

  let _recIdB: Ast::ItemId = moduleB.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: dummySpan(),
    name: String::create("Box"),
    genericParameters: tpB,
    fields: fieldsB,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  let var0B: Ast::PatternId = moduleB.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: dummySpan(),
    name: String::create("A"),
    annotation: Option::NONE,
    metadata: Ast::emptyMetadata(),
  }));
  let var1B: Ast::PatternId = moduleB.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: dummySpan(),
    name: String::create("B"),
    annotation: Option::NONE,
    metadata: Ast::emptyMetadata(),
  }));
  let mut variantsB: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  variantsB.push(var0B);
  variantsB.push(var1B);

  let _enumIdB: Ast::ItemId = moduleB.addRootItem(Ast::Item::Node::Enum(Ast::Item::Enum {
    span: dummySpan(),
    name: String::create("Dir"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    variants: variantsB,
    methods: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  let paramB: Ast::PatternId = moduleB.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: dummySpan(),
    name: String::create("n"),
    annotation: Option::NONE,
    metadata: Ast::emptyMetadata(),
  }));
  let mut paramsB: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  paramsB.push(paramB);
  let bodyB: Ast::StatementId = moduleB.addStatement(Ast::Statement::Node::Block(Ast::Statement::Block {
    span: dummySpan(),
    statements: Vector::new<Ast::StatementId>(),
    tail: Option::NONE,
  }));
  let _fnIdB: Ast::ItemId = moduleB.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: dummySpan(),
    name: String::create("abs"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: paramsB,
    returnType: Option::NONE,
    body: bodyB,
    metadata: Ast::emptyMetadata(),
  }));

  let mut defStoreB: Analyzer::DefinitionStore = Analyzer::DefinitionStore::init();
  let mut typeStoreB: Analyzer::TypeStore = Analyzer::TypeStore::init();
  let mut symbolsB: Analyzer::SymbolTable = Analyzer::SymbolTable::init();

  let pass1B: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &moduleB.roots,
    &mut defStoreB,
    &mut typeStoreB,
    &mut symbolsB,
    &moduleB,
  );

  let pass2B: Analyzer::Binder::BinderOutput = Analyzer::Binder::completeRoots(
    &moduleB.roots,
    &mut defStoreB,
    &mut typeStoreB,
    &mut symbolsB,
    &moduleB,
    &pass1B,
  );

  // Both runs must produce the same defStore length and typeStore length.
  Test::assertEq<u64>(defStoreA.length(), defStoreB.length());
  Test::assertEq<u64>(typeStoreA.length(), typeStoreB.length());

  // pass-2 outputs must have the same nodeIds/defIds count and ordinals.
  Test::assertEq<u64>(pass2A.nodeIds.length(), pass2B.nodeIds.length());
  Test::assertEq<u64>(pass2A.defIds.length(), pass2B.defIds.length());

  let count: u64 = pass2A.defIds.length();
  let mut index: u64 = 0;
  while (index < count) {
    if (let Option::SOME(idA) = pass2A.defIds.get(index)) {
      if (let Option::SOME(idB) = pass2B.defIds.get(index)) {
        Test::assertEq<u32>(idA.raw(), idB.raw());
      }
    }
    index += 1;
  }

  // pass-1 outputs must also be identical (same ordinals).
  Test::assertEq<u64>(pass1A.defIds.length(), pass1B.defIds.length());
  let pass1Count: u64 = pass1A.defIds.length();
  let mut pass1Index: u64 = 0;
  while (pass1Index < pass1Count) {
    if (let Option::SOME(idA) = pass1A.defIds.get(pass1Index)) {
      if (let Option::SOME(idB) = pass1B.defIds.get(pass1Index)) {
        Test::assertEq<u32>(idA.raw(), idB.raw());
      }
    }
    pass1Index += 1;
  }
}
