    span: dummySpan(),
    value: Ast::Expression::LiteralValue::Int(0),
  }));

  let constId: Ast::ItemId = module.addItem(Ast::Item::Node::Constant(Ast::Item::Constant {
    span: dummySpan(),
    name: String::create("VERSION"),
    annotation: Option::NONE,
    value: exprId,
    metadata: Ast::emptyMetadata(),
  }));

  let _exportId: Ast::ItemId = module.addRootItem(Ast::Item::Node::Export(Ast::Item::Export {
    span: dummySpan(),
    declaration: Option::SOME(constId),
    items: Vector::new<Ast::ImportBinding>(),
    source: Option::NONE,
    sourceSpan: Option::NONE,
    metadata: Ast::emptyMetadata(),
  }));

  let pass1: Analyzer::Binder::BinderOutput = Analyzer::Binder::predeclareRoots(
    &module.roots,
    &mut defStore,
    &mut typeStore,
    &mut symbols,
