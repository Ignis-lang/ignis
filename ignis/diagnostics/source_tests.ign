import Fs from "std::fs";
import Test from "std::test";

import
  FileId,
  SourceFile,
  SourceLocation,
  SourceMap,
  SourceSpan,
  TextRange,
from "@compiler::diagnostics";

function readUtf8Fixture(path: str): String {
  return match (Fs::readToString(path)) {
    Result::OK(value) -> value,
    Result::ERROR(_) -> @panic("missing UTF-8 diagnostics fixture"),
  };
}

function utf8FixturePath(): str {
  return "test_cases/selfhost/diagnostics/compat_utf8_excerpt/input.ign";
}

function utf8SourceFile(): SourceFile {
  let path: str = utf8FixturePath();
  let text: String = readUtf8Fixture(path);

  return SourceFile::create(path, text.toStr());
}

function utf8Word(): String {
  return readUtf8Fixture(utf8FixturePath()).substring(0, 4);
}

@test
function sourceSpanParsesFixtureTextAndRetainsPath(): void {
  let text: String = String::create("fixtures/input.ign:12-34");
  let mut backing: Vector<String> = Vector::new<String>();
  let span: SourceSpan = SourceSpan::parse(&text, &mut backing);

  Test::assertEq<str>(span.filePath, "fixtures/input.ign");
  Test::assertEq<u64>(span.start, 12);
  Test::assertEq<u64>(span.end, 34);
  Test::assertEq<u64>(backing.length(), 1);
}

@test
function sourceSnippetTrimsLineEndingsAndShowsZeroLengthCaret(): void {
  let source: SourceFile = SourceFile::create("fixtures/empty_span.ign", "first\nproblem\nthird\n");
  let span: SourceSpan = SourceSpan::new("fixtures/empty_span.ign", 8, 8);
  let rendered: String = source.snippet(span);

  Test::assertEq<str>(rendered.toStr(), "   2 | problem\n     |   ^");
}

@test
function sourceLocationsPreserveUnicodeAndByteColumns(): void {
  let source: SourceFile = utf8SourceFile();
  let scalarLocation: SourceLocation = source.lineCol(3);
  let byteLocation: SourceLocation = source.byteLineCol(3);

  Test::assertEq<u32>(scalarLocation.line, 1);
  Test::assertEq<u32>(scalarLocation.column, 3);
  Test::assertEq<u32>(scalarLocation.byteColumn, 4);

  Test::assertEq<u32>(byteLocation.line, 1);
  Test::assertEq<u32>(byteLocation.column, 4);
  Test::assertEq<u32>(byteLocation.byteColumn, 4);
}

@test
function sourceSnippetUsesCharacterWidthForMultibyteSpan(): void {
  let source: SourceFile = utf8SourceFile();
  let singleWidth: String = source.snippet(SourceSpan::new("fixtures/utf8.ign", 1, 3));
  let mixedWidth: String = source.snippet(SourceSpan::new("fixtures/utf8.ign", 1, 4));
  let mut snapshot: String = String::new();

  snapshot.pushStr("single=\n");
  snapshot.push(&singleWidth);
  snapshot.pushStr("\n\nmixed=\n");
  snapshot.push(&mixedWidth);

  let renderedWord: String = utf8Word();
  let singleCaret: String = String::create("  ^");
  let doubleCaret: String = String::create("  ^^");

  Test::assertSnapshot("source-multibyte-snippets", snapshot.toStr());
  Test::assert(singleWidth.contains(&renderedWord));
  Test::assert(mixedWidth.contains(&renderedWord));
  Test::assert(singleWidth.contains(&singleCaret));
  Test::assert(!singleWidth.contains(&doubleCaret));
  Test::assert(mixedWidth.contains(&doubleCaret));

}

@test
function sourceSnippetRendersMultilineSpanLikeStage0(): void {
  let source: SourceFile = SourceFile::create("fixtures/multiline.ign", "alpha\nbeta\ngamma");
  let rendered: String = source.snippet(SourceSpan::new("fixtures/multiline.ign", 2, 10));

  Test::assertEq<str>(rendered.toStr(), "   1 | alpha\n     |   ^^^\n   2 | beta\n     | ^^^^");
}

@test
function textRangeReportsLengthEmptinessAndContains(): void {
  let range: TextRange = TextRange::new(2, 5);

  Test::assertEq<u64>(range.length(), 3);
  Test::assert(!range.isEmpty());
  Test::assert(range.isValid());

  Test::assert(!range.contains(1));
  Test::assert(range.contains(2));
  Test::assert(range.contains(4));
  Test::assert(!range.contains(5));

  let empty: TextRange = TextRange::emptyAt(7);
  Test::assertEq<u64>(empty.length(), 0);
  Test::assert(empty.isEmpty());
}

@test
function textRangeMergeCoversBothRanges(): void {
  let left: TextRange = TextRange::new(2, 4);
  let right: TextRange = TextRange::new(6, 9);
  let merged: TextRange = TextRange::merge(&left, &right);

  Test::assertEq<u64>(merged.start, 2);
  Test::assertEq<u64>(merged.end, 9);
}

@test
function sourceMapDeduplicatesFilesByPath(): void {
  let mut map: SourceMap = SourceMap::new();
  let first: FileId = map.addFile("fixtures/input.ign", "alpha");
  let second: FileId = map.addFile("fixtures/input.ign", "alpha");
  let other: FileId = map.addFile("fixtures/other.ign", "beta");

  Test::assertEq<u32>(first.raw(), second.raw());
  Test::assert(first.raw() != other.raw());
  Test::assertEq<u64>(map.fileCount(), 2);
}

@test
function sourceMapLooksUpRegisteredPaths(): void {
  let mut map: SourceMap = SourceMap::new();
  let id: FileId = map.addFile("fixtures/input.ign", "alpha");

  let Option::SOME(found) = map.lookupByPath("fixtures/input.ign") else {
    Test::assert(false);
    return;
  };

  Test::assertEq<u32>(found.raw(), id.raw());
  Test::assert(map.lookupByPath("fixtures/missing.ign").isNone());
}

@test
function sourceMapDelegatesResolutionToRegisteredFile(): void {
  let mut map: SourceMap = SourceMap::new();
  let id: FileId = map.addFile("fixtures/multiline.ign", "alpha\nbeta\ngamma");

  let Option::SOME(location) = map.lineCol(id, 8) else {
    Test::assert(false);
    return;
  };

  Test::assertEq<u32>(location.line, 2);
  Test::assertEq<u32>(location.column, 3);

  let Option::SOME(rendered) = map.snippet(id, SourceSpan::new("fixtures/multiline.ign", 2, 10)) else {
    Test::assert(false);
    return;
  };

  Test::assertEq<str>(rendered.toStr(), "   1 | alpha\n     |   ^^^\n   2 | beta\n     | ^^^^");
}

@test
function sourceMapRegistersVirtualFiles(): void {
  let mut map: SourceMap = SourceMap::new();
  let id: FileId = map.addVirtual("synthetic", "generated");

  let Option::SOME(file) = map.get(id) else {
    Test::assert(false);
    return;
  };

  Test::assertEq<str>(file.text.toStr(), "generated");
  Test::assertEq<u64>(map.fileCount(), 1);
}

@test
function sourceMapReturnsNoneForUnknownFileId(): void {
  let mut populated: SourceMap = SourceMap::new();
  let id: FileId = populated.addFile("fixtures/input.ign", "alpha");

  let empty: SourceMap = SourceMap::new();

  Test::assert(empty.get(id).isNone());
  Test::assert(empty.lineCol(id, 0).isNone());
}

@test
function sourceSpanExposesFileIndependentRange(): void {
  let span: SourceSpan = SourceSpan::new("fixtures/input.ign", 4, 10);
  let range: TextRange = span.range();

  Test::assertEq<u64>(range.start, 4);
  Test::assertEq<u64>(range.end, 10);
}
