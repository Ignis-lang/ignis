import SourceSpan from "@compiler::diagnostics";
import Vector from "std::vector";

export namespace Ast {
  namespace Item {
    record Function {
      public span: SourceSpan;
      public name: String;
      public parameters: Vector<Ast::PatternId>;
      public returnType: Option<Ast::TypeId>;
      public body: Ast::StatementId;
      public metadata: Ast::Metadata;
    }

    record Record {
      public span: SourceSpan;
      public name: String;
      public fields: Vector<Ast::PatternId>;
      public methods: Vector<Ast::ItemId>;
      public metadata: Ast::Metadata;
    }

    record Enum {
      public span: SourceSpan;
      public name: String;
      public variants: Vector<Ast::PatternId>;
      public methods: Vector<Ast::ItemId>;
      public metadata: Ast::Metadata;
    }

    record Namespace {
      public span: SourceSpan;
      public name: String;
      public items: Vector<Ast::ItemId>;
      public metadata: Ast::Metadata;
    }

    record Import {
      public span: SourceSpan;
      public path: Vector<String>;
      public metadata: Ast::Metadata;
    }

    record Extern {
      public span: SourceSpan;
      public name: String;
      public metadata: Ast::Metadata;
    }

    record Constant {
      public span: SourceSpan;
      public name: String;
      public annotation: Option<Ast::TypeId>;
      public value: Ast::ExpressionId;
      public metadata: Ast::Metadata;
    }

    record Export {
      public span: SourceSpan;
      public item: Ast::ItemId;
      public metadata: Ast::Metadata;
    }

    record TypeAlias {
      public span: SourceSpan;
      public name: String;
      public value: Ast::TypeId;
      public metadata: Ast::Metadata;
    }

    record Trait {
      public span: SourceSpan;
      public name: String;
      public methods: Vector<Ast::ItemId>;
      public metadata: Ast::Metadata;
    }

    enum Node {
      Function(Function),
      Record(Record),
      Enum(Enum),
      Namespace(Namespace),
      Import(Import),
      Extern(Extern),
      Constant(Constant),
      Export(Export),
      TypeAlias(TypeAlias),
      Trait(Trait),
    }
  }
}
