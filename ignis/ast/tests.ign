import Test from "std::test";
import Vector from "std::vector";

import SourceSpan from "@compiler::diagnostics";
import Ast from "@compiler::ast";

function astText(value: str): String {
  return value.toString();
}

function buildSnapshotModule(rootName: String): Ast::Module {
  let mut module: Ast::Module = Ast::Module::init();

  let literalExpression: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::Literal(Ast::Expression::Literal {
    span: SourceSpan::new("fixtures/ast_snapshot.ign", 32, 34),
    value: Ast::Expression::LiteralValue::Int(42),
  }));

  let bindingPattern: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: SourceSpan::new("fixtures/ast_snapshot.ign", 15, 20),
    name: astText("value"),
    annotation: Option::NONE,
    metadata: Ast::emptyMetadata(),
  }));
  module.addPattern(Ast::Pattern::Node::Wildcard(Ast::Pattern::Wildcard {
    span: SourceSpan::new("fixtures/ast_snapshot.ign", 45, 46),
  }));

  let letStatement: Ast::StatementId = module.addStatement(Ast::Statement::Node::Let(Ast::Statement::Let {
    span: SourceSpan::new("fixtures/ast_snapshot.ign", 0, 14),
    pattern: bindingPattern,
    annotation: Option::NONE,
    value: Option::SOME(literalExpression),
  }));
  module.addStatement(Ast::Statement::Node::Return(Ast::Statement::Return {
    span: SourceSpan::new("fixtures/ast_snapshot.ign", 25, 31),
    value: Option::SOME(literalExpression),
  }));

  module.addItem(Ast::Item::Node::Namespace(Ast::Item::Namespace {
    span: SourceSpan::new("fixtures/ast_snapshot.ign", 47, 66),
    name: astText("Helpers"),
    items: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: SourceSpan::new("fixtures/ast_snapshot.ign", 67, 98),
    name: rootName,
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: letStatement,
    metadata: Ast::emptyMetadata(),
  }));
  module.addRootItem(Ast::Item::Node::Namespace(Ast::Item::Namespace {
    span: SourceSpan::new("fixtures/ast_snapshot.ign", 99, 130),
    name: astText("Utility"),
    items: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  module.addPattern(Ast::Pattern::Node::Tuple(Ast::Pattern::Tuple {
    span: SourceSpan::new("fixtures/ast_snapshot.ign", 131, 138),
    elements: Vector::new<Ast::PatternId>(),
  }));
  module.addStatement(Ast::Statement::Node::Expression(Ast::Statement::Expression {
    span: SourceSpan::new("fixtures/ast_snapshot.ign", 139, 148),
    expression: literalExpression,
  }));
  module.addPattern(Ast::Pattern::Node::Or(Ast::Pattern::Or {
    span: SourceSpan::new("fixtures/ast_snapshot.ign", 173, 184),
    alternatives: Vector::new<Ast::PatternId>(),
  }));

  return module;
}
function expectedSnapshotText(): str {
  return "roots:\n  - item#1\n  - item#2\n\nitems:\n  - item#0 Namespace span=fixtures/ast_snapshot.ign:47-66 name=\"Helpers\" items=[]\n  - item#1 Function span=fixtures/ast_snapshot.ign:67-98 name=\"main\" parameters=[] returnType=none body=statement#0\n  - item#2 Namespace span=fixtures/ast_snapshot.ign:99-130 name=\"Utility\" items=[]\n\nexpressions:\n  - expression#0 Literal span=fixtures/ast_snapshot.ign:32-34 value=Int(42)\n\nstatements:\n  - statement#0 Let span=fixtures/ast_snapshot.ign:0-14 pattern=pattern#0 annotation=none value=expression#0\n  - statement#1 Return span=fixtures/ast_snapshot.ign:25-31 value=expression#0\n  - statement#2 Expression span=fixtures/ast_snapshot.ign:139-148 expression=expression#0\n\ntypes:\n\npatterns:\n  - pattern#0 Binding span=fixtures/ast_snapshot.ign:15-20 name=\"value\" annotation=none\n  - pattern#1 Wildcard span=fixtures/ast_snapshot.ign:45-46\n  - pattern#2 Tuple span=fixtures/ast_snapshot.ign:131-138 elements=[]\n  - pattern#3 Or span=fixtures/ast_snapshot.ign:173-184 alternatives=[]\n";
}

function expectedStructuredLiteralAndBinaryText(): str {
  return "roots:\n\nitems:\n\nexpressions:\n  - expression#0 Literal span=fixtures/ast_literals.ign:0-2 value=Int(42)\n  - expression#1 Literal span=fixtures/ast_literals.ign:3-7 value=Boolean(true)\n  - expression#2 Binary span=fixtures/ast_literals.ign:0-7 operator=Add left=expression#0 right=expression#1\n\nstatements:\n\ntypes:\n\npatterns:\n";
}

@test
function astSerializerRendersGenericParametersAndBounds(): void {
  let mut module: Ast::Module = Ast::Module::init();
  let mut bounds: Vector<Ast::GenericBound> = Vector::new<Ast::GenericBound>();
  let mut boundSegments: Vector<String> = Vector::new<String>();
  let mut genericParameters: Vector<Ast::GenericParam> = Vector::new<Ast::GenericParam>();
  let body: Ast::StatementId = module.addStatement(Ast::Statement::Node::Block(Ast::Statement::Block {
    span: SourceSpan::new("fixtures/ast_generics.ign", 35, 37),
    statements: Vector::new<Ast::StatementId>(),
    tail: Option::NONE,
  }));

  boundSegments.push(astText("Hash"));
  bounds.push(Ast::GenericBound {
    span: SourceSpan::new("fixtures/ast_generics.ign", 18, 22),
    segments: boundSegments,
  });
  genericParameters.push(Ast::GenericParam {
    span: SourceSpan::new("fixtures/ast_generics.ign", 15, 22),
    name: astText("T"),
    bounds: bounds,
  });

  module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: SourceSpan::new("fixtures/ast_generics.ign", 0, 37),
    name: astText("identity"),
    genericParameters: genericParameters,
    parameters: Vector::new<Ast::PatternId>(),
    returnType: Option::NONE,
    body: body,
    metadata: Ast::emptyMetadata(),
  }));

  let rendered: String = Ast::Serializer::render(&module);
  let expectedGenerics: String = String::create("generics=[\"T\":[[\"Hash\"]]]");

  if (!rendered.contains(&expectedGenerics)) {
    @panic("expected serializer to render generic parameters and bounds");
  }
}

@test
function astSerializerRendersMetadataAndRecordMethods(): void {
  let mut module: Ast::Module = Ast::Module::init();
  let mut fieldModifiers: Vector<Ast::Modifier> = Vector::new<Ast::Modifier>();
  let mut itemAttributes: Vector<Ast::Attribute> = Vector::new<Ast::Attribute>();
  let mut methodAttributes: Vector<Ast::Attribute> = Vector::new<Ast::Attribute>();
  let mut parameterAttributes: Vector<Ast::Attribute> = Vector::new<Ast::Attribute>();
  let mut methodModifiers: Vector<Ast::Modifier> = Vector::new<Ast::Modifier>();
  let mut fieldTypeSegments: Vector<String> = Vector::new<String>();
  let mut recordFields: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  let mut recordMethods: Vector<Ast::ItemId> = Vector::new<Ast::ItemId>();
  let mut methodParameters: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  let mut itemAttributeArguments: Vector<String> = Vector::new<String>();
  let mut methodAttributeArguments: Vector<String> = Vector::new<String>();
  let mut parameterAttributeArguments: Vector<String> = Vector::new<String>();

  fieldModifiers.push(Ast::Modifier::Public);
  methodModifiers.push(Ast::Modifier::Public);
  methodModifiers.push(Ast::Modifier::Static);
  itemAttributeArguments.push(astText("\"c\""));
  itemAttributeArguments.push(astText("level"));
  methodAttributeArguments.push(astText("init"));
  parameterAttributeArguments.push(astText("input"));
  itemAttributes.push(Ast::Attribute {
    span: SourceSpan::new("fixtures/ast_metadata.ign", 0, 18),
    name: astText("packed"),
    arguments: itemAttributeArguments,
  });
  methodAttributes.push(Ast::Attribute {
    span: SourceSpan::new("fixtures/ast_metadata.ign", 47, 59),
    name: astText("builder"),
    arguments: methodAttributeArguments,
  });
  parameterAttributes.push(Ast::Attribute {
    span: SourceSpan::new("fixtures/ast_metadata.ign", 80, 92),
    name: astText("trace"),
    arguments: parameterAttributeArguments,
  });
  fieldTypeSegments.push(astText("i32"));

  let fieldType: Ast::TypeId = module.addType(Ast::Type::Node::Path(Ast::Type::Path {
    span: SourceSpan::new("fixtures/ast_metadata.ign", 34, 37),
    segments: fieldTypeSegments,
  }));
  let fieldPattern: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: SourceSpan::new("fixtures/ast_metadata.ign", 25, 37),
    name: astText("value"),
    annotation: Option::SOME(fieldType),
    metadata: Ast::Metadata {
      attributes: Vector::new<Ast::Attribute>(),
      modifiers: fieldModifiers,
    },
  }));
  let methodParameter: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: SourceSpan::new("fixtures/ast_metadata.ign", 93, 103),
    name: astText("value"),
    annotation: Option::SOME(fieldType),
    metadata: Ast::Metadata {
      attributes: parameterAttributes,
      modifiers: Vector::new<Ast::Modifier>(),
    },
  }));
  let methodBody: Ast::StatementId = module.addStatement(Ast::Statement::Node::Block(Ast::Statement::Block {
    span: SourceSpan::new("fixtures/ast_metadata.ign", 117, 119),
    statements: Vector::new<Ast::StatementId>(),
    tail: Option::NONE,
  }));
  methodParameters.push(methodParameter);
  let methodItem: Ast::ItemId = module.addItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: SourceSpan::new("fixtures/ast_metadata.ign", 47, 119),
    name: astText("init"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: methodParameters,
    returnType: Option::NONE,
    body: methodBody,
    metadata: Ast::Metadata {
      attributes: methodAttributes,
      modifiers: methodModifiers,
    },
  }));

  recordMethods.push(methodItem);
  recordFields.push(fieldPattern);
  module.addRootItem(Ast::Item::Node::Record(Ast::Item::Record {
    span: SourceSpan::new("fixtures/ast_metadata.ign", 0, 119),
    name: astText("Packet"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    fields: recordFields,
    methods: recordMethods,
    metadata: Ast::Metadata {
      attributes: itemAttributes,
      modifiers: Vector::new<Ast::Modifier>(),
    },
  }));

  let rendered: String = Ast::Serializer::render(&module);
  let expectedItemMetadata: String = String::create("metadata=attrs[@packed(\"c\", level)@fixtures/ast_metadata.ign:0-18] modifiers[]");
  let expectedMethods: String = String::create("methods=[item#0]");
  let expectedMethodMetadata: String = String::create("metadata=attrs[@builder(init)@fixtures/ast_metadata.ign:47-59] modifiers[public, static]");
  let expectedBindingMetadata: String = String::create("metadata=attrs[] modifiers[public]");
  let expectedParameterMetadata: String = String::create("Binding span=fixtures/ast_metadata.ign:93-103 name=\"value\" annotation=type#0 metadata=attrs[@trace(input)@fixtures/ast_metadata.ign:80-92] modifiers[]");

  if (!rendered.contains(&expectedItemMetadata)) {
    @panic("expected serializer to render item metadata with arguments and span");
  }

  if (!rendered.contains(&expectedMethods)) {
    @panic("expected serializer to render record methods");
  }

  if (!rendered.contains(&expectedMethodMetadata)) {
    @panic("expected serializer to render method metadata");
  }

  if (!rendered.contains(&expectedBindingMetadata)) {
    @panic("expected serializer to render binding modifiers");
  }

  if (!rendered.contains(&expectedParameterMetadata)) {
    @panic("expected serializer to render parameter binding metadata with span");
  }
}
@test
function astSerializerRendersImportAndExportStructure(): void {
  let mut module: Ast::Module = Ast::Module::init();
  let mut importItems: Vector<Ast::ImportBinding> = Vector::new<Ast::ImportBinding>();
  let mut exportItems: Vector<Ast::ImportBinding> = Vector::new<Ast::ImportBinding>();

  importItems.push(Ast::ImportBinding {
    span: SourceSpan::new("fixtures/ast_import_export.ign", 7, 10),
    kind: Ast::ImportBindingKind::Named,
    name: Option::SOME(astText("Foo")),
    alias: Option::NONE,
  });
  importItems.push(Ast::ImportBinding {
    span: SourceSpan::new("fixtures/ast_import_export.ign", 12, 13),
    kind: Ast::ImportBindingKind::Discard,
    name: Option::NONE,
    alias: Option::NONE,
  });
  exportItems.push(Ast::ImportBinding {
    span: SourceSpan::new("fixtures/ast_import_export.ign", 45, 48),
    kind: Ast::ImportBindingKind::Named,
    name: Option::SOME(astText("Bar")),
    alias: Option::NONE,
  });

  module.addRootItem(Ast::Item::Node::Import(Ast::Item::Import {
    span: SourceSpan::new("fixtures/ast_import_export.ign", 0, 31),
    items: importItems,
    source: astText("std::io"),
    sourceSpan: SourceSpan::new("fixtures/ast_import_export.ign", 18, 27),
    metadata: Ast::emptyMetadata(),
  }));
  module.addRootItem(Ast::Item::Node::Export(Ast::Item::Export {
    span: SourceSpan::new("fixtures/ast_import_export.ign", 32, 60),
    declaration: Option::NONE,
    items: exportItems,
    source: Option::SOME(astText("./bar")),
    sourceSpan: Option::SOME(SourceSpan::new("fixtures/ast_import_export.ign", 49, 56)),
    metadata: Ast::emptyMetadata(),
  }));

  let rendered: String = Ast::Serializer::render(&module);

  let expectedRenderedNeedle1: String = String::create("Import span=fixtures/ast_import_export.ign:0-31 items=[Named(\"Foo\")@fixtures/ast_import_export.ign:7-10, Discard@fixtures/ast_import_export.ign:12-13] from=\"std::io\" sourceSpan=fixtures/ast_import_export.ign:18-27");
  Test::assert(rendered.contains(&expectedRenderedNeedle1));
  let expectedRenderedNeedle2: String = String::create("Export span=fixtures/ast_import_export.ign:32-60 declaration=none items=[Named(\"Bar\")@fixtures/ast_import_export.ign:45-48] from=\"./bar\" sourceSpan=fixtures/ast_import_export.ign:49-56");
  Test::assert(rendered.contains(&expectedRenderedNeedle2));
}

@test
function astModuleAllocatesCategoryLocalIdsAndTracksRoots(): void {
  let mut module: Ast::Module = Ast::Module::init();
  let mut returnTypeSegments: Vector<String> = Vector::new<String>();
  let mut functionParameters: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  let expression: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::Literal(Ast::Expression::Literal {
    span: SourceSpan::new("fixtures/ast.ign", 0, 2),
    value: Ast::Expression::LiteralValue::Int(42),
  }));
  let statement: Ast::StatementId = module.addStatement(Ast::Statement::Node::Return(Ast::Statement::Return {
    span: SourceSpan::new("fixtures/ast.ign", 3, 11),
    value: Option::SOME(expression),
  }));

  returnTypeSegments.push(String::create("i32"));

  let returnType: Ast::TypeId = module.addType(Ast::Type::Node::Path(Ast::Type::Path {
    span: SourceSpan::new("fixtures/ast.ign", 12, 15),
    segments: returnTypeSegments,
  }));
  let pattern: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: SourceSpan::new("fixtures/ast.ign", 16, 21),
    name: astText("value"),
    annotation: Option::SOME(returnType),
    metadata: Ast::emptyMetadata(),
  }));

  functionParameters.push(pattern);

  let firstRoot: Ast::ItemId = module.addRootItem(Ast::Item::Node::Function(Ast::Item::Function {
    span: SourceSpan::new("fixtures/ast.ign", 22, 40),
    name: astText("main"),
    genericParameters: Vector::new<Ast::GenericParam>(),
    parameters: functionParameters,
    returnType: Option::SOME(returnType),
    body: statement,
    metadata: Ast::emptyMetadata(),
  }));
  let secondRoot: Ast::ItemId = module.addRootItem(Ast::Item::Node::Namespace(Ast::Item::Namespace {
    span: SourceSpan::new("fixtures/ast.ign", 41, 64),
    name: astText("Support"),
    items: Vector::new<Ast::ItemId>(),
    metadata: Ast::emptyMetadata(),
  }));

  Test::assertEq<u32>(firstRoot.raw(), 0);
  Test::assertEq<u32>(secondRoot.raw(), 1);
  Test::assertEq<u32>(expression.raw(), 0);
  Test::assertEq<u32>(statement.raw(), 0);
  Test::assertEq<u32>(returnType.raw(), 0);
  Test::assertEq<u32>(pattern.raw(), 0);

  Test::assertEq<u64>(module.roots.length(), 2);
  Test::assertEq<u64>(module.items.length(), 2);
  Test::assertEq<u64>(module.expressions.length(), 1);
  Test::assertEq<u64>(module.statements.length(), 1);
  Test::assertEq<u64>(module.types.length(), 1);
  Test::assertEq<u64>(module.patterns.length(), 1);

  match (module.roots.get(0)) {
    Option::SOME(value) -> Test::assertEq<u32>(value.raw(), firstRoot.raw()),
    Option::NONE -> @panic("missing first root"),
  };

  match (module.roots.get(1)) {
    Option::SOME(value) -> Test::assertEq<u32>(value.raw(), secondRoot.raw()),
    Option::NONE -> @panic("missing second root"),
  };
}

@test
function astSerializerRendersStructuredLiteralValuesAndBinaryOperators(): void {
  let mut module: Ast::Module = Ast::Module::init();
  let left: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::Literal(Ast::Expression::Literal {
    span: SourceSpan::new("fixtures/ast_literals.ign", 0, 2),
    value: Ast::Expression::LiteralValue::Int(42),
  }));
  let right: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::Literal(Ast::Expression::Literal {
    span: SourceSpan::new("fixtures/ast_literals.ign", 3, 7),
    value: Ast::Expression::LiteralValue::Boolean(true),
  }));

  module.addExpression(Ast::Expression::Node::Binary(Ast::Expression::Binary {
    span: SourceSpan::new("fixtures/ast_literals.ign", 0, 7),
    operator: Ast::Expression::BinaryOperator::Add,
    left: left,
    right: right,
  }));

  let rendered: String = Ast::Serializer::render(&module);

  Test::assertEq<str>(rendered.toStr(), expectedStructuredLiteralAndBinaryText());
}

@test
function astSerializerRendersStructuredPatterns(): void {
  let mut module: Ast::Module = Ast::Module::init();
  let mut bindingAttributes: Vector<Ast::Attribute> = Vector::new<Ast::Attribute>();
  let mut bindingAttributeArguments: Vector<String> = Vector::new<String>();
  let mut bindingModifiers: Vector<Ast::Modifier> = Vector::new<Ast::Modifier>();
  let mut annotationSegments: Vector<String> = Vector::new<String>();
  let mut pathSegments: Vector<String> = Vector::new<String>();
  let mut tupleElements: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  let mut pathArguments: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  let mut orAlternatives: Vector<Ast::PatternId> = Vector::new<Ast::PatternId>();
  let literalExpression: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::Literal(Ast::Expression::Literal {
    span: SourceSpan::new("fixtures/ast_patterns.ign", 46, 47),
    value: Ast::Expression::LiteralValue::Int(0),
  }));

  bindingAttributeArguments.push(astText("input"));
  bindingAttributes.push(Ast::Attribute {
    span: SourceSpan::new("fixtures/ast_patterns.ign", 0, 13),
    name: astText("trace"),
    arguments: bindingAttributeArguments,
  });
  bindingModifiers.push(Ast::Modifier::Public);
  annotationSegments.push(astText("Packet"));
  let annotationType: Ast::TypeId = module.addType(Ast::Type::Node::Path(Ast::Type::Path {
    span: SourceSpan::new("fixtures/ast_patterns.ign", 22, 28),
    segments: annotationSegments,
  }));

  let bindingPattern: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: SourceSpan::new("fixtures/ast_patterns.ign", 14, 28),
    name: astText("value"),
    annotation: Option::SOME(annotationType),
    metadata: Ast::Metadata {
      attributes: bindingAttributes,
      modifiers: bindingModifiers,
    },
  }));
  let literalPattern: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Literal(Ast::Pattern::Literal {
    span: SourceSpan::new("fixtures/ast_patterns.ign", 46, 47),
    expression: literalExpression,
  }));
  let wildcardPattern: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Wildcard(Ast::Pattern::Wildcard {
    span: SourceSpan::new("fixtures/ast_patterns.ign", 49, 50),
  }));

  tupleElements.push(literalPattern);
  tupleElements.push(wildcardPattern);
  let tuplePattern: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Tuple(Ast::Pattern::Tuple {
    span: SourceSpan::new("fixtures/ast_patterns.ign", 45, 51),
    elements: tupleElements,
  }));

  pathSegments.push(astText("Option"));
  pathSegments.push(astText("SOME"));
  pathArguments.push(tuplePattern);
  pathArguments.push(bindingPattern);
  let pathPattern: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Path(Ast::Pattern::Path {
    span: SourceSpan::new("fixtures/ast_patterns.ign", 30, 58),
    segments: pathSegments,
    arguments: pathArguments,
  }));

  orAlternatives.push(pathPattern);
  orAlternatives.push(bindingPattern);
  module.addPattern(Ast::Pattern::Node::Or(Ast::Pattern::Or {
    span: SourceSpan::new("fixtures/ast_patterns.ign", 30, 66),
    alternatives: orAlternatives,
  }));

  let rendered: String = Ast::Serializer::render(&module);
  let expectedBinding: String = String::create("Binding span=fixtures/ast_patterns.ign:14-28 name=\"value\" annotation=type#0 metadata=attrs[@trace(input)@fixtures/ast_patterns.ign:0-13] modifiers[public]");
  let expectedLiteral: String = String::create("Literal span=fixtures/ast_patterns.ign:46-47 expression=expression#0");
  let expectedWildcard: String = String::create("Wildcard span=fixtures/ast_patterns.ign:49-50");
  let expectedTuple: String = String::create("Tuple span=fixtures/ast_patterns.ign:45-51 elements=[pattern#1, pattern#2]");
  let expectedPath: String = String::create("Path span=fixtures/ast_patterns.ign:30-58 segments=[\"Option\", \"SOME\"] arguments=[pattern#3, pattern#0]");
  let expectedOr: String = String::create("Or span=fixtures/ast_patterns.ign:30-66 alternatives=[pattern#4, pattern#0]");

  if (!rendered.contains(&expectedBinding)) {
    @panic("expected serializer to render binding pattern annotation and metadata");
  }

  if (!rendered.contains(&expectedLiteral)) {
    @panic("expected serializer to render literal pattern expression link");
  }

  if (!rendered.contains(&expectedWildcard)) {
    @panic("expected serializer to render wildcard pattern span");
  }

  if (!rendered.contains(&expectedTuple)) {
    @panic("expected serializer to render tuple pattern elements");
  }

  if (!rendered.contains(&expectedPath)) {
    @panic("expected serializer to render path pattern segments and arguments");
  }

  if (!rendered.contains(&expectedOr)) {
    @panic("expected serializer to render or-pattern alternatives");
  }
}

@test
function astModuleRepresentsExpandedParityVariantsWithTypedIds(): void {
  let mut module: Ast::Module = Ast::Module::init();
  let mut importItems: Vector<Ast::ImportBinding> = Vector::new<Ast::ImportBinding>();
  let mut vectorElements: Vector<Ast::ExpressionId> = Vector::new<Ast::ExpressionId>();
  let mut blockStatements: Vector<Ast::StatementId> = Vector::new<Ast::StatementId>();

  importItems.push(Ast::ImportBinding {
    span: SourceSpan::new("fixtures/ast_parity.ign", 188, 189),
    kind: Ast::ImportBindingKind::Discard,
    name: Option::NONE,
    alias: Option::NONE,
  });

  let bindingPattern: Ast::PatternId = module.addPattern(Ast::Pattern::Node::Binding(Ast::Pattern::Binding {
    span: SourceSpan::new("fixtures/ast_parity.ign", 0, 5),
    name: astText("value"),
    annotation: Option::NONE,
    metadata: Ast::emptyMetadata(),
  }));
  let variableExpression: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::Variable(Ast::Expression::Variable {
    span: SourceSpan::new("fixtures/ast_parity.ign", 6, 11),
    name: astText("value"),
  }));
  let fallbackExpression: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::Literal(Ast::Expression::Literal {
    span: SourceSpan::new("fixtures/ast_parity.ign", 12, 22),
    value: Ast::Expression::LiteralValue::String(String::create("fallback")),
  }));

  vectorElements.push(variableExpression);
  vectorElements.push(fallbackExpression);

  let vectorExpression: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::Vector(Ast::Expression::VectorLiteral {
    span: SourceSpan::new("fixtures/ast_parity.ign", 23, 40),
    elements: vectorElements,
  }));
  let memberAccessExpression: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::MemberAccess(Ast::Expression::MemberAccess {
    span: SourceSpan::new("fixtures/ast_parity.ign", 41, 53),
    object: variableExpression,
    operator: Ast::Expression::AccessOperator::Dot,
    member: astText("length"),
  }));
  let assignmentExpression: Ast::ExpressionId = module.addExpression(Ast::Expression::Node::Assignment(Ast::Expression::Assignment {
    span: SourceSpan::new("fixtures/ast_parity.ign", 54, 70),
    target: memberAccessExpression,
    value: vectorExpression,
    operator: Ast::Expression::AssignmentOperator::Assign,
  }));

  let breakStatement: Ast::StatementId = module.addStatement(Ast::Statement::Node::Break(Ast::Statement::Break {
    span: SourceSpan::new("fixtures/ast_parity.ign", 71, 76),
    value: Option::SOME(fallbackExpression),
  }));
  let variableStatement: Ast::StatementId = module.addStatement(Ast::Statement::Node::Variable(Ast::Statement::Variable {
    span: SourceSpan::new("fixtures/ast_parity.ign", 77, 99),
    mutable: true,
    pattern: bindingPattern,
    annotation: Option::NONE,
    value: Option::SOME(vectorExpression),
  }));
  let letElseStatement: Ast::StatementId = module.addStatement(Ast::Statement::Node::LetElse(Ast::Statement::LetElse {
    span: SourceSpan::new("fixtures/ast_parity.ign", 100, 134),
    pattern: bindingPattern,
    annotation: Option::NONE,
    value: variableExpression,
    elseBranch: breakStatement,
  }));

  blockStatements.push(variableStatement);
  blockStatements.push(letElseStatement);

  let blockStatement: Ast::StatementId = module.addStatement(Ast::Statement::Node::Block(Ast::Statement::Block {
    span: SourceSpan::new("fixtures/ast_parity.ign", 135, 180),
    statements: blockStatements,
    tail: Option::SOME(assignmentExpression),
  }));
  let importItem: Ast::ItemId = module.addItem(Ast::Item::Node::Import(Ast::Item::Import {
    span: SourceSpan::new("fixtures/ast_parity.ign", 181, 194),
    items: importItems,
    source: astText("std::io"),
    sourceSpan: SourceSpan::new("fixtures/ast_parity.ign", 190, 198),
    metadata: Ast::emptyMetadata(),
  }));
  let itemStatement: Ast::StatementId = module.addStatement(Ast::Statement::Node::Item(Ast::Statement::Item {
    span: SourceSpan::new("fixtures/ast_parity.ign", 181, 194),
    item: importItem,
  }));

  Test::assertEq<u64>(module.expressions.length(), 5);
  Test::assertEq<u64>(module.statements.length(), 5);
  Test::assertEq<u64>(module.items.length(), 1);

  match (module.expressions.get(assignmentExpression)) {
    Option::SOME(Ast::Expression::Node::Assignment(value)) -> {
      Test::assertEq<u32>(value.target.raw(), memberAccessExpression.raw());
      Test::assertEq<u32>(value.value.raw(), vectorExpression.raw());
    },
    _ -> @panic("missing assignment expression"),
  };

  match (module.expressions.get(memberAccessExpression)) {
    Option::SOME(Ast::Expression::Node::MemberAccess(value)) -> {
      Test::assertEq<u32>(value.object.raw(), variableExpression.raw());
      Test::assertEq<str>(value.member.toStr(), "length");
    },
    _ -> @panic("missing member access expression"),
  };

  match (module.statements.get(variableStatement)) {
    Option::SOME(Ast::Statement::Node::Variable(value)) -> {
      Test::assertEq<boolean>(value.mutable, true);
      Test::assertEq<u32>(value.pattern.raw(), bindingPattern.raw());
      Test::assertEq<u32>(match (value.value) {
        Option::SOME(expressionId) -> expressionId.raw(),
        Option::NONE -> @panic("missing variable value"),
      }, vectorExpression.raw());
    },
    _ -> @panic("missing variable statement"),
  };

  match (module.statements.get(letElseStatement)) {
    Option::SOME(Ast::Statement::Node::LetElse(value)) -> {
      Test::assertEq<u32>(value.pattern.raw(), bindingPattern.raw());
      Test::assertEq<u32>(value.value.raw(), variableExpression.raw());
      Test::assertEq<u32>(value.elseBranch.raw(), breakStatement.raw());
    },
    _ -> @panic("missing let-else statement"),
  };

  match (module.statements.get(blockStatement)) {
    Option::SOME(Ast::Statement::Node::Block(value)) -> {
      Test::assertEq<u64>(value.statements.length(), 2);
      Test::assertEq<u32>(match (value.tail) {
        Option::SOME(expressionId) -> expressionId.raw(),
        Option::NONE -> @panic("missing block tail"),
      }, assignmentExpression.raw());
    },
    _ -> @panic("missing block statement"),
  };

  match (module.statements.get(itemStatement)) {
    Option::SOME(Ast::Statement::Node::Item(value)) -> Test::assertEq<u32>(value.item.raw(), importItem.raw()),
    _ -> @panic("missing item statement"),
  };
}

@test
function astSerializerSnapshotIsDeterministicAndStable(): void {
  let module: Ast::Module = buildSnapshotModule(astText("main"));
  let snapshot: String = Ast::Serializer::render(&module);

  Test::assertSnapshot("ast-serializer-stable-module", snapshot.toStr());
}

@test
function astSerializerRendersEquivalentModulesIdentically(): void {
  let leftModule: Ast::Module = buildSnapshotModule(astText("main"));
  let rightModule: Ast::Module = buildSnapshotModule(astText("main"));
  let left: String = Ast::Serializer::render(&leftModule);
  let right: String = Ast::Serializer::render(&rightModule);
  let expected: str = expectedSnapshotText();

  Test::assertEq<str>(left.toStr(), right.toStr());
  Test::assertEq<str>(left.toStr(), expected);
}
