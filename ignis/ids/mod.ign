import Eq from "std::hash";

@implements(Copy, Eq, Display)
export record Id<Tag> {
  public id: u32;

  public static fromRaw(id: u32): Id<Tag> {
    return Id { id: id };
  }

  public raw(&self): u32 {
    return self.id;
  }

  public equals(&self, other: &Id<Tag>): boolean {
    return self.id == other.id;
  }

  public display(&self): String {
    return String::create("Id(").concat(self.id).concat(")");
  }
}
