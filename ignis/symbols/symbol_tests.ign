import Test from "std::test";

import Symbol from "@compiler::symbols";

@test
function symbolConstructionReturnsRawId(): void {
  let symbol: Symbol = Symbol::fromRaw(42);

  if (symbol.raw() != 42) {
    @panic("symbol raw id mismatch");
  }
}

@test
function symbolEqualityComparesRawIds(): void {
  let left: Symbol = Symbol::fromRaw(7);
  let right: Symbol = Symbol::fromRaw(7);
  let other: Symbol = Symbol::fromRaw(8);

  if (!@eq<Symbol>(&left, &right)) {
    @panic("symbols with matching ids are not equal");
  }

  if (@eq<Symbol>(&left, &other)) {
    @panic("symbols with different ids are equal");
  }
}

@test
function symbolIsCopy(): void {
  let original: Symbol = Symbol::fromRaw(99);
  let copied: Symbol = original;

  if (original.raw() != 99) {
    @panic("original symbol changed after copy");
  }

  if (copied.raw() != 99) {
    @panic("copied symbol raw id mismatch");
  }
}

@test
function symbolRenderIsExplicitAndStable(): void {
  let symbol: Symbol = Symbol::fromRaw(7);

  Test::assertEq<str>(symbol.display().toStr(), "Symbol(7)");
}
