import Eq from "std::hash";

@implements(Copy, Eq, Display)
export record Symbol {
  id: u32;

  public static fromRaw(id: u32): Symbol {
    return Symbol { id: id };
  }

  public raw(&self): u32 {
    return self.id;
  }

  public equals(&self, other: &Symbol): boolean {
    return self.id == other.id;
  }

  public display(&self): String {
    return String::create("Symbol(").concat(self.id).concat(")");
  }
}
