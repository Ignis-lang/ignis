// Test: enums preserve @implements(Eq) for generic bounds
// Expected: no diagnostics

trait Eq {
}

@implements(Eq)
enum Status {
  OK,
  ERROR,

  equals(&self, other: &Status): boolean {
    return true;
  }
}

record Box<T: Eq> {
  public value: T;
}

function main(): i32 {
  let _wrapped: Box<Status> = Box { value: Status::OK };
  return 0;
}
