// Test: Immutable slices stay Copy even when their element type is non-Copy

@implements(Drop)
record Tracker {
    public id: i32;
    drop(&mut self): void { return; }
}

function firstId(values: Tracker[]): i32 {
    return values[0].id;
}

function main(): i32 {
    let data: Tracker[1] = [Tracker { id: 7 }];
    let view: Tracker[] = data;
    let copy: Tracker[] = view;

    return firstId(copy);
}
