// Test: Cannot mutate a record-backed buffer while a borrowed slice view is alive

record Buffer {
    values: i32[2];

    public toSlice(&self): i32[] {
        return self.values;
    }

    public push(&mut self, value: i32): void {
        self.values[0] = value;
    }
}

function main(): void {
    let mut data: Buffer = Buffer { values: [1, 2] };
    let view: i32[] = data.toSlice();
    data.push(3);
    let first: i32 = view[0];
    return;
}
