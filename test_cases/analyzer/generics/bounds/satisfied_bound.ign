trait Hash {
  hash(&self): i32;
}

@implements(Hash)
record Key {
  public value: i32;

  hash(&self): i32 {
    return self.value;
  }
}

function hashValue<T: Hash>(value: T): i32 {
  return value.hash();
}

function main(): i32 {
  let key: Key = Key { value: 42 };
  return hashValue<Key>(key);
}
