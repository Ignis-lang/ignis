//! Compile-time-only std placeholders for directive execution.
//!
//! This module is intentionally minimal in Phase 4.1. It exists so the std
//! manifest can classify `std::compile` as opt-in and compile-time-only without
//! exposing any runtime functions or linkable ABI.

/// Placeholder compile-time context type.
///
/// This empty record is a stub for later directive-only APIs.
export record Context {}
