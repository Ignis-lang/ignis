import String from "std::string";
import Test from "std::test";
import Vector from "std::vector";

@implements(Drop)
record Tracker {
  counter: *mut i32;
  public marker: i32;

  drop(&mut self): void {
    *self.counter = *self.counter * 10 + self.marker;
  }
}

function sumFirstThreeMarkers(values: Tracker[]): i32 {
  return values[0].marker + values[1].marker + values[2].marker;
}

function sumFirstThreeBytes(bytes: u8[]): u32 {
  return (bytes[0] as u32) + (bytes[1] as u32) + (bytes[2] as u32);
}

@test
function toSlicePassesVectorStorageAsSlice(): void {
  let mut drops: i32 = 0;
  let mut values: Vector<Tracker> = Vector::new<Tracker>();
  values.push(Tracker { counter: (&mut drops) as *mut i32, marker: 10 });
  values.push(Tracker { counter: (&mut drops) as *mut i32, marker: 20 });
  values.push(Tracker { counter: (&mut drops) as *mut i32, marker: 30 });

  let view: Tracker[] = values.toSlice();

  Test::assertEq<i32>(sumFirstThreeMarkers(view), 60);
}

@test
function toSliceExposesPushedBytesInOrder(): void {
  let mut bytes: Vector<u8> = Vector::new<u8>();
  bytes.push(10 as u8);
  bytes.push(20 as u8);
  bytes.push(30 as u8);

  let view: u8[] = bytes.toSlice();

  Test::assertEq<u32>(sumFirstThreeBytes(view), 60 as u32);
}

@test
function clearDropsStringElementsBeforeReuse(): void {
  let mut values: Vector<String> = Vector::new<String>();
  values.push(String::create("alpha"));
  values.push(String::create("beta"));

  values.clear();

  Test::assertEq<u64>(values.length(), 0);

  values.push(String::create("gamma"));

  Test::assertEq<u64>(values.length(), 1);
}

@test
function newWithCapacityStartsEmptyAndPreservesCapacity(): void {
  let mut values: Vector<String> = Vector::new<String>(8 as u64);

  Test::assertEq<u64>(values.length(), 0);

  values.push(String::create("alpha"));
  values.push(String::create("beta"));

  Test::assertEq<u64>(values.length(), 2);
}

@test
function dropDropsStringElements(): void {
  let mut drops: i32 = 0;

  {
    let mut values: Vector<Tracker> = Vector::new<Tracker>();
    values.push(Tracker { counter: (&mut drops) as *mut i32, marker: 4 });
    values.push(Tracker { counter: (&mut drops) as *mut i32, marker: 5 });
  }

  Test::assertEq<i32>(drops, 45);
}

@test
function clearAndDropRunElementDropExactlyOnce(): void {
  let mut directDrop: i32 = 0;
  let mut drops: i32 = 0;

  let mut probe: Tracker = Tracker { counter: (&mut directDrop) as *mut i32, marker: 9 };
  probe.drop();
  Test::assertEq<i32>(directDrop, 9);

  {
    let mut values: Vector<Tracker> = Vector::new<Tracker>();
    values.push(Tracker { counter: (&mut drops) as *mut i32, marker: 1 });
    values.push(Tracker { counter: (&mut drops) as *mut i32, marker: 2 });

    values.clear();

    Test::assertEq<i32>(drops, 12);

    values.push(Tracker { counter: (&mut drops) as *mut i32, marker: 3 });
  }

  Test::assertEq<i32>(drops, 123);
}
