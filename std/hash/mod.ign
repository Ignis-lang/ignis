@extension(str)
/// Implements `Hash` for NUL-terminated string views.
function hash(value: str, hasher: &mut Hasher): void {
  let mut state: &mut Hasher = hasher;
  state.writeStr(value);
}

@extension(str)
/// Implements byte-wise equality for NUL-terminated string views.
///
/// Comparison stops at the first NUL byte in either view. Use owned `String`
/// equality when interior NUL bytes must participate in comparison.
function equals(value: str, other: str): boolean {
  let left: *u8 = value as *u8;
  let right: *u8 = other as *u8;
  let mut index: u64 = 0;

  while (true) {
    let leftByte: u8 = *(left + index);
    let rightByte: u8 = *(right + index);

    if (leftByte != rightByte) {
      return false;
    }

    if (leftByte == 0) {
      return true;
    }

    index += 1;
  }

  return true;
}
