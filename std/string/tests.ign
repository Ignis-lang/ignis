import Hasher from "std::hash";
import Memory from "std::memory";
import String, Utf8Cursor, Utf8ScalarSpan from "std::string";
import Test from "std::test";

function hashString(value: &String): u64 {
  let mut hasher: Hasher = Hasher::new();
  value.hash(&mut hasher);
  return hasher.finish();
}

function buildInteriorNulString(last: char): String {
  let mut value: String = String::new();
  value.pushChar('a');
  value.pushChar('\0');
  value.pushChar(last);
  return value;
}

function nextScalar(cursor: &mut Utf8Cursor): Utf8ScalarSpan {
  let mut stream: &mut Utf8Cursor = cursor;

  let Option::SOME(value) = stream.advance() else {
    Test::fail();
    @unreachable();
  };

  return value;
}

function utf8SampleString(): String {
  let raw: *mut u8 = Memory::allocateVector<u8>(6);

  @write<u8>(raw, 'a' as u8);
  @write<u8>(raw + 1, 195 as u8);
  @write<u8>(raw + 2, 169 as u8);
  @write<u8>(raw + 3, 228 as u8);
  @write<u8>(raw + 4, 184 as u8);
  @write<u8>(raw + 5, 173 as u8);

  return String::create(raw, 6 as u64);
}

function utf8TailString(): String {
  let raw: *mut u8 = Memory::allocateVector<u8>(5);

  @write<u8>(raw, 195 as u8);
  @write<u8>(raw + 1, 169 as u8);
  @write<u8>(raw + 2, 228 as u8);
  @write<u8>(raw + 3, 184 as u8);
  @write<u8>(raw + 4, 173 as u8);

  return String::create(raw, 5 as u64);
}

@test
function hashEqualStringsMatchAndDifferentStringsDiverge(): void {
  let first: String = String::create("alpha");
  let second: String = String::create("alpha");
  let third: String = String::create("beta");

  let firstHash: u64 = hashString(&first);
  let secondHash: u64 = hashString(&second);
  let thirdHash: u64 = hashString(&third);

  Test::assertEq<u64>(firstHash, secondHash);
  Test::assertNe<u64>(firstHash, thirdHash);
}

@test
function hashPreservesInteriorNulBytes(): void {
  let first: String = buildInteriorNulString('b');
  let second: String = buildInteriorNulString('b');
  let third: String = buildInteriorNulString('c');

  let firstHash: u64 = hashString(&first);
  let secondHash: u64 = hashString(&second);
  let thirdHash: u64 = hashString(&third);

  Test::assertEq<u64>(firstHash, secondHash);
  Test::assertNe<u64>(firstHash, thirdHash);
}

@test
function toStrIsZeroCopyBorrowedView(): void {
  let owned: String = String::create("hello");
  let view: str = owned.toStr();

  let viewPtr: u64 = @integerFromPointer(view as *u8);
  let selfPtr: u64 = @integerFromPointer(owned.toStr() as *u8);

  Test::assertEq<u64>(viewPtr, selfPtr);

  let trailing: u8 = @integerFromPointer(view as *u8) + owned.length()
    |> @pointerFromInteger<*mut u8>(_)
    |> @read<u8>(_);

  Test::assertEq<u8>(trailing, 0);
}

@test
function createFromStrCopiesAndPreservesTrailingNul(): void {
  let raw: *mut u8 = Memory::allocateVector<u8>(6);

  @write<u8>(raw, 'h' as u8);
  @write<u8>(raw + 1, 'e' as u8);
  @write<u8>(raw + 2, 'l' as u8);
  @write<u8>(raw + 3, 'l' as u8);
  @write<u8>(raw + 4, 'o' as u8);
  @write<u8>(raw + 5, 0);

  let owned: String = String::create(raw as str);
  @write<u8>(raw, 'j' as u8);

  let firstByte: char = match (owned.charAt(0)) {
    Option::SOME(value) -> value,
    _ -> '?',
  };

  Test::assertEq<char>(firstByte, 'h');

  let trailing: u8 = @integerFromPointer(owned.toStr() as *u8) + owned.length()
    |> @pointerFromInteger<*mut u8>(_)
    |> @read<u8>(_);

  Test::assertEq<u8>(trailing, 0);

  Memory::free(raw);
}

@test
function asBytesBorrowsOwnedBytesAndPreservesInteriorNul(): void {
  let owned: String = buildInteriorNulString('b');
  let bytes: u8[] = owned.asBytes();

  Test::assertEq<u8>(bytes[0], 'a' as u8);
  Test::assertEq<u8>(bytes[1], 0);
  Test::assertEq<u8>(bytes[2], 'b' as u8);
}

@test
function strAsBytesBorrowsUntilTerminatingNul(): void {
  let text: str = "az";
  let bytes: u8[] = text.asBytes();

  Test::assertEq<u8>(bytes[0], 'a' as u8);
  Test::assertEq<u8>(bytes[1], 'z' as u8);
}

@test
function strToCharsCopiesAsciiBytesIntoOwnedVector(): void {
  let text: str = "az";
  let chars: Vector<char> = text.toChars();
  let data: *mut char = chars.asPtr() as *mut char;

  Test::assertEq<u64>(chars.length(), 2);
  Test::assertEq<char>(@read<char>(data), 'a');
  Test::assertEq<char>(@read<char>(data + 1), 'z');
}

@test
function strToCharsStopsAtFirstTerminatingNul(): void {
  let raw: *mut u8 = Memory::allocateVector<u8>(4);

  @write<u8>(raw, 'a' as u8);
  @write<u8>(raw + 1, 'z' as u8);
  @write<u8>(raw + 2, 0);
  @write<u8>(raw + 3, 'q' as u8);

  let text: str = raw as str;
  let chars: Vector<char> = text.toChars();
  let data: *mut char = chars.asPtr() as *mut char;

  Test::assertEq<u64>(chars.length(), 2);
  Test::assertEq<char>(@read<char>(data), 'a');
  Test::assertEq<char>(@read<char>(data + 1), 'z');

  Memory::free(raw);
}

@test
function charAtDecodesUtf8ScalarAtByteBoundary(): void {
  let raw: *mut u8 = Memory::allocateVector<u8>(6);
  @write<u8>(raw, 'a' as u8);
  @write<u8>(raw + 1, 195 as u8);
  @write<u8>(raw + 2, 169 as u8);
  @write<u8>(raw + 3, 228 as u8);
  @write<u8>(raw + 4, 184 as u8);
  @write<u8>(raw + 5, 173 as u8);

  let text: String = String::create(raw, 6 as u64);

  let first: char = match (text.charAt(0)) {
    Option::SOME(value) -> value,
    Option::NONE -> '?',
  };
  let accented: char = match (text.charAt(1)) {
    Option::SOME(value) -> value,
    Option::NONE -> '?',
  };
  let ideograph: char = match (text.charAt(3)) {
    Option::SOME(value) -> value,
    Option::NONE -> '?',
  };

  Test::assertEq<i32>(first as i32, 'a' as i32);
  Test::assertEq<i32>(accented as i32, 233);
  Test::assertEq<i32>(ideograph as i32, 20013);

  Memory::free(raw);
}

@test
function pushCharEncodesScalarUtf8BytesAndPushByteStaysByteOriented(): void {
  let mut text: String = String::new();
  text.pushChar('é');
  text.pushByte('!' as u8);

  let first: u8 = match (text.byteAt(0)) {
    Option::SOME(value) -> value,
    Option::NONE -> 0,
  };
  let second: u8 = match (text.byteAt(1)) {
    Option::SOME(value) -> value,
    Option::NONE -> 0,
  };
  let third: u8 = match (text.byteAt(2)) {
    Option::SOME(value) -> value,
    Option::NONE -> 0,
  };

  Test::assertEq<u64>(text.length(), 3);
  Test::assertEq<u8>(first, 195 as u8);
  Test::assertEq<u8>(second, 169 as u8);
  Test::assertEq<u8>(third, '!' as u8);
}

@test
function byteAtReadsRawUtf8BytesWithoutScalarDecoding(): void {
  let raw: *mut u8 = Memory::allocateVector<u8>(2);
  @write<u8>(raw, 195 as u8);
  @write<u8>(raw + 1, 169 as u8);

  let text: String = String::create(raw, 2 as u64);

  let first: u8 = match (text.byteAt(0)) {
    Option::SOME(value) -> value,
    Option::NONE -> 0,
  };
  let second: u8 = match (text.byteAt(1)) {
    Option::SOME(value) -> value,
    Option::NONE -> 0,
  };

  Test::assertEq<u8>(first, 195 as u8);
  Test::assertEq<u8>(second, 169 as u8);

  Memory::free(raw);
}

@test
function stringHelpersCoverPrefixesSlicesTrimmingAndLines(): void {
  let text: String = String::create("  alpha\nbeta\n  ");
  let trimmed: String = text.trimAsciiWhitespace();
  let expectedFirstLine: str = "alpha";
  let lines: Vector<String> = trimmed.lines();
  let firstLine: &String = match (lines.get(0)) {
    Option::SOME(value) -> value,
    Option::NONE -> {
      Test::fail();
      @unreachable();
    },
  };
  let secondLine: &String = match (lines.get(1)) {
    Option::SOME(value) -> value,
    Option::NONE -> {
      Test::fail();
      @unreachable();
    },
  };

  Test::assert(text.startsWith("  al"));
  Test::assert(!text.startsWith("alpha"));
  Test::assert(trimmed.equals("alpha\nbeta"));
  Test::assert(expectedFirstLine.equals(firstLine.toStr()));
  Test::assertEq<u64>(match (text.indexOfCharFrom('a', 0)) { Option::SOME(value) -> value, Option::NONE -> 99 }, 2);
  Test::assertEq<str>(trimmed.toStr(), "alpha\nbeta");
  Test::assertEq<u64>(lines.length(), 2);
  Test::assertEq<str>(firstLine.toStr(), "alpha");
  Test::assertEq<str>(secondLine.toStr(), "beta");
}

@test
function utf8CursorAdvancesByScalarBoundaries(): void {
  let source: String = utf8SampleString();
  let mut cursor: Utf8Cursor = source.cursor();

  let first: Utf8ScalarSpan = nextScalar(&mut cursor);
  Test::assertEq<u32>(first.codepoint, 'a' as u32);
  Test::assertEq<u64>(first.startByte, 0);
  Test::assertEq<u64>(first.endByte, 1);

  let second: Utf8ScalarSpan = nextScalar(&mut cursor);
  Test::assertEq<u32>(second.codepoint, 233);
  Test::assertEq<u64>(second.startByte, 1);
  Test::assertEq<u64>(second.endByte, 3);

  let third: Utf8ScalarSpan = nextScalar(&mut cursor);
  Test::assertEq<u32>(third.codepoint, 20013);
  Test::assertEq<u64>(third.startByte, 3);
  Test::assertEq<u64>(third.endByte, 6);

  Test::assert(cursor.isAtEnd());
}

@test
function utf8CursorSlicesByByteRange(): void {
  let source: String = utf8SampleString();
  let cursor: Utf8Cursor = source.cursor();
  let value: String = cursor.slice(1, 6);
  let expected: String = utf8TailString();

  Test::assert(value.equals(&expected));
}

@test
function utf8CursorEatAsciiConsumesOnlyMatchingAscii(): void {
  let source: String = utf8SampleString();
  let mut cursor: Utf8Cursor = source.cursor();

  Test::assert(cursor.eatAscii('a'));
  Test::assertEq<u64>(cursor.position(), 1);

  Test::assert(!cursor.eatAscii('a'));
  Test::assertEq<u64>(cursor.position(), 1);

  Test::assert(!cursor.eatAscii('b'));
  Test::assertEq<u64>(cursor.position(), 1);
}

@test
function forEachDecodesUtf8Scalars(): void {
  let raw: *mut u8 = Memory::allocateVector<u8>(6);
  @write<u8>(raw, 'a' as u8);
  @write<u8>(raw + 1, 195 as u8);
  @write<u8>(raw + 2, 169 as u8);
  @write<u8>(raw + 3, 228 as u8);
  @write<u8>(raw + 4, 184 as u8);
  @write<u8>(raw + 5, 173 as u8);

  let text: String = String::create(raw, 6 as u64);
  let visited: *mut char = Memory::allocateVector<char>(3);
  let index: *mut u64 = Memory::allocateVector<u64>(1);
  @write<u64>(index, 0);

  text.forEach((value: char): void -> {
    let current: u64 = @read<u64>(index);
    @write<char>(visited + current, value);
    @write<u64>(index, current + 1);
  });

  let count: u64 = @read<u64>(index);
  let first: char = @read<char>(visited);
  let accented: char = @read<char>(visited + 1);
  let ideograph: char = @read<char>(visited + 2);

  Test::assertEq<u64>(count, 3);
  Test::assertEq<i32>(first as i32, 'a' as i32);
  Test::assertEq<i32>(accented as i32, 233);
  Test::assertEq<i32>(ideograph as i32, 20013);

  Memory::free(visited);
  Memory::free(index as *mut u8);
  Memory::free(raw);
}

@test
function mapDecodesUtf8Scalars(): void {
  let raw: *mut u8 = Memory::allocateVector<u8>(5);
  @write<u8>(raw, 195 as u8);
  @write<u8>(raw + 1, 169 as u8);
  @write<u8>(raw + 2, 228 as u8);
  @write<u8>(raw + 3, 184 as u8);
  @write<u8>(raw + 4, 173 as u8);

  let text: String = String::create(raw, 5 as u64);
  let mapped: String = text.map((value: char): char -> {
    if (value == 'é') {
      return 'x';
    }

    if (value == 20013 as char) {
      return 'y';
    }

    return '?';
  });

  let first: char = match (mapped.charAt(0)) {
    Option::SOME(value) -> value,
    Option::NONE -> '?',
  };
  let second: char = match (mapped.charAt(1)) {
    Option::SOME(value) -> value,
    Option::NONE -> '?',
  };

  Test::assertEq<u64>(mapped.length(), 2);
  Test::assertEq<char>(first, 'x');
  Test::assertEq<char>(second, 'y');

  Memory::free(raw);
}

@test
function snapshotStdRunnerSmoke(): void {
  Test::assertSnapshot("smoke", "std-string-smoke\n");
}
