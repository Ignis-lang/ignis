//! # Serializer Trait
//!
//! Shared format-agnostic record serialization contract.

import _ from "std::serializer::error";
import _ from "std::serializer::writer";

export trait Serialize {
  serialize(
    &self,
    output: &mut String,
    writer: &Serializer::Writer
  ): Result<boolean, Serializer::Error>;
}
