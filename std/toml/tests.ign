import Math from "std::math";
import Memory from "std::memory";
import Test from "std::test";
import Toml from "std::toml";
import Vector from "std::vector";
import TomlError, TomlErrorKind from "./error";
import TomlSpan, TomlToken, TomlTokenKind from "./token";
import TomlArray, TomlDateTimeKind, TomlDocument, TomlParserCursor, TomlTable, TomlValue, TomlValueKind from "./value";

function tokenAt(tokens: &Vector<TomlToken>, index: u64): &TomlToken {
  let Option::SOME(token) = Toml::tokenAt(tokens, index) else {
    Test::fail();
    @unreachable();
  };

  return token;
}

function expectTokens(source: str, tokens: &mut Vector<TomlToken>): void {
  if (let Option::SOME(_) = Toml::lexInto(source, tokens)) {
    Test::fail();
    @unreachable();
  }
}

function expectTokens(source: &String, tokens: &mut Vector<TomlToken>): void {
  if (let Option::SOME(_) = Toml::lexInto(source, tokens)) {
    Test::fail();
    @unreachable();
  }
}

function expectError(source: str, error: &mut TomlError): void {
  let mut output: &mut TomlError = error;
  let mut tokens: Vector<TomlToken> = Vector::init<TomlToken>();

  let Option::SOME(value) = Toml::lexInto(source, &mut tokens) else {
    Test::fail();
    @unreachable();
  };

  *output = value.clone();
}

function utf8TomlSource(): String {
  let raw: *mut u8 = Memory::allocateVector<u8>(18);

  @write<u8>(raw, 'n' as u8);
  @write<u8>(raw + 1, 'a' as u8);
  @write<u8>(raw + 2, 'm' as u8);
  @write<u8>(raw + 3, 'e' as u8);
  @write<u8>(raw + 4, ' ' as u8);
  @write<u8>(raw + 5, '=' as u8);
  @write<u8>(raw + 6, ' ' as u8);
  @write<u8>(raw + 7, '"' as u8);
  @write<u8>(raw + 8, 'c' as u8);
  @write<u8>(raw + 9, 'a' as u8);
  @write<u8>(raw + 10, 'f' as u8);
  @write<u8>(raw + 11, 195 as u8);
  @write<u8>(raw + 12, 169 as u8);
  @write<u8>(raw + 13, ' ' as u8);
  @write<u8>(raw + 14, 228 as u8);
  @write<u8>(raw + 15, 184 as u8);
  @write<u8>(raw + 16, 173 as u8);
  @write<u8>(raw + 17, '"' as u8);

  return String::create(raw, 18 as u64);
}

function utf8TomlValue(): String {
  let raw: *mut u8 = Memory::allocateVector<u8>(9);

  @write<u8>(raw, 'c' as u8);
  @write<u8>(raw + 1, 'a' as u8);
  @write<u8>(raw + 2, 'f' as u8);
  @write<u8>(raw + 3, 195 as u8);
  @write<u8>(raw + 4, 169 as u8);
  @write<u8>(raw + 5, ' ' as u8);
  @write<u8>(raw + 6, 228 as u8);
  @write<u8>(raw + 7, 184 as u8);
  @write<u8>(raw + 8, 173 as u8);

  return String::create(raw, 9 as u64);
}

function assertTokenKind(actual: TomlTokenKind, expected: TomlTokenKind): void {
  Test::assert(actual == expected);
}

function assertErrorKind(actual: TomlErrorKind, expected: TomlErrorKind): void {
  Test::assert(actual == expected);
}

function expectParse(source: str): TomlDocument {
  let Result::OK(document) = Toml::parse(source) else {
    Test::fail();
    @unreachable();
  };

  return document;
}

function expectParse(source: &String): TomlDocument {
  let Result::OK(document) = Toml::parse(source) else {
    Test::fail();
    @unreachable();
  };

  return document;
}

function expectParseError(source: str, error: &mut TomlError): void {
  let mut output: &mut TomlError = error;
  let Result::ERROR(value) = Toml::parse(source) else {
    Test::fail();
    @unreachable();
  };

  *output = value.clone();
}

function assertSpan(span: TomlSpan, start: u64, end: u64): void {
  Test::assertEq<u64>(span.start, start);
  Test::assertEq<u64>(span.end, end);
}

function assertStringText(actual: str, expected: str): void {
  let expectedText: String = String::create(expected);
  let actualText: String = String::create(actual);
  Test::assert(actualText.equals(&expectedText));
}

function assertValueIsInteger(
  value: TomlValue,
  expected: i64,
  start: u64,
  end: u64,
  keyStart: u64,
  keyEnd: u64
): void {
  Test::assert(value.kind() == TomlValueKind::INTEGER);
  Test::assertEq<i64>(value.asInteger(), expected);
  assertSpan(value.span, start, end);
  assertSpan(value.keySpan, keyStart, keyEnd);
}

function assertValueIsFloat(
  value: TomlValue,
  expected: f64,
  start: u64,
  end: u64,
  keyStart: u64,
  keyEnd: u64
): void {
  Test::assert(value.kind() == TomlValueKind::FLOAT);
  Test::assert(Math::fabs(value.asFloat() - expected) < 0.000001);
  assertSpan(value.span, start, end);
  assertSpan(value.keySpan, keyStart, keyEnd);
}

function assertValueIsBoolean(
  value: TomlValue,
  expected: boolean,
  start: u64,
  end: u64,
  keyStart: u64,
  keyEnd: u64
): void {
  Test::assert(value.kind() == TomlValueKind::BOOLEAN);
  Test::assertEq<boolean>(value.asBoolean(), expected);
  assertSpan(value.span, start, end);
  assertSpan(value.keySpan, keyStart, keyEnd);
}

function assertValueIsDateTime(
  value: TomlValue,
  expectedKind: TomlDateTimeKind,
  expectedRaw: str,
  start: u64,
  end: u64,
  keyStart: u64,
  keyEnd: u64,
): void {
  Test::assert(value.kind() == TomlValueKind::DATE_TIME);
  assertSpan(value.span, start, end);
  assertSpan(value.keySpan, keyStart, keyEnd);

  let Option::SOME(dateTime) = value.asDateTime() else {
    Test::fail();
    @unreachable();
  };

  Test::assert(dateTime.kind == expectedKind);
  assertStringText(dateTime.raw, expectedRaw);
}

function assertToken(
  token: &TomlToken,
  kind: TomlTokenKind,
  lexeme: str,
  start: u64,
  end: u64,
): void {
  assertTokenKind(token.kind, kind);

  let expectedLexeme: String = String::create(lexeme);
  Test::assert(token.lexeme.equals(&expectedLexeme));
  Test::assertEq<u64>(token.span.start, start);
  Test::assertEq<u64>(token.span.end, end);
}

@test
function lexSkipsCommentsAndEmitsNewlines(): void {
  let mut tokens: Vector<TomlToken> = Vector::init<TomlToken>();
  expectTokens("# lead\nname = true\n# tail\n", &mut tokens);

  Test::assertEq<u64>(Toml::tokenCount(&tokens), 7);
  assertToken(tokenAt(&tokens, 0), TomlTokenKind::NEWLINE, "\n", 6, 7);
  assertToken(tokenAt(&tokens, 1), TomlTokenKind::IDENTIFIER, "name", 7, 11);
  assertToken(tokenAt(&tokens, 2), TomlTokenKind::EQUALS, "=", 12, 13);
  assertToken(tokenAt(&tokens, 3), TomlTokenKind::BOOLEAN, "true", 14, 18);
  assertToken(tokenAt(&tokens, 4), TomlTokenKind::NEWLINE, "\n", 18, 19);
  assertToken(tokenAt(&tokens, 5), TomlTokenKind::NEWLINE, "\n", 25, 26);
  assertToken(tokenAt(&tokens, 6), TomlTokenKind::EOF, "", 26, 26);
}

@test
function lexRecognizesTablesDottedKeysArraysAndScalars(): void {
  let mut tokens: Vector<TomlToken> = Vector::init<TomlToken>();
  expectTokens("[package]\npath.to = [\"std\", \"ffi\"]\ncount = -42\nflag = false", &mut tokens);

  Test::assertEq<u64>(Toml::tokenCount(&tokens), 22);
  assertToken(tokenAt(&tokens, 0), TomlTokenKind::LEFT_BRACKET, "[", 0, 1);
  assertToken(tokenAt(&tokens, 1), TomlTokenKind::IDENTIFIER, "package", 1, 8);
  assertToken(tokenAt(&tokens, 2), TomlTokenKind::RIGHT_BRACKET, "]", 8, 9);
  assertToken(tokenAt(&tokens, 4), TomlTokenKind::IDENTIFIER, "path", 10, 14);
  assertToken(tokenAt(&tokens, 5), TomlTokenKind::DOT, ".", 14, 15);
  assertToken(tokenAt(&tokens, 6), TomlTokenKind::IDENTIFIER, "to", 15, 17);
  assertToken(tokenAt(&tokens, 8), TomlTokenKind::LEFT_BRACKET, "[", 20, 21);
  assertToken(tokenAt(&tokens, 9), TomlTokenKind::STRING, "std", 21, 26);
  assertToken(tokenAt(&tokens, 10), TomlTokenKind::COMMA, ",", 26, 27);
  assertToken(tokenAt(&tokens, 11), TomlTokenKind::STRING, "ffi", 28, 33);
  assertToken(tokenAt(&tokens, 12), TomlTokenKind::RIGHT_BRACKET, "]", 33, 34);
  assertToken(tokenAt(&tokens, 16), TomlTokenKind::INTEGER, "-42", 43, 46);
  assertToken(tokenAt(&tokens, 20), TomlTokenKind::BOOLEAN, "false", 54, 59);
  assertToken(tokenAt(&tokens, 21), TomlTokenKind::EOF, "", 59, 59);
}

@test
function lexRecognizesQuotedKeysAndQuotedStrings(): void {
  let mut tokens: Vector<TomlToken> = Vector::init<TomlToken>();
  expectTokens("\"alias-key\" = \"value\"\n", &mut tokens);

  Test::assertEq<u64>(Toml::tokenCount(&tokens), 5);
  assertToken(tokenAt(&tokens, 0), TomlTokenKind::STRING, "alias-key", 0, 11);
  assertToken(tokenAt(&tokens, 1), TomlTokenKind::EQUALS, "=", 12, 13);
  assertToken(tokenAt(&tokens, 2), TomlTokenKind::STRING, "value", 14, 21);
  assertToken(tokenAt(&tokens, 3), TomlTokenKind::NEWLINE, "\n", 21, 22);
  assertToken(tokenAt(&tokens, 4), TomlTokenKind::EOF, "", 22, 22);
}

@test
function lexPreservesUtf8QuotedStringContent(): void {
  let source: String = utf8TomlSource();
  let mut tokens: Vector<TomlToken> = Vector::init<TomlToken>();
  expectTokens(&source, &mut tokens);
  let expectedValue: String = utf8TomlValue();

  Test::assertEq<u64>(Toml::tokenCount(&tokens), 4);
  assertToken(tokenAt(&tokens, 0), TomlTokenKind::IDENTIFIER, "name", 0, 4);
  assertToken(tokenAt(&tokens, 1), TomlTokenKind::EQUALS, "=", 5, 6);
  Test::assert(tokenAt(&tokens, 2).lexeme.equals(&expectedValue));
  assertTokenKind(tokenAt(&tokens, 2).kind, TomlTokenKind::STRING);
  Test::assertEq<u64>(tokenAt(&tokens, 2).span.start, 7);
  Test::assertEq<u64>(tokenAt(&tokens, 2).span.end, 18);
  assertToken(tokenAt(&tokens, 3), TomlTokenKind::EOF, "", 18, 18);
}

@test
function lexReturnsTokensForBorrowedUtf8Source(): void {
  let source: String = utf8TomlSource();
  let Result::OK(tokens) = Toml::lex(&source) else {
    Test::fail();
    @unreachable();
  };
  let expectedValue: String = utf8TomlValue();

  Test::assertEq<u64>(Toml::tokenCount(&tokens), 4);
  assertToken(tokenAt(&tokens, 0), TomlTokenKind::IDENTIFIER, "name", 0, 4);
  Test::assert(tokenAt(&tokens, 2).lexeme.equals(&expectedValue));
  assertTokenKind(tokenAt(&tokens, 2).kind, TomlTokenKind::STRING);
  assertToken(tokenAt(&tokens, 3), TomlTokenKind::EOF, "", 18, 18);
}

@test
function lexReportsMalformedTokenSpan(): void {
  let mut error: TomlError = TomlError::unexpectedCharacter(TomlSpan::new(0, 0));
  expectError("@oops = 1", &mut error);

  assertErrorKind(error.kind, TomlErrorKind::UNEXPECTED_CHARACTER);
  Test::assertEq<u64>(error.span.start, 0);
  Test::assertEq<u64>(error.span.end, 1);
}

@test
function lexRecognizesInlineTableBracesAndFiniteFloatForms(): void {
  let mut tokens: Vector<TomlToken> = Vector::init<TomlToken>();
  expectTokens("point = { x = 1.5, y = -2e3 }\n", &mut tokens);

  Test::assertEq<u64>(Toml::tokenCount(&tokens), 13);
  assertToken(tokenAt(&tokens, 0), TomlTokenKind::IDENTIFIER, "point", 0, 5);
  assertToken(tokenAt(&tokens, 2), TomlTokenKind::LEFT_BRACE, "{", 8, 9);
  assertToken(tokenAt(&tokens, 5), TomlTokenKind::FLOAT, "1.5", 14, 17);
  assertToken(tokenAt(&tokens, 6), TomlTokenKind::COMMA, ",", 17, 18);
  assertToken(tokenAt(&tokens, 9), TomlTokenKind::FLOAT, "-2e3", 23, 27);
  assertToken(tokenAt(&tokens, 10), TomlTokenKind::RIGHT_BRACE, "}", 28, 29);
  assertToken(tokenAt(&tokens, 11), TomlTokenKind::NEWLINE, "\n", 29, 30);
  assertToken(tokenAt(&tokens, 12), TomlTokenKind::EOF, "", 30, 30);
}

@test
function lexRecognizesSpecialFloatForms(): void {
  let mut tokens: Vector<TomlToken> = Vector::init<TomlToken>();
  expectTokens("positive = +inf\nnegative = -nan\n", &mut tokens);

  Test::assertEq<u64>(Toml::tokenCount(&tokens), 9);
  assertToken(tokenAt(&tokens, 0), TomlTokenKind::IDENTIFIER, "positive", 0, 8);
  assertToken(tokenAt(&tokens, 2), TomlTokenKind::FLOAT, "+inf", 11, 15);
  assertToken(tokenAt(&tokens, 3), TomlTokenKind::NEWLINE, "\n", 15, 16);
  assertToken(tokenAt(&tokens, 4), TomlTokenKind::IDENTIFIER, "negative", 16, 24);
  assertToken(tokenAt(&tokens, 6), TomlTokenKind::FLOAT, "-nan", 27, 31);
  assertToken(tokenAt(&tokens, 7), TomlTokenKind::NEWLINE, "\n", 31, 32);
  assertToken(tokenAt(&tokens, 8), TomlTokenKind::EOF, "", 32, 32);
}

@test
function lexRecognizesLiteralStrings(): void {
  let mut tokens: Vector<TomlToken> = Vector::init<TomlToken>();
  expectTokens("path = 'C:\\Users\\node'\n", &mut tokens);

  Test::assertEq<u64>(Toml::tokenCount(&tokens), 5);
  assertToken(tokenAt(&tokens, 0), TomlTokenKind::IDENTIFIER, "path", 0, 4);
  assertToken(tokenAt(&tokens, 1), TomlTokenKind::EQUALS, "=", 5, 6);
  assertToken(tokenAt(&tokens, 2), TomlTokenKind::STRING, "C:\\Users\\node", 7, 22);
  assertToken(tokenAt(&tokens, 3), TomlTokenKind::NEWLINE, "\n", 22, 23);
  assertToken(tokenAt(&tokens, 4), TomlTokenKind::EOF, "", 23, 23);
}

@test
function lexRecognizesMultilineStrings(): void {
  let mut tokens: Vector<TomlToken> = Vector::init<TomlToken>();
  expectTokens("basic = \"\"\"line one\nline two\"\"\"\nliteral = '''raw \\\\ text\nnext'''\n", &mut tokens);

  Test::assertEq<u64>(Toml::tokenCount(&tokens), 9);
  assertToken(tokenAt(&tokens, 0), TomlTokenKind::IDENTIFIER, "basic", 0, 5);
  assertToken(tokenAt(&tokens, 2), TomlTokenKind::STRING, "line one\nline two", 8, 31);
  assertToken(tokenAt(&tokens, 3), TomlTokenKind::NEWLINE, "\n", 31, 32);
  assertToken(tokenAt(&tokens, 4), TomlTokenKind::IDENTIFIER, "literal", 32, 39);
  assertToken(tokenAt(&tokens, 6), TomlTokenKind::STRING, "raw \\\\ text\nnext", 42, 64);
  assertToken(tokenAt(&tokens, 7), TomlTokenKind::NEWLINE, "\n", 64, 65);
  assertToken(tokenAt(&tokens, 8), TomlTokenKind::EOF, "", 65, 65);
}

@test
function lexRecognizesBasicStringUnicodeEscapes(): void {
  let mut tokens: Vector<TomlToken> = Vector::init<TomlToken>();
  expectTokens("face = \"\\u0041\\U00000042\"\n", &mut tokens);

  Test::assertEq<u64>(Toml::tokenCount(&tokens), 5);
  assertToken(tokenAt(&tokens, 0), TomlTokenKind::IDENTIFIER, "face", 0, 4);
  assertToken(tokenAt(&tokens, 2), TomlTokenKind::STRING, "AB", 7, 25);
  assertToken(tokenAt(&tokens, 3), TomlTokenKind::NEWLINE, "\n", 25, 26);
  assertToken(tokenAt(&tokens, 4), TomlTokenKind::EOF, "", 26, 26);
}

@test
function lexRecognizesArrayOfTablesAndDateTimeLiterals(): void {
  let mut tokens: Vector<TomlToken> = Vector::init<TomlToken>();
  expectTokens("[[items]]\ncreated = 1979-05-27T07:32:00Z\nlocalDate = 1979-05-27\n", &mut tokens);

  Test::assertEq<u64>(Toml::tokenCount(&tokens), 15);
  assertToken(tokenAt(&tokens, 0), TomlTokenKind::LEFT_BRACKET, "[", 0, 1);
  assertToken(tokenAt(&tokens, 1), TomlTokenKind::LEFT_BRACKET, "[", 1, 2);
  assertToken(tokenAt(&tokens, 2), TomlTokenKind::IDENTIFIER, "items", 2, 7);
  assertToken(tokenAt(&tokens, 3), TomlTokenKind::RIGHT_BRACKET, "]", 7, 8);
  assertToken(tokenAt(&tokens, 4), TomlTokenKind::RIGHT_BRACKET, "]", 8, 9);
  assertToken(tokenAt(&tokens, 8), TomlTokenKind::DATE_TIME, "1979-05-27T07:32:00Z", 20, 40);
  assertToken(tokenAt(&tokens, 12), TomlTokenKind::DATE_TIME, "1979-05-27", 53, 63);
  assertToken(tokenAt(&tokens, 14), TomlTokenKind::EOF, "", 64, 64);
}

@test
function lexReportsInvalidEscapeSpan(): void {
  let mut error: TomlError = TomlError::unexpectedCharacter(TomlSpan::new(0, 0));
  expectError("name = \"bad\\q\"", &mut error);

  assertErrorKind(error.kind, TomlErrorKind::INVALID_ESCAPE);
  Test::assertEq<u64>(error.span.start, 11);
  Test::assertEq<u64>(error.span.end, 12);
}

@test
function lexReportsInvalidNumberSpan(): void {
  let mut error: TomlError = TomlError::unexpectedCharacter(TomlSpan::new(0, 0));
  expectError("value = 1_", &mut error);

  assertErrorKind(error.kind, TomlErrorKind::INVALID_NUMBER);
  Test::assertEq<u64>(error.span.start, 8);
  Test::assertEq<u64>(error.span.end, 10);
}

@test
function lexReportsInvalidDateTimeSpan(): void {
  let mut error: TomlError = TomlError::unexpectedCharacter(TomlSpan::new(0, 0));
  expectError("created = 1979-05-27T07:32:00+24:00", &mut error);

  assertErrorKind(error.kind, TomlErrorKind::INVALID_DATE_TIME);
  Test::assertEq<u64>(error.span.start, 10);
  Test::assertEq<u64>(error.span.end, 35);
}

@test
function tomlValueCreatesStringAndPreservesSpan(): void {
  let span: TomlSpan = TomlSpan::new(7, 14);
  let keySpan: TomlSpan = TomlSpan::new(0, 4);
  let value: TomlValue = TomlValue::string("ignis", span, keySpan);

  Test::assert(value.kind() == TomlValueKind::STRING);
  Test::assertEq<u64>(value.span.start, 7);
  Test::assertEq<u64>(value.span.end, 14);

  let Option::SOME(text) = value.asString() else {
    Test::fail();
    @unreachable();
  };

  let expected: String = String::create("ignis");
  let actual: String = String::create(text);
  Test::assert(actual.equals(&expected));
}

@test
function tomlValueArrayStoresNestedValues(): void {
  let span: TomlSpan = TomlSpan::new(0, 9);
  let keySpan: TomlSpan = TomlSpan::new(0, 4);
  let mut array: TomlArray = TomlArray::new(span);

  array.push(TomlValue::string("one", span, keySpan));
  array.push(TomlValue::string("two", span, keySpan));

  let value: TomlValue = TomlValue::array(array, span, keySpan);

  let Option::SOME(foundArray) = value.asArray() else {
    Test::fail();
    @unreachable();
  };

  Test::assertEq<u64>(foundArray.length(), 2);

  let Option::SOME(first) = foundArray.item(0) else {
    Test::fail();
    @unreachable();
  };

  let Option::SOME(firstText) = first.asString() else {
    Test::fail();
    @unreachable();
  };

  let expected: String = String::create("one");
  let actual: String = String::create(firstText);
  Test::assert(actual.equals(&expected));
}

@test
function tomlDocumentLooksUpRootStringValues(): void {
  let rootSpan: TomlSpan = TomlSpan::new(0, 20);
  let nameSpan: TomlSpan = TomlSpan::new(10, 14);
  let root: TomlTable = TomlTable::new(rootSpan);

  root.insert("name", TomlValue::string("ignis", nameSpan, nameSpan), nameSpan);

  let document: TomlDocument = TomlDocument::new(root, rootSpan);
  let Result::OK(name) = document.getString("name") else {
    Test::fail();
    @unreachable();
  };

  let expected: String = String::create("ignis");
  let actual: String = String::create(name);
  Test::assert(actual.equals(&expected));
}

@test
function tomlDocumentBaselineSupportsGetAndGetArrayQueries(): void {
  let rootSpan: TomlSpan = TomlSpan::new(0, 40);
  let titleKeySpan: TomlSpan = TomlSpan::new(0, 5);
  let titleValueSpan: TomlSpan = TomlSpan::new(8, 15);
  let featuresSpan: TomlSpan = TomlSpan::new(18, 32);
  let root: TomlTable = TomlTable::new(rootSpan);
  let mut features: TomlArray = TomlArray::new(featuresSpan);

  features.push(TomlValue::string("lexer", TomlSpan::new(19, 26), titleKeySpan));
  features.push(TomlValue::string("parser", TomlSpan::new(28, 36), titleKeySpan));

  root.insert("title", TomlValue::string("ignis", titleValueSpan, titleKeySpan), titleKeySpan);
  root.insert("features", TomlValue::array(features, featuresSpan, TomlSpan::new(18, 26)), TomlSpan::new(18, 26));

  let document: TomlDocument = TomlDocument::new(root, rootSpan);
  let Option::SOME(titleValue) = document.get("title") else {
    Test::fail();
    @unreachable();
  };

  let Option::SOME(title) = titleValue.asString() else {
    Test::fail();
    @unreachable();
  };

  assertStringText(title, "ignis");

  let Result::OK(array) = document.getArray("features") else {
    Test::fail();
    @unreachable();
  };

  Test::assertEq<u64>(array.length(), 2);
}

// Parser completion stays Ignis-only; do not route Rust config parsing through std::toml.

@test
function parseSupportsOwnedAndBorrowedSources(): void {
  let ownedSource: String = String::create("title = \"Ignis\"\nanswer = 42\n");
  let ownedDocument: TomlDocument = expectParse(&ownedSource);
  let borrowedDocument: TomlDocument = expectParse("title = \"Ignis\"\nanswer = 42\n");

  let Result::OK(ownedTitle) = ownedDocument.getString("title") else {
    Test::fail();
    @unreachable();
  };
  let Result::OK(borrowedTitle) = borrowedDocument.getString("title") else {
    Test::fail();
    @unreachable();
  };

  assertStringText(ownedTitle, "Ignis");
  assertStringText(borrowedTitle, "Ignis");
}

@test
function parserCursorTracksPeekAdvanceExpectAndSkipNewlines(): void {
  let Result::OK(tokens) = Toml::lex("\nname = true\n") else {
    Test::fail();
    @unreachable();
  };
  let ownedTokens: Vector<TomlToken> = tokens;
  let mut cursor: TomlParserCursor = TomlParserCursor::create(&ownedTokens);

  let Option::SOME(first) = cursor.peekKind() else {
    Test::fail();
    @unreachable();
  };

  assertTokenKind(first, TomlTokenKind::NEWLINE);
  cursor.skipNewlines();

  let matchedIdentifier: boolean = cursor.matchKind(TomlTokenKind::IDENTIFIER);
  Test::assertEq<boolean>(matchedIdentifier, true);
  let expectedEqualsResult: Result<TomlSpan, TomlError> = cursor.expect(TomlTokenKind::EQUALS);
  let Result::OK(expectedEqualsSpan) = expectedEqualsResult else {
    Test::fail();
    @unreachable();
  };
  assertSpan(expectedEqualsSpan, 6, 7);

  let Option::SOME(booleanToken) = cursor.advance() else {
    Test::fail();
    @unreachable();
  };

  assertTokenKind(booleanToken, TomlTokenKind::BOOLEAN);
}

@test
function parseReadsScalarKindsAndPreservesSpans(): void {
  let document: TomlDocument = expectParse(
    "title = \"Ignis\"\ncount = 42\nratio = 3.5\nflag = true\ncreated = 1979-05-27T07:32:00Z\n",
  );

  let Option::SOME(title) = document.get("title") else {
    Test::fail();
    @unreachable();
  };
  let Option::SOME(titleText) = title.asString() else {
    Test::fail();
    @unreachable();
  };

  assertStringText(titleText, "Ignis");
  assertSpan(title.span, 8, 15);
  assertSpan(title.keySpan, 0, 5);

  let Option::SOME(count) = document.get("count") else {
    Test::fail();
    @unreachable();
  };
  let Option::SOME(ratio) = document.get("ratio") else {
    Test::fail();
    @unreachable();
  };
  let Option::SOME(flag) = document.get("flag") else {
    Test::fail();
    @unreachable();
  };
  let Option::SOME(created) = document.get("created") else {
    Test::fail();
    @unreachable();
  };

  assertValueIsInteger(count, 42, 24, 26, 16, 21);
  assertValueIsFloat(ratio, 3.5, 35, 38, 27, 32);
  assertValueIsBoolean(flag, true, 46, 50, 39, 43);
  assertValueIsDateTime(created, TomlDateTimeKind::OFFSET_DATE_TIME, "1979-05-27T07:32:00Z", 61, 81, 51, 58);
}

@test
function parseRejectsMalformedTopLevelItemsWithUnexpectedToken(): void {
  let mut error: TomlError = TomlError::unexpectedToken(TomlSpan::new(0, 0));
  expectParseError("title = \"Ignis\" count = 42", &mut error);

  assertErrorKind(error.kind, TomlErrorKind::UNEXPECTED_TOKEN);
  assertSpan(error.span, 16, 21);
}

@test
function parseRequiresHeadersAndAssignmentsToTerminateAtLineBoundaries(): void {
  let mut headerError: TomlError = TomlError::unexpectedToken(TomlSpan::new(0, 0));
  let mut assignmentError: TomlError = TomlError::unexpectedToken(TomlSpan::new(0, 0));

  expectParseError("[package] title = \"ignis\"", &mut headerError);
  expectParseError("title = \"ignis\" flag = false", &mut assignmentError);

  assertErrorKind(headerError.kind, TomlErrorKind::UNEXPECTED_TOKEN);
  assertSpan(headerError.span, 10, 15);
  assertErrorKind(assignmentError.kind, TomlErrorKind::UNEXPECTED_TOKEN);
  assertSpan(assignmentError.span, 16, 20);
}

@test
function parseBuildsNestedTablesArraysAndMixedArrayValues(): void {
  let document: TomlDocument = expectParse(
    "title = \"Ignis\"\nauthor.name = \"Irene\"\n[package]\nname = \"compiler\"\nfeatures = [\"lexer\", 42, { enabled = true }]\n[[bench]]\nname = \"parse\"\n[[bench]]\nname = \"codegen\"\npoint = { x = 1, y = 2 }\n",
  );

  let Result::OK(authorName) = document.getString("author.name") else {
    Test::fail();
    @unreachable();
  };
  let Result::OK(packageName) = document.getString("package.name") else {
    Test::fail();
    @unreachable();
  };
  let Result::OK(features) = document.getArray("package.features") else {
    Test::fail();
    @unreachable();
  };

  assertStringText(authorName, "Irene");
  assertStringText(packageName, "compiler");
  Test::assertEq<u64>(features.length(), 3);

  let Option::SOME(stringValue) = features.item(0) else {
    Test::fail();
    @unreachable();
  };
  let Option::SOME(integerValue) = features.item(1) else {
    Test::fail();
    @unreachable();
  };
  let Option::SOME(inlineTableValue) = features.item(2) else {
    Test::fail();
    @unreachable();
  };

  let Option::SOME(featureName) = stringValue.asString() else {
    Test::fail();
    @unreachable();
  };
  assertStringText(featureName, "lexer");
  Test::assertEq<i64>(integerValue.asInteger(), 42);
  Test::assert(inlineTableValue.kind() == TomlValueKind::TABLE);

  let Option::SOME(benchValue) = document.get("bench") else {
    Test::fail();
    @unreachable();
  };

  Test::assert(benchValue.kind() == TomlValueKind::ARRAY_OF_TABLES);
  Test::assertEq<u64>(benchValue.asArrayOfTables().length(), 2);
}

@test
function parseRejectsDuplicateAndConflictingDefinitionsWithStableSpans(): void {
  let mut duplicateKey: TomlError = TomlError::unexpectedToken(TomlSpan::new(0, 0));
  let mut tableConflict: TomlError = TomlError::unexpectedToken(TomlSpan::new(0, 0));
  let mut arrayConflict: TomlError = TomlError::unexpectedToken(TomlSpan::new(0, 0));
  let mut inlineConflict: TomlError = TomlError::unexpectedToken(TomlSpan::new(0, 0));

  expectParseError("fruit.apple = 1\nfruit.apple = 2\n", &mut duplicateKey);
  expectParseError("fruit = 1\n[fruit]\n", &mut tableConflict);
  expectParseError("[[products]]\nname = \"hammer\"\n[products]\n", &mut arrayConflict);
  expectParseError("point = { x = 1 }\npoint.y = 2\n", &mut inlineConflict);

  assertErrorKind(duplicateKey.kind, TomlErrorKind::DUPLICATE_KEY);
  assertSpan(duplicateKey.span, 16, 27);
  assertErrorKind(tableConflict.kind, TomlErrorKind::TABLE_CONFLICT);
  assertSpan(tableConflict.span, 10, 17);
  assertErrorKind(arrayConflict.kind, TomlErrorKind::TABLE_CONFLICT);
  assertSpan(arrayConflict.span, 29, 39);
  assertErrorKind(inlineConflict.kind, TomlErrorKind::TABLE_CONFLICT);
  assertSpan(inlineConflict.span, 18, 25);
}

@test
function parseKeepsTypedLookupsWorkingForParserProducedNestedOutput(): void {
  let document: TomlDocument = expectParse(
    "title = \"Ignis\"\n[package]\nname = \"compiler\"\nfeatures = [\"lexer\", \"parser\"]\n",
  );

  let Result::OK(title) = document.getString("title") else {
    Test::fail();
    @unreachable();
  };
  let Result::OK(features) = document.getArray("package.features") else {
    Test::fail();
    @unreachable();
  };

  assertStringText(title, "Ignis");
  Test::assertEq<u64>(features.length(), 2);

  let Result::ERROR(missingError) = document.getString("package.version") else {
    Test::fail();
    @unreachable();
  };
  let Result::ERROR(typeError) = document.getArray("title") else {
    Test::fail();
    @unreachable();
  };

  assertErrorKind(missingError.kind, TomlErrorKind::LOOKUP_NOT_FOUND);
  assertErrorKind(typeError.kind, TomlErrorKind::LOOKUP_TYPE_MISMATCH);
  assertSpan(typeError.span, 8, 15);
}
