import Test from "std::test";

@test
function charClassifiesAsciiCharsWithExplicitAsciiNames(): void {
  let upper: char = 'A';
  let lower: char = 'z';
  let digit: char = '7';
  let zero: char = '0';
  let nine: char = '9';
  let q: char = 'Q';
  let three: char = '3';
  let underscore: char = '_';

  Test::assert(upper.isAsciiAlpha());
  Test::assert(lower.isAsciiAlpha());
  Test::assert(!digit.isAsciiAlpha());

  Test::assert(zero.isAsciiNumeric());
  Test::assert(nine.isAsciiNumeric());
  Test::assert(!lower.isAsciiNumeric());

  Test::assert(q.isAsciiAlphanumeric());
  Test::assert(three.isAsciiAlphanumeric());
  Test::assert(!underscore.isAsciiAlphanumeric());
}

@test
function charClassifiesUtf8Scalars(): void {
  let latin: char = 'é';
  let cjk: char = '中';
  let fullWidthDigit: char = '５';
  let asciiHex: char = 'A';
  let fullWidthHex: char = 'Ｇ';

  Test::assert(latin.isAlpha());
  Test::assert(cjk.isAlpha());
  Test::assert(latin.isAlphabetic());
  Test::assert(fullWidthDigit.isNumeric());
  Test::assert(fullWidthDigit.isDigit());
  Test::assert(fullWidthDigit.isAlphanumeric());
  Test::assert(asciiHex.isHexDigit());
  Test::assert(!fullWidthHex.isHexDigit());
}

@test
function charClassifiesHexDigitsWhitespaceAndCase(): void {
  let zero: char = '0';
  let lowerA: char = 'a';
  let upperF: char = 'F';
  let lowerG: char = 'g';
  let space: char = ' ';
  let newline: char = '\n';
  let tab: char = '\t';
  let upperA: char = 'A';
  let lowerZ: char = 'z';
  let upperZ: char = 'Z';
  let nonBreakingSpace: char = 160 as char;

  Test::assert(zero.isAsciiHexDigit());
  Test::assert(lowerA.isAsciiHexDigit());
  Test::assert(upperF.isAsciiHexDigit());
  Test::assert(!lowerG.isAsciiHexDigit());

  Test::assert(space.isAsciiWhitespace());
  Test::assert(newline.isAsciiWhitespace());
  Test::assert(tab.isAsciiWhitespace());
  Test::assert(!upperA.isAsciiWhitespace());
  Test::assert(nonBreakingSpace.isWhitespace());

  Test::assert(upperA.isAsciiUppercase());
  Test::assert(!lowerA.isAsciiUppercase());
  Test::assert(lowerA.isAsciiLowercase());
  Test::assert(!upperA.isAsciiLowercase());

  Test::assertEq<char>(upperA.toAsciiLowercase(), lowerA);
  Test::assertEq<char>(lowerZ.toAsciiLowercase(), lowerZ);
  Test::assertEq<char>(lowerA.toAsciiUppercase(), upperA);
  Test::assertEq<char>(upperZ.toAsciiUppercase(), upperZ);
}
