//!
//! # Test Assertions
//!
//! Minimal assertion helpers for `@test` functions.
//!
//! This v0.5 surface intentionally stays small:
//! - `Test::assert(condition)`
//! - `Test::assertEq(left: i32, right: i32)`
//! - `Test::fail()`
//!
//! No custom messages, diff rendering, or non-test runners are provided here.
//!
//! ## Example
//!
//! ```ignis
//! import Test from "std::test";
//!
//! @test
//! function smoke(): void {
//!   Test::assert(true);
//!   Test::assertEq(2 + 2, 4);
//! }
//! ```

/// Assertion helpers for `@test` bodies.
export record Test {
  /// Fails the current test when `condition` is false.
  public static assert(condition: boolean): void {
    if (!condition) {
      @panic("assertion failed");
    }
  }

  /// Fails the current test unconditionally.
  public static fail(): void {
    @panic("test failed");
  }

  /// Fails the current test when two `i32` values are not equal.
  public static assertEq(left: i32, right: i32): void {
    if (!(left == right)) {
      @panic("assertion failed: values are not equal");
    }
  }
}
