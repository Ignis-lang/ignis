import BitSet from "std::collections";
import Test from "std::test";

@test
function bitSetInsertRemoveAndContainsTrackMembership(): void {
  let mut bits: BitSet = BitSet::new();

  Test::assert(!bits.contains(1));

  bits.insert(1);
  bits.insert(65);

  Test::assert(bits.contains(1));
  Test::assert(bits.contains(65));
  Test::assertEq<u64>(bits.lengthWords(), 2);

  bits.remove(1);

  Test::assert(!bits.contains(1));
  Test::assert(bits.contains(65));
}

@test
function bitSetClearRemovesAllMembership(): void {
  let mut bits: BitSet = BitSet::new();
  bits.insert(0);
  bits.insert(63);
  bits.insert(64);

  bits.clear();

  Test::assertEq<u64>(bits.lengthWords(), 0);
  Test::assert(!bits.contains(0));
  Test::assert(!bits.contains(64));
}

@test
function bitSetInitAliasForwardsToNewConstructor(): void {
  let mut bits: BitSet = BitSet::init();

  bits.insert(7);

  Test::assert(bits.contains(7));
  Test::assertEq<u64>(bits.lengthWords(), 1);
}
