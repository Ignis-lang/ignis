//!
//! # Filesystem
//!
//! Filesystem operations with structured error handling.
//!
//! All fallible operations return `Result<T, Io::IoError>` instead of
//! raw errno codes. Import `Io` alongside `Fs` to inspect errors.
//!
//! ## Module Tree
//!
//! ```
//! std::fs                     (this file — hub, re-exports Fs namespace)
//!   std::fs::sys::mod         (platform dispatch layer)
//!     std::fs::sys::unix      (POSIX syscall wrappers — Linux/glibc)
//! ```
//!
//! ## Sub-namespaces
//!
//! | Namespace       | Description                                |
//! |-----------------|--------------------------------------------|
//! | `Fs::Sys`       | Platform syscall wrappers (selected at compile time) |
//!
//! ## Types
//!
//! | Type                    | Description                                         |
//! |-------------------------|-----------------------------------------------------|
//! | `Fs::Sys::Stat`         | File metadata from `stat(2)` / `fstat(2)`           |
//! | `Fs::Sys::SysDirEntry`  | Single directory entry from `readdir(3)`            |
//!
//! ## Constants
//!
//! Open flags, seek modes, permission bits, and dirent type constants
//! are available under `Fs::Sys`. See `sys/unix.ign` for the full list.
//!
//! ## Platform
//!
//! Currently Linux and macOS (POSIX). The `Fs::Sys` layer is designed so
//! future targets can add sibling backend modules and the dispatch hub
//! (`sys/mod.ign`) selects at compile time via `@configFlag`.
//!
//! ## Example
//!
//! ```ignis
//! import Fs from "std::fs";
//! import Io from "std::io";
//!
//! function main(): i32 {
//!   // stat a file
//!   let result: Result<Fs::Sys::Stat, Io::IoError> =
//!     Fs::Sys::stat("/etc/hosts");
//!
//!   if result.isOk() {
//!     let st: Fs::Sys::Stat = result.unwrap();
//!     // st.size, st.mode, st.uid, st.gid, ...
//!     return 0;
//!   }
//!   return 1;
//! }
//! ```
//!
//! ```ignis
//! import Fs from "std::fs";
//! import Io from "std::io";
//!
//! function main(): i32 {
//!   // write a file
//!   let fd: Result<i32, Io::IoError> = Fs::Sys::open(
//!     "/tmp/hello.txt",
//!     Fs::Sys::O_WRONLY | Fs::Sys::O_CREAT | Fs::Sys::O_TRUNC,
//!     438,
//!   );
//!   if fd.isError() { return 1; }
//!
//!   let rawFd: i32 = fd.unwrap();
//!   let msg: *u8 = "hello\n";
//!   Fs::Sys::write(rawFd, msg as *mut void, 6);
//!   Fs::Sys::close(rawFd);
//!   return 0;
//! }
//! ```

import _ from "std::fs::sys";
import _ from "std::fs::metadata";
import _ from "std::fs::file";
import _ from "std::fs::dir";

import FFI from "std::ffi";
import Io from "std::io";
import LibC from "std::libc";
import Memory from "std::memory";
import Path from "std::path";

/// Filesystem convenience APIs built on `Fs::Sys` and safe owned path handling.
///
/// Overloads accepting owned `String` or `Path::PathBuf` reject interior NULs
/// before crossing into C APIs. Raw `str` overloads preserve C-string semantics
/// and may stop at the first NUL byte.
export namespace Fs {
  const DEFAULT_CREATE_DIR_MODE: u32 = 493;

  /// Builds the standard invalid-path error used for interior-NUL path inputs.
  function invalidPathError(): Io::IoError {
    return Io::IoError::fromErrno(LibC::Errno::EINVAL);
  }

  /// Converts an owned string path to `CString`, rejecting interior NUL bytes.
  function validatedPath(path: &String): Result<FFI::CString, Io::IoError> {
    return match (FFI::CString::ofString(path)) {
      Result::OK(value) -> Result::OK(value),
      Result::ERROR(_) -> Result::ERROR(Fs::invalidPathError()),
    };
  }

  /// Converts a `PathBuf` to `CString`, rejecting interior NUL bytes.
  function validatedPath(path: &Path::PathBuf): Result<FFI::CString, Io::IoError> {
    let pathString: String = path.toString();
    return Fs::validatedPath(&pathString);
  }

  /// Reads a raw C-string path into bytes with buffered file reads.
  function readRaw(path: str): Result<Vector<u8>, Io::IoError> {
    let mut file: Fs::File = Fs::File::open(path)!;
    let mut output: Vector<u8> = Vector::init<u8>();

    let bufSize: u64 = 4096;
    let buf: *mut u8 = Memory::allocateVector<u8>(bufSize);

    defer Memory::free(buf);

    while (true) {
      let count: i64 = file.read(buf as *mut void, bufSize)!;
      if (count == 0) {
        break;
      }

      let mut i: i64 = 0;
      while (i < count) {
        @integerFromPointer(buf) + i
          |> @pointerFromInteger<*mut u8>(_)
          |> @read<u8>(_)
          |> output.push();
        i += 1;
      }
    }

    return Result::OK(output);
  }

  /// Reads an entire file into a byte vector (4 KiB buffered reads).
  function read(path: str): Result<Vector<u8>, Io::IoError> {
    return Fs::readRaw(path);
  }

  /// Reads an owned string path into bytes after validating C-string safety.
  function read(path: &String): Result<Vector<u8>, Io::IoError> {
    let cPath: FFI::CString = Fs::validatedPath(path)!;
    return Fs::readRaw(cPath.asStr() as str);
  }

  /// Reads a `PathBuf` into bytes after validating C-string safety.
  function read(path: &Path::PathBuf): Result<Vector<u8>, Io::IoError> {
    let cPath: FFI::CString = Fs::validatedPath(path)!;
    return Fs::readRaw(cPath.asStr() as str);
  }

  /// Reads an entire file into a byte vector.
  function readToBytes(path: str): Result<Vector<u8>, Io::IoError> {
    return Fs::read(path);
  }

  /// Alias for `read(&String)`.
  function readToBytes(path: &String): Result<Vector<u8>, Io::IoError> {
    return Fs::read(path);
  }

  /// Alias for `read(&PathBuf)`.
  function readToBytes(path: &Path::PathBuf): Result<Vector<u8>, Io::IoError> {
    return Fs::read(path);
  }

  /// Reads a full file and returns it as a String.
  ///
  /// The resulting owned string preserves every byte in the file, including
  /// interior NUL bytes.
  function readToString(path: str): Result<String, Io::IoError> {
    return Fs::readToStringBytes(Fs::readRaw(path)!);
  }

  /// Converts a byte vector into an owned `String`, preserving interior NULs.
  function readToStringBytes(bytes: Vector<u8>): Result<String, Io::IoError> {
    let len: u64 = bytes.length();

    let raw: *mut u8 = Memory::allocateVector<u8>(len + 1);

    defer Memory::free(raw);

    if (len > 0) {
      Memory::copy<u8>(raw, bytes.asPtr(), len);
    }

    @integerFromPointer(raw) + len
      |> @pointerFromInteger<*mut u8>(_)
      |> @write<u8>(_, 0);

    return Result::OK(String::create(raw, len));
  }

  /// Reads an owned string path into an owned `String` after path validation.
  function readToString(path: &String): Result<String, Io::IoError> {
    return Fs::readToStringBytes(Fs::read(path)!);
  }

  /// Reads a `PathBuf` into an owned `String` after path validation.
  function readToString(path: &Path::PathBuf): Result<String, Io::IoError> {
    let pathString: String = path.toString();
    return Fs::readToString(&pathString);
  }

  /// Creates/truncates a file and writes all bytes from `data`.
  function writeBytesRaw(path: str, data: *void, len: u64): Result<void, Io::IoError> {
    let mut file: Fs::File = Fs::File::create(path)!;
    let writeResult: i64 = file.write(data, len)!;

    if (writeResult != len) {
      return Result::ERROR(Io::IoError {
        kind: Io::ErrorKind::OTHER,
        raw: 0,
        message: "short write",
      });
    }

    return Result::OK(());
  }

  /// Creates/truncates a file and writes all bytes from `data`.
  function writeBytes(path: str, data: *void, len: u64): Result<void, Io::IoError> {
    return Fs::writeBytesRaw(path, data, len);
  }

  /// Writes raw bytes to an owned string path after path validation.
  function writeBytes(path: &String, data: *void, len: u64): Result<void, Io::IoError> {
    let cPath: FFI::CString = Fs::validatedPath(path)!;
    return Fs::writeBytesRaw(cPath.asStr() as str, data, len);
  }

  /// Writes raw bytes to a `PathBuf` after path validation.
  function writeBytes(path: &Path::PathBuf, data: *void, len: u64): Result<void, Io::IoError> {
    let cPath: FFI::CString = Fs::validatedPath(path)!;
    return Fs::writeBytesRaw(cPath.asStr() as str, data, len);
  }

  /// Creates/truncates a file and writes all bytes from `data`.
  function write(path: str, data: *void, len: u64): Result<void, Io::IoError> {
    return Fs::writeBytesRaw(path, data, len);
  }

  /// Alias for `writeBytes(&String, data, len)`.
  function write(path: &String, data: *void, len: u64): Result<void, Io::IoError> {
    return Fs::writeBytes(path, data, len);
  }

  /// Alias for `writeBytes(&PathBuf, data, len)`.
  function write(path: &Path::PathBuf, data: *void, len: u64): Result<void, Io::IoError> {
    return Fs::writeBytes(path, data, len);
  }

  /// Creates/truncates a file and writes a C string.
  function write(path: str, text: str): Result<void, Io::IoError> {
    let len: u64 = LibC::String::strlen(text as *u8);
    return Fs::writeBytesRaw(path, text as *void, len);
  }

  /// Writes a NUL-terminated text view to an owned string path.
  function write(path: &String, text: str): Result<void, Io::IoError> {
    let len: u64 = LibC::String::strlen(text as *u8);
    return Fs::writeBytes(path, text as *void, len);
  }

  /// Writes a NUL-terminated text view to a `PathBuf`.
  function write(path: &Path::PathBuf, text: str): Result<void, Io::IoError> {
    let len: u64 = LibC::String::strlen(text as *u8);
    return Fs::writeBytes(path, text as *void, len);
  }

  /// Creates/truncates a file and writes an entire String.
  ///
  /// This is byte-counted: it always writes `s.length()` bytes from the owned
  /// buffer, even when interior NUL bytes exist.
  function writeString(path: str, s: &String): Result<void, Io::IoError> {
    return Fs::writeBytesRaw(path, s.toStr() as *void, s.length());
  }

  /// Writes all bytes from an owned string to an owned string path.
  function writeString(path: &String, s: &String): Result<void, Io::IoError> {
    return Fs::writeBytes(path, s.toStr() as *void, s.length());
  }

  /// Writes all bytes from an owned string to a `PathBuf`.
  function writeString(path: &Path::PathBuf, s: &String): Result<void, Io::IoError> {
    return Fs::writeBytes(path, s.toStr() as *void, s.length());
  }

  /// Returns true when `path` exists.
  function exists(path: str): boolean {
    let statResult: Result<Fs::Sys::Stat, Io::IoError> = Fs::Sys::stat(path);
    return statResult.isOk();
  }

  /// Reads raw metadata from a C-string path.
  function metadataRaw(path: str): Result<Fs::Metadata, Io::IoError> {
    let stat: Fs::Sys::Stat = Fs::Sys::stat(path)!;
    return Result::OK(Fs::metadataFromStat(&stat));
  }

  /// Reads metadata for `path`.
  function metadata(path: str): Result<Fs::Metadata, Io::IoError> {
    return Fs::metadataRaw(path);
  }

  /// Reads metadata for an owned string path after path validation.
  function metadata(path: &String): Result<Fs::Metadata, Io::IoError> {
    let cPath: FFI::CString = Fs::validatedPath(path)!;
    return Fs::metadataRaw(cPath.asStr() as str);
  }

  /// Reads metadata for a `PathBuf` after path validation.
  function metadata(path: &Path::PathBuf): Result<Fs::Metadata, Io::IoError> {
    let cPath: FFI::CString = Fs::validatedPath(path)!;
    return Fs::metadataRaw(cPath.asStr() as str);
  }

  /// Returns the canonical absolute path for an existing filesystem entry.
  function canonicalizeRaw(path: str): Result<Path::PathBuf, Io::IoError> {
    let canonicalPath: String = Fs::Sys::realpath(path)!;
    return Result::OK(Path::PathBuf::fromString(&canonicalPath));
  }

  /// Returns the canonical absolute path for an existing filesystem entry.
  function canonicalize(path: str): Result<Path::PathBuf, Io::IoError> {
    return Fs::canonicalizeRaw(path);
  }

  /// Canonicalizes an owned string path after path validation.
  function canonicalize(path: &String): Result<Path::PathBuf, Io::IoError> {
    let cPath: FFI::CString = Fs::validatedPath(path)!;
    return Fs::canonicalizeRaw(cPath.asStr() as str);
  }

  /// Canonicalizes a `PathBuf` after path validation.
  function canonicalize(path: &Path::PathBuf): Result<Path::PathBuf, Io::IoError> {
    let cPath: FFI::CString = Fs::validatedPath(path)!;
    return Fs::canonicalizeRaw(cPath.asStr() as str);
  }

  /// Returns the host temporary-directory root.
  function tempDir(): Result<Path::PathBuf, Io::IoError> {
    let tempPath: String = Fs::Sys::tempDirPath()!;
    return Fs::canonicalize(&tempPath);
  }

  /// Creates a single directory.
  function createDirRaw(path: str, mode: u32): Result<void, Io::IoError> {
    return Fs::Sys::mkdir(path, mode);
  }

  /// Creates a single directory.
  function createDir(path: str, mode: u32): Result<void, Io::IoError> {
    return Fs::createDirRaw(path, mode);
  }

  /// Creates a single directory using an `i32` mode.
  function createDir(path: str, mode: i32): Result<void, Io::IoError> {
    return Fs::createDirRaw(path, mode as u32);
  }

  /// Creates a single directory for an owned string path.
  function createDir(path: &String, mode: u32): Result<void, Io::IoError> {
    let cPath: FFI::CString = Fs::validatedPath(path)!;
    return Fs::createDirRaw(cPath.asStr() as str, mode);
  }

  /// Creates a single directory for an owned string path using an `i32` mode.
  function createDir(path: &String, mode: i32): Result<void, Io::IoError> {
    let cPath: FFI::CString = Fs::validatedPath(path)!;
    return Fs::createDirRaw(cPath.asStr() as str, mode as u32);
  }

  /// Creates a single directory for a `PathBuf`.
  function createDir(path: &Path::PathBuf, mode: u32): Result<void, Io::IoError> {
    let cPath: FFI::CString = Fs::validatedPath(path)!;
    return Fs::createDirRaw(cPath.asStr() as str, mode);
  }

  /// Creates a single directory for a `PathBuf` using an `i32` mode.
  function createDir(path: &Path::PathBuf, mode: i32): Result<void, Io::IoError> {
    let cPath: FFI::CString = Fs::validatedPath(path)!;
    return Fs::createDirRaw(cPath.asStr() as str, mode as u32);
  }

  /// Recursively creates directories for `path` (mkdir -p behavior).
  function createDirAllRaw(path: str): Result<void, Io::IoError> {
    let pathString: String = String::create(path);
    if (pathString.length() == 0) {
      return Result::OK(());
    }

    let mut current: String = String::new();
    let len: u64 = pathString.length();
    let rawPath: *mut u8 = pathString.toStr() as *mut u8;
    let firstByte: u8 = @read<u8>(rawPath);
    let isAbsolute: boolean = firstByte == 47;

    if (isAbsolute) {
      current.pushChar('/');
    }

    let mut segmentStart: u64 = isAbsolute ? 1 : 0;
    let mut index: u64 = segmentStart;
    while (index <= len) {
      let mut isSeparator: boolean = index == len;
      if (!isSeparator) {
        let b: u8 = @integerFromPointer(rawPath) + index
          |> @pointerFromInteger<*mut u8>(_)
          |> @read<u8>(_);
        isSeparator = b == 47;
      }

      if (isSeparator) {
        let segmentLen: u64 = index - segmentStart;
        if (segmentLen > 0) {
          let segment: String = pathString.substring(segmentStart as i64, segmentLen as i64);

          if (current.length() > 0 && !(isAbsolute && current.length() == 1)) {
            current.pushChar('/');
          }

          current.push(&segment);

          if (!Fs::exists(current.toStr())) {
            Fs::Sys::mkdir(current.toStr(), DEFAULT_CREATE_DIR_MODE)!;
          }
        }

        segmentStart = index + 1;
      }

      index += 1;
    }

    return Result::OK(());
  }

  /// Recursively creates directories for `path` (mkdir -p behavior).
  function createDirAll(path: str): Result<void, Io::IoError> {
    return Fs::createDirAllRaw(path);
  }

  /// Recursively creates directories for an owned string path.
  function createDirAll(path: &String): Result<void, Io::IoError> {
    let cPath: FFI::CString = Fs::validatedPath(path)!;
    return Fs::createDirAllRaw(cPath.asStr() as str);
  }

  /// Recursively creates directories for a `PathBuf`.
  function createDirAll(path: &Path::PathBuf): Result<void, Io::IoError> {
    let cPath: FFI::CString = Fs::validatedPath(path)!;
    return Fs::createDirAllRaw(cPath.asStr() as str);
  }

  /// Removes a file.
  function removeFileRaw(path: str): Result<void, Io::IoError> {
    return Fs::Sys::unlink(path);
  }

  /// Removes a file.
  function removeFile(path: str): Result<void, Io::IoError> {
    return Fs::removeFileRaw(path);
  }

  /// Removes a file at an owned string path.
  function removeFile(path: &String): Result<void, Io::IoError> {
    let cPath: FFI::CString = Fs::validatedPath(path)!;
    return Fs::removeFileRaw(cPath.asStr() as str);
  }

  /// Removes a file at a `PathBuf`.
  function removeFile(path: &Path::PathBuf): Result<void, Io::IoError> {
    let cPath: FFI::CString = Fs::validatedPath(path)!;
    return Fs::removeFileRaw(cPath.asStr() as str);
  }

  /// Removes an empty directory.
  function removeDirRaw(path: str): Result<void, Io::IoError> {
    return Fs::Sys::rmdir(path);
  }

  /// Removes an empty directory.
  function removeDir(path: str): Result<void, Io::IoError> {
    return Fs::removeDirRaw(path);
  }

  /// Removes an empty directory at an owned string path.
  function removeDir(path: &String): Result<void, Io::IoError> {
    let cPath: FFI::CString = Fs::validatedPath(path)!;
    return Fs::removeDirRaw(cPath.asStr() as str);
  }

  /// Removes an empty directory at a `PathBuf`.
  function removeDir(path: &Path::PathBuf): Result<void, Io::IoError> {
    let cPath: FFI::CString = Fs::validatedPath(path)!;
    return Fs::removeDirRaw(cPath.asStr() as str);
  }

  /// Removes a directory tree without following symlink directories.
  function removeDirAllRaw(path: str): Result<void, Io::IoError> {
    return Fs::removeDirAllPath(path);
  }

  /// Removes a directory tree without following symlink directories.
  function removeDirAll(path: str): Result<void, Io::IoError> {
    return Fs::removeDirAllRaw(path);
  }

  /// Recursively removes a directory tree at an owned string path.
  function removeDirAll(path: &String): Result<void, Io::IoError> {
    let cPath: FFI::CString = Fs::validatedPath(path)!;
    return Fs::removeDirAllRaw(cPath.asStr() as str);
  }

  /// Recursively removes a directory tree at a `PathBuf`.
  function removeDirAll(path: &Path::PathBuf): Result<void, Io::IoError> {
    let cPath: FFI::CString = Fs::validatedPath(path)!;
    return Fs::removeDirAllRaw(cPath.asStr() as str);
  }

  /// Returns a depth-first directory walker that treats symlinks as leaves.
  function walkRaw(path: str): Result<Vector<String>, Io::IoError> {
    return Fs::collectWalk(path);
  }

  /// Returns a depth-first directory walker that treats symlinks as leaves.
  function walk(path: str): Result<Vector<String>, Io::IoError> {
    return Fs::walkRaw(path);
  }

  /// Walks an owned string path after path validation.
  function walk(path: &String): Result<Vector<String>, Io::IoError> {
    let cPath: FFI::CString = Fs::validatedPath(path)!;
    return Fs::walkRaw(cPath.asStr() as str);
  }

  /// Walks a `PathBuf` after path validation.
  function walk(path: &Path::PathBuf): Result<Vector<String>, Io::IoError> {
    let cPath: FFI::CString = Fs::validatedPath(path)!;
    return Fs::walkRaw(cPath.asStr() as str);
  }
}
